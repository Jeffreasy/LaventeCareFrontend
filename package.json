{
  "name": "laventecare",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "overrides": {
    "@vercel/routing-utils": {
      "path-to-regexp": "6.3.0"
    }
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{astro,ts,tsx,js,css}\" \"tests/**/*.ts\" \"*.{js,mjs,json,ts}\"",
    "format:check": "prettier --check \"src/**/*.{astro,ts,tsx,js,css}\" \"tests/**/*.ts\" \"*.{js,mjs,json,ts}\"",
    "type-check": "astro check",
    "verify": "npm run format:check && npm run lint && npm run type-check && npm run test && npm run build"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@astrojs/vercel": "^11.0.3",
    "@nanostores/persistent": "^1.3.5",
    "@nanostores/react": "^1.1.0",
    "@tailwindcss/vite": "^4.3.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "astro": "^7.1.3",
    "clsx": "^2.1.1",
    "jose": "^6.2.4",
    "nanostores": "^1.4.1",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.3.3",
    "tailwindcss-animate": "^1.0.7",
    "web-vitals": "^6.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^1.7.0",
    "prettier": "^3.9.6",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0"
  }
}
