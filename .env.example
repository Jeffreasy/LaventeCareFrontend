# ============================================
# LaventeCare - Environment Configuration
# ============================================

# Storyblok CMS Configuration
# Get your access token from: https://app.storyblok.com/
# Navigate to Settings > Access Tokens > Preview Token
STORYBLOK_TOKEN=your_storyblok_preview_token_here

# Site Configuration (Production)
# Update this to your production domain when deploying
# SITE=https://lavente.care

# Optional: Google Analytics / Tag Manager
# GTM_ID=GTM-XXXXXXX

# Optional: Environment indicator
# NODE_ENV=production

