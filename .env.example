# ============================================
# LaventeCare - Environment Configuration
# ============================================

# Backend Auth System (REQUIRED)
PUBLIC_API_URL=https://laventecareauthsystems.onrender.com
PUBLIC_TENANT_ID=your-tenant-uuid-here

# Optional JWT verification overrides (defaults to PUBLIC_API_URL origin)
# JWT_ISSUER=https://laventecareauthsystems.onrender.com
# JWT_AUDIENCE=laventecare

# Site Configuration (Production)
# Update this to your production domain when deploying
# SITE=https://www.laventecare.nl

# Optional: Google Analytics / Tag Manager
# GTM_ID=GTM-XXXXXXX

# Optional: Environment indicator
# NODE_ENV=production

