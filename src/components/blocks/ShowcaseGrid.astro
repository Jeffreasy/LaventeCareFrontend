---
import type { ShowcaseTenant } from '../../lib/types';
import Card from '../ui/Card.astro';

const API_URL = import.meta.env.PUBLIC_API_URL;
let tenants: ShowcaseTenant[] = [];

try {
  const response = await fetch(`${API_URL}/api/v1/showcase`);
  if (response.ok) {
    tenants = await response.json();

    // Data is now correct from backend
  } else {
    // Graceful fallback (Silence is Golden)
    if (import.meta.env.DEV) console.error('Failed to fetch showcase tenants');
  }
} catch (e) {
  // Non-blocking error handling
  if (import.meta.env.DEV) console.error('Showcase fetch error', e);
}
---

{
  tenants.length > 0 && (
    <section class="py-16 md:py-24 relative overflow-hidden">
      <div class="container mx-auto px-4">
        <div class="text-center mb-16">
          <span class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-4 block animate-in fade-in slide-in-from-bottom-2 duration-700">
            Ecosystem & Agency Portfolio
          </span>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 font-display tracking-tight leading-[1.1]">
            Powered by{' '}
            <span class="text-transparent bg-clip-text bg-linear-to-r from-active to-secondary">
              LaventeCare
            </span>
          </h2>
          <p class="text-white/60 max-w-2xl mx-auto text-lg leading-relaxed font-ui">
            Van SaaS-security tot maatwerk platforms.{' '}
            <span class="text-active font-medium">Wij bouwen de toekomst.</span>
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 auto-rows-fr">
          {tenants.map((tenant, index) => {
            return (
              <a
                href={tenant.app_url}
                target="_blank"
                rel="noopener noreferrer"
                class="group block h-full"
              >
                <Card
                  hover
                  class="h-full flex flex-col transition-transform duration-500 hover:-translate-y-2"
                >
                  {/* Card Header: Logo & Badge */}
                  <div class="flex items-start justify-between mb-6">
                    <div class="relative w-20 h-20 rounded-2xl bg-white/20 backdrop-blur-xl border border-white/20 flex items-center justify-center overflow-hidden shadow-inner group-hover:scale-105 transition-transform duration-500">
                      {tenant.logo_url ? (
                        <img
                          src={tenant.logo_url}
                          alt={tenant.name}
                          width="80"
                          height="80"
                          loading="lazy"
                          decoding="async"
                          class="w-full h-full object-contain p-2"
                        />
                      ) : (
                        <span class="text-3xl font-bold text-white/30 font-display">
                          {tenant.name.charAt(0)}
                        </span>
                      )}
                    </div>

                    <span class="px-3 py-1.5 rounded-full text-[11px] font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20 shadow-sm backdrop-blur-md">
                      {tenant.category || 'App'}
                    </span>
                  </div>

                  {/* Card Body: Title & Info */}
                  <div class="mb-4">
                    <h3 class="text-2xl font-bold text-white mb-1 font-display group-hover:text-active transition-colors duration-300">
                      {tenant.name}
                    </h3>
                    {tenant.tagline && (
                      <p class="text-white/50 text-sm font-medium tracking-wide">
                        {tenant.tagline}
                      </p>
                    )}
                  </div>

                  <p class="text-white/70 text-base mb-8 line-clamp-3 grow leading-relaxed font-light">
                    {tenant.description}
                  </p>

                  {/* Footer: Tags & Action */}
                  <div class="mt-auto space-y-6">
                    {tenant.tags && tenant.tags.length > 0 && (
                      <div class="flex flex-wrap gap-2">
                        {tenant.tags.slice(0, 3).map((tag) => (
                          <span class="text-xs text-white/50 bg-white/5 px-3 py-1.5 rounded-lg border border-white/5 font-medium transition-colors group-hover:bg-white/10">
                            #{tag}
                          </span>
                        ))}
                      </div>
                    )}

                    <div class="flex items-center text-active text-sm font-bold border-t border-white/5 pt-5 group/link">
                      <span class="group-hover/link:underline">Bekijk Project</span>
                      <svg
                        class="w-4 h-4 ml-2 group-hover/link:translate-x-1 transition-transform"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M17 8l4 4m0 0l-4 4m4-4H3"
                        />
                      </svg>
                    </div>
                  </div>
                </Card>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )
}
