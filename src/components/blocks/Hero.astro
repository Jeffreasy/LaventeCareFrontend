---
import { cn } from '../../lib/utils';
// Button, backgroundImage, and alignmentClasses removed

interface CTA {
  label: string;
  url: string;
}

interface Props {
  headline: string;
  subtitle?: string;
  description?: string;
  ctaPrimary?: CTA;
  ctaSecondary?: CTA;
  stats?: {
    value: string;
    label: string;
  }[];
  alignment?: 'left' | 'center' | 'right';
  size?: 'small' | 'medium' | 'large';
  class?: string;
}

const {
  headline,
  subtitle,
  description,
  ctaPrimary,
  ctaSecondary,
  stats,
  alignment = 'center',
  size = 'large',
  class: className,
} = Astro.props;

// Size variants
const sizeClasses = {
  small: 'py-16 md:py-20',
  medium: 'py-20 md:py-28',
  large: 'py-28 md:py-36 lg:py-44',
};

// Alignment classes
// Size based on section size
const headingSize = {
  small: 'text-4xl md:text-5xl',
  medium: 'text-5xl md:text-6xl',
  large: 'text-6xl md:text-7xl lg:text-8xl',
};
---

<section
  class={cn(
    'relative overflow-hidden flex items-center min-h-[85vh] md:min-h-[95vh]',
    sizeClasses[size],
    className
  )}
>
  <!-- Subtle Tint Layer (transparent — body Royal Ambient shows through) -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-active/5"></div>
  </div>

  <!-- Floating Shapes (Pure CSS) -->
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
    <!-- Large floating circle (Teal) -->
    <div
      class="absolute top-20 right-10 md:right-1/4 w-120 h-120 rounded-full bg-active/15 blur-3xl animate-float-slow will-change-transform mix-blend-screen"
    >
    </div>

    <!-- Medium floating blob (Navy/Secondary) -->
    <div
      class="absolute bottom-20 left-10 w-72 h-72 rounded-full bg-secondary/20 blur-3xl animate-float-medium will-change-transform mix-blend-screen"
      style="animation-delay: 1s;"
    >
    </div>

    <!-- The 'Roze/Coral' Signature Warm Gradient -->
    <div
      class="absolute top-1/3 right-10 w-100 h-100 rounded-full blur-[100px] animate-float-fast will-change-transform opacity-60 mix-blend-screen"
      style="background: radial-gradient(circle, oklch(0.65 0.22 15 / 0.25), transparent 70%); animation-delay: 2.5s;"
    >
    </div>

    <!-- Small accent shapes -->
    <div
      class="absolute top-1/4 left-1/4 w-32 h-32 rounded-full bg-white/10 blur-2xl animate-float-fast will-change-transform"
    >
    </div>
    <div
      class="absolute bottom-1/3 right-1/3 w-40 h-40 rounded-full bg-active/10 blur-2xl animate-float-slow will-change-transform"
      style="animation-delay: 2s;"
    >
    </div>
  </div>

  <!-- Grid Pattern Overlay -->
  <div class="absolute inset-0 z-0 opacity-[0.03]">
    <div
      class="absolute inset-0"
      style="background-image: linear-gradient(white 1px, transparent 1px), linear-gradient(90deg, white 1px, transparent 1px); background-size: 50px 50px;"
    >
    </div>
  </div>

  <!-- Content -->
  <div class="container relative z-10 mx-auto px-4 md:px-6">
    <div class={cn('flex flex-col gap-8 max-w-5xl', alignment === 'center' ? 'mx-auto' : '')}>
      <!-- Trust Badge -->
      {
        subtitle && (
          <div class={cn('inline-flex', alignment === 'center' && 'justify-center')}>
            <span class="clinical-glass px-6 py-2.5 rounded-full text-xs font-bold tracking-[0.15em] uppercase text-active backdrop-blur-xl border border-white/10 shadow-lg animate-in fade-in slide-in-from-top-4 duration-1000">
              {subtitle}
            </span>
          </div>
        )
      }

      <!-- Headline with Gradient Text -->
      <h1
        class={cn(
          headingSize[size],
          'font-display font-black leading-none tracking-tight',
          alignment === 'left' && 'text-left',
          alignment === 'center' && 'text-center',
          alignment === 'right' && 'text-right'
        )}
      >
        <span
          class="bg-linear-to-r from-white via-white/95 to-white/70 bg-clip-text text-transparent drop-shadow-sm"
        >
          {headline}
        </span>
      </h1>

      <!-- Description -->
      {
        description && (
          <p
            class={cn(
              'text-xl md:text-2xl text-white/80 leading-relaxed max-w-3xl font-light',
              alignment === 'center' && 'mx-auto'
            )}
            set:html={description}
          />
        )
      }

      <!-- CTAs -->
      {
        (ctaPrimary || ctaSecondary) && (
          <div
            class={cn(
              'flex flex-col sm:flex-row gap-4',
              alignment === 'center' && 'justify-center',
              alignment === 'right' && 'justify-end'
            )}
          >
            {ctaPrimary && (
              <a href={ctaPrimary.url} class="btn-hero-primary">
                {ctaPrimary.label}
              </a>
            )}
            {ctaSecondary && (
              <a href={ctaSecondary.url} class="btn-hero-secondary">
                {ctaSecondary.label}
              </a>
            )}
          </div>
        )
      }

      <!-- Stats Section -->
      {
        stats && stats.length > 0 && (
          <div
            class={cn(
              'grid grid-cols-3 gap-4 md:gap-8 mt-10 md:mt-12 pt-8 md:pt-12 border-t border-white/10',
              alignment === 'center' && 'max-w-2xl mx-auto'
            )}
          >
            {stats.map((stat) => (
              <div class="text-center">
                <div class="text-xl sm:text-3xl md:text-5xl font-bold text-active mb-1 md:mb-2 font-display leading-tight">
                  {stat.value}
                </div>
                <div class="text-[11px] sm:text-xs md:text-sm text-white/60 leading-snug">
                  {stat.label}
                </div>
              </div>
            ))}
          </div>
        )
      }
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-12 left-1/2 -translate-x-1/2 z-10 animate-scroll-hint">
    <div class="flex flex-col items-center gap-2 text-white/60">
      <span class="text-xs font-medium tracking-wider uppercase">Scroll</span>
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </div>
</section>

<style>
  @keyframes gradient-shift {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  @keyframes gradient-x {
    0%,
    100% {
      background-position: 0% center;
    }
    50% {
      background-position: 200% center;
    }
  }

  @keyframes float-slow {
    0%,
    100% {
      transform: translateY(0) translateX(0) scale(1);
    }
    33% {
      transform: translateY(-30px) translateX(20px) scale(1.05);
    }
    66% {
      transform: translateY(20px) translateX(-20px) scale(0.95);
    }
  }

  @keyframes float-medium {
    0%,
    100% {
      transform: translateY(0) translateX(0) rotate(0deg);
    }
    50% {
      transform: translateY(-20px) translateX(15px) rotate(5deg);
    }
  }

  @keyframes float-fast {
    0%,
    100% {
      transform: translateY(0) scale(1);
    }
    50% {
      transform: translateY(-15px) scale(1.1);
    }
  }

  .animate-gradient-shift {
    background-size: 200% 200%;
    animation: gradient-shift 15s ease infinite;
  }

  .animate-gradient-x {
    background-size: 200% auto;
    animation: gradient-x 8s linear infinite;
  }

  .animate-float-slow {
    animation: float-slow 20s ease-in-out infinite;
  }

  .animate-float-medium {
    animation: float-medium 15s ease-in-out infinite;
  }

  .animate-float-fast {
    animation: float-fast 10s ease-in-out infinite;
  }

  /* [L3] Scroll hint: limited iterations instead of infinite bounce */
  @keyframes scroll-hint {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(8px);
    }
  }

  .animate-scroll-hint {
    animation: scroll-hint 1.5s ease-in-out 3;
  }
</style>
