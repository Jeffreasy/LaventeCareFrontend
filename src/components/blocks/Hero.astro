---
import { cn } from '../../lib/utils';
// Button, backgroundImage, and alignmentClasses removed

interface CTA {
  label: string;
  url: string;
}

interface Props {
  headline: string;
  subtitle?: string;
  description?: string;
  backgroundImage?: {
    filename: string;
    alt?: string;
  };
  ctaPrimary?: CTA;
  ctaSecondary?: CTA;
  stats?: {
    value: string;
    label: string;
  }[];
  alignment?: 'left' | 'center' | 'right';
  size?: 'small' | 'medium' | 'large';
  class?: string;
}

const {
  headline,
  subtitle,
  description,
  backgroundImage,
  ctaPrimary,
  ctaSecondary,
  stats,
  alignment = 'center',
  size = 'large',
  class: className,
} = Astro.props;

// Size variants
const sizeClasses = {
  small: 'py-16 md:py-20',
  medium: 'py-20 md:py-28',
  large: 'py-28 md:py-36 lg:py-44',
};

// Alignment classes
const alignmentClasses = {
  left: 'text-left items-start',
  center: 'text-center items-center',
  right: 'text-right items-end',
};

// Heading size based on section size
const headingSize = {
  small: 'text-4xl md:text-5xl',
  medium: 'text-5xl md:text-6xl',
  large: 'text-6xl md:text-7xl lg:text-8xl',
};
---

<section
  class={cn(
    'relative overflow-hidden flex items-center min-h-[95vh]',
    sizeClasses[size],
    className
  )}
>
  <!-- Animated Gradient Background -->
  <div class="absolute inset-0 z-0">
    <div
      class="absolute inset-0 bg-linear-to-br from-active via-secondary to-active/50 opacity-20"
    >
    </div>
    <div class="absolute inset-0 bg-background/60 backdrop-blur-sm"></div>
  </div>

  <!-- Floating Shapes (Pure CSS) -->
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
    <!-- Large floating circle -->
    <div
      class="absolute top-20 right-10 w-96 h-96 rounded-full bg-active/10 blur-3xl animate-float-slow"
    >
    </div>

    <!-- Medium floating blob -->
    <div
      class="absolute bottom-20 left-10 w-72 h-72 rounded-full bg-secondary/10 blur-2xl animate-float-medium"
    >
    </div>

    <!-- Small accent shapes -->
    <div
      class="absolute top-1/3 left-1/4 w-32 h-32 rounded-full bg-white/5 blur-xl animate-float-fast"
    >
    </div>
    <div
      class="absolute bottom-1/3 right-1/3 w-40 h-40 rounded-full bg-white/5 blur-xl animate-float-slow"
      style="animation-delay: 2s;"
    >
    </div>
  </div>

  <!-- Grid Pattern Overlay -->
  <div class="absolute inset-0 z-0 opacity-[0.03]">
    <div
      class="absolute inset-0"
      style="background-image: linear-gradient(white 1px, transparent 1px), linear-gradient(90deg, white 1px, transparent 1px); background-size: 50px 50px;"
    >
    </div>
  </div>

  <!-- Content -->
  <div class="container relative z-10 mx-auto px-4 md:px-6">
    <div class={cn('flex flex-col gap-8 max-w-5xl', alignment === 'center' ? 'mx-auto' : '')}>
      <!-- Trust Badge -->
      {
        subtitle && (
          <div class={cn('inline-flex', alignment === 'center' && 'justify-center')}>
            <span class="clinical-glass px-6 py-2.5 rounded-full text-xs font-bold tracking-[0.15em] uppercase text-active backdrop-blur-xl border border-white/10 shadow-lg animate-in fade-in slide-in-from-top-4 duration-1000">
              {subtitle}
            </span>
          </div>
        )
      }

      <!-- Headline with Gradient Text -->
      <h1
        class={cn(
          headingSize[size],
          'font-display font-black leading-[1.0] tracking-tight',
          alignment === 'left' && 'text-left',
          alignment === 'center' && 'text-center',
          alignment === 'right' && 'text-right'
        )}
      >
        <span
          class="bg-linear-to-r from-white via-white/95 to-white/70 bg-clip-text text-transparent drop-shadow-sm"
        >
          {headline}
        </span>
      </h1>

      <!-- Description -->
      {
        description && (
          <p
            class={cn(
              'text-xl md:text-2xl text-white/80 leading-relaxed max-w-3xl font-light',
              alignment === 'center' && 'mx-auto'
            )}
          >
            {description}
          </p>
        )
      }

      <!-- CTAs -->
      {
        (ctaPrimary || ctaSecondary) && (
          <div
            class={cn(
              'flex flex-col sm:flex-row gap-4',
              alignment === 'center' && 'justify-center',
              alignment === 'right' && 'justify-end'
            )}
          >
            {ctaPrimary && (
              <a
                href={ctaPrimary.url}
                class="group relative px-8 py-4 bg-background text-white border-2 border-active rounded-2xl font-semibold text-lg shadow-2xl hover:bg-active transition-all duration-300 hover:scale-105 overflow-hidden"
              >
                <span class="relative z-10">{ctaPrimary.label}</span>
              </a>
            )}
            {ctaSecondary && (
              <a
                href={ctaSecondary.url}
                class="group px-8 py-4 clinical-glass border-2 border-white/30 text-white rounded-2xl font-semibold text-lg backdrop-blur-xl hover:bg-white/10 hover:border-white/50 transition-all duration-300 hover:scale-105"
              >
                {ctaSecondary.label}
              </a>
            )}
          </div>
        )
      }

      <!-- Stats Section -->
      {
        stats && stats.length > 0 && (
          <div
            class={cn(
              'grid grid-cols-3 gap-8 mt-12 pt-12 border-t border-white/10',
              alignment === 'center' && 'max-w-2xl mx-auto'
            )}
          >
            {stats.map((stat) => (
              <div class="text-center">
                <div class="text-4xl md:text-5xl font-bold text-white mb-2 font-display">{stat.value}</div>
                <div class="text-sm text-white/70">{stat.label}</div>
              </div>
            ))}
          </div>
        )
      }
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-12 left-1/2 -translate-x-1/2 z-10 animate-bounce">
    <div class="flex flex-col items-center gap-2 text-white/60">
      <span class="text-xs font-medium tracking-wider uppercase">Scroll</span>
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </div>
</section>

<style>
  @keyframes gradient-shift {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  @keyframes gradient-x {
    0%,
    100% {
      background-position: 0% center;
    }
    50% {
      background-position: 200% center;
    }
  }

  @keyframes float-slow {
    0%,
    100% {
      transform: translateY(0) translateX(0) scale(1);
    }
    33% {
      transform: translateY(-30px) translateX(20px) scale(1.05);
    }
    66% {
      transform: translateY(20px) translateX(-20px) scale(0.95);
    }
  }

  @keyframes float-medium {
    0%,
    100% {
      transform: translateY(0) translateX(0) rotate(0deg);
    }
    50% {
      transform: translateY(-20px) translateX(15px) rotate(5deg);
    }
  }

  @keyframes float-fast {
    0%,
    100% {
      transform: translateY(0) scale(1);
    }
    50% {
      transform: translateY(-15px) scale(1.1);
    }
  }

  .animate-gradient-shift {
    background-size: 200% 200%;
    animation: gradient-shift 15s ease infinite;
  }

  .animate-gradient-x {
    background-size: 200% auto;
    animation: gradient-x 8s linear infinite;
  }

  .animate-float-slow {
    animation: float-slow 20s ease-in-out infinite;
  }

  .animate-float-medium {
    animation: float-medium 15s ease-in-out infinite;
  }

  .animate-float-fast {
    animation: float-fast 10s ease-in-out infinite;
  }
</style>
