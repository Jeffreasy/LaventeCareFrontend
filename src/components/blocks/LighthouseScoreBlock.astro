---
import Icon from '../ui/Icon.astro';

interface LighthouseScore {
  label: string;
  value: number;
}

interface Props {
  projectName: string;
  scores: LighthouseScore[];
  context: string;
  liveUrl?: string;
}

const { projectName, scores, context, liveUrl } = Astro.props;
---

<section class="clinical-glass rounded-(--radius-hero) border border-white/8 p-6 md:p-8">
  <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-5 mb-6">
    <div>
      <div
        class="flex items-center gap-2 text-active text-xs font-bold uppercase tracking-[0.18em] mb-2"
      >
        <Icon name="gauge" size={16} />
        Lighthouse
      </div>
      <h2 class="text-xl md:text-2xl font-black text-white font-display">{projectName}</h2>
    </div>
    {
      liveUrl && (
        <a
          href={liveUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-active text-sm font-semibold hover:underline"
        >
          Live bekijken
          <Icon name="external-link" size={14} />
        </a>
      )
    }
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
    {
      scores.map((score) => (
        <div class="rounded-(--radius-card) border border-active/20 bg-active/5 p-4 text-center">
          <div class="text-3xl font-black text-active font-display">{score.value}</div>
          <div class="text-[11px] uppercase tracking-wider text-white/50 font-bold mt-1">
            {score.label}
          </div>
        </div>
      ))
    }
  </div>

  <p class="text-white/60 text-sm leading-relaxed font-ui">{context}</p>
</section>
