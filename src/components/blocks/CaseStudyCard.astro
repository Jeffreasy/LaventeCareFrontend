---
import TechStackBadge from '../ui/TechStackBadge.astro';

interface Props {
  name: string;
  category: string;
  description: string;
  techStack?: string[];
  liveUrl?: string;
  caseStudyUrl?: string;
  class?: string;
}

const { name, category, description, techStack = [], liveUrl, caseStudyUrl, class: className } = Astro.props;
---

<div class:list={['group clinical-glass rounded-(--radius-feature) border border-white/8 hover:border-active/30 transition-all duration-(--transition-base) overflow-hidden', className]}>
  <!-- Card Content -->
  <div class="p-6 md:p-8 flex flex-col h-full">
    <!-- Header: Category Badge -->
    <div class="flex items-start justify-between mb-4">
      <span class="px-3 py-1.5 rounded-full text-[11px] font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20">
        {category}
      </span>
    </div>

    <!-- Title -->
    <h3 class="text-xl md:text-2xl font-bold text-white mb-2 font-display group-hover:text-active transition-colors">
      {name}
    </h3>

    <!-- Description -->
    <p class="text-white/70 text-sm md:text-base mb-6 leading-relaxed font-ui flex-1">
      {description}
    </p>

    <!-- Tech Stack -->
    {techStack.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-5">
        {techStack.map((tech) => (
          <TechStackBadge tech={tech} variant="subtle" />
        ))}
      </div>
    )}

    <!-- Live Link -->
    {liveUrl && (
      <a
        href={liveUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center text-active text-sm font-bold pt-4 border-t border-white/5 group/link hover:underline"
      >
        <span>Bekijk live</span>
        <svg
          class="w-4 h-4 ml-2 group-hover/link:translate-x-1 transition-transform"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    )}
    {caseStudyUrl && (
      <a
        href={caseStudyUrl}
        class="flex items-center text-white/50 text-xs font-semibold mt-3 hover:text-active transition-colors group/cs"
      >
        <span>Lees case study →</span>
      </a>
    )}
  </div>
</div>
