---
import Icon from '../ui/Icon.astro';
import SectionHeader from '../ui/SectionHeader.astro';

interface Props {
  locale?: 'nl' | 'en';
  showHeader?: boolean;
}

const { locale = 'nl', showHeader = true } = Astro.props;
const isEnglish = locale === 'en';

const copy = isEnglish
  ? {
      label: 'Fixed website packages',
      heading: 'A professional website with a <span class="text-active">clear scope</span>',
      description:
        'Three transparent starting points. The scope is agreed before work begins, so price, delivery and responsibilities remain clear.',
      recommended: 'Most chosen',
      buildLabel: 'Website build',
      oneOff: 'one-off',
      from: 'From',
      vat: 'All prices exclude VAT.',
      managementLabel: 'Managed after launch',
      perMonth: '/month',
      transfer: 'Or transfer to your own account without a LaventeCare subscription.',
      scope:
        'You supply final copy, logo and images before work starts. Domain registration, business mailboxes, paid licences and third-party subscriptions are not included unless stated in the quote.',
      managementTitle: 'A clear choice after launch',
      management:
        'Choose managed hosting and maintenance by LaventeCare, or have the website transferred to an account in your name. Content changes and new functionality are always agreed separately.',
      careTerms: 'View Website Care terms',
      cta: 'Discuss this package',
      packages: [
        {
          name: 'Website Start',
          eyebrow: 'Compact',
          price: '€750',
          carePrice: '€29',
          careDescription: 'Hosting, SSL, monitoring and technical updates',
          description:
            'A fast, credible one-page website for a business that needs a strong online foundation.',
          features: [
            'One complete, responsive page',
            'Tailored to your logo, colours and visual identity',
            'Technical SEO foundation and sitemap',
            'Performance and image optimisation',
            'SSL, deployment and launch check',
            'One consolidated revision round',
          ],
          href: '/contact?type=website-start',
        },
        {
          name: 'Website Business',
          eyebrow: 'For enquiries',
          price: '€1,000',
          carePrice: '€49',
          careDescription: 'Including form and transactional email monitoring',
          description:
            'A complete business website that receives and confirms enquiries professionally.',
          features: [
            'Up to three responsive pages',
            'Everything included in Website Start',
            'One secure contact or enquiry form',
            'Notification to one company email address',
            'Visitor confirmation (business mailbox excluded)',
            'Spam protection and two revision rounds',
          ],
          href: '/contact?type=website-business',
          featured: true,
        },
        {
          name: 'Custom Website',
          eyebrow: 'Unique direction',
          price: '€1,500',
          prefix: 'From',
          carePrice: '€75',
          carePrefix: 'From',
          careDescription: 'For custom hosting, monitoring and technical continuity',
          description:
            'For a distinct visual direction, an unconventional structure or requirements outside the fixed packages.',
          features: [
            'Unique visual and page direction',
            'Custom sections and interactions',
            'Form and transactional email flow',
            'Technical SEO and performance foundation',
            'Clear growth path for later extensions',
            'Fixed quote after a free intake',
          ],
          href: '/contact?type=website-custom',
        },
      ],
    }
  : {
      label: 'Vaste websitepakketten',
      heading:
        'Een professionele website met een <span class="text-active">duidelijke afspraak</span>',
      description:
        'Drie transparante startpunten. Ik leg vooraf vast wat inbegrepen is, zodat prijs, planning en verantwoordelijkheden helder blijven.',
      recommended: 'Meest gekozen',
      buildLabel: 'Realisatie website',
      oneOff: 'eenmalig',
      from: 'Vanaf',
      vat: 'Alle prijzen zijn exclusief btw.',
      managementLabel: 'Beheer na livegang',
      perMonth: '/maand',
      transfer: 'Of overdracht naar uw eigen account zonder LaventeCare-abonnement.',
      scope:
        'U levert definitieve teksten, logo en afbeeldingen aan voordat de bouw start. Domeinregistratie, zakelijke mailboxen, betaalde licenties en externe abonnementen zijn alleen inbegrepen als dit in de offerte staat.',
      managementTitle: 'Na livegang een duidelijke keuze',
      management:
        'Kies voor beheerde hosting en onderhoud door LaventeCare, of laat de website overdragen naar een account op uw naam. Inhoudelijke wijzigingen en nieuwe functies spreken we altijd apart af.',
      careTerms: 'Bekijk de voorwaarden van Website Care',
      cta: 'Bespreek dit pakket',
      packages: [
        {
          name: 'Website Start',
          eyebrow: 'Compact',
          price: '€750',
          carePrice: '€29',
          careDescription: 'Hosting, SSL, bewaking en technische updates',
          description:
            'Een snelle, betrouwbare one-page website voor een bedrijf dat professioneel zichtbaar wil zijn.',
          features: [
            'Eén complete, responsive pagina',
            'Aangepast aan uw logo, kleuren en huisstijl',
            'Technische SEO-basis en sitemap',
            'Snelheids- en afbeeldingsoptimalisatie',
            'SSL, publicatie en controle bij livegang',
            'Eén gebundelde correctieronde',
          ],
          href: '/contact?type=website-start',
        },
        {
          name: 'Website Business',
          eyebrow: 'Voor aanvragen',
          price: '€1.000',
          carePrice: '€49',
          careDescription: 'Inclusief bewaking van formulier en transactionele e-mail',
          description:
            'Een complete bedrijfswebsite die aanvragen professioneel ontvangt en automatisch bevestigt.',
          features: [
            'Maximaal drie responsive pagina’s',
            'Alles uit Website Start',
            'Eén veilig contact- of aanvraagformulier',
            'Melding naar één bedrijfsadres',
            'Bezoekersbevestiging (zakelijke mailbox niet inbegrepen)',
            'Spambeveiliging en twee correctierondes',
          ],
          href: '/contact?type=website-business',
          featured: true,
        },
        {
          name: 'Website Maatwerk',
          eyebrow: 'Unieke richting',
          price: '€1.500',
          prefix: 'Vanaf',
          carePrice: '€75',
          carePrefix: 'Vanaf',
          careDescription: 'Voor maatwerkhosting, bewaking en technische continuïteit',
          description:
            'Voor een unieke uitstraling, afwijkende structuur of wensen buiten de vaste pakketten.',
          features: [
            'Unieke visuele en inhoudelijke richting',
            'Maatwerksecties en interacties',
            'Formulier en transactionele e-mailflow',
            'Technische SEO- en snelheidsbasis',
            'Heldere groeiroute voor uitbreidingen',
            'Vaste offerte na een gratis intake',
          ],
          href: '/contact?type=website-maatwerk',
        },
      ],
    };
---

<section
  id={isEnglish ? 'website-packages' : 'website-pakketten'}
  class="scroll-mt-28"
  aria-label={copy.label}
>
  {
    showHeader && (
      <SectionHeader label={copy.label} heading={copy.heading} description={copy.description} />
    )
  }

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    {
      copy.packages.map((item, index) => (
        <article
          data-animate="fade-up"
          class:list={[
            'clinical-glass relative flex h-full flex-col overflow-hidden rounded-(--radius-feature) p-6 md:p-8 transition-colors',
            item.featured
              ? 'border-2 border-active bg-active/5 shadow-xl shadow-active/10'
              : 'border border-white/8 hover:border-active/25',
            index === 1 && 'delay-100',
            index === 2 && 'delay-200',
          ]}
        >
          {item.featured && (
            <span class="absolute right-0 top-0 rounded-bl-xl bg-active px-3 py-1.5 font-display text-[10px] font-black uppercase tracking-[0.16em] text-white">
              {copy.recommended}
            </span>
          )}

          <span class="mb-3 font-display text-xs font-bold uppercase tracking-[0.18em] text-active">
            {item.eyebrow}
          </span>
          <h3 class="mb-2 font-display text-xl font-black text-white">{item.name}</h3>
          <p class="mb-5 min-h-15 font-ui text-sm leading-relaxed text-white/55">
            {item.description}
          </p>

          <p class="mb-2 font-ui text-[11px] font-bold uppercase tracking-[0.16em] text-white/60">
            {copy.buildLabel}
          </p>
          <div class="mb-1 flex items-end gap-2">
            {item.prefix && (
              <span class="pb-1 font-ui text-sm font-semibold text-white/50">{item.prefix}</span>
            )}
            <span class="font-display text-4xl font-black tracking-tight text-white">
              {item.price}
            </span>
          </div>
          <p class="mb-6 font-ui text-xs text-white/60">
            {copy.oneOff} · {copy.vat}
          </p>

          <div class="mb-6 rounded-xl border border-active/15 bg-active/5 p-4">
            <p class="mb-2 font-ui text-[10px] font-bold uppercase tracking-[0.16em] text-active">
              {copy.managementLabel}
            </p>
            <div class="flex items-end gap-2">
              {item.carePrefix && (
                <span class="pb-0.5 font-ui text-xs font-semibold text-white/45">
                  {item.carePrefix}
                </span>
              )}
              <span class="font-display text-2xl font-black text-white">{item.carePrice}</span>
              <span class="pb-0.5 font-ui text-xs text-white/45">{copy.perMonth}</span>
            </div>
            <p class="mt-2 font-ui text-xs leading-relaxed text-white/50">{item.careDescription}</p>
          </div>

          <div class="mb-6 h-px bg-white/8" />
          <ul class="mb-8 flex-1 space-y-3 font-ui text-sm text-white/70">
            {item.features.map((feature) => (
              <li class="flex items-start gap-3">
                <Icon name="check" size={15} class="mt-0.5 shrink-0 text-active" />
                <span>{feature}</span>
              </li>
            ))}
          </ul>

          <a
            href={item.href}
            class:list={[
              'flex min-h-12 items-center justify-center gap-2 rounded-xl px-4 py-3 text-center font-ui text-sm font-bold transition-colors focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-active',
              item.featured
                ? 'bg-active text-white shadow-lg shadow-active/20 hover:bg-active/90'
                : 'border border-white/15 text-white hover:border-active/40 hover:bg-white/5',
            ]}
          >
            {copy.cta}
            <Icon name="arrow-right" size={16} />
          </a>
        </article>
      ))
    }
  </div>

  <div class="mt-6 grid grid-cols-1 gap-3 lg:grid-cols-[0.9fr_1.1fr]">
    <p
      class="rounded-xl border border-white/8 bg-white/3 p-5 font-ui text-xs leading-relaxed text-white/50"
    >
      <span class="mb-1 block font-bold text-white/75">{isEnglish ? 'Scope' : 'Afbakening'}</span>
      {copy.scope}
    </p>
    <p
      class="rounded-xl border border-active/20 bg-active/5 p-5 font-ui text-xs leading-relaxed text-white/55"
    >
      <span class="mb-1 block font-bold text-active">{copy.managementTitle}</span>
      {copy.management}
      <span class="mt-2 block text-white/60">{copy.transfer}</span>
      <a
        href="/website-care"
        class="mt-3 inline-flex font-bold text-active underline underline-offset-2"
      >
        {copy.careTerms}
      </a>
    </p>
  </div>
</section>
