---
import { cn } from '../../lib/utils';

interface FAQItem {
  question: string;
  answer: string;
}

interface FAQCategory {
  title: string;
  items: FAQItem[];
}

const faqs: FAQCategory[] = [
  {
    title: 'Agency & Maatwerk',
    items: [
      {
        question: 'Bouwen jullie ook applicaties op maat?',
        answer:
          'Absoluut. Naast onze Auth Systems functioneren wij als een high-end development agency. Wij bouwen complete digitale ecosystemen, van bliksemsnelle websites tot complexe SaaS-platformen en IoT-dashboards, die naadloos integreren met ons beveiligingssysteem.',
      },
      {
        question: 'Wat is LaventeCare Auth Systems precies?',
        answer:
          'Dit is onze core technologie: een "Headless" Authenticatie Provider die wij inzetten voor onze eigen projecten én als losstaand product aanbieden. Het handelt alle complexe beveiliging af, zodat wij (of jouw team) ons puur kunnen focussen op de unieke features van de applicatie.',
      },
      {
        question: 'Doen jullie ook projecten zonder jullie Auth Systeem?',
        answer:
          'Zeker. Hoewel ons Auth Systeem direct "Day 1" beveiliging biedt, zijn wij experts in Astro, React en moderne web-architectuur. Wij nemen projecten aan variërend van high-performance landing pages tot volledige bedrijfsapplicaties, met of zonder onze specifieke backend modules.',
      },
    ],
  },
  {
    title: 'Beveiliging & Privacy',
    items: [
      {
        question: 'Hoe veilig zijn de wachtwoorden van mijn gebruikers?',
        answer:
          'Veiligheid is onze topprioriteit. Wachtwoorden worden nooit als platte tekst opgeslagen, maar gehasht met Bcrypt (Cost 12) volgens de standaarden van 2026. Daarnaast hanteren we een strikt "Input is Toxic" beleid, wat betekent dat elke invoer streng gevalideerd wordt om injectie-aanvallen te voorkomen.',
      },
      {
        question: 'Ondersteunen jullie Multi-Factor Authenticatie (MFA)?',
        answer:
          'Ja. Wij bieden ingebouwde ondersteuning voor TOTP (Time-based One-Time Passwords) die werken met apps zoals Google Authenticator of Authy. Ook genereren we cryptografische backup-codes voor noodtoegang.',
      },
      {
        question: 'Hoe beschermen jullie tegen brute-force aanvallen?',
        answer:
          'We maken gebruik van actieve verdedigingsmechanismen zoals Rate Limiting. Het systeem staat maximaal 25 verzoeken per seconde toe (met een burst van 50) om misbruik te voorkomen zonder normale gebruikers te hinderen.',
      },
      {
        question: 'Is mijn data gescheiden van andere klanten?',
        answer:
          'Ja. Wij hanteren een strikte Multi-Tenancy architectuur. Elke klant (Tenant) heeft een unieke ID en we gebruiken Row Level Security (RLS) in de database. Dit is een "fortress" aanpak die op databaseniveau garandeert dat data nooit tussen verschillende tenants kan lekken.',
      },
    ],
  },
  {
    title: 'Integratie & Functionaliteit',
    items: [
      {
        question: 'Welk type tokens gebruiken jullie voor sessies?',
        answer:
          'Wij gebruiken een Dual-Token systeem voor optimale balans tussen veiligheid en gebruiksgemak: Access Tokens (kortlevende JWTs, bijv. 15 minuten) voor snelle toegang, en Refresh Tokens (langer houdbaar, veilig opgeslagen en geroteerd) om diefstal te voorkomen.',
      },
      {
        question: 'Kan ik mijn eigen e-mailinstellingen gebruiken?',
        answer:
          'Absoluut. Hoewel we een systeem-standaard hebben, kunnen tenants hun eigen SMTP-gateway (zoals Outlook, SendGrid of eigen servers) configureren. Wachtwoorden voor deze gateways worden versleuteld opgeslagen met AES-encryptie.',
      },
      {
        question: 'Hoe beheer ik de rechten van mijn gebruikers?',
        answer:
          'Het systeem werkt met een "Role-Based Access Control" (RBAC) model. Je kunt gebruikers toewijzen aan rollen zoals Admin (volledige toegang), Editor (wijzigen maar niet beheren) en Viewer (alleen-lezen).',
      },
    ],
  },
  {
    title: 'Compliance & Beheer',
    items: [
      {
        question: 'Worden acties in het systeem gelogd?',
        answer:
          'Ja, voor compliance (zoals GDPR/AVG) en veiligheid houden we een onveranderlijk (immutable) Audit Log bij. Hierin worden alle kritieke acties (zoals inloggen, gebruikers verwijderen of instellingen wijzigen) onweerlegbaar vastgelegd.',
      },
      {
        question: 'Wat gebeurt er met sessies als een gebruiker uitlogt?',
        answer:
          'Bij een uitlog-actie wordt de gehele "Token Family" ingetrokken. Dit zorgt ervoor dat alle actieve sessies op dat apparaat (en eventuele gekloonde tokens) direct onbruikbaar worden gemaakt.',
      },
      {
        question: 'Hoe zit het met inactieve accounts of tokens?',
        answer:
          'Een geautomatiseerd achtergrondproces (The Janitor) schoont continu verlopen sessies en tokens op om de database schoon te houden en het aanvalsoppervlak te minimaliseren.',
      },
    ],
  },
];

// Generate JSON-LD for FAQPage
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.flatMap((category) =>
    category.items.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    }))
  ),
};
---

<section id="faq" class="py-24 relative overflow-hidden">
  <!-- JSON-LD Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-4xl mx-auto text-center mb-16">
      <span class="text-[oklch(0.70_0.18_158)] font-semibold tracking-wider uppercase mb-4 block">
        Support & Info
      </span>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6 font-display">
        Veelgestelde Vragen
      </h2>
      <p class="text-xl text-white/70">
        Alles wat je moet weten over het LaventeCare Auth System, beveiliging en integratie.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 max-w-7xl mx-auto">
      <!-- Left Column (Categories 1 & 3) -->
      <div class="md:col-span-6 space-y-12">
        {
          [faqs[0], faqs[2]].map((category) => (
            <div class="fade-in-up">
              <h3 class="text-2xl font-bold text-white mb-6 pl-2 border-l-4 border-active">
                {category.title}
              </h3>
              <div class="space-y-4">
                {category.items.map((item) => (
                  <details class="group clinical-glass rounded-2xl border border-white/10 open:border-active/50 transition-all duration-300">
                    <summary class="flex items-center justify-between p-6 cursor-pointer list-none select-none">
                      <span class="text-lg font-medium text-white/90 group-hover:text-white transition-colors pr-4">
                        {item.question}
                      </span>
                      <span class="ml-auto flex-shrink-0 text-active bg-active/10 rounded-full p-1 transition-transform duration-300 group-open:rotate-180">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="20"
                          height="20"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <path d="m6 9 6 6 6-6" />
                        </svg>
                      </span>
                    </summary>
                    <div class="px-6 pb-6 text-white/70 leading-relaxed animate-in fade-in slide-in-from-top-2 duration-200">
                      {item.answer}
                    </div>
                  </details>
                ))}
              </div>
            </div>
          ))
        }
      </div>

      <!-- Right Column (Categories 2 & 4) - Offset by pt-16 for Anti-Safe Harbor -->
      <div class="md:col-span-6 space-y-12 md:pt-24">
        {
          [faqs[1], faqs[3]].map((category) => (
            <div class="fade-in-up">
              <h3 class="text-2xl font-bold text-white mb-6 pl-2 border-l-4 border-secondary">
                {category.title}
              </h3>
              <div class="space-y-4">
                {category.items.map((item) => (
                  <details class="group clinical-glass rounded-2xl border border-white/10 open:border-secondary/50 transition-all duration-300">
                    <summary class="flex items-center justify-between p-6 cursor-pointer list-none select-none">
                      <span class="text-lg font-medium text-white/90 group-hover:text-white transition-colors pr-4">
                        {item.question}
                      </span>
                      <span class="ml-auto flex-shrink-0 text-secondary bg-secondary/10 rounded-full p-1 transition-transform duration-300 group-open:rotate-180">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="20"
                          height="20"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <path d="m6 9 6 6 6-6" />
                        </svg>
                      </span>
                    </summary>
                    <div class="px-6 pb-6 text-white/70 leading-relaxed animate-in fade-in slide-in-from-top-2 duration-200">
                      {item.answer}
                    </div>
                  </details>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
