---
interface MenuItem {
  label: string;
  link: { cached_url: string };
  items?: MenuItem[];
}

interface Props {
  logo?: {
    filename: string;
    alt?: string;
  };
  menu: MenuItem[];
  siteName?: string;
}

const { logo, menu, siteName = 'LaventeCare' } = Astro.props;
---

<nav
  class="fixed top-0 left-0 right-0 z-50 border-b border-white/10 bg-background/80 backdrop-blur-xl transition-all duration-300"
  transition:name="navbar"
>
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center space-x-2">
        {
          logo?.filename ? (
            <img src={logo.filename} alt={logo.alt || siteName} width="32" height="32" class="h-8 w-auto" />
          ) : (
            <span class="text-xl font-bold text-[oklch(0.70_0.18_158)] font-display">
              {siteName}
            </span>
          )
        }
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-8">
        {
          menu.map((item) => {
            const href = item.link.cached_url === 'home' ? '/' : `/${item.link.cached_url}`;
            
            if (item.items && item.items.length > 0) {
              return (
                <div class="relative group">
                  <button class="flex items-center space-x-1 text-white/70 hover:text-[oklch(0.70_0.18_158)] transition-colors font-medium hover:bg-white/5 px-3 py-2 rounded-lg cursor-pointer">
                    <span>{item.label}</span>
                    <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </button>
                  
                  <div class="absolute left-0 top-full pt-2 opacity-0 translate-y-2 pointer-events-none group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto transition-all duration-200 min-w-[200px]">
                    <div class="clinical-glass rounded-xl border border-white/10 p-2 shadow-xl flex flex-col gap-1">
                      {item.items.map((subItem) => (
                        <a
                          href={`/${subItem.link.cached_url}`}
                          class="block px-4 py-2 text-sm text-white/70 hover:text-[oklch(0.70_0.18_158)] hover:bg-white/5 rounded-lg transition-colors"
                        >
                          {subItem.label}
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              );
            }

            return (
              <a
                href={href}
                class="text-white/70 hover:text-[oklch(0.70_0.18_158)] transition-colors font-medium hover:bg-white/5 px-3 py-2 rounded-lg"
              >
                {item.label}
              </a>
            );
          })
        }
      </div>

      <!-- Login Button (Desktop) -->
      <div class="hidden md:flex items-center space-x-4">
        <a 
          href="/login" 
          class="px-5 py-2 rounded-lg bg-white/5 border border-white/10 hover:bg-white/10 text-white font-medium transition-colors flex items-center space-x-2"
        >
          <svg class="w-4 h-4 text-[oklch(0.70_0.18_158)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"></path></svg>
          <span>Login</span>
        </a>
      </div>

      <!-- Mobile Menu Button (Pure CSS Details) -->
      <details id="mobile-menu" class="md:hidden group">
        <summary class="list-none p-2 text-white/70 hover:text-white cursor-pointer">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </summary>

        <!-- Mobile Menu Content -->
        <div class="absolute top-16 left-0 right-0 bg-[oklch(0.15_0.05_168)]/95 backdrop-blur-3xl border-t border-white/10 shadow-2xl h-[calc(100vh-4rem)] overflow-y-auto">
          <div class="px-4 py-4 space-y-2">
            {
              menu.map((item) => {
                const href = item.link.cached_url === 'home' ? '/' : `/${item.link.cached_url}`;
                
                if (item.items && item.items.length > 0) {
                  return (
                    <div class="space-y-1">
                      <span class="block px-2 text-sm font-semibold text-white/50 uppercase tracking-wider">
                        {item.label}
                      </span>
                      {item.items.map((subItem) => (
                        <a
                          href={`/${subItem.link.cached_url}`}
                          class="block pl-4 py-2 text-white/70 hover:text-[oklch(0.70_0.18_158)] transition-colors border-l border-white/5 hover:border-[oklch(0.70_0.18_158)]/30"
                        >
                          {subItem.label}
                        </a>
                      ))}
                    </div>
                  );
                }

                return (
                  <a
                    href={href}
                    class="block py-2 text-white/70 hover:text-[oklch(0.70_0.18_158)] transition-colors"
                  >
                    {item.label}
                  </a>
                );
              })
            }
            <div class="pt-4 border-t border-white/5">
              <a href="/login" class="block w-full text-center py-3 rounded-lg bg-[oklch(0.70_0.18_158)]/10 text-[oklch(0.70_0.18_158)] font-bold border border-[oklch(0.70_0.18_158)]/20">
                Login
              </a>
            </div>
          </div>
        </div>
      </details>
    </div>
  </div>
</nav>

<style>
  /* Open/Close animation for details dropdown */
  details summary::-webkit-details-marker {
    display: none;
  }

  details[open] summary svg {
    transform: rotate(90deg);
  }

  details summary svg {
    transition: transform 0.3s ease;
  }
</style>


<script>
  // Mobile Menu Logic
  const mobileMenu = document.getElementById('mobile-menu') as HTMLDetailsElement;
  
  if (mobileMenu) {
    // 0. Scroll Lock Logic
    const toggleScrollLock = (isOpen: boolean) => {
      if (isOpen) {
        document.body.style.overflow = 'hidden';
      } else {
        document.body.style.overflow = '';
      }
    };

    // Listen for toggle events (native <details> behavior)
    mobileMenu.addEventListener('toggle', () => {
      toggleScrollLock(mobileMenu.open);
    });

    // 1. Auto-close on link click
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.removeAttribute('open');
        // Toggle event will handle scroll unlock
      });
    });

    // 2. Click outside to close
    document.addEventListener('click', (e) => {
      if (mobileMenu.hasAttribute('open') && !mobileMenu.contains(e.target as Node)) {
        mobileMenu.removeAttribute('open');
        // Toggle event will handle scroll unlock
      }
    });
  }
</script>
