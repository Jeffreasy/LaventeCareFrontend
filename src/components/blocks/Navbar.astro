---
interface MenuItem {
  label: string;
  link: { cached_url: string };
  items?: MenuItem[];
}

interface Props {
  logo?: {
    filename: string;
    alt?: string;
  };
  menu: MenuItem[];
  siteName?: string;
}

const { logo, menu, siteName = 'LaventeCare' } = Astro.props;
---

<nav
  class="fixed top-0 left-0 right-0 z-50 border-b border-white/10 bg-background/80 backdrop-blur-xl transition-all duration-300"
  transition:name="navbar"
>
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center space-x-2 group">
        {
          logo?.filename ? (
            <img
              src={logo.filename}
              alt={logo.alt || siteName}
              width="64"
              height="64"
              class="h-16 w-auto group-hover:opacity-80 transition-opacity"
            />
          ) : (
            <span class="text-xl font-black text-active font-display tracking-tight group-hover:opacity-80 transition-opacity">
              {siteName}
            </span>
          )
        }
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-8">
        {
          menu.map((item) => {
            const href = item.link.cached_url === 'home' ? '/' : `/${item.link.cached_url}`;

            if (item.items && item.items.length > 0) {
              return (
                <div class="relative group">
                  <button class="flex items-center space-x-1 text-white/70 hover:text-active transition-colors font-medium hover:bg-white/5 px-3 py-2 rounded-lg cursor-pointer">
                    <span class="font-ui tracking-wide text-sm">{item.label}</span>
                    <svg
                      class="w-4 h-4 transition-transform group-hover:rotate-180"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 9l-7 7-7-7"
                      />
                    </svg>
                  </button>

                  <div class="absolute left-0 top-full pt-2 opacity-0 translate-y-2 pointer-events-none group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto transition-all duration-200 min-w-[200px]">
                    <div class="bg-background/95 backdrop-blur-3xl rounded-xl border border-white/10 p-2 shadow-xl flex flex-col gap-1">
                      {item.items.map((subItem) => (
                        <a
                          href={`/${subItem.link.cached_url}`}
                          class="block px-4 py-2 text-sm text-white/70 hover:text-active hover:bg-white/5 rounded-lg transition-colors font-ui"
                        >
                          {subItem.label}
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              );
            }

            return (
              <a
                href={href}
                class="text-white/70 hover:text-active transition-colors font-medium hover:bg-white/5 px-3 py-2 rounded-lg font-ui tracking-wide text-sm"
              >
                {item.label}
              </a>
            );
          })
        }

        {/* Admin Dropdown (visible only when logged in) */}
        {Astro.locals.isAdmin && (
          <div class="relative group">
            <button class="flex items-center space-x-1 text-white/70 hover:text-active transition-colors font-medium hover:bg-white/5 px-3 py-2 rounded-lg cursor-pointer">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              <span class="font-ui tracking-wide text-sm">Admin</span>
              <svg
                class="w-4 h-4 transition-transform group-hover:rotate-180"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"
                />
              </svg>
            </button>

            <div class="absolute left-0 top-full pt-2 opacity-0 translate-y-2 pointer-events-none group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto transition-all duration-200 min-w-[200px]">
              <div class="bg-background/95 backdrop-blur-3xl rounded-xl border border-white/10 p-2 shadow-xl flex flex-col gap-1">
                <a
                  href="/admin"
                  class="block px-4 py-2 text-sm text-white/70 hover:text-active hover:bg-white/5 rounded-lg transition-colors font-ui"
                >
                  Dashboard
                </a>
                <a
                  href="/admin/settings"
                  class="block px-4 py-2 text-sm text-white/70 hover:text-active hover:bg-white/5 rounded-lg transition-colors font-ui"
                >
                  Settings
                </a>
              </div>
            </div>
          </div>
        )}
      </div>

      <!-- Auth Buttons (Desktop) -->
      <div class="hidden md:flex items-center space-x-4">
        {Astro.locals.isLoggedIn ? (
          <form action="/api/auth/logout" method="POST">
            <button
              type="submit"
              class="px-5 py-2 rounded-lg bg-white/5 border border-white/10 hover:bg-red-500/10 hover:border-red-500/20 hover:text-red-400 text-white font-medium transition-all duration-300 flex items-center space-x-2 font-ui shadow-sm cursor-pointer"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
              </svg>
              <span>Logout</span>
            </button>
          </form>
        ) : (
          <a
            href="/login"
            class="px-5 py-2 rounded-lg bg-white/5 border border-white/10 hover:bg-active/10 hover:border-active/20 hover:text-active text-white font-medium transition-all duration-300 flex items-center space-x-2 font-ui shadow-sm"
          >
            <svg class="w-4 h-4 text-active" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M11 16l4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"
              ></path>
            </svg>
            <span>Login</span>
          </a>
        )}
      </div>

      <!-- Mobile Menu Button (Pure CSS Details) -->
      <details id="mobile-menu" class="md:hidden group">
        <summary
          class="list-none p-2 text-white/70 hover:text-white cursor-pointer transition-colors"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </summary>

        <!-- Mobile Menu Content -->
        <div
          class="absolute top-16 left-0 right-0 bg-background/95 backdrop-blur-3xl border-t border-white/10 shadow-2xl h-[calc(100vh-4rem)] overflow-y-auto"
        >
          <div class="px-4 py-4 space-y-2">
            {
              menu.map((item) => {
                const href = item.link.cached_url === 'home' ? '/' : `/${item.link.cached_url}`;

                if (item.items && item.items.length > 0) {
                  return (
                    <div class="space-y-1">
                      <span class="block px-2 text-sm font-bold text-white/40 uppercase tracking-widest font-display">
                        {item.label}
                      </span>
                      {item.items.map((subItem) => (
                        <a
                          href={`/${subItem.link.cached_url}`}
                          class="block pl-4 py-3 text-white/70 hover:text-active transition-colors border-l border-white/5 hover:border-active/50 font-ui"
                        >
                          {subItem.label}
                        </a>
                      ))}
                    </div>
                  );
                }

                return (
                  <a
                    href={href}
                    class="block py-3 text-white/70 hover:text-active transition-colors font-ui text-lg font-medium border-b border-white/5 last:border-0"
                  >
                    {item.label}
                  </a>
                );
              })
            }
            
            {/* Admin Section (Mobile) */}
            {Astro.locals.isAdmin && (
              <div class="pt-6 border-t border-white/5">
                <span class="block px-2 text-sm font-bold text-white/40 uppercase tracking-widest font-display mb-2">
                  Admin
                </span>
                <a
                  href="/admin"
                  class="block py-3 text-white/70 hover:text-active transition-colors font-ui text-lg font-medium border-b border-white/5"
                >
                  Dashboard
                </a>
                <a
                  href="/admin/settings"
                  class="block py-3 text-white/70 hover:text-active transition-colors font-ui text-lg font-medium border-b border-white/5"
                >
                  Settings
                </a>
              </div>
            )}

            <div class="pt-6 border-t border-white/5 mt-4">
              {Astro.locals.isLoggedIn ? (
                <form action="/api/auth/logout" method="POST">
                  <button
                    type="submit"
                    class="block w-full text-center py-4 rounded-xl bg-red-500/10 text-red-400 font-bold border border-red-500/20 hover:bg-red-500/20 transition-all cursor-pointer"
                  >
                    Logout
                  </button>
                </form>
              ) : (
                <a
                  href="/login"
                  class="block w-full text-center py-4 rounded-xl bg-active/10 text-active font-bold border border-active/20 hover:bg-active/20 transition-all"
                >
                  Login
                </a>
              )}
            </div>
          </div>
        </div>
      </details>
    </div>
  </div>
</nav>

<style>
  /* Open/Close animation for details dropdown */
  details summary::-webkit-details-marker {
    display: none;
  }

  details[open] summary svg {
    transform: rotate(90deg);
  }

  details summary svg {
    transition: transform 0.3s ease;
  }
</style>

<script>
  // Mobile Menu Logic
  const mobileMenu = document.getElementById('mobile-menu') as HTMLDetailsElement;

  if (mobileMenu) {
    // 0. Scroll Lock Logic
    const toggleScrollLock = (isOpen: boolean) => {
      if (isOpen) {
        document.body.style.overflow = 'hidden';
      } else {
        document.body.style.overflow = '';
      }
    };

    // Listen for toggle events (native <details> behavior)
    mobileMenu.addEventListener('toggle', () => {
      toggleScrollLock(mobileMenu.open);
    });

    // 1. Auto-close on link click
    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.removeAttribute('open');
        // Toggle event will handle scroll unlock
      });
    });

    // 2. Click outside to close
    document.addEventListener('click', (e) => {
      if (mobileMenu.hasAttribute('open') && !mobileMenu.contains(e.target as Node)) {
        mobileMenu.removeAttribute('open');
        // Toggle event will handle scroll unlock
      }
    });
  }
</script>
