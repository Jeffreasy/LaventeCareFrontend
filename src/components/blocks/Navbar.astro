---
interface MenuItem {
  label: string;
  link: { cached_url: string };
  items?: MenuItem[];
}

interface Props {
  logo?: {
    filename: string;
    alt?: string;
  };
  menu: MenuItem[];
  siteName?: string;
}

const { menu } = Astro.props;
import Logo from '../ui/Logo.astro';
const currentPath = Astro.url.pathname;

/** Check if a menu item or any of its children match the current path */
function isActive(item: MenuItem): boolean {
  const href = item.link.cached_url === 'home' ? '/' : `/${item.link.cached_url}`;
  if (currentPath === href || currentPath.startsWith(href + '/')) return true;
  if (item.items) return item.items.some((sub) => currentPath === `/${sub.link.cached_url}`);
  return false;
}
---

<nav
  id="main-nav"
  class="fixed top-4 left-4 right-4 z-50 clinical-glass rounded-2xl border-b border-white/10 transition-all duration-300"
  transition:name="navbar"
  role="navigation"
  aria-label="Main navigation"
>
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between nav-inner">
      {/* Logo */}
      <Logo size="md" showText={true} />

      {/* Desktop Navigation */}
      <div class="hidden lg:flex items-center gap-1">
        {
          menu.map((item) => {
            const href = item.link.cached_url === 'home' ? '/' : `/${item.link.cached_url}`;
            const active = isActive(item);

            if (item.items && item.items.length > 0) {
              return (
                <div class="relative group">
                  <button
                    class={`nav-link flex items-center gap-1.5 cursor-pointer ${active ? 'is-active' : ''}`}
                    aria-label={`Open ${item.label} menu`}
                    aria-haspopup="true"
                  >
                    <span>{item.label}</span>
                    <svg
                      class="w-3.5 h-3.5 transition-transform duration-200 group-hover:rotate-180"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        d="M19 9l-7 7-7-7"
                      />
                    </svg>
                  </button>

                  <div
                    class="nav-dropdown absolute left-1/2 -translate-x-1/2 top-full pt-3"
                    role="menu"
                  >
                    <div class="nav-dropdown__panel">
                      {item.items.map((subItem) => {
                        const subHref = `/${subItem.link.cached_url}`;
                        const subActive = currentPath === subHref;
                        return (
                          <a
                            href={subHref}
                            class={`nav-dropdown__item ${subActive ? 'is-active' : ''}`}
                            aria-current={subActive ? 'page' : undefined}
                            role="menuitem"
                          >
                            {subItem.label}
                          </a>
                        );
                      })}
                    </div>
                  </div>
                </div>
              );
            }

            return (
              <a
                href={href}
                class={`nav-link ${active ? 'is-active' : ''}`}
                aria-current={active ? 'page' : undefined}
              >
                {item.label}
              </a>
            );
          })
        }

        {/* Admin Dropdown (visible only when logged in) */}
        {
          Astro.locals.isAdmin && (
            <div class="relative group">
              <button
                class="nav-link flex items-center gap-1.5 cursor-pointer"
                aria-label="Open admin menu"
                aria-haspopup="true"
              >
                <svg
                  class="w-4 h-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
                  />
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                  />
                </svg>
                <span>Admin</span>
                <svg
                  class="w-3.5 h-3.5 transition-transform duration-200 group-hover:rotate-180"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2.5"
                    d="M19 9l-7 7-7-7"
                  />
                </svg>
              </button>

              <div
                class="nav-dropdown absolute left-1/2 -translate-x-1/2 top-full pt-3"
                role="menu"
              >
                <div class="nav-dropdown__panel">
                  <a href="/admin" class="nav-dropdown__item" role="menuitem">
                    Dashboard
                  </a>
                  <a href="/admin/settings" class="nav-dropdown__item" role="menuitem">
                    Settings
                  </a>
                </div>
              </div>
            </div>
          )
        }
      </div>

      {/* Desktop CTA + Auth */}
      <div class="hidden lg:flex items-center gap-3">
        <a href="/contact" class="nav-cta-contact"> Contact </a>
        {
          Astro.locals.isLoggedIn ? (
            <form action="/api/auth/logout" method="POST">
              <button type="submit" class="nav-cta-auth nav-cta-auth--logout">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"
                  />
                </svg>
                <span>Logout</span>
              </button>
            </form>
          ) : null
        }
      </div>

      {/* Mobile Menu Button */}
      <details id="mobile-menu" class="lg:hidden group">
        <summary
          class="list-none p-2 text-white/70 hover:text-white cursor-pointer transition-colors"
          aria-label="Mobile menu toggle"
          aria-controls="mobile-menu-content"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              class="hamburger-top"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16"></path>
            <path
              class="hamburger-mid"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 12h16"></path>
            <path
              class="hamburger-bot"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 18h16"></path>
          </svg>
        </summary>

        {/* Mobile Menu Panel */}
        <div id="mobile-menu-content" class="mobile-panel" role="menu">
          <div class="px-5 py-6 space-y-1">
            {
              menu.map((item, i) => {
                const href = item.link.cached_url === 'home' ? '/' : `/${item.link.cached_url}`;

                if (item.items && item.items.length > 0) {
                  return (
                    <div class="mobile-nav-group" style={`--stagger: ${i}`}>
                      <span class="mobile-nav-label">{item.label}</span>
                      <div class="space-y-0.5 mt-1">
                        {item.items.map((subItem, j) => {
                          const subHref = `/${subItem.link.cached_url}`;
                          const subActive = currentPath === subHref;
                          return (
                            <a
                              href={subHref}
                              class={`mobile-nav-subitem ${subActive ? 'is-active' : ''}`}
                              style={`--stagger: ${i + j + 1}`}
                              aria-current={subActive ? 'page' : undefined}
                            >
                              {subItem.label}
                            </a>
                          );
                        })}
                      </div>
                    </div>
                  );
                }

                return (
                  <a
                    href={href}
                    class={`mobile-nav-item ${currentPath === href ? 'is-active' : ''}`}
                    style={`--stagger: ${i}`}
                    aria-current={currentPath === href ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                );
              })
            }

            {/* Admin Section (Mobile) */}
            {
              Astro.locals.isAdmin && (
                <div class="pt-4 mt-4 border-t border-white/5">
                  <span class="mobile-nav-label">Admin</span>
                  <a href="/admin" class="mobile-nav-subitem" style="--stagger: 8">
                    Dashboard
                  </a>
                  <a href="/admin/settings" class="mobile-nav-subitem" style="--stagger: 9">
                    Settings
                  </a>
                </div>
              )
            }

            {/* Mobile CTA */}
            <div class="pt-6 mt-4 border-t border-white/8 space-y-3" style="--stagger: 10">
              <a href="/contact" class="mobile-cta mobile-cta--primary"> Contact </a>
              {
                Astro.locals.isLoggedIn ? (
                  <form action="/api/auth/logout" method="POST">
                    <button type="submit" class="mobile-cta mobile-cta--logout">
                      Logout
                    </button>
                  </form>
                ) : null
              }
            </div>
          </div>
        </div>
      </details>
    </div>
  </div>
</nav>

<style>
  /* ── Navbar Shell ───────────────────────────────────── */

  .nav-inner {
    height: 4rem;
    transition: height 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Scroll-compact state */
  #main-nav.is-scrolled {
    background: color-mix(in oklch, var(--color-panel) 88%, transparent);
    border-color: rgba(255, 255, 255, 0.06);
    box-shadow:
      0 8px 32px -8px rgba(0, 0, 0, 0.4),
      0 0 0 1px rgba(255, 255, 255, 0.04);
  }

  #main-nav.is-scrolled .nav-inner {
    height: 3.25rem;
  }

  /* ── Desktop Nav Links ─────────────────────────────── */

  .nav-link {
    position: relative;
    padding: 0.5rem 0.875rem;
    border-radius: 0.5rem;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: rgba(255, 255, 255, 0.6);
    transition:
      color 0.2s ease,
      background-color 0.2s ease;
    text-decoration: none;
  }

  .nav-link:hover {
    color: rgba(255, 255, 255, 0.95);
    background: rgba(255, 255, 255, 0.05);
  }

  .nav-link.is-active {
    color: var(--color-active);
  }

  /* Animated underline */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 0.875rem;
    right: 0.875rem;
    height: 2px;
    border-radius: 1px;
    background: linear-gradient(90deg, var(--color-active), var(--color-cta));
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-link:hover::after {
    transform: scaleX(0.6);
    opacity: 0.5;
  }

  .nav-link.is-active::after {
    transform: scaleX(1);
    opacity: 1;
  }

  /* ── Desktop Dropdown ──────────────────────────────── */

  .nav-dropdown {
    opacity: 0;
    transform: translateY(6px);
    pointer-events: none;
    transition:
      opacity 0.2s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    min-width: 220px;
  }

  .group:hover .nav-dropdown,
  .group:focus-within .nav-dropdown {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .group:focus-within > .nav-link svg:last-child {
    transform: rotate(180deg);
  }

  .nav-dropdown__panel {
    background: color-mix(in oklch, var(--color-background) 95%, transparent);
    backdrop-filter: blur(32px);
    -webkit-backdrop-filter: blur(32px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.75rem;
    padding: 0.375rem;
    box-shadow:
      0 20px 50px -12px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(255, 255, 255, 0.04);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  /* Triangle arrow */
  .nav-dropdown__panel::before {
    content: '';
    position: absolute;
    top: 6px;
    left: 50%;
    transform: translateX(-50%);
    width: 10px;
    height: 10px;
    background: color-mix(in oklch, var(--color-background) 95%, transparent);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-bottom: none;
    border-right: none;
    rotate: 45deg;
    border-radius: 2px 0 0 0;
  }

  .nav-dropdown__item {
    display: block;
    padding: 0.5rem 0.875rem;
    font-size: 0.8125rem;
    font-family: var(--font-ui);
    color: rgba(255, 255, 255, 0.6);
    border-radius: 0.5rem;
    transition:
      color 0.15s ease,
      background 0.15s ease;
    text-decoration: none;
  }

  .nav-dropdown__item:hover {
    color: var(--color-active);
    background: rgba(255, 255, 255, 0.05);
  }

  .nav-dropdown__item.is-active {
    color: var(--color-active);
    background: color-mix(in oklch, var(--color-active) 8%, transparent);
  }

  /* ── Desktop CTA Buttons ───────────────────────────── */

  .nav-cta-contact {
    padding: 0.5rem 1.25rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    font-family: var(--font-ui);
    border: 1px solid color-mix(in oklch, var(--color-active) 50%, transparent);
    color: var(--color-active);
    text-decoration: none;
    transition: all 0.2s ease;
    min-height: 2.5rem;
    display: flex;
    align-items: center;
  }

  .nav-cta-contact:hover {
    background: var(--color-active);
    color: white;
    border-color: var(--color-active);
    box-shadow: 0 0 20px -4px color-mix(in oklch, var(--color-active) 40%, transparent);
  }

  .nav-cta-auth {
    padding: 0.5rem 1.25rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    font-family: var(--font-ui);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: white;
    text-decoration: none;
    transition: all 0.25s ease;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
  }

  .nav-cta-auth:hover {
    background: color-mix(in oklch, var(--color-active) 12%, transparent);
    border-color: color-mix(in oklch, var(--color-active) 25%, transparent);
    color: var(--color-active);
  }

  .nav-cta-auth--logout:hover {
    background: oklch(0.6 0.22 25 / 0.1);
    border-color: oklch(0.6 0.22 25 / 0.2);
    color: oklch(0.7 0.18 25);
  }

  /* ── Hamburger Animation ───────────────────────────── */

  details summary::-webkit-details-marker {
    display: none;
  }

  details summary svg path {
    transition:
      transform 0.3s ease,
      opacity 0.2s ease;
    transform-origin: center;
  }

  details[open] summary .hamburger-top {
    transform: translateY(6px) rotate(45deg);
  }

  details[open] summary .hamburger-mid {
    opacity: 0;
  }

  details[open] summary .hamburger-bot {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* ── Mobile Panel ──────────────────────────────────── */

  .mobile-panel {
    position: absolute;
    top: 100%;
    left: -1px;
    right: -1px;
    margin-top: 0.5rem;
    background: color-mix(in oklch, var(--color-background) 98%, transparent);
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 1rem;
    box-shadow:
      0 24px 60px -12px rgba(0, 0, 0, 0.6),
      0 0 0 1px rgba(255, 255, 255, 0.03);
    max-height: calc(100dvh - 6rem);
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  /* ── Mobile Nav Items ──────────────────────────────── */

  .mobile-nav-item {
    display: block;
    padding: 0.875rem 0.75rem;
    font-family: var(--font-ui);
    font-size: 1.0625rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    border-radius: 0.625rem;
    transition:
      color 0.15s ease,
      background 0.15s ease;
    position: relative;
  }

  .mobile-nav-item:hover {
    color: rgba(255, 255, 255, 0.95);
    background: rgba(255, 255, 255, 0.04);
  }

  .mobile-nav-item.is-active {
    color: var(--color-active);
    background: color-mix(in oklch, var(--color-active) 6%, transparent);
  }

  /* Active accent bar */
  .mobile-nav-item.is-active::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 60%;
    border-radius: 0 3px 3px 0;
    background: linear-gradient(to bottom, var(--color-active), var(--color-cta));
  }

  .mobile-nav-group {
    padding-top: 0.75rem;
  }

  .mobile-nav-label {
    display: block;
    padding: 0.25rem 0.75rem;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.3);
    font-family: var(--font-display);
  }

  .mobile-nav-subitem {
    display: block;
    padding: 0.75rem 0.75rem 0.75rem 1.25rem;
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    border-radius: 0.5rem;
    transition:
      color 0.15s ease,
      background 0.15s ease;
    position: relative;
  }

  .mobile-nav-subitem:hover {
    color: rgba(255, 255, 255, 0.95);
    background: rgba(255, 255, 255, 0.04);
  }

  .mobile-nav-subitem.is-active {
    color: var(--color-active);
    background: color-mix(in oklch, var(--color-active) 6%, transparent);
  }

  .mobile-nav-subitem.is-active::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 50%;
    border-radius: 0 3px 3px 0;
    background: var(--color-active);
  }

  /* ── Mobile CTAs ───────────────────────────────────── */

  .mobile-cta {
    display: block;
    width: 100%;
    text-align: center;
    padding: 0.9375rem;
    border-radius: 0.75rem;
    font-weight: 600;
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
    border: none;
  }

  .mobile-cta--primary {
    border: 1px solid color-mix(in oklch, var(--color-active) 50%, transparent);
    color: var(--color-active);
    background: transparent;
  }

  .mobile-cta--primary:hover {
    background: var(--color-active);
    color: white;
  }

  .mobile-cta--secondary {
    background: color-mix(in oklch, var(--color-active) 8%, transparent);
    color: var(--color-active);
    border: 1px solid color-mix(in oklch, var(--color-active) 15%, transparent);
  }

  .mobile-cta--logout {
    background: oklch(0.6 0.22 25 / 0.08);
    color: oklch(0.7 0.18 25);
    border: 1px solid oklch(0.6 0.22 25 / 0.15);
  }

  /* ── Staggered Entrance Animation ──────────────────── */

  @media (prefers-reduced-motion: no-preference) {
    details[open] .mobile-panel {
      animation: panel-in 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    details[open] .mobile-nav-item,
    details[open] .mobile-nav-group,
    details[open] .mobile-nav-subitem {
      animation: item-stagger-in 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      animation-delay: calc(0.06s * var(--stagger, 0) + 0.1s);
      opacity: 0;
    }
  }

  @keyframes panel-in {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes item-stagger-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Focus Indicators ──────────────────────────────── */

  nav button:focus-visible,
  nav a:focus-visible,
  nav summary:focus-visible {
    outline: 2px solid oklch(0.6 0.14 200);
    outline-offset: 2px;
    border-radius: 0.5rem;
  }

  /* ── Reduced Motion ────────────────────────────────── */

  @media (prefers-reduced-motion: reduce) {
    .nav-link::after {
      transition: none;
    }
    .nav-dropdown {
      transition: none;
    }
    .nav-inner {
      transition: none;
    }
    details[open] .mobile-nav-item,
    details[open] .mobile-nav-group,
    details[open] .mobile-nav-subitem {
      opacity: 1;
      animation: none;
    }
  }
</style>

<script>
  // ── Scroll Compact ────────────────────────────────────
  const nav = document.getElementById('main-nav');
  if (nav) {
    const onScroll = () => {
      nav.classList.toggle('is-scrolled', window.scrollY > 32);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // ── Mobile Menu Logic ─────────────────────────────────
  const mobileMenu = document.getElementById('mobile-menu') as HTMLDetailsElement;

  if (mobileMenu) {
    const toggleScrollLock = (isOpen: boolean) => {
      document.body.style.overflow = isOpen ? 'hidden' : '';
    };

    mobileMenu.addEventListener('toggle', () => {
      toggleScrollLock(mobileMenu.open);
    });

    // Auto-close on link click
    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.removeAttribute('open');
      });
    });

    // Click outside to close
    document.addEventListener('click', (e) => {
      if (mobileMenu.hasAttribute('open') && !mobileMenu.contains(e.target as Node)) {
        mobileMenu.removeAttribute('open');
      }
    });

    // Escape to close
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && mobileMenu.hasAttribute('open')) {
        mobileMenu.removeAttribute('open');
        // Return focus to the summary (hamburger)
        mobileMenu.querySelector('summary')?.focus();
      }
    });
  }
</script>
