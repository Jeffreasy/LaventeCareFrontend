---
import type { SEOProps } from '../../lib/types';
import type { Locale } from '../../lib/i18n';

interface Props extends Partial<SEOProps> {
  noindex?: boolean;
  locale?: Locale;
  alternatePath?: string | null;
}

const {
  title = 'LaventeCare — AI Prompt Engineering, Web & IoT Solutions',
  description = 'LaventeCare combines AI prompt engineering with full-stack development and IoT expertise. Custom AI solutions and high-performance web applications.',
  image,
  noindex = false,
  locale = 'nl',
  alternatePath = null,
} = Astro.props;

const isEN = locale === 'en';
const ogLocale = isEN ? 'en_US' : 'nl_NL';

const ownDomain = isEN ? 'https://www.laventecare.com' : 'https://www.laventecare.nl';
const altDomain = isEN ? 'https://www.laventecare.nl' : 'https://www.laventecare.com';

const canonicalURL = new URL(Astro.url.pathname, ownDomain);
const ogImageUrl = image?.filename
  ? new URL(image.filename, ownDomain).href
  : new URL('/og-image.png', ownDomain).href;

// hreflang alternate URL (if a mapping exists)
const alternateURL = alternatePath ? new URL(alternatePath, altDomain).href : null;
const selfHreflang = isEN ? 'en' : 'nl';
const altHreflang = isEN ? 'nl' : 'en';
---

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex,nofollow" />}
<meta name="author" content="Jeffrey Lavente" />
<meta name="geo.region" content="NL-FL" />
<meta name="geo.placename" content="Dronten" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- hreflang: self -->
<link rel="alternate" hreflang={selfHreflang} href={canonicalURL.href} />
<!-- hreflang: alternate language (if mapping exists) -->
{alternateURL && <link rel="alternate" hreflang={altHreflang} href={alternateURL} />}
<!-- hreflang: x-default always points to NL (primary market) -->
<link rel="alternate" hreflang="x-default" href="https://www.laventecare.nl" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content="LaventeCare" />
<meta property="og:locale" content={ogLocale} />
{alternateURL && <meta property="og:locale:alternate" content={isEN ? 'nl_NL' : 'en_US'} />}
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />
<meta property="og:image:type" content="image/png" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL.href} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:image:alt" content={title} />
