---
interface FooterColumn {
  title: string;
  links: Array<{
    label: string;
    link: { cached_url: string };
  }>;
}

interface SocialLink {
  platform: string;
  url: string;
}

interface Props {
  columns: FooterColumn[];
  socialLinks: SocialLink[];
  copyright: string;
}

const { columns, socialLinks, copyright } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="bg-background/95 backdrop-blur-xl text-muted-foreground border-t border-white/10">
  <div class="container mx-auto px-4 py-12">
    <!-- Footer Columns -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-8">
      {
        columns.map((column) => (
          <div>
            <h3 class="text-foreground font-semibold mb-4">{column.title}</h3>
            <ul class="space-y-2">
              {column.links.map((link) => (
                <li>
                  <a href={`/${link.link.cached_url}`} class="hover:text-primary transition-colors">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- LaventeCare Branding -->
    <div class="border-t border-white/10 py-8 grid md:grid-cols-2 gap-6">
        <div class="flex items-center space-x-4">
             <div class="w-10 h-10 rounded-lg bg-[oklch(0.70_0.18_158)]/10 flex items-center justify-center border border-[oklch(0.70_0.18_158)]/20">
                <svg class="w-6 h-6 text-[oklch(0.70_0.18_158)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
             </div>
             <div>
                <span class="block text-white font-bold text-sm">Powered by LaventeCare</span>
                <span class="block text-white/50 text-xs">Enterprise Astro Architecture</span>
             </div>
        </div>

        <div class="flex items-center space-x-4 md:justify-end">
            <div class="flex items-center px-4 py-2 rounded-lg bg-white/5 border border-white/10">
                <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse mr-2"></div>
                <span class="text-xs text-white/70 font-mono">LaventeCare AuthSystem: <span class="text-green-400">Online</span></span>
            </div>
        </div>
    </div>

    <!-- Social Links & Copyright -->
    <div
      class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center"
    >
      <!-- Social Links -->
      {
        socialLinks.length > 0 && (
          <div class="flex space-x-4 mb-4 md:mb-0">
            {socialLinks.map((social) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-muted-foreground hover:text-white transition-colors"
                aria-label={social.platform}
              >
                <span class="text-sm uppercase">{social.platform}</span>
              </a>
            ))}
          </div>
        )
      }

      <!-- Copyright -->
      <p class="text-sm text-muted-foreground">
        {copyright.replace('2026', currentYear.toString())}
      </p>
    </div>
  </div>
</footer>
