---
interface FooterColumn {
  title: string;
  links: Array<{
    label: string;
    link: { cached_url: string };
  }>;
}

interface SocialLink {
  platform: string;
  url: string;
}

interface Props {
  columns: FooterColumn[];
  socialLinks: SocialLink[];
  copyright: string;
}

const { columns, socialLinks, copyright } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="text-white/70 border-t border-white/10">
  <div class="container mx-auto px-4 py-12">
    <!-- Footer Columns -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-8">
      {
        columns.map((column) => (
          <div>
            <h3 class="text-white font-semibold mb-4">{column.title}</h3>
            <ul class="space-y-2">
              {column.links.map((link) => (
                <li>
                  <a
                    href={`/${link.link.cached_url}`}
                    class="hover:text-active transition-colors focus-visible:outline-2 focus-visible:outline-active focus-visible:outline-offset-2 focus-visible:rounded"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- LaventeCare Branding -->
    <div class="border-t border-white/10 py-8 text-center">
      <p class="text-white/60 text-sm font-ui">
        Built with <span class="text-active font-semibold">LaventeCare</span> Enterprise Astro Architecture
      </p>
    </div>

    <!-- Social Links & Copyright -->
    <div
      class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center"
    >
      <!-- Social Links -->
      {
        socialLinks.length > 0 && (
          <div class="flex space-x-4 mb-4 md:mb-0">
            {socialLinks.map((social) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-white/70 hover:text-white transition-colors focus-visible:outline-2 focus-visible:outline-active focus-visible:outline-offset-2 focus-visible:rounded"
                aria-label={social.platform}
              >
                <span class="text-sm uppercase">{social.platform}</span>
              </a>
            ))}
          </div>
        )
      }

      <!-- Copyright -->
      <p class="text-sm text-white/60">
        {copyright.replace('2026', currentYear.toString())}
      </p>
    </div>
  </div>
</footer>
