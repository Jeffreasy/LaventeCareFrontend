---
import Logo from '../ui/Logo.astro';
interface FooterColumn {
  title: string;
  links: Array<{
    label: string;
    link: { cached_url: string };
  }>;
}

interface SocialLink {
  platform: string;
  url: string;
}

interface Props {
  columns: FooterColumn[];
  socialLinks: SocialLink[];
  copyright: string;
}

const { columns, socialLinks, copyright } = Astro.props;
const currentYear = new Date().getFullYear();

function isExternal(url: string): boolean {
  return url.startsWith('http');
}
---

<footer class="text-white/70 border-t border-white/10 mt-auto">
  <div class="container mx-auto px-4 py-10 md:py-16">
    <!-- Top: Brand + Columns -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-12 mb-10">
      <!-- Brand Column -->
      <div class="md:col-span-1">
        <Logo size="md" showText={true} class="mb-3" />
        <p class="text-white/50 text-sm leading-relaxed font-ui mb-4">
          AI Prompt Engineering, Web & IoT Solutions.
          Van chip tot cloud.
        </p>
        <div class="text-xs text-white/40 space-y-1 font-ui">
          <p>Dronten, Nederland</p>
          <p>KVK 88162710</p>
        </div>
      </div>

      <!-- Footer Columns -->
      {columns.map((column) => (
        <div>
          <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider font-display">
            {column.title}
          </h3>
          <ul class="space-y-2.5">
            {column.links.map((link) => {
              const href = isExternal(link.link.cached_url)
                ? link.link.cached_url
                : `/${link.link.cached_url}`;
              const external = isExternal(link.link.cached_url);
              return (
                <li>
                  <a
                    href={href}
                    class="text-sm hover:text-active transition-colors focus-visible:outline-2 focus-visible:outline-active focus-visible:outline-offset-2 focus-visible:rounded font-ui"
                    {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  >
                    {link.label}
                    {external && (
                      <svg class="w-3 h-3 inline-block ml-1 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                      </svg>
                    )}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </div>

    <!-- Social + Copyright -->
    <div class="border-t border-white/8 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <!-- Social Links -->
      {socialLinks.length > 0 && (
        <div class="flex items-center gap-4">
          {socialLinks.map((social) => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-white/50 hover:text-active transition-colors text-sm font-ui flex items-center gap-1.5"
              aria-label={social.platform}
            >
              {social.platform === 'LinkedIn' && (
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              )}
              {social.platform === 'GitHub' && (
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
              )}
              <span>{social.platform}</span>
            </a>
          ))}
        </div>
      )}

      <!-- Copyright -->
      <p class="text-xs text-white/40 font-ui text-center md:text-right">
        {copyright.replace('2026', currentYear.toString())}
      </p>
    </div>
  </div>
</footer>
