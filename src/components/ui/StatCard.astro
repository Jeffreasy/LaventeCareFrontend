---
interface Props {
  value: string;
  label: string;
  class?: string;
}

const { value, label, class: className } = Astro.props;
---

<div class:list={['text-center px-4', className]}>
  <div class="text-3xl md:text-4xl font-black text-active mb-1 font-display">
    {value}
  </div>
  <div class="text-sm text-white/60 font-ui">
    {label}
  </div>
</div>
