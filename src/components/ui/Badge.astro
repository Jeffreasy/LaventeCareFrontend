---
import { cn } from '../../lib/utils';

export interface Props {
  variant?: 'success' | 'warning' | 'error' | 'info' | 'active';
  glow?: boolean;
  class?: string;
}

const { variant = 'active', glow = false, class: className } = Astro.props;

const variantClasses = {
  success: 'bg-success/10 text-success border-success/20',
  warning: 'bg-warning/10 text-warning border-warning/20',
  error: 'bg-error/10 text-error border-error/20',
  info: 'bg-secondary/10 text-secondary border-secondary/20',
  active: 'bg-active/10 text-active border-active/20',
};

const glowClasses = {
  success: 'shadow-[0_0_8px_rgba(var(--color-success),0.3)] hover:scale-105',
  warning: 'shadow-[0_0_8px_rgba(var(--color-warning),0.3)] hover:scale-105',
  error: 'shadow-[0_0_8px_rgba(var(--color-error),0.3)] hover:scale-105',
  info: 'shadow-[0_0_8px_rgba(var(--color-secondary),0.3)] hover:scale-105',
  active: 'shadow-[0_0_8px_rgba(var(--color-active),0.3)] hover:scale-105',
};
---

<span
  class={cn(
    'inline-flex items-center px-3 py-1 rounded-[var(--radius-utility)] text-xs font-semibold tracking-wide uppercase border backdrop-blur-sm transition-all duration-[var(--transition-base)]',
    variantClasses[variant],
    glow && glowClasses[variant],
    className
  )}
>
  <slot />
</span>
