---
interface Props {
  class?: string;
  showText?: boolean;
  size?: 'sm' | 'md' | 'lg';
}

const { class: className, showText = false, size = 'md' } = Astro.props;

const sizeMap = {
  sm: 'h-6',
  md: 'h-8',
  lg: 'h-10',
};

const textSizeMap = {
  sm: 'text-sm',
  md: 'text-lg',
  lg: 'text-2xl',
};

// Unique ID to avoid SVG gradient conflicts
const uid = `lc-${Math.random().toString(36).slice(2, 8)}`;
---

<a
  href="/"
  class:list={['logo-mark inline-flex items-center gap-2.5 no-underline', className]}
  aria-label="LaventeCare — Home"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 200 100"
    class:list={[sizeMap[size], 'w-auto']}
    role="img"
    aria-hidden="true"
  >
    <defs>
      <linearGradient id={`${uid}-g`} x1="0%" y1="50%" x2="100%" y2="50%">
        <stop offset="0%" stop-color="#0891B2"></stop>
        <stop offset="100%" stop-color="#059669"></stop>
      </linearGradient>
      <linearGradient id={`${uid}-gl`} x1="0%" y1="50%" x2="100%" y2="50%">
        <stop offset="0%" stop-color="#0891B2" stop-opacity="0.35"></stop>
        <stop offset="100%" stop-color="#059669" stop-opacity="0.35"></stop>
      </linearGradient>
      {/* Bright gradient for the traveling light — matches brand colors */}
      <linearGradient id={`${uid}-bright`} x1="0%" y1="50%" x2="100%" y2="50%">
        <stop offset="0%" stop-color="#67E8F9"></stop>
        <stop offset="50%" stop-color="#A5F3FC"></stop>
        <stop offset="100%" stop-color="#6EE7B7"></stop>
      </linearGradient>
    </defs>

    {/* Glow */}
    <path
      d="M 55 20 C 18 20, 18 80, 55 80 C 82 80, 90 50, 100 50 C 110 50, 118 20, 145 20 C 182 20, 182 80, 145 80 C 118 80, 110 50, 100 50 C 90 50, 82 20, 55 20 Z"
      fill="none"
      stroke={`url(#${uid}-gl)`}
      stroke-width="16"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="logo-glow"></path>

    {/* Main infinity */}
    <path
      d="M 55 20 C 18 20, 18 80, 55 80 C 82 80, 90 50, 100 50 C 110 50, 118 20, 145 20 C 182 20, 182 80, 145 80 C 118 80, 110 50, 100 50 C 90 50, 82 20, 55 20 Z"
      fill="none"
      stroke={`url(#${uid}-g)`}
      stroke-width="10"
      stroke-linecap="round"
      stroke-linejoin="round"></path>

    {/* Layer 1 — Deep ambient glow (widest, most blurred, longest trail) */}
    <path
      d="M 55 20 C 18 20, 18 80, 55 80 C 82 80, 90 50, 100 50 C 110 50, 118 20, 145 20 C 182 20, 182 80, 145 80 C 118 80, 110 50, 100 50 C 90 50, 82 20, 55 20 Z"
      fill="none"
      stroke={`url(#${uid}-bright)`}
      stroke-width="20"
      stroke-linecap="round"
      class="infinity-trail infinity-trail--deep"
      pathLength="1000"></path>

    {/* Layer 2 — Mid glow (medium width, medium blur, shorter trail) */}
    <path
      d="M 55 20 C 18 20, 18 80, 55 80 C 82 80, 90 50, 100 50 C 110 50, 118 20, 145 20 C 182 20, 182 80, 145 80 C 118 80, 110 50, 100 50 C 90 50, 82 20, 55 20 Z"
      fill="none"
      stroke={`url(#${uid}-bright)`}
      stroke-width="10"
      stroke-linecap="round"
      class="infinity-trail infinity-trail--mid"
      pathLength="1000"></path>

    {/* Layer 3 — Hot core (sharp white, short head) */}
    <path
      d="M 55 20 C 18 20, 18 80, 55 80 C 82 80, 90 50, 100 50 C 110 50, 118 20, 145 20 C 182 20, 182 80, 145 80 C 118 80, 110 50, 100 50 C 90 50, 82 20, 55 20 Z"
      fill="none"
      stroke="white"
      stroke-width="3"
      stroke-linecap="round"
      class="infinity-trail infinity-trail--core"
      pathLength="1000"></path>

    {/* Globe detail in left loop */}
    <g opacity="0.6">
      <circle cx="55" cy="50" r="12" fill="none" stroke="#0891B2" stroke-width="1.5"></circle>
      <ellipse cx="55" cy="50" rx="5" ry="12" fill="none" stroke="#0891B2" stroke-width="1.2"
      ></ellipse>
      <line x1="43" y1="50" x2="67" y2="50" stroke="#0891B2" stroke-width="1.2"></line>
    </g>

    {/* Code cross in right loop */}
    <g opacity="0.75">
      <path
        d="M 138 50 L 152 50 M 145 43 L 145 57"
        stroke="#059669"
        stroke-width="3.5"
        stroke-linecap="round"></path>
    </g>
  </svg>

  {
    showText && (
      <span
        class:list={[
          textSizeMap[size],
          'logo-wordmark font-display whitespace-nowrap leading-none',
        ]}
      >
        <>
          <span class="logo-wordmark__lavente">Lavente</span>
          <span class="logo-wordmark__care">Care</span>
        </>
      </span>
    )
  }
</a>

<style>
  .logo-glow {
    filter: blur(3px);
  }

  .logo-mark {
    text-decoration: none;
  }

  /* ── Traveling Light — Comet Trail System ───────────── */

  /* Layer 1: Deep ambient — long comet tail, heavy blur */
  .infinity-trail--deep {
    stroke-dasharray: 100 900;
    filter: blur(8px);
    opacity: 0.3;
  }

  /* Layer 2: Mid glow — medium tail, medium blur */
  .infinity-trail--mid {
    stroke-dasharray: 70 930;
    filter: blur(4px);
    opacity: 0.55;
  }

  /* Layer 3: Hot core — short head, crisp */
  .infinity-trail--core {
    stroke-dasharray: 30 970;
    opacity: 0.95;
  }

  @media (prefers-reduced-motion: no-preference) {
    .logo-mark:hover svg {
      filter: drop-shadow(0 0 10px oklch(0.6 0.14 200 / 0.4));
      transition: filter 0.3s ease;
    }

    .infinity-trail {
      animation: infinity-trace 6s linear infinite;
    }

    /* Stagger layers — glow trails slightly behind the core */
    .infinity-trail--deep {
      animation-delay: -0.15s;
    }
    .infinity-trail--mid {
      animation-delay: -0.05s;
    }
  }

  @keyframes infinity-trace {
    from {
      stroke-dashoffset: 0;
    }
    to {
      stroke-dashoffset: -1000;
    }
  }

  /* Reduced motion: hide all light layers */
  @media (prefers-reduced-motion: reduce) {
    .infinity-trail {
      display: none;
    }
  }

  /* ── Premium Wordmark ──────────────────────────────── */

  .logo-wordmark {
    font-weight: 800;
    letter-spacing: -0.02em;
    position: relative;
    overflow: hidden;
  }

  /* "Lavente" — clean white with subtle cool tint */
  .logo-wordmark__lavente {
    background: linear-gradient(135deg, #ffffff 0%, #e0f2fe 60%, #cffafe 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* "Care" — brand gradient */
  .logo-wordmark__care {
    background: linear-gradient(135deg, #22d3ee 0%, #0891b2 40%, #059669 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Shimmer highlight sweep on hover */
  .logo-wordmark::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 0%,
      transparent 35%,
      oklch(0.95 0.01 200 / 0.25) 45%,
      oklch(1 0 0 / 0.4) 50%,
      oklch(0.95 0.01 200 / 0.25) 55%,
      transparent 65%,
      transparent 100%
    );
    transform: translateX(-100%);
    pointer-events: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .logo-mark:hover .logo-wordmark::after {
      animation: wordmark-shimmer 0.8s ease-out forwards;
    }
  }

  @keyframes wordmark-shimmer {
    from {
      transform: translateX(-100%);
    }
    to {
      transform: translateX(100%);
    }
  }
</style>
