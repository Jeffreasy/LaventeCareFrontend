---
import { cn } from '../../lib/utils';
import IconBox from './IconBox.astro';
import type { LucideIcon } from 'lucide-react';

export interface Props {
  title: string;
  description: string;
  icon?: LucideIcon;
  hover?: boolean;
  class?: string;
}

const { title, description, icon, hover = true, class: className } = Astro.props;
---

<div
  class={cn(
    'clinical-glass p-8 rounded-[var(--radius-feature)] border border-white/10',
    hover && 'feature-card',
    className
  )}
>
  {icon && (
    <IconBox icon={icon} size="lg" class="mb-4" />
  )}
  <slot name="icon" />
  
  <h3 class="text-xl font-bold text-white mb-3 font-display">
    {title}
  </h3>
  
  <p class="text-white/70 leading-relaxed">
    {description}
  </p>
  
  <slot />
</div>
