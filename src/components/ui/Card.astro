---
import { cn } from '../../lib/utils';

export interface Props {
  hover?: boolean;
  class?: string;
  padding?: 'none' | 'sm' | 'md' | 'lg';
}

const { hover = false, class: className, padding = 'md' } = Astro.props;

const paddingClasses = {
  none: '',
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8',
};
---

<div
  class={cn(hover ? 'clinical-glass-hover' : 'clinical-glass', paddingClasses[padding], className)}
>
  <slot />
</div>
