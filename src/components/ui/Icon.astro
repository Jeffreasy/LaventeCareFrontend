const { name, size = 24, class: className } = Astro.props;
const icon = icons[name];
---

<svg
  class:list={[className]}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  {icon.paths.map((d) => <path d={d} />)}
  {'circles' in icon && icon.circles?.map((c) => <circle cx={c.cx} cy={c.cy} r={c.r} />)}
  {
    'rects' in icon &&
      icon.rects?.map((r) => <rect x={r.x} y={r.y} width={r.width} height={r.height} rx={r.rx} />)
  }
  {'extraPaths' in icon && icon.extraPaths?.map((d) => <path d={d} />)}
  {'polylines' in icon && icon.polylines?.map((p) => <polyline points={p} />)}
</svg>
