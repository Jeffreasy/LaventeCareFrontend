---
interface Props {
  score: number;
  label: string;
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { score, label, size = 'md', class: className } = Astro.props;

const sizeMap = {
  sm: { dimension: 64, strokeWidth: 4, fontSize: 'text-sm', labelSize: 'text-[9px]' },
  md: { dimension: 88, strokeWidth: 5, fontSize: 'text-xl', labelSize: 'text-[10px]' },
  lg: { dimension: 112, strokeWidth: 6, fontSize: 'text-2xl', labelSize: 'text-xs' },
};

const config = sizeMap[size];
const radius = (config.dimension - config.strokeWidth * 2) / 2;
const circumference = 2 * Math.PI * radius;
const offset = circumference - (score / 100) * circumference;
const center = config.dimension / 2;

// OKLCH color mapping: green for 90+, amber for 50-89, red for <50
const getScoreColor = (s: number) => {
  if (s >= 90) return { stroke: 'oklch(0.72 0.19 155)', glow: 'oklch(0.72 0.19 155 / 0.35)' };
  if (s >= 50) return { stroke: 'oklch(0.80 0.16 80)', glow: 'oklch(0.80 0.16 80 / 0.35)' };
  return { stroke: 'oklch(0.65 0.22 25)', glow: 'oklch(0.65 0.22 25 / 0.35)' };
};

const colors = getScoreColor(score);
---

<div class:list={['lighthouse-gauge flex flex-col items-center gap-2', className]}>
  <div class="relative" style={`width: ${config.dimension}px; height: ${config.dimension}px;`}>
    <svg
      viewBox={`0 0 ${config.dimension} ${config.dimension}`}
      class="lighthouse-gauge__svg"
      aria-label={`${label}: ${score} van 100`}
      role="img"
    >
      {/* Background track */}
      <circle
        cx={center}
        cy={center}
        r={radius}
        fill="none"
        stroke="rgba(255,255,255,0.06)"
        stroke-width={config.strokeWidth}></circle>
      {/* Score arc */}
      <circle
        cx={center}
        cy={center}
        r={radius}
        fill="none"
        stroke={colors.stroke}
        stroke-width={config.strokeWidth}
        stroke-linecap="round"
        stroke-dasharray={circumference}
        stroke-dashoffset={circumference}
        class="lighthouse-gauge__arc"
        style={`--gauge-offset: ${offset}; --gauge-circumference: ${circumference}; --gauge-glow: ${colors.glow};`}
        transform={`rotate(-90 ${center} ${center})`}></circle>
    </svg>
    {/* Score number overlay */}
    <div class="absolute inset-0 flex items-center justify-center">
      <span
        class:list={[config.fontSize, 'font-black font-display text-white lighthouse-gauge__score']}
      >
        {score}
      </span>
    </div>
  </div>
  <span
    class:list={[
      config.labelSize,
      'text-white/50 font-ui font-medium tracking-wide uppercase text-center leading-tight',
    ]}
  >
    {label}
  </span>
</div>
