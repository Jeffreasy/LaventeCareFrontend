---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import TechStackBadge from '../../components/ui/TechStackBadge.astro';
import Icon, { type IconName } from '../../components/ui/Icon.astro';

const laws = [
  {
    num: '01',
    title: 'Alles wat binnenkomt is verdacht',
    subtitle: 'Geen blindelings vertrouwen',
    desc: 'Alles wat binnenkomt — formulieren, API-verzoeken, uploads — wordt behandeld als potentieel schadelijk: automatisch gecontroleerd en gefilterd. Kwaadaardige invoer wordt geblokkeerd voordat het schade kan doen aan uw systeem of data.',
  },
  {
    num: '02',
    title: 'Aanvallers leren niets uit foutmeldingen',
    subtitle: 'Aanvallers leren niets',
    desc: 'Bezoekers krijgen nooit technische foutmeldingen te zien die hackers kunnen misbruiken. Fouten worden intern bijgehouden en opgelost, zonder dat buitenstaanders inzicht krijgen in de werking van uw systeem.',
  },
  {
    num: '03',
    title: 'De database bewaakt zichzelf',
    subtitle: 'Gescheiden op databaseniveau',
    desc: 'Uw data wordt op databaseniveau gescheiden van andere klanten met PostgreSQL Row Level Security. Zelfs als er een fout in de code zit, kan data van andere bedrijven niet worden ingezien. De database zélf handhaaft wie welke gegevens mag zien.',
  },
  {
    num: '04',
    title: 'Betrouwbaar, ook bij grote drukte',
    subtitle: 'Geen fouten bij hoge belasting',
    desc: 'Ontworpen om fouten zoals data-corruptie of dubbele boekingen te voorkomen, ook onder hoge belasting — veel gelijktijdige gebruikers zonder dat gegevens door elkaar lopen.',
  },
  {
    num: '05',
    title: 'Alleen bewezen, gecontroleerde onderdelen',
    subtitle: 'Minder kwetsbaar, meer controle',
    desc: 'Alleen bewezen en gecontroleerde software wordt gebruikt. Minder afhankelijkheden betekent minder kwetsbaarheden — en elke externe component wordt regelmatig gecontroleerd op bekende problemen.',
  },
];

const watUKrijgt = [
  {
    icon: 'shield-check',
    title: 'Gescheiden klantdata',
    desc: 'Uw bedrijfsgegevens zijn technisch gescheiden van andere klanten. Bij een fout kan niemand bij andermans data.',
  },
  {
    icon: 'lock',
    title: 'Versleutelde opslag',
    desc: 'Gevoelige gegevens worden versleuteld opgeslagen. Bij een hack zijn deze data niet bruikbaar voor kwaadwillenden.',
  },
  {
    icon: 'clipboard-list',
    title: 'Elke actie traceerbaar',
    desc: 'Alle acties worden vastgelegd en kunnen niet worden aangepast. Misbruik of fouten zijn altijd achteraf terug te vinden.',
  },
  {
    icon: 'zap',
    title: 'Automatische bescherming',
    desc: 'Verdachte bezoekers en bots worden automatisch geblokkeerd voordat ze schade kunnen doen. Zonder dat u er iets voor hoeft te doen.',
  },
  {
    icon: 'shield-check',
    title: 'Privacy by Design',
    desc: 'Gebouwd volgens AVG-principes: dataminimalisatie, versleutelde opslag en verwerkersovereenkomst beschikbaar. Concrete compliance hangt af van contractuele afspraken en uw inrichting.',
  },
  {
    icon: 'refresh-cw',
    title: 'Automatische opschoning',
    desc: 'Verlopen sessies en tokens worden automatisch opgeruimd. Geen zwerfdata, geen vergeten toegangsrechten.',
  },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Beveiliging & Authenticatie',
  description:
    'Uw klantdata structureel beschermd en gescheiden. Beveiliging als fundament ingebouwd volgens Privacy by Design en AVG-principes — zodat de technische basis voor naleving structureel verankerd is.',
  provider: {
    '@type': 'ProfessionalService',
    name: 'LaventeCare',
    url: 'https://www.laventecare.nl',
  },
  areaServed: 'NL',
  serviceType: 'App Security & Authentication Architecture',
  serviceOutput:
    'Volledige authenticatiesystemen, role-based access control en data-isolatie structuren',
};
---

<script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

<Layout
  title="Beveiliging & Authenticatie — Veilig vanaf de basis | LaventeCare"
  description="Gegevens van elke klant strikt gescheiden, toegang per rol en elke actie vastgelegd. Beveiliging vanaf de basis ingebouwd — niet als bijzaak achteraf."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto mb-16">
        <span
          class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-3 flex items-center gap-2"
          ><Icon name="shield-check" size={16} class="text-active" /> Beveiliging & Authenticatie</span
        >
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 font-display tracking-tight"
        >
          Uw data <span class="text-active">beschermd</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 font-ui leading-relaxed mb-6">
          Beveiliging zit <span class="text-white font-semibold">vanaf de eerste regel code
          ingebouwd</span>. De gegevens van uw klanten staan technisch gescheiden, iedereen ziet
          alleen wat hij mag, en elke actie wordt vastgelegd. Zo blijft uw klantdata beschermd —
          zelfs bij fouten in het systeem.
        </p>
        <div class="flex flex-wrap gap-2">
          {
            ['Gescheiden klantdata', 'Toegang per rol', 'Alles traceerbaar', 'Versleuteling', 'Veilig gescheiden'].map(
              (t) => <TechStackBadge tech={t} />
            )
          }
        </div>
      </div>

      <!-- Wat U Krijgt -->
      <SectionHeader
        label="Het resultaat"
        heading='Wat u <span class="text-active">concreet krijgt</span>'
        description="Niet hoe het werkt, maar wat het voor uw bedrijf betekent."
      />

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto mb-16">
        {
          watUKrijgt.map((item, index) => (
            <div
              data-animate="scale-up"
              class={`delay-${(index % 3) * 100} clinical-glass p-5 rounded-(--radius-card) border border-white/8 hover:border-active/20 transition-colors group`}
            >
              <div class="flex items-start gap-3 mb-3">
                <div class="w-9 h-9 rounded-lg bg-active/10 flex items-center justify-center shrink-0 group-hover:bg-active/20 transition-colors">
                  <Icon name={item.icon as IconName} size={18} class="text-active" />
                </div>
                <h3 class="text-sm font-bold text-white font-display pt-1.5">{item.title}</h3>
              </div>
              <p class="text-white/60 text-xs font-ui leading-relaxed">{item.desc}</p>
            </div>
          ))
        }
      </div>

      <!-- De 5 Principes -->
      <SectionHeader
        label="Veiligheid vanaf de basis"
        heading='Vijf <span class="text-active">beveiligingsprincipes</span>'
        description="Vijf strikte principes die de kern vormen van elk systeem — ontwikkeld uit de praktijk van het bouwen van platformen waar elke klant zijn eigen, afgeschermde plek heeft."
      />

      <div class="space-y-4 max-w-4xl mx-auto mb-16">
        {
          laws.map((law, index) => (
            <div
              data-animate="fade-up"
              class={`delay-${index * 100} clinical-glass p-5 md:p-8 rounded-(--radius-feature) border border-white/8 hover:border-active/20 transition-colors group`}
            >
              <div class="flex items-start gap-4 md:gap-6">
                <div class="w-10 h-10 md:w-12 md:h-12 rounded-xl bg-active/10 flex items-center justify-center shrink-0 group-hover:bg-active/20 transition-colors">
                  <span class="text-active text-sm md:text-base font-bold font-display">
                    {law.num}
                  </span>
                </div>
                <div>
                  <h3 class="text-base md:text-lg font-bold text-white mb-1 font-display">
                    {law.title}
                  </h3>
                  <p class="text-active text-xs font-bold uppercase tracking-wider mb-2 font-display">
                    {law.subtitle}
                  </p>
                  <p class="text-white/60 text-sm leading-relaxed font-ui">{law.desc}</p>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <!-- AVG & Compliance -->
      <div
        class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-active/20 bg-active/5 max-w-4xl mx-auto mb-16"
      >
        <div class="flex items-center gap-3 mb-6">
          <Icon name="shield-check" size={24} class="text-active" />
          <h2 class="text-xl md:text-2xl font-bold text-white font-display">
            AVG & Privacy by Design
          </h2>
        </div>
        <p class="text-white/70 font-ui text-sm leading-relaxed mb-6">
          Alle applicaties worden gebouwd volgens het principe van <strong class="text-white"
            >Privacy by Design</strong
          >. Databescherming is van begin af aan meeontworpen — niet achteraf toegevoegd.
          Concrete AVG-compliance hangt af van contractuele afspraken, uw inrichting en gebruik;
          een <strong class="text-white">verwerkersovereenkomst</strong> is beschikbaar.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <ul class="space-y-3 text-sm font-ui text-white/70">
            <li class="flex gap-3">
              <Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Dataminimalisatie —
              alleen opslaan wat nodig is
            </li>
            <li class="flex gap-3">
              <Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Versleutelde opslag
              van gevoelige gegevens
            </li>
            <li class="flex gap-3">
              <Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Automatische opschoning
              van verlopen data
            </li>
          </ul>
          <ul class="space-y-3 text-sm font-ui text-white/70">
            <li class="flex gap-3">
              <Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Verwerkersovereenkomst
              beschikbaar
            </li>
            <li class="flex gap-3">
              <Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Elke actie wordt
              vastgelegd in een logboek dat niet achteraf aangepast kan worden
            </li>
            <li class="flex gap-3">
              <Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Geteste procedure voor
              datalekken
            </li>
          </ul>
        </div>
      </div>

      <!-- Architecturale Details (voor de geïnteresseerde lezer) -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <div class="clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8">
          <h3 class="text-lg font-bold text-white mb-4 font-display">Onder de motorkap</h3>
          <p class="text-white/50 text-xs font-ui mb-4">
            Voor ontwikkelaars en technisch geïnteresseerden:
          </p>
          <ul class="space-y-3 text-sm font-ui text-white/70">
            <li class="flex gap-3">
              <Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Row Level Security op
              alle kritieke tabellen
            </li>
            <li class="flex gap-3">
              <Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Dual-Token authenticatie
              (access + refresh)
            </li>
            <li class="flex gap-3">
              <Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Zero-Trust API design:
              elk verzoek wordt geverifieerd
            </li>
            <li class="flex gap-3">
              <Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Rate limiting tegen
              brute-force aanvallen
            </li>
          </ul>
        </div>
        <div class="clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8">
          <h3 class="text-lg font-bold text-white mb-4 font-display">Dagelijkse bescherming</h3>
          <p class="text-white/50 text-xs font-ui mb-4">Wat continu op de achtergrond draait:</p>
          <ul class="space-y-3 text-sm font-ui text-white/70">
            <li class="flex gap-3">
              <Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Twee-factor authenticatie
              voor beheerders
            </li>
            <li class="flex gap-3">
              <Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Automatische opschoning
              van verlopen sessies
            </li>
            <li class="flex gap-3">
              <Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Content Security Policy
              tegen code-injectie
            </li>
            <li class="flex gap-3">
              <Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Per-klant toegangscontrole
              op API-niveau
            </li>
          </ul>
        </div>
      </div>

      <!-- Trust Trigger -->
      <div class="max-w-4xl mx-auto mt-8">
        <div class="clinical-glass p-5 md:p-6 rounded-(--radius-feature) border border-active/15 bg-active/5">
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-center">
            <div>
              <Icon name="shield-check" size={22} class="text-active block mb-2 mx-auto" />
              <p class="text-white/60 text-xs font-ui">Gegevens van elke klant strikt gescheiden</p>
            </div>
            <div>
              <Icon name="clipboard-list" size={22} class="text-active block mb-2 mx-auto" />
              <p class="text-white/60 text-xs font-ui">Elke actie wordt vastgelegd</p>
            </div>
            <div>
              <Icon name="lock" size={22} class="text-active block mb-2 mx-auto" />
              <p class="text-white/60 text-xs font-ui">Iedereen ziet alleen wat hij mag (toegang per rol)</p>
            </div>
          </div>
          <p class="text-white/40 text-xs font-ui text-center mt-4">
            Live in gebruik in meerdere projecten en bewezen in de praktijk.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container mx-auto px-4 text-center">
      <a href="/contact?type=security" class="btn-primary">
        Beveilig uw applicatie
        <Icon name="arrow-right" size={16} />
      </a>
    </div>
  </section>
</Layout>
