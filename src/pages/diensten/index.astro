---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import PillarCard from '../../components/blocks/PillarCard.astro';
import Icon from '../../components/ui/Icon.astro';

const pillars = [
  {
    title: 'IT Advies & Consultancy',
    description:
      'Onafhankelijk sparringpartner en second opinion, zonder bouwverplichting. Nuchter advies over software, architectuur en digitale keuzes — het eerste gesprek is gratis.',
    icon: 'handshake',
    tags: ['Onafhankelijk advies', 'Second opinion', 'Sparringpartner'],
    href: '/diensten/consultancy',
  },
  {
    title: 'AI & Automatisering',
    description:
      'AI die repetitief werk overneemt en uw data benut voor snellere beslissingen. Betrouwbaar en meetbaar, en een mens beslist mee op de belangrijke momenten.',
    icon: 'brain-circuit',
    tags: ['AI-automatisering', 'Digitale medewerkers', 'Bedrijfsdata'],
    href: '/diensten/ai-prompt-engineering',
    featured: true,
  },
  {
    title: 'Slimme Monitoring & Sensoren',
    description:
      'Van sensor tot dashboard: problemen vroegtijdig signaleren en kostbare stilstand voorkomen. Realtime monitoring, op afstand en zonder onderhoud.',
    icon: 'radio',
    tags: ['Realtime monitoring', 'Automatische alarmering', 'Op afstand'],
    href: '/diensten/iot-hardware',
  },
  {
    title: 'Maatwerk Platformen',
    description:
      'Losse tools en handwerk vervangen door één systeem dat met u meegroeit. Alle gegevens op één plek en altijd actueel, waar registratie, data en communicatie samenkomen.',
    icon: 'building-2',
    tags: ['Alles op één plek', 'Workflows', 'Dashboards', 'Groeit met u mee'],
    href: '/diensten/maatwerk-platformen',
  },
  {
    title: 'Klanten werven',
    description:
      'Uw website wordt een systeem dat bezoekers omzet in concrete aanvragen. Automatisch, meetbaar en zonder extra marketingkosten.',
    icon: 'target',
    tags: ['Offertetrajecten', 'Aanvragen opvolgen', 'SEO'],
    href: '/diensten/lead-generation',
  },
  {
    title: 'Beveiliging & Authenticatie',
    description:
      "Uw klantdata is beschermd en gescheiden op databaseniveau. Zo blijven risico's klein en gegevens veilig — ook bij fouten of aanvallen.",
    icon: 'shield-check',
    tags: ['Gescheiden klantdata', 'Toegang per rol', 'Alles traceerbaar'],
    href: '/diensten/security',
    featured: true,
  },
] as const;
---

<Layout
  title="Diensten — Websites, AI, IoT, Platformen & Security | LaventeCare"
  description="Van professionele website tot werkend bedrijfssysteem: websites, consultancy, AI-automatisering, bewaking, maatwerkplatformen, klanten werven en beveiliging."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <SectionHeader
        level={1}
        label="Diensten"
        heading='Van online basis tot <span class="text-active">werkend systeem</span>'
        description="Begin met een professionele website via een vaste snelle route. Zodra uw vraag processen, gegevens of automatisering raakt, sluiten zes specialistische diensten daarop aan."
      />

      <a
        href="/diensten/websites"
        data-animate="fade-up"
        class="group clinical-glass mx-auto mb-10 grid max-w-5xl grid-cols-1 items-center gap-6 rounded-(--radius-hero) border border-active/25 bg-active/5 p-6 transition-colors hover:border-active/45 md:grid-cols-[1fr_auto] md:p-8"
      >
        <div>
          <span
            class="mb-2 flex items-center gap-2 font-display text-xs font-bold uppercase tracking-[0.18em] text-active"
          >
            <Icon name="monitor" size={16} /> Vaste websitepakketten
          </span>
          <h2 class="mb-2 font-display text-2xl font-black text-white">
            Professionele websites vanaf €750
          </h2>
          <p class="max-w-2xl font-ui text-sm leading-relaxed text-white/60">
            Snel, veilig en zonder zware pagebuilder. Met een vaste prijs, duidelijke afbakening en
            ruimte om later door te groeien.
          </p>
        </div>
        <span class="flex items-center gap-2 font-ui text-sm font-bold text-active">
          Bekijk pakketten
          <Icon
            name="arrow-right"
            size={17}
            class="transition-transform group-hover:translate-x-1"
          />
        </span>
      </a>

      <div class="mx-auto mb-6 max-w-5xl">
        <p class="font-display text-xs font-bold uppercase tracking-[0.18em] text-white/35">
          Zes specialistische diensten
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto mb-16">
        {
          pillars.map((pillar, index) => (
            <div data-animate="fade-up" class={`delay-${index * 100}`}>
              <PillarCard {...pillar} />
            </div>
          ))
        }
      </div>

      <!-- Doelgroepen -->
      <div class="max-w-4xl mx-auto">
        <SectionHeader
          label="Doelgroepen"
          heading='Voor mkb-organisaties waar terugkerende processen tijd, fouten of omzet <span class="text-active">raken</span>'
        />

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div
            data-animate="fade-up"
            class="clinical-glass p-6 rounded-(--radius-card) border border-white/8 text-center"
          >
            <Icon name="building" size={24} class="text-active block mb-3 mx-auto" />
            <h3 class="text-sm font-bold text-white mb-2 font-display">MKB-organisaties</h3>
            <p class="text-white/50 text-xs font-ui">
              Bedrijven die digitale groei, automatisering en maatwerksoftware goed en betrouwbaar
              geregeld willen hebben.
            </p>
          </div>
          <div
            data-animate="fade-up"
            class="delay-100 clinical-glass p-6 rounded-(--radius-card) border border-white/8 text-center"
          >
            <Icon name="handshake" size={24} class="text-active block mb-3 mx-auto" />
            <h3 class="text-sm font-bold text-white mb-2 font-display">Dienstverleners</h3>
            <p class="text-white/50 text-xs font-ui">
              Meer aanvragen, betere vindbaarheid en veilige klantportalen — zonder extra
              marketingkosten.
            </p>
          </div>
          <div
            data-animate="fade-up"
            class="delay-200 clinical-glass p-6 rounded-(--radius-card) border border-white/8 text-center"
          >
            <Icon name="refresh-cw" size={24} class="text-active block mb-3 mx-auto" />
            <h3 class="text-sm font-bold text-white mb-2 font-display">Operationele teams</h3>
            <p class="text-white/50 text-xs font-ui">
              Teams met terugkerende processen die van handmatig werk naar één systeem willen dat
              met hen meegroeit.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div
        class="clinical-glass p-8 md:p-12 rounded-(--radius-hero) border border-white/8 max-w-4xl mx-auto text-center"
      >
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 font-display">
          Klaar om te starten?
        </h2>
        <p class="text-white/70 mb-6 max-w-xl mx-auto font-ui">
          Plan een intake en ontdek waar u direct tijd, kosten of risico kunt besparen.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/werkwijze" class="btn-secondary">Bekijk de werkwijze</a>
          <a href="/contact" class="btn-primary">
            Plan een intake
            <Icon name="arrow-right" size={16} />
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
