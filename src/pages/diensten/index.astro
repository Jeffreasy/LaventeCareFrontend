---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import PillarCard from '../../components/blocks/PillarCard.astro';
import Icon from '../../components/ui/Icon.astro';

const pillars = [
  {
    title: 'AI & Prompt Engineering',
    description:
      'AI die repetitief werk overneemt en uw data benut voor betere en snellere beslissingen — betrouwbaar, schaalbaar en meetbaar in uw dagelijkse processen.',
    icon: 'brain-circuit',
    tags: ['AI-automatisering', 'Digitale medewerkers', 'Bedrijfsdata'],
    href: '/diensten/ai-prompt-engineering',
    featured: true,
  },
  {
    title: 'Slimme Monitoring & Sensoren',
    description:
      'Realtime monitoring die storingen vroegtijdig detecteert en schade of kostbare stilstand voorkomt. Van sensor tot dashboard, op afstand en zonder onderhoud.',
    icon: 'radio',
    tags: ['Realtime monitoring', 'Automatische alarmering', 'Op afstand'],
    href: '/diensten/iot-hardware',
  },
  {
    title: 'Maatwerk Platformen & Events',
    description:
      'Registratie, ticketing en donaties — volledig geautomatiseerd en ontworpen om foutloos te draaien. Uw volledige evenement of actie beheerd vanuit één centraal systeem.',
    icon: 'building-2',
    tags: ['Registratie', 'Donaties', 'Dashboards', 'Schaalbaar'],
    href: '/diensten/maatwerk-platformen',
  },
  {
    title: 'Lead Generation & Matchmaking',
    description:
      'Meer aanvragen uit uw website, zonder extra marketingkosten. Bezoekers worden automatisch gestuurd richting een offerte of aanvraag, zodat ze sneller converteren.',
    icon: 'target',
    tags: ['Offertetrajecten', 'Lead-management', 'SEO'],
    href: '/diensten/lead-generation',
  },
  {
    title: 'Beveiliging & Authenticatie',
    description:
      "Uw klantdata is structureel beschermd en gescheiden, zodat risico's worden geminimaliseerd en uw data veilig blijft — ook bij fouten of aanvallen.",
    icon: 'shield-check',
    tags: ['Data-isolatie', 'Authenticatie', 'AVG-compliance'],
    href: '/diensten/security',
    featured: true,
  },
] as const;
---

<Layout
  title="Diensten — Maatwerkplatformen, AI, IoT & Security | LaventeCare"
  description="Van AI-automatisering tot ingebouwde beveiliging — complete systemen die schalen, beveiligen en automatiseren. Vijf geïntegreerde diensten, één engineer."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Platformdiensten"
        heading='Vijf pijlers, één <span class="text-active">compleet ecosysteem</span>'
        description="Geen losse projecten, maar een geïntegreerd systeem: elke pijler versterkt de andere. Van AI-automatisering tot databescherming — alles draait op dezelfde robuuste kern."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto mb-16">
        {
          pillars.map((pillar, index) => (
            <div data-animate="fade-up" class={`delay-${index * 100}`}>
              <PillarCard {...pillar} />
            </div>
          ))
        }
      </div>

      <!-- Doelgroepen -->
      <div class="max-w-4xl mx-auto">
        <SectionHeader
          label="Doelgroepen"
          heading='Bedrijven waar stilstand, fouten of inefficiëntie direct <span class="text-active">geld kosten</span>'
        />

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div
            data-animate="fade-up"
            class="clinical-glass p-6 rounded-(--radius-card) border border-white/8 text-center"
          >
            <Icon name="factory" size={24} class="text-active block mb-3 mx-auto" />
            <h3 class="text-sm font-bold text-white mb-2 font-display">Industrie & Installaties</h3>
            <p class="text-white/50 text-xs font-ui">
              Waar stilstand direct geld kost. Realtime monitoring en preventief onderhoud.
            </p>
          </div>
          <div
            data-animate="fade-up"
            class="delay-100 clinical-glass p-6 rounded-(--radius-card) border border-white/8 text-center"
          >
            <Icon name="building" size={24} class="text-active block mb-3 mx-auto" />
            <h3 class="text-sm font-bold text-white mb-2 font-display">
              MKB (Bouw, Groen, Automotive)
            </h3>
            <p class="text-white/50 text-xs font-ui">
              Meer aanvragen, betere vindbaarheid en veilige klantportalen.
            </p>
          </div>
          <div
            data-animate="fade-up"
            class="delay-200 clinical-glass p-6 rounded-(--radius-card) border border-white/8 text-center"
          >
            <Icon name="heart" size={24} class="text-active block mb-3 mx-auto" />
            <h3 class="text-sm font-bold text-white mb-2 font-display">Non-Profits & Events</h3>
            <p class="text-white/50 text-xs font-ui">
              Minder chaos, meer overzicht. Geautomatiseerde registratie en donaties.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div
        class="clinical-glass p-8 md:p-12 rounded-(--radius-hero) border border-white/8 max-w-4xl mx-auto text-center"
      >
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 font-display">
          Klaar om te starten?
        </h2>
        <p class="text-white/70 mb-6 max-w-xl mx-auto font-ui">
          Plan een intake en ontdek waar u direct tijd, kosten of risico kunt besparen.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/werkwijze" class="btn-secondary">Bekijk de werkwijze</a>
          <a href="/contact" class="btn-primary">
            Plan een intake
            <Icon name="arrow-right" size={16} />
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
