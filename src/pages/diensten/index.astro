---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import PillarCard from '../../components/blocks/PillarCard.astro';
import Icon from '../../components/ui/Icon.astro';

const pillars = [
  {
    title: 'AI & Prompt Engineering',
    description: 'Custom AI-agents, LLM-integratie en professionele prompt engineering. Van intelligente workflows tot RAG-systemen die uw bedrijfsdata benutten.',
    icon: 'brain-circuit',
    tags: ['GPT-4', 'Claude', 'LangChain', 'RAG', 'Custom Agents'],
    href: '/diensten/ai-prompt-engineering',
    featured: true,
  },
  {
    title: 'IoT & Hardware Monitoring',
    description: 'End-to-end telemetrie-oplossingen voor de industrie en koeltechniek. ESP32/C++ firmware met deep-sleep en BLE-integratie, gekoppeld aan live dashboards.',
    icon: 'radio',
    tags: ['C++', 'ESP32', 'BLE', 'Deep-sleep', 'Convex'],
    href: '/diensten/iot-hardware',
  },
  {
    title: 'Maatwerk Platformen & Events',
    description: 'Complexe, data-intensieve platformen voor goede doelen en evenementen. Registratie, ticketing, donaties en real-time datatoegang.',
    icon: 'building-2',
    tags: ['Astro', 'React 19', 'Convex', 'Go Auth', 'Vercel'],
    href: '/diensten/maatwerk-platformen',
  },
  {
    title: 'Matchmaking & Lead Generation',
    description: 'Conversiegerichte portalen waar vraag en aanbod samenkomen. Veilige klantomgevingen, multi-step offertetrajecten en geavanceerde lead-management.',
    icon: 'target',
    tags: ['Next.js', 'Supabase', 'SEO', 'Vercel'],
    href: '/diensten/lead-generation',
  },
  {
    title: 'LaventeCare Core — Security & Auth',
    description: 'De Go-gebaseerde back-end die fungeert als het hart van alle applicaties. Bank-Grade authenticatie, Zero-Trust API\'s en Database Fortress.',
    icon: 'shield-check',
    tags: ['Go', 'PostgreSQL', 'Redis', 'JWT', 'RBAC'],
    href: '/diensten/security',
    featured: true,
  },
] as const;
---

<Layout
  title="Diensten — LaventeCare"
  description="AI prompt engineering, IoT-oplossingen, maatwerk platformen en security. Ontdek de vijf kernactiviteiten van LaventeCare."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Kernactiviteiten"
        heading='Vijf pijlers, één <span class="text-active">complete oplossing</span>'
        description="LaventeCare onderscheidt zich door een uitzonderlijk breed technisch spectrum. Elke pijler staat op zichzelf, maar samen vormen ze een naadloos ecosysteem."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto mb-16">
        {pillars.map((pillar) => (
          <PillarCard {...pillar} />
        ))}
      </div>

      <!-- Doelgroepen -->
      <div class="max-w-4xl mx-auto">
        <SectionHeader
          label="Doelgroepen"
          heading='Voor wie ik <span class="text-active">bouw</span>'
        />

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="clinical-glass p-6 rounded-(--radius-card) border border-white/8 text-center">
            <Icon name="factory" size={24} class="text-active block mb-3 mx-auto" />
            <h3 class="text-sm font-bold text-white mb-2 font-display">Industrie & Installatietechniek</h3>
            <p class="text-white/50 text-xs font-ui">IoT-monitoring en Smart Industry oplossingen voor producenten en installateurs.</p>
          </div>
          <div class="clinical-glass p-6 rounded-(--radius-card) border border-white/8 text-center">
            <Icon name="building" size={24} class="text-active block mb-3 mx-auto" />
            <h3 class="text-sm font-bold text-white mb-2 font-display">Groot MKB</h3>
            <p class="text-white/50 text-xs font-ui">Bouw, groenvoorziening en automotive. Gesloten portalen en lead-management.</p>
          </div>
          <div class="clinical-glass p-6 rounded-(--radius-card) border border-white/8 text-center">
            <Icon name="heart" size={24} class="text-active block mb-3 mx-auto" />
            <h3 class="text-sm font-bold text-white mb-2 font-display">Non-Profits & Events</h3>
            <p class="text-white/50 text-xs font-ui">Betrouwbare registraties, ticketstromen en financiële transacties.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="clinical-glass p-8 md:p-12 rounded-(--radius-hero) border border-white/8 max-w-4xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 font-display">
          Klaar om te starten?
        </h2>
        <p class="text-white/70 mb-6 max-w-xl mx-auto font-ui">
          Begin met een gratis intake gesprek van 30 minuten. Ik bespreek met u de scope, technische haalbaarheid en budgetindicatie.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/werkwijze" class="btn-secondary">Bekijk de werkwijze</a>
          <a href="/contact" class="btn-primary">
            Plan een intake
            <Icon name="arrow-right" size={16} />
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
