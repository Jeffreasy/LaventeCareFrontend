---
import Layout from '../../layouts/Layout.astro';
import TechStackBadge from '../../components/ui/TechStackBadge.astro';
import Icon, { type IconName } from '../../components/ui/Icon.astro';

const features = [
  {
    icon: 'clipboard-list',
    title: 'Registratie & Ticketing',
    desc: 'Deelnemers melden zich eenvoudig aan, terwijl het systeem automatisch alles verwerkt — van bevestiging tot wachtlijst. Geen handmatig werk.',
  },
  {
    icon: 'heart',
    title: 'Veilige donaties',
    desc: 'Donaties worden veilig verwerkt en overzichtelijk geregistreerd, zodat u vertrouwen uitstraalt naar uw doelgroep.',
  },
  {
    icon: 'bar-chart-2',
    title: 'Direct inzicht',
    desc: 'U ziet realtime hoeveel deelnemers en donaties binnenkomen, zodat u direct kunt bijsturen.',
  },
  {
    icon: 'mail',
    title: 'Automatische communicatie',
    desc: 'Deelnemers en donateurs worden automatisch op de hoogte gehouden — bevestigingen, updates en herinneringen, zonder extra werk.',
  },
  {
    icon: 'layout-dashboard',
    title: 'Alles in één beheerpaneel',
    desc: 'Gebruikers, inschrijvingen, donaties en communicatie — alles beheerd vanuit één overzichtelijk scherm.',
  },
  {
    icon: 'git-merge',
    title: 'Van aanmelding tot opvolging',
    desc: 'Het volledige traject geautomatiseerd: van inschrijving tot bevestiging, opvolging en evaluatie.',
  },
];
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Maatwerk Platformen & Events',
  description:
    'Geautomatiseerde registratie, donaties, acties en communicatie. Uw volledige evenement of actie beheerd vanuit één centraal, foutloos systeem.',
  provider: {
    '@type': 'ProfessionalService',
    name: 'LaventeCare',
    url: 'https://www.laventecare.nl',
  },
  areaServed: 'NL',
  serviceType: 'Custom Platform & Event Software Development',
  serviceOutput: 'Registratiesystemen, live dashboards en API-integraties op maat',
};
---

<script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

<Layout
  title="Maatwerk Platformen & Grote Evenementen | LaventeCare"
  description="Uw evenement of actie volledig beheerd vanuit één systeem. Registratie, donaties, communicatie en live inzicht — automatisch en schaalbaar."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto mb-16">
        <span
          class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-3 flex items-center gap-2"
          ><Icon name="building-2" size={16} class="text-active" /> Maatwerk Platformen</span
        >
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 font-display tracking-tight"
        >
          Platformen die <span class="text-active">presteren</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 font-ui leading-relaxed mb-4">
          Veel organisaties werken met losse tools en handmatige processen, waardoor inschrijvingen,
          donaties en communicatie onoverzichtelijk worden. Ik bouw platformen die alles
          samenbrengen in één systeem — automatisch, schaalbaar en betrouwbaar.
        </p>
        <p class="text-base text-active/80 font-ui font-bold mb-6">
          Uw volledige evenement of actie beheerd vanuit één platform.
        </p>
        <div class="flex flex-wrap gap-2">
          {
            [
              'Alles in één systeem:',
              'Registratie',
              'Donaties',
              'E-mail',
              'Dashboards',
              'Beheer',
            ].map((t) => <TechStackBadge tech={t} />)
          }
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto mb-16">
        {
          features.map((f, i) => (
            <div
              data-animate="fade-up"
              class={`delay-${(i % 3) * 100} clinical-glass p-5 rounded-(--radius-card) border border-white/8 hover:border-active/20 transition-colors group`}
            >
              <div class="flex items-start gap-3 mb-3">
                <div class="w-9 h-9 rounded-lg bg-active/10 flex items-center justify-center shrink-0 group-hover:bg-active/20 transition-colors">
                  <Icon name={f.icon as IconName} size={18} class="text-active" />
                </div>
                <h3 class="text-sm font-bold text-white font-display pt-1.5">{f.title}</h3>
              </div>
              <p class="text-white/60 text-xs font-ui leading-relaxed">{f.desc}</p>
            </div>
          ))
        }
      </div>

      <!-- Referenties -->
      <div class="max-w-3xl mx-auto">
        <p class="text-white/50 text-sm font-ui mb-4 text-center">Referentieprojecten</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <a
            href="/portfolio/de-koninklijke-loop"
            data-animate="fade-up"
            class="clinical-glass p-6 rounded-(--radius-feature) border border-white/8 hover:border-active/30 transition-colors group"
          >
            <h3
              class="text-lg font-bold text-white font-display mb-1 group-hover:text-active transition-colors"
            >
              De Koninklijke Loop
            </h3>
            <p class="text-white/60 text-sm font-ui mb-2">
              Evenementenplatform met registratie, ticketing en live data.
            </p>
            <p class="text-active text-xs font-bold font-ui">
              100+ deelnemers • 0 handmatig werk voor de organisatie
            </p>
          </a>
          <a
            href="/portfolio/whisky-for-charity"
            data-animate="fade-up"
            class="clinical-glass p-6 rounded-(--radius-feature) border border-white/8 hover:border-active/30 transition-colors group"
          >
            <h3
              class="text-lg font-bold text-white font-display mb-1 group-hover:text-active transition-colors"
            >
              Whisky for Charity
            </h3>
            <p class="text-white/60 text-sm font-ui mb-2">
              Liefdadigheidsplatform met veilige donatiestromen.
            </p>
            <p class="text-active text-xs font-bold font-ui">
              €10K+ opgehaald • 0 mislukte transacties
            </p>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container mx-auto px-4 text-center">
      <a href="/contact?type=platform" class="btn-primary">
        Plan een gesprek
        <Icon name="arrow-right" size={16} />
      </a>
      <p class="text-white/40 text-sm font-ui mt-3">
        Plan een gesprek en ontdek hoe u tijd bespaart en overzicht terugkrijgt.
      </p>
    </div>
  </section>
</Layout>
