---
import Layout from '../../layouts/Layout.astro';
import TechStackBadge from '../../components/ui/TechStackBadge.astro';
import Icon, { type IconName } from '../../components/ui/Icon.astro';

const features = [
  {
    icon: 'clipboard-list',
    title: 'Registratie & aanmeldingen',
    desc: 'Gebruikers en klanten melden zich eenvoudig aan. Het systeem verwerkt daarna alles automatisch — van bevestiging tot opvolging. Geen handmatig werk.',
  },
  {
    icon: 'database',
    title: 'Alles op één plek',
    desc: 'Losse tools, spreadsheets en handwerk vervangen door één centraal systeem, zodat iedereen met dezelfde actuele gegevens werkt.',
  },
  {
    icon: 'bar-chart-2',
    title: 'Direct inzicht',
    desc: 'U ziet realtime wat er binnenkomt en wat er speelt, zodat u direct kunt bijsturen op basis van actuele data.',
  },
  {
    icon: 'mail',
    title: 'Automatische communicatie',
    desc: 'Klanten en gebruikers worden automatisch op de hoogte gehouden — bevestigingen, updates en herinneringen, zonder extra werk.',
  },
  {
    icon: 'layout-dashboard',
    title: 'Alles in één beheerpaneel',
    desc: 'Gebruikers, aanvragen, data en communicatie — alles beheerd vanuit één overzichtelijk scherm.',
  },
  {
    icon: 'git-merge',
    title: 'Van aanvraag tot opvolging',
    desc: 'Het volledige proces geautomatiseerd: van eerste actie tot bevestiging, opvolging en evaluatie.',
  },
];
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Maatwerk Platformen',
  description:
    'Losse tools en handwerk vervangen door één systeem dat met u meegroeit: alle gegevens op één plek, altijd actueel, waar registratie, data en communicatie samenkomen.',
  provider: {
    '@type': 'ProfessionalService',
    name: 'LaventeCare',
    url: 'https://www.laventecare.nl',
  },
  areaServed: 'NL',
  serviceType: 'Custom Platform Software Development',
  serviceOutput: 'Maatwerkplatformen, live dashboards en API-integraties op maat',
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

<Layout
  title="Maatwerk Platformen — Alles op één plek | LaventeCare"
  description="Losse tools en handwerk vervangen door één systeem dat met u meegroeit: alle gegevens op één plek, altijd actueel, waar registratie, data en communicatie samenkomen. Automatisch geregeld."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto mb-16">
        <span
          class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-3 flex items-center gap-2"
          ><Icon name="building-2" size={16} class="text-active" /> Maatwerk Platformen</span
        >
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 font-display tracking-tight"
        >
          Alles op één plek, <span class="text-active">automatisch geregeld</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 font-ui leading-relaxed mb-4">
          Veel organisaties werken met losse tools en handmatige processen, waardoor gegevens,
          aanvragen en communicatie onoverzichtelijk worden. Wij bouwen platformen die alles
          samenbrengen in één systeem — automatisch, betrouwbaar en dat met u meegroeit.
        </p>
        <p class="text-base text-active/80 font-ui font-bold mb-6">
          Losse tools en handwerk vervangen door één systeem dat met u meegroeit.
        </p>
        <div class="flex flex-wrap gap-2">
          {
            [
              'Eén centraal systeem',
              'Registratie',
              'Workflows',
              'E-mail',
              'Dashboards',
              'Beheer',
            ].map((t) => <TechStackBadge tech={t} />)
          }
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto mb-16">
        {
          features.map((f, i) => (
            <div
              data-animate="fade-up"
              class={`delay-${(i % 3) * 100} clinical-glass p-5 rounded-(--radius-card) border border-white/8 hover:border-active/20 transition-colors group`}
            >
              <div class="flex items-start gap-3 mb-3">
                <div class="w-9 h-9 rounded-lg bg-active/10 flex items-center justify-center shrink-0 group-hover:bg-active/20 transition-colors">
                  <Icon name={f.icon as IconName} size={18} class="text-active" />
                </div>
                <h3 class="text-sm font-bold text-white font-display pt-1.5">{f.title}</h3>
              </div>
              <p class="text-white/60 text-xs font-ui leading-relaxed">{f.desc}</p>
            </div>
          ))
        }
      </div>

      <!-- Referenties -->
      <div class="max-w-3xl mx-auto">
        <p class="text-white/50 text-sm font-ui mb-4 text-center">Referentieprojecten</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <a
            href="/portfolio/de-koninklijke-loop"
            data-animate="fade-up"
            class="clinical-glass p-6 rounded-(--radius-feature) border border-white/8 hover:border-active/30 transition-colors group"
          >
            <h3
              class="text-lg font-bold text-white font-display mb-1 group-hover:text-active transition-colors"
            >
              De Koninklijke Loop
            </h3>
            <p class="text-white/60 text-sm font-ui mb-2">
              Evenementenplatform met registratie, ticketing en live data.
            </p>
            <p class="text-active text-xs font-bold font-ui">
              Real-time registratie • geautomatiseerde verwerking voor de organisatie
            </p>
          </a>
          <a
            href="/portfolio/whisky-for-charity"
            data-animate="fade-up"
            class="clinical-glass p-6 rounded-(--radius-feature) border border-white/8 hover:border-active/30 transition-colors group"
          >
            <h3
              class="text-lg font-bold text-white font-display mb-1 group-hover:text-active transition-colors"
            >
              Whisky for Charity
            </h3>
            <p class="text-white/60 text-sm font-ui mb-2">
              Liefdadigheidsplatform met veilige donatiestromen.
            </p>
            <p class="text-active text-xs font-bold font-ui">
              Veilige donatieverwerking • overzichtelijke registratie
            </p>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container mx-auto px-4 text-center">
      <a href="/contact?type=platform" class="btn-primary">
        Plan een gesprek
        <Icon name="arrow-right" size={16} />
      </a>
      <p class="text-white/40 text-sm font-ui mt-3">
        Plan een gesprek en ontdek hoe u tijd bespaart en overzicht terugkrijgt.
      </p>
    </div>
  </section>
</Layout>
