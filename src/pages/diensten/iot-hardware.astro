---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import TechStackBadge from '../../components/ui/TechStackBadge.astro';
import Icon from '../../components/ui/Icon.astro';

const features = [
  { title: 'Deep-sleep firmware', desc: 'Maanden batterijduur door intelligent energiebeheer.' },
  { title: 'BLE-integratie', desc: 'Bluetooth Low Energy voor korte-afstandscommunicatie.' },
  { title: 'Over-the-Air Updates', desc: 'Firmware op afstand bijwerken zonder fysieke toegang.' },
  { title: 'Real-time dashboards', desc: 'Live data via Convex met directe visualisatie.' },
  { title: 'Kritieke alarmering', desc: 'Automatische notificaties bij drempelwaarden.' },
  { title: 'Cloud-synchronisatie', desc: 'Sensordata real-time verwerkt en opgeslagen.' },
];
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'IoT & Hardware Monitoring',
  description: 'End-to-end IoT-oplossingen: ESP32/C++ firmware, deep-sleep, BLE, sensortelemetrie en live cloud dashboards.',
  provider: {
    '@type': 'ProfessionalService',
    name: 'LaventeCare',
    url: 'https://www.laventecare.nl',
  },
  areaServed: 'NL',
  serviceType: 'IoT Development & Hardware Monitoring',
  serviceOutput: 'ESP32 firmware, sensornetwerken, cloud dashboards en real-time monitoring systemen',
};
---

<script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

<Layout
  title="IoT & Hardware Monitoring — LaventeCare"
  description="End-to-end IoT-oplossingen: ESP32/C++ firmware, deep-sleep, BLE, sensortelemetrie en live cloud dashboards. Smart Industry monitoring."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto mb-16">
        <span class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-3 flex items-center gap-2"><Icon name="radio" size={16} class="text-active" /> IoT & Hardware</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 font-display tracking-tight">
          Van sensor tot <span class="text-active">dashboard</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 font-ui leading-relaxed mb-6">
          Ontwikkeling van end-to-end telemetrie-oplossingen voor de industrie en koeltechniek. ESP32/C++ firmware met deep-sleep en BLE-integratie, gekoppeld aan live dashboards. Data wordt real-time verwerkt voor directe visualisatie en kritieke alarmering.
        </p>
        <div class="flex flex-wrap gap-2">
          {['C++', 'ESP32', 'BLE', 'Convex', 'React Dashboard', 'Deep-sleep'].map((t) => (
            <TechStackBadge tech={t} />
          ))}
        </div>
      </div>

      <!-- Features Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto mb-16">
        {features.map((f) => (
          <div class="clinical-glass p-5 rounded-(--radius-card) border border-white/8">
            <h3 class="text-sm font-bold text-white mb-2 font-display">{f.title}</h3>
            <p class="text-white/60 text-xs font-ui">{f.desc}</p>
          </div>
        ))}
      </div>

      <!-- Doelgroep -->
      <div class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-active/20 max-w-3xl mx-auto mb-16">
        <h2 class="text-xl font-bold text-white mb-4 font-display">Doelgroep</h2>
        <p class="text-white/70 font-ui mb-4">Producenten en installateurs van hardware die de transitie willen maken naar 'Smart' apparatuur:</p>
        <ul class="space-y-2 text-sm font-ui text-white/60">
          <li class="flex items-start gap-3"><Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Industrie & klimaatbeheersing</li>
          <li class="flex items-start gap-3"><Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Koeltechniek & installatietechniek</li>
          <li class="flex items-start gap-3"><Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Remote monitoring & preventief onderhoud</li>
        </ul>
      </div>

      <!-- Case Study Reference -->
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-white/50 text-sm font-ui mb-4">Referentieproject</p>
        <div class="clinical-glass p-6 rounded-(--radius-feature) border border-white/8 inline-block">
          <h3 class="text-lg font-bold text-white font-display mb-1">SmartCoolCare</h3>
          <p class="text-white/60 text-sm font-ui">Industriële koelmonitoring met ESP32-sensors, deep-sleep firmware en live cloud dashboards.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4 text-center">
      <a href="/contact?type=iot" class="btn-primary">
        Bespreek uw IoT-project
        <Icon name="arrow-right" size={16} />
      </a>
    </div>
  </section>
</Layout>
