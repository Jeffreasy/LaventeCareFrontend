---
import Layout from '../../layouts/Layout.astro';
import TechStackBadge from '../../components/ui/TechStackBadge.astro';
import Icon, { type IconName } from '../../components/ui/Icon.astro';

const features = [
  {
    icon: 'battery-charging',
    title: 'Maandenlang zonder onderhoud',
    desc: 'Sensoren werken maandenlang zonder onderhoud, waardoor u geen tijd verliest aan handmatige controles of batterijwissels.',
  },
  {
    icon: 'wifi',
    title: 'Direct inzetbaar',
    desc: 'Geen bekabeling nodig — snel te installeren en direct operationeel, zonder ingrijpende aanpassingen aan uw locatie.',
  },
  {
    icon: 'refresh-cw',
    title: 'Updates op afstand',
    desc: 'Software-updates worden op afstand doorgevoerd. Geen monteur nodig, geen stilstand voor uw apparaten.',
  },
  {
    icon: 'smartphone',
    title: 'Altijd en overal inzicht',
    desc: 'Altijd en overal realtime inzicht in uw systemen — op smartphone, tablet of desktop.',
  },
  {
    icon: 'bell',
    title: 'Ingrijpen vóór schade ontstaat',
    desc: 'Bij afwijkingen ontvangt u direct een melding, zodat u kunt ingrijpen voordat schade of stilstand ontstaat.',
  },
  {
    icon: 'database',
    title: 'Veilig opgeslagen, altijd inzichtelijk',
    desc: 'Alle sensordata wordt veilig opgeslagen en realtime verwerkt, zodat u continu inzicht heeft in prestaties en trends.',
  },
];
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Slimme Monitoring & Sensoren',
  description:
    'Realtime monitoring die storingen vroegtijdig detecteert en kostbare stilstand voorkomt. Van fysieke sensor tot cloud dashboard.',
  provider: {
    '@type': 'ProfessionalService',
    name: 'LaventeCare',
    url: 'https://www.laventecare.nl',
  },
  areaServed: 'NL',
  serviceType: 'IoT Development & Monitoring Solutions',
  serviceOutput: 'Sensorschermen, automatische beslisbomen en remote hardware management',
};
---

<script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

<Layout
  title="Slimme Monitoring & Sensoren — Risico's Voorkomen | LaventeCare"
  description="Voorkom storingen en schade met realtime monitoring. Sensoren die maandenlang meegaan, automatische alarmering en live dashboards."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto mb-16">
        <span
          class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-3 flex items-center gap-2"
          ><Icon name="radio" size={16} class="text-active" /> IoT & Hardware</span
        >
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 font-display tracking-tight"
        >
          Van sensor tot <span class="text-active">dashboard</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 font-ui leading-relaxed mb-4">
          Storingen worden vaak pas ontdekt als het al mis is — met schade en kosten tot gevolg. Ik
          bouw systemen die problemen vroegtijdig signaleren, zodat u kunt ingrijpen voordat het te
          laat is.
        </p>
        <p class="text-base text-active/80 font-ui font-bold mb-6">
          Minder stilstand, minder schade, meer controle.
        </p>
        <div class="flex flex-wrap gap-2">
          {
            [
              'Realtime monitoring',
              'Automatische alarmering',
              'Live dashboards',
              'Op afstand',
              'Groeit met u mee',
            ].map((t) => <TechStackBadge tech={t} />)
          }
        </div>
      </div>

      <!-- Resultaten -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto mb-16">
        <div data-animate="fade-up" class="clinical-glass p-5 rounded-(--radius-card) border border-active/20 text-center">
          <div class="text-2xl md:text-3xl font-black text-active mb-1 font-display">24/7</div>
          <p class="text-white/50 text-xs font-ui">Bewaking op afstand</p>
        </div>
        <div data-animate="fade-up" class="clinical-glass p-5 rounded-(--radius-card) border border-active/20 text-center">
          <div class="text-2xl md:text-3xl font-black text-active mb-1 font-display">Maanden</div>
          <p class="text-white/50 text-xs font-ui">Zuinig — werkt maandenlang op één batterij</p>
        </div>
        <div data-animate="fade-up" class="clinical-glass p-5 rounded-(--radius-card) border border-active/20 text-center">
          <div class="text-2xl md:text-3xl font-black text-active mb-1 font-display">Draadloos</div>
          <p class="text-white/50 text-xs font-ui">Geen kabels nodig</p>
        </div>
        <div data-animate="fade-up" class="clinical-glass p-5 rounded-(--radius-card) border border-active/20 text-center">
          <div class="text-2xl md:text-3xl font-black text-active mb-1 font-display">Op afstand</div>
          <p class="text-white/50 text-xs font-ui">Updates op afstand, geen monteur nodig</p>
        </div>
      </div>

      <!-- Features Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto mb-16">
        {
          features.map((f, i) => (
            <div
              data-animate="fade-up"
              class={`delay-${(i % 3) * 100} clinical-glass p-5 rounded-(--radius-card) border border-white/8 hover:border-active/20 transition-colors group`}
            >
              <div class="flex items-start gap-3 mb-3">
                <div class="w-9 h-9 rounded-lg bg-active/10 flex items-center justify-center shrink-0 group-hover:bg-active/20 transition-colors">
                  <Icon name={f.icon as IconName} size={18} class="text-active" />
                </div>
                <h3 class="text-sm font-bold text-white font-display pt-1.5">{f.title}</h3>
              </div>
              <p class="text-white/60 text-xs font-ui leading-relaxed">{f.desc}</p>
            </div>
          ))
        }
      </div>

      <!-- Doelgroep -->
      <div
        data-animate="fade-up"
        class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-active/20 max-w-3xl mx-auto mb-16"
      >
        <h2 class="text-xl font-bold text-white mb-4 font-display">Herkenbaar?</h2>
        <p class="text-white/70 font-ui mb-4">
          Bedrijven waar storingen direct kosten of schade veroorzaken:
        </p>
        <ul class="space-y-3 text-sm font-ui text-white/60">
          <li class="flex items-start gap-3">
            <Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Koelinstallaties waar
            temperatuurafwijkingen tot productverlies leiden
          </li>
          <li class="flex items-start gap-3">
            <Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Productieomgevingen waar
            stilstand direct geld kost
          </li>
          <li class="flex items-start gap-3">
            <Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Technische installaties
            die nu handmatig geïnspecteerd worden
          </li>
        </ul>
      </div>

      <!-- Hoe het werkt -->
      <div data-animate="fade-up" class="max-w-3xl mx-auto mb-16">
        <h2 class="text-xl font-bold text-white mb-6 font-display text-center">Van sensor tot actie</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="clinical-glass p-5 rounded-(--radius-card) border border-white/8 text-center">
            <div class="text-2xl font-black text-active/40 font-display mb-2">01</div>
            <p class="text-sm font-bold text-white font-display mb-1">Sensor meet</p>
            <p class="text-white/50 text-xs font-ui">De sensor meet de waarde en gaat daarna in slaapstand om stroom te sparen.</p>
          </div>
          <div class="clinical-glass p-5 rounded-(--radius-card) border border-white/8 text-center">
            <div class="text-2xl font-black text-active/40 font-display mb-2">02</div>
            <p class="text-sm font-bold text-white font-display mb-1">Cloud verwerkt</p>
            <p class="text-white/50 text-xs font-ui">Data wordt opgeslagen, geanalyseerd, vergeleken met drempels</p>
          </div>
          <div class="clinical-glass p-5 rounded-(--radius-card) border border-white/8 text-center">
            <div class="text-2xl font-black text-active/40 font-display mb-2">03</div>
            <p class="text-sm font-bold text-white font-display mb-1">U krijgt actie</p>
            <p class="text-white/50 text-xs font-ui">Live dashboard + automatisch alarm bij afwijkingen</p>
          </div>
        </div>
      </div>

      <!-- Case Study Reference -->
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-white/50 text-sm font-ui mb-4">Referentieproject</p>
        <a
          href="/portfolio/smartcoolcare"
          data-animate="fade-up"
          class="clinical-glass p-6 rounded-(--radius-feature) border border-white/8 hover:border-active/30 transition-colors inline-block group"
        >
          <h3 class="text-lg font-bold text-white font-display mb-1 group-hover:text-active transition-colors">SmartCoolCare</h3>
          <p class="text-white/60 text-sm font-ui mb-2">
            Temperatuurbewaking met automatische signalering — voorkomt schade, minimaliseert
            stilstand en geeft continu inzicht.
          </p>
          <p class="text-active text-xs font-bold font-ui">
            ESP32 + BLE • realtime monitoring • OTA firmware updates
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4 text-center">
      <a href="/contact?type=iot" class="btn-primary">
        Plan een gesprek
        <Icon name="arrow-right" size={16} />
      </a>
      <p class="text-white/40 text-sm font-ui mt-3">
        Voorkom schade en stilstand — plan een gesprek en ontdek de mogelijkheden.
      </p>
    </div>
  </section>
</Layout>
