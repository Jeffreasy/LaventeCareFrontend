---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import TechStackBadge from '../../components/ui/TechStackBadge.astro';
import Icon from '../../components/ui/Icon.astro';

const features = [
  { title: 'Digitale medewerkers', desc: 'Digitale medewerkers die repetitieve taken overnemen en zelfstandig werken volgens uw bedrijfsregels — 24/7, zonder pauze en zonder extra personeelskosten.' },
  { title: 'Geïntegreerd in uw software', desc: 'Uw bestaande software wordt slimmer door koppeling met AI-modellen. Geen losstaand experiment, maar onderdeel van uw workflow.' },
  { title: 'Betrouwbare resultaten', desc: 'AI die consistente en bruikbare resultaten levert, zodat u erop kunt vertrouwen in uw dagelijkse processen — zonder verrassingen.' },
  { title: 'AI op uw eigen data', desc: 'AI die werkt op uw eigen documenten en systemen, zodat antwoorden relevant en betrouwbaar zijn — niet gebaseerd op het internet.' },
  { title: 'Minder handmatig werk', desc: 'Repetitieve taken zoals rapportages, classificaties en data-invoer worden automatisch afgehandeld, zodat uw team zich richt op wat telt.' },
  { title: 'Direct inzicht', desc: 'Realtime inzichten en voorspellingen in dashboards, zodat u sneller beslissingen kunt nemen.' },
];

const useCases = [
  { title: 'Klantenservice automatisering', desc: 'AI die veelgestelde vragen automatisch afhandelt, waardoor uw team minder tijd kwijt is aan support en sneller kan schalen.' },
  { title: 'Content & documentatie', desc: 'Automatische rapportages, vertalingen en content-generatie — uren werk teruggebracht tot minuten.' },
  { title: 'Data-analyse & inzichten', desc: 'Stel vragen aan uw data in normale taal: "Wat was onze omzet vorige maand per regio?" — en krijg direct antwoord.' },
  { title: 'Code-assistentie & review', desc: 'AI die codekwaliteit bewaakt, bugs detecteert en verbeteringen voorstelt — snellere ontwikkeling met minder fouten.' },
];
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'AI & Automatisering',
  description: 'AI die repetitief werk overneemt en uw data benut voor betere beslissingen — betrouwbaar, schaalbaar en meetbaar in uw dagelijkse processen.',
  provider: {
    '@type': 'ProfessionalService',
    name: 'LaventeCare',
    url: 'https://www.laventecare.nl',
  },
  areaServed: 'NL',
  serviceType: 'AI Automation & Integration Services',
  serviceOutput: 'Digitale medewerkers, AI-workflows en data-infrastructuur',
};
---

<script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

<Layout
  title="AI & Automatisering — Sneller en Beter Werken | LaventeCare"
  description="Laat AI werk uit handen nemen. Digitale medewerkers, slimme automatisering en AI geïntegreerd in uw bedrijfsprocessen — betrouwbaar en meetbaar."
>
  <!-- Hero -->
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto mb-16">
        <span class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-3 flex items-center gap-2"><Icon name="brain-circuit" size={16} class="text-active" /> AI & Prompt Engineering</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 font-display tracking-tight">
          Intelligentie die <span class="text-active">werkt</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 font-ui leading-relaxed mb-4">
          Veel bedrijven experimenteren met AI, maar krijgen onbetrouwbare of inconsistente resultaten. Ik bouw AI-systemen die wél betrouwbaar werken en daadwerkelijk tijd en kosten besparen.
        </p>
        <p class="text-base text-active/80 font-ui font-bold mb-6">
          Laat AI werk uit handen nemen — betrouwbaar, schaalbaar en meetbaar.
        </p>
        <div class="flex flex-wrap gap-2">
          {['AI-automatisering', 'Digitale medewerkers', 'Bedrijfsdata', 'Integraties', 'Dashboards'].map((t) => (
            <TechStackBadge tech={t} />
          ))}
        </div>
      </div>

      <!-- Wat is een AI Prompt Engineer -->
      <div class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-active/20 max-w-4xl mx-auto mb-16">
        <h2 class="text-xl md:text-2xl font-bold text-white mb-6 font-display">Waarom professionele AI?</h2>
        <div class="space-y-4 text-white/70 font-ui text-sm leading-relaxed">
          <p>
            AI werkt alleen goed als het goed wordt aangestuurd. Ik ontwerp AI-systemen die <strong class="text-white">betrouwbaar, consistent en geïntegreerd</strong> werken binnen uw processen — niet als experiment, maar als onderdeel van uw bedrijfsvoering.
          </p>
          <p>
            Het verschil met "zelf ChatGPT gebruiken"? Professionele AI-systemen leveren <strong class="text-white">reproduceerbare resultaten</strong>, werken op uw eigen data, zijn gekoppeld aan uw software en hebben ingebouwde kwaliteitscontrole.
          </p>
        </div>
      </div>

      <!-- Features Grid -->
      <SectionHeader
        label="Wat ik bouw"
        heading='Van prompt tot <span class="text-active">productie</span>'
        description="AI-oplossingen die verder gaan dan een chatvenster."
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto mb-16">
        {features.map((f) => (
          <div class="clinical-glass p-5 rounded-(--radius-card) border border-white/8">
            <h3 class="text-sm font-bold text-white mb-2 font-display">{f.title}</h3>
            <p class="text-white/60 text-xs font-ui">{f.desc}</p>
          </div>
        ))}
      </div>

      <!-- Hoe werkt het -->
      <div class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-active/20 max-w-4xl mx-auto mb-16">
        <h2 class="text-xl font-bold text-white mb-6 font-display">Hoe werkt het?</h2>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
          <div class="text-center">
            <span class="text-active text-2xl font-black font-display block mb-2">01</span>
            <h3 class="text-sm font-bold text-white mb-1 font-display">Waar bespaart AI tijd?</h3>
            <p class="text-white/60 text-xs font-ui">Welke processen kosten nu het meeste tijd en zijn geschikt voor automatisering?</p>
          </div>
          <div class="text-center">
            <span class="text-active text-2xl font-black font-display block mb-2">02</span>
            <h3 class="text-sm font-bold text-white mb-1 font-display">Betrouwbaar maken</h3>
            <p class="text-white/60 text-xs font-ui">AI-systeem ontwerpen dat voorspelbare, consistente resultaten levert.</p>
          </div>
          <div class="text-center">
            <span class="text-active text-2xl font-black font-display block mb-2">03</span>
            <h3 class="text-sm font-bold text-white mb-1 font-display">Integreren</h3>
            <p class="text-white/60 text-xs font-ui">Koppeling aan uw systemen, databases en dagelijkse workflows.</p>
          </div>
          <div class="text-center">
            <span class="text-active text-2xl font-black font-display block mb-2">04</span>
            <h3 class="text-sm font-bold text-white mb-1 font-display">Continu verbeteren</h3>
            <p class="text-white/60 text-xs font-ui">Optimalisatie op basis van output-kwaliteit, kosten en gebruikersfeedback.</p>
          </div>
        </div>
      </div>

      <!-- Use Cases -->
      <SectionHeader
        label="Toepassingen"
        heading='AI in de <span class="text-active">praktijk</span>'
        description="Concrete voorbeelden van hoe bedrijven AI prompt engineering inzetten."
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-4xl mx-auto mb-16">
        {useCases.map((uc) => (
          <div class="clinical-glass p-5 rounded-(--radius-card) border border-white/8">
            <h3 class="text-sm font-bold text-white mb-2 font-display">{uc.title}</h3>
            <p class="text-white/60 text-xs font-ui">{uc.desc}</p>
          </div>
        ))}
      </div>

      <!-- Doelgroep -->
      <div class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-active/20 max-w-3xl mx-auto mb-16">
        <h2 class="text-xl font-bold text-white mb-4 font-display">Herkenbaar?</h2>
        <p class="text-white/70 font-ui mb-4">Organisaties die merken dat AI meer kan, maar het zelf niet betrouwbaar krijgen:</p>
        <ul class="space-y-3 text-sm font-ui text-white/60">
          <li class="flex items-start gap-3"><Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> U besteedt uren aan taken die AI in minuten kan doen</li>
          <li class="flex items-start gap-3"><Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Uw team experimenteert met ChatGPT maar krijgt inconsistente resultaten</li>
          <li class="flex items-start gap-3"><Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> U wilt AI inzetten, maar weet niet waar te beginnen</li>
          <li class="flex items-start gap-3"><Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> U heeft veel data, maar haalt er te weinig waarde uit</li>
        </ul>
      </div>

      <!-- Referentie -->
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-white/50 text-sm font-ui mb-4">Interne case study</p>
        <div class="clinical-glass p-6 rounded-(--radius-feature) border border-white/8 inline-block">
          <h3 class="text-lg font-bold text-white font-display mb-1">LaventeCare Projecten</h3>
          <p class="text-white/60 text-sm font-ui">AI wordt dagelijks gebruikt binnen mijn eigen projecten — voor codekwaliteit, automatisering en analyse — waardoor ontwikkeling sneller verloopt, fouten worden verminderd en kwaliteit consistent blijft.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4 text-center">
      <a href="/contact?type=ai" class="btn-primary">
        Plan een gesprek
        <Icon name="arrow-right" size={16} />
      </a>
      <p class="text-white/40 text-sm font-ui mt-3">Plan een gesprek en ontdek hoeveel tijd u kunt besparen.</p>
    </div>
  </section>
</Layout>
