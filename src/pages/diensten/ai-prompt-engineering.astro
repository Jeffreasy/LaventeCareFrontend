---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import TechStackBadge from '../../components/ui/TechStackBadge.astro';
import Icon from '../../components/ui/Icon.astro';

const features = [
  { title: 'Custom AI Agents', desc: 'Autonome digitale medewerkers die taken uitvoeren, data analyseren en beslissingen nemen op basis van uw bedrijfslogica.' },
  { title: 'LLM-integratie', desc: 'Naadloze koppeling van GPT-4, Claude of open-source modellen aan uw bestaande software en workflows.' },
  { title: 'Prompt Design & Optimalisatie', desc: 'Strategisch ontworpen prompts die consistente, betrouwbare output leveren — geen willekeurige AI-antwoorden.' },
  { title: 'RAG-systemen', desc: 'Retrieval Augmented Generation: AI die antwoorden baseert op úw bedrijfsdata, documenten en kennisbank.' },
  { title: 'AI-workflow Automatisering', desc: 'Repetitieve processen automatiseren met intelligente AI-chains die meerdere stappen autonoom doorlopen.' },
  { title: 'AI-gedreven Dashboards', desc: 'Real-time inzichten en voorspellingen gevisualiseerd in op maat gemaakte interfaces.' },
];

const useCases = [
  { title: 'Klantenservice automatisering', desc: 'AI-agent die veelgestelde vragen beantwoordt, tickets categoriseert en escaleert wanneer nodig.' },
  { title: 'Content & documentatie', desc: 'Geautomatiseerde rapportages, vertaling en content-generatie met menselijke review-flow.' },
  { title: 'Data-analyse & inzichten', desc: 'Natuurlijke-taal queries op uw database: "Wat was onze omzet vorige maand per regio?"' },
  { title: 'Code-assistentie & review', desc: 'Custom AI-tools die codekwaliteit bewaken, bugs detecteren en refactoring suggesties doen.' },
];
---

<Layout
  title="AI Prompt Engineering — LaventeCare"
  description="Professionele AI prompt engineering diensten: custom AI-agents, LLM-integratie, RAG-systemen en workflow-automatisering. Van concept tot productie. Dronten, Nederland."
>
  <!-- Hero -->
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto mb-16">
        <span class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-3 flex items-center gap-2"><Icon name="brain-circuit" size={16} class="text-active" /> AI & Prompt Engineering</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 font-display tracking-tight">
          Intelligentie die <span class="text-active">werkt</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 font-ui leading-relaxed mb-6">
          Een AI prompt engineer ontwerpt, optimaliseert en implementeert de instructies waarmee AI-modellen zoals GPT-4 en Claude betrouwbare, consistente resultaten leveren. Het verschil tussen een chatbot die "iets probeert" en een AI-systeem dat daadwerkelijk waarde toevoegt? <span class="text-white font-semibold">Professionele prompt engineering.</span>
        </p>
        <div class="flex flex-wrap gap-2">
          {['GPT-4', 'Claude', 'LangChain', 'RAG', 'Custom Agents', 'Python', 'Vector DB'].map((t) => (
            <TechStackBadge tech={t} />
          ))}
        </div>
      </div>

      <!-- Wat is een AI Prompt Engineer -->
      <div class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-active/20 max-w-4xl mx-auto mb-16">
        <h2 class="text-xl md:text-2xl font-bold text-white mb-6 font-display">Wat is een AI Prompt Engineer?</h2>
        <div class="space-y-4 text-white/70 font-ui text-sm leading-relaxed">
          <p>
            Een <strong class="text-white">AI prompt engineer</strong> is een specialist die de brug slaat tussen menselijke intentie en kunstmatige intelligentie. Waar traditionele software werkt met exacte code-instructies, werken Large Language Models (LLMs) met <strong class="text-white">natuurlijke taal</strong> — en de kwaliteit van die instructies bepaalt het verschil tussen bruikbare output en ruis.
          </p>
          <p>
            Professionele prompt engineering gaat verder dan "een vraag stellen aan ChatGPT". Het omvat <strong class="text-white">system prompts</strong>, <strong class="text-white">chain-of-thought reasoning</strong>, <strong class="text-white">few-shot learning</strong>, output-structurering en het bouwen van complete AI-pipelines die betrouwbaar en reproduceerbaar werken in productieomgevingen.
          </p>
          <p>
            Bij LaventeCare combineer ik prompt engineering met full-stack development. Dat betekent dat de AI-oplossingen die ik bouw niet in isolatie leven — ze worden <strong class="text-white">geïntegreerd in bestaande systemen</strong>, gekoppeld aan databases, beveiligd met Zero-Trust architectuur en voorzien van professionele interfaces.
          </p>
        </div>
      </div>

      <!-- Features Grid -->
      <SectionHeader
        label="Wat ik bouw"
        heading='Van prompt tot <span class="text-active">productie</span>'
        description="AI-oplossingen die verder gaan dan een chatvenster."
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto mb-16">
        {features.map((f) => (
          <div class="clinical-glass p-5 rounded-(--radius-card) border border-white/8">
            <h3 class="text-sm font-bold text-white mb-2 font-display">{f.title}</h3>
            <p class="text-white/60 text-xs font-ui">{f.desc}</p>
          </div>
        ))}
      </div>

      <!-- Hoe werkt het -->
      <div class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-active/20 max-w-4xl mx-auto mb-16">
        <h2 class="text-xl font-bold text-white mb-6 font-display">Hoe werkt het?</h2>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
          <div class="text-center">
            <span class="text-active text-2xl font-black font-display block mb-2">01</span>
            <h3 class="text-sm font-bold text-white mb-1 font-display">Discovery</h3>
            <p class="text-white/60 text-xs font-ui">Welke processen zijn geschikt voor AI-automatisering?</p>
          </div>
          <div class="text-center">
            <span class="text-active text-2xl font-black font-display block mb-2">02</span>
            <h3 class="text-sm font-bold text-white mb-1 font-display">Prompt Design</h3>
            <p class="text-white/60 text-xs font-ui">Strategisch ontwerp van system prompts, guardrails en output-structuren.</p>
          </div>
          <div class="text-center">
            <span class="text-active text-2xl font-black font-display block mb-2">03</span>
            <h3 class="text-sm font-bold text-white mb-1 font-display">Integratie</h3>
            <p class="text-white/60 text-xs font-ui">Koppeling aan uw systemen: API's, databases, dashboards.</p>
          </div>
          <div class="text-center">
            <span class="text-active text-2xl font-black font-display block mb-2">04</span>
            <h3 class="text-sm font-bold text-white mb-1 font-display">Optimalisatie</h3>
            <p class="text-white/60 text-xs font-ui">Continue verbetering op basis van output-kwaliteit en kosten.</p>
          </div>
        </div>
      </div>

      <!-- Use Cases -->
      <SectionHeader
        label="Toepassingen"
        heading='AI in de <span class="text-active">praktijk</span>'
        description="Concrete voorbeelden van hoe bedrijven AI prompt engineering inzetten."
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-4xl mx-auto mb-16">
        {useCases.map((uc) => (
          <div class="clinical-glass p-5 rounded-(--radius-card) border border-white/8">
            <h3 class="text-sm font-bold text-white mb-2 font-display">{uc.title}</h3>
            <p class="text-white/60 text-xs font-ui">{uc.desc}</p>
          </div>
        ))}
      </div>

      <!-- Doelgroep -->
      <div class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-active/20 max-w-3xl mx-auto mb-16">
        <h2 class="text-xl font-bold text-white mb-4 font-display">Voor wie?</h2>
        <p class="text-white/70 font-ui mb-4">Organisaties die AI willen inzetten als strategisch voordeel:</p>
        <ul class="space-y-2 text-sm font-ui text-white/60">
          <li class="flex items-start gap-3"><Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> MKB dat repetitieve processen wil automatiseren</li>
          <li class="flex items-start gap-3"><Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Softwarebedrijven die AI-features willen toevoegen</li>
          <li class="flex items-start gap-3"><Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Organisaties met grote hoeveelheden ongestructureerde data</li>
          <li class="flex items-start gap-3"><Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Bedrijven die custom ChatGPT-achtige tools willen voor intern gebruik</li>
        </ul>
      </div>

      <!-- Referentie -->
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-white/50 text-sm font-ui mb-4">Interne case study</p>
        <div class="clinical-glass p-6 rounded-(--radius-feature) border border-white/8 inline-block">
          <h3 class="text-lg font-bold text-white font-display mb-1">LaventeCare Codebase</h3>
          <p class="text-white/60 text-sm font-ui">Alle LaventeCare-projecten worden gebouwd met AI-gedreven development workflows — van code-generatie tot geautomatiseerde audits en prompt-gestuurde security reviews.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4 text-center">
      <a href="/contact?type=ai" class="btn-primary">
        Bespreek uw AI-project
        <Icon name="arrow-right" size={16} />
      </a>
    </div>
  </section>
</Layout>
