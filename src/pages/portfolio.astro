const caseStudies = isEnglish ? enCaseStudies : nlCaseStudies;
---

<Layout
  title={isEnglish
    ? 'Portfolio & Case Studies — LaventeCare'
    : 'Portfolio & Case Studies — LaventeCare'}
  description={isEnglish
    ? 'See how LaventeCare helps organisations with IoT, automation and software built for growth.'
    : 'Bekijk hoe wij bedrijven helpen met IoT, automatisering en software die met u meegroeit.'}
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4 relative z-10">
      <SectionHeader
        level={1}
        label={isEnglish ? 'Live in production' : 'Live in gebruik'}
        heading={isEnglish
          ? 'Every project runs <span class="text-active">in the real world</span>'
          : 'Elk project draait <span class="text-active">live in de praktijk</span>'}
        description={isEnglish
          ? 'Systems used every day — built to save time, prevent errors and deliver measurable results.'
          : 'Systemen die elke dag echt gebruikt worden — gebouwd om tijd te besparen, fouten te voorkomen en resultaat te leveren.'}
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto mb-16">
        {
          caseStudies.map((study, index) => (
            <div data-animate="fade-up" class={`delay-${(index % 3) * 100}`}>
              <CaseStudyCard {...study} />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div
        class="clinical-glass p-8 md:p-12 rounded-(--radius-hero) border border-white/8 max-w-4xl mx-auto text-center"
      >
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 font-display">
          {isEnglish ? 'Ready for the next project?' : 'Klaar voor het volgende project?'}
        </h2>
        <p class="text-white/70 mb-6 max-w-xl mx-auto font-ui">
          {
            isEnglish
              ? 'Book a free discovery call and explore what a focused solution could do for your organisation.'
              : 'Plan een gratis adviesgesprek en ontdek hoe we dit ook voor uw bedrijf kunnen realiseren.'
          }
        </p>
        <a href="/contact" class="btn-primary">
          {isEnglish ? 'Book a free discovery call' : 'Plan een gratis adviesgesprek'}
          <Icon name="arrow-right" size={16} />
        </a>
      </div>
    </div>
  </section>
</Layout>
