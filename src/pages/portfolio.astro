const enCaseStudies = [
  {
    name: 'De Koninklijke Loop',
    category: 'Events',
    description:
      'An event platform that handles registration, ticketing and donations without manual administration.',
    techStack: ['Astro', 'React 19', 'Convex', 'Go Auth', 'Vercel'],
    liveUrl: 'https://www.dekoninklijkeloop.nl/',
