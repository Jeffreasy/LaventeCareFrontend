    metrics: ['Real-time registration', 'Zero manual processing', 'Automated ticket flow'],
  },
  {
    name: 'JeffDash',
    category: 'QR Platform',
    description:
      'A dynamic QR platform with real-time scan analytics, campaign insights and brand-ready exports.',
    techStack: ['Next.js', 'Convex', 'React 19', 'Clerk'],
    liveUrl: 'https://www.jeffdash.com/',
    caseStudyUrl: '/portfolio/jeffdash',
