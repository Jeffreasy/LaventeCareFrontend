---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import CaseStudyCard from '../components/blocks/CaseStudyCard.astro';
import Icon from '../components/ui/Icon.astro';

const caseStudies = [
  {
    name: 'De Koninklijke Loop',
    category: 'Evenementen',
    description:
      'Evenementenplatform dat registratie, ticketing en donaties automatiseert — waardoor 100+ deelnemers verwerkt werden zonder handmatig werk.',
    techStack: ['Astro', 'React 19', 'Convex', 'Go Auth', 'Vercel'],
    liveUrl: 'https://www.dekoninklijkeloop.nl/',
    caseStudyUrl: '/portfolio/de-koninklijke-loop',
    lighthouseScores: [
      { category: 'Perf', score: 93 },
      { category: 'A11y', score: 95 },
      { category: 'BP', score: 92 },
    ],
  },
  {
    name: 'JeffDash',
    category: 'QR Platform',
    description:
      'Dynamisch QR-code platform dat realtime inzicht geeft in scangedrag, waardoor marketingcampagnes direct meetbaar en optimaliseerbaar worden.',
    techStack: ['Next.js', 'Convex', 'React 19', 'Go Auth'],
    liveUrl: 'https://www.jeffdash.com/',
    caseStudyUrl: '/portfolio/jeffdash',
    lighthouseScores: [
      { category: 'Perf', score: 99 },
      { category: 'A11y', score: 95 },
      { category: 'BP', score: 96 },
      { category: 'SEO', score: 92 },
    ],
  },
  {
    name: 'C&F Bouw',
    category: 'Lead Generation',
    description:
      'Lead-generation platform dat zorgt voor +340% organisch verkeer binnen 6 maanden en structureel meer aanvragen voor de bouwsector.',
    techStack: ['Next.js', 'Supabase', 'Vercel'],
    liveUrl: 'https://www.cfbouw.nl/',
    caseStudyUrl: '/portfolio/cf-bouw',
    lighthouseScores: [
      { category: 'Perf', score: 99 },
      { category: 'A11y', score: 97 },
      { category: 'BP', score: 100 },
      { category: 'SEO', score: 100 },
    ],
  },
  {
    name: 'Whisky for Charity',
    category: 'Charity',
    description:
      'Liefdadigheidsplatform dat veilige donatiestromen en veilingen faciliteert, zodat donateurs volledig inzicht hebben in donaties en bestedingen.',
    techStack: ['Astro', 'Convex', 'HTML Email'],
    liveUrl: 'https://www.whiskyforcharity.com/',
    caseStudyUrl: '/portfolio/whisky-for-charity',
    lighthouseScores: [
      { category: 'Perf', score: 71 },
      { category: 'A11y', score: 95 },
      { category: 'BP', score: 96 },
      { category: 'SEO', score: 100 },
    ],
  },
  {
    name: 'TuinHub',
    category: 'Matchmaking',
    description:
      'Platform dat tuineigenaren en hoveniers verbindt en direct leads genereert voor aangesloten bedrijven.',
    techStack: ['Next.js', 'Supabase', 'Vercel', 'SEO'],
    liveUrl: 'https://tuinhub.nl/',
    caseStudyUrl: '/portfolio/tuinhub',
    lighthouseScores: [
      { category: 'Perf', score: 98 },
      { category: 'A11y', score: 96 },
      { category: 'BP', score: 92 },
      { category: 'SEO', score: 100 },
    ],
  },
  {
    name: 'SmartCoolCare',
    category: 'IoT & Hardware',
    description:
      'Realtime koelmonitoring die temperatuur-afwijkingen direct detecteert en (product)schade of systeemstilstand voorkomt.',
    techStack: ['C++/ESP32', 'BLE', 'Convex', 'React'],
    liveUrl: 'https://www.smartcoolcare.nl/',
    caseStudyUrl: '/portfolio/smartcoolcare',
    lighthouseScores: [
      { category: 'Perf', score: 99 },
      { category: 'A11y', score: 90 },
      { category: 'BP', score: 96 },
      { category: 'SEO', score: 100 },
    ],
  },
  {
    name: 'Dustin Auto Garage',
    category: 'Werkplaatsbeheer',
    description:
      'Werkplaats-managementsysteem dat voertuigregistraties, RDW-koppelingen en facturatie stroomlijnt — zodat de monteur kan focussen op werk, terwijl het systeem de administratie en planning automatiseert.',
    techStack: ['Astro', 'React 19', 'Convex', 'Go Auth'],
    caseStudyUrl: '/portfolio/dustin-auto-garage',
  },
];
---

<Layout
  title="Portfolio & Case Studies - LaventeCare"
  description="Bekijk hoe wij bedrijven helpen met IoT, automatisering en schaalbare platformen."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4 relative z-10">
      <SectionHeader
        label="Bewezen in productie"
        heading='Elk project is <span class="text-active">live in productie</span>'
        description="Bewezen systemen die dagelijks gebruikt worden — gebouwd om tijd te besparen, fouten te voorkomen en resultaat te leveren."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto mb-16">
        {
          caseStudies.map((study, index) => (
            <div data-animate="fade-up" class={`delay-${(index % 3) * 100}`}>
              <CaseStudyCard {...study} />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div
        class="clinical-glass p-8 md:p-12 rounded-(--radius-hero) border border-white/8 max-w-4xl mx-auto text-center"
      >
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 font-display">
          Klaar voor het volgende project?
        </h2>
        <p class="text-white/70 mb-6 max-w-xl mx-auto font-ui">
          Plan een intake en ontdek hoe we dit ook voor uw bedrijf kunnen realiseren.
        </p>
        <a href="/contact" class="btn-primary">
          Plan een intake
          <Icon name="arrow-right" size={16} />
        </a>
      </div>
    </div>
  </section>
</Layout>
