---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import CaseStudyCard from '../components/blocks/CaseStudyCard.astro';


const caseStudies = [
  {
    name: 'De Koninklijke Loop',
    category: 'Evenementen',
    description: 'Compleet evenementenplatform met registratie, ticketing, donaties en real-time data. Astro 2026 Master Stack met Convex real-time backend.',
    techStack: ['Astro', 'React 19', 'Convex', 'Go Auth', 'Vercel'],
    liveUrl: 'https://www.dekoninklijkeloop.nl/',
    caseStudyUrl: '/portfolio/de-koninklijke-loop',
  },
  {
    name: 'JeffDash',
    category: 'SaaS Platform',
    description: 'Persoonlijk SaaS-dashboard ecosysteem met multi-tenant architectuur, real-time data synchronisatie, IoT-integraties en geavanceerd state management.',
    techStack: ['Next.js', 'Convex', 'React 19', 'Go Auth'],
    liveUrl: 'https://www.jeffdash.com/',
    caseStudyUrl: '/portfolio/jeffdash',
  },
  {
    name: 'C&F Bouw',
    category: 'Lead Generation',
    description: 'Professioneel lead-generation portaal voor de bouwsector met offertetrajecten, klantportaal en SEO-optimalisatie.',
    techStack: ['Next.js', 'Supabase', 'Vercel'],
    liveUrl: 'https://www.cfbouw.nl/',
    caseStudyUrl: '/portfolio/cf-bouw',
  },
  {
    name: 'Whisky for Charity',
    category: 'Charity',
    description: 'Evenementenplatform voor liefdadigheid met veilige donatiestromen, orderverwerking en geautomatiseerde communicatie.',
    techStack: ['Astro', 'Convex', 'HTML Email'],
    liveUrl: 'https://www.whiskyforcharity.com/',
    caseStudyUrl: '/portfolio/whisky-for-charity',
  },
  {
    name: 'TuinHub',
    category: 'Matchmaking',
    description: 'Matchmaking-platform voor de groensector waar tuineigenaren en hoveniers samenkomen. Multi-step offertetrajecten en realtime leads.',
    techStack: ['Next.js', 'Supabase', 'Vercel', 'SEO'],
    liveUrl: 'https://tuinhub.nl/',
    caseStudyUrl: '/portfolio/tuinhub',
  },
  {
    name: 'SmartCoolCare',
    category: 'IoT & Hardware',
    description: 'Industriële koelmonitoring met ESP32-sensors, deep-sleep firmware en live cloud dashboards voor temperatuur- en alarmdata.',
    techStack: ['C++/ESP32', 'BLE', 'Convex', 'React'],
    liveUrl: 'https://www.smartcoolcare.nl/',
    caseStudyUrl: '/portfolio/smartcoolcare',
  },
  {
    name: 'Dustin Auto Garage',
    category: 'Werkplaatsbeheer',
    description: 'Volledig werkplaats-managementsysteem met Kanban-bord, CRM, voertuigbeheer, RDW-integratie en facturatie. Multi-tenant architectuur.',
    techStack: ['Astro', 'React 19', 'Convex', 'Go Auth'],
    caseStudyUrl: '/portfolio/dustin-auto-garage',
  },
];
---

<Layout
  title="Portfolio — LaventeCare"
  description="Bekijk het bewezen track record van LaventeCare. Van IoT-firmware tot conversion-driven platformen. Elk project is live in productie."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Bewezen track record"
        heading='Elk project is <span class="text-active">live in productie</span>'
        description="Van IoT-firmware tot conversion-driven platformen. Deze projecten demonstreren de breedte van LaventeCare's technische expertise."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto mb-16">
        {caseStudies.map((study) => (
          <CaseStudyCard {...study} />
        ))}
      </div>
    </div>
  </section>



  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="clinical-glass p-8 md:p-12 rounded-(--radius-hero) border border-white/8 max-w-4xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 font-display">
          Klaar voor het volgende project?
        </h2>
        <p class="text-white/70 mb-6 max-w-xl mx-auto font-ui">
          Laten we bespreken hoe ik uw idee kan realiseren. Begin met een gratis intake gesprek.
        </p>
        <a href="/contact" class="btn-primary">
          Plan een intake
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
