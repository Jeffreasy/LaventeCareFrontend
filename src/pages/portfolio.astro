---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import CaseStudyCard from '../components/blocks/CaseStudyCard.astro';
import Icon from '../components/ui/Icon.astro';

const caseStudies = [
  {
    name: 'De Koninklijke Loop',
    category: 'Evenementen',
    description:
      'Evenementenplatform dat registratie, ticketing en donaties regelt. Deelnemers worden verwerkt zonder handmatig werk.',
    techStack: ['Astro', 'React 19', 'Convex', 'Go Auth', 'Vercel'],
    liveUrl: 'https://www.dekoninklijkeloop.nl/',
    caseStudyUrl: '/portfolio/de-koninklijke-loop',
    metrics: [
      'Real-time registratie',
      '0 Handmatig beheer',
      'Geautomatiseerde ticketflow',
    ],
  },
  {
    name: 'JeffDash',
    category: 'QR Platform',
    description:
      'QR-code platform dat live laat zien hoe vaak er gescand wordt. Zo ziet u direct welke campagne werkt en wat u kunt verbeteren.',
    techStack: ['Next.js', 'Convex', 'React 19', 'Clerk'],
    liveUrl: 'https://www.jeffdash.com/',
    caseStudyUrl: '/portfolio/jeffdash',
    metrics: [
      'Dynamische QR-codes',
      'Real-time inzicht in scans',
      'Gegevens strikt gescheiden',
    ],
  },
  {
    name: 'C&F Bouw',
    category: 'Klanten werven',
    description:
      'Website omgebouwd tot een systeem dat meer aanvragen binnenhaalt. Speciaal gemaakt voor de bouwsector.',
    techStack: ['Astro', 'Convex', 'Go Auth'],
    liveUrl: 'https://www.cfbouw.nl/',
    caseStudyUrl: '/portfolio/cf-bouw',
    metrics: [
      'Offertes in stappen',
      'Volledig geautomatiseerde offertes',
      'Branche-specifieke SEO',
    ],
  },
  {
    name: 'Whisky for Charity',
    category: 'Charity',
    description:
      'Liefdadigheidsplatform dat donaties en veilingen veilig verwerkt. Donateurs zien precies waar hun geld naartoe gaat.',
    techStack: ['Astro', 'HTML Email', 'Vercel'],
    liveUrl: 'https://www.whiskyforcharity.com/',
    caseStudyUrl: '/portfolio/whisky-for-charity',
    metrics: [
      'Gesloten Betaalsysteem',
      'Fraude-preventie inbegrepen',
    ],
  },
  {
    name: 'TuinHub',
    category: 'Matchmaking',
    description:
      'Platform dat tuineigenaren en hoveniers verbindt en direct aanvragen oplevert voor aangesloten bedrijven.',
    techStack: ['Astro', 'Convex', 'Go Auth', 'SEO'],
    liveUrl: 'https://tuinhub.nl/',
    caseStudyUrl: '/portfolio/tuinhub',
    metrics: [
      'Aanvragen direct doorgestuurd',
      'Automatisch koppelen',
    ],
  },
  {
    name: 'SmartCoolCare',
    category: 'IoT & Hardware',
    description:
      'Live koelbewaking die temperatuur-afwijkingen direct opmerkt en zo (product)schade of stilstand voorkomt.',
    techStack: ['C++/ESP32', 'BLE', 'Convex', 'React'],
    liveUrl: 'https://www.smartcoolcare.nl/',
    caseStudyUrl: '/portfolio/smartcoolcare',
    metrics: [
      'Zuinig, werkt maandenlang',
      'Live overzicht in de cloud',
      'Updates op afstand',
    ],
  },
  {
    name: 'Dustin Auto Garage',
    category: 'Werkplaatsbeheer',
    description:
      'Werkplaatssysteem dat voertuigregistratie, RDW-koppeling en facturatie regelt. Zo houdt de monteur tijd over voor het echte werk. Het systeem doet de administratie en planning.',
    techStack: ['Astro', 'React 19', 'Convex', 'Go Auth'],
    caseStudyUrl: '/portfolio/dustin-auto-garage',
    metrics: [
      'Volledige RDW Integratie',
      'Digitale Werkplaatsplanning',
      'Geautomatiseerde Facturatie',
    ],
  },
];
---

<Layout
  title="Portfolio & Case Studies - LaventeCare"
  description="Bekijk hoe wij bedrijven helpen met IoT, automatisering en software die met u meegroeit."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4 relative z-10">
      <SectionHeader
        label="Live in gebruik"
        heading='Elk project draait <span class="text-active">live in de praktijk</span>'
        description="Systemen die elke dag echt gebruikt worden — gebouwd om tijd te besparen, fouten te voorkomen en resultaat te leveren."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto mb-16">
        {
          caseStudies.map((study, index) => (
            <div data-animate="fade-up" class={`delay-${(index % 3) * 100}`}>
              <CaseStudyCard {...study} />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div
        class="clinical-glass p-8 md:p-12 rounded-(--radius-hero) border border-white/8 max-w-4xl mx-auto text-center"
      >
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 font-display">
          Klaar voor het volgende project?
        </h2>
        <p class="text-white/70 mb-6 max-w-xl mx-auto font-ui">
          Plan een gratis adviesgesprek en ontdek hoe we dit ook voor uw bedrijf kunnen realiseren.
        </p>
        <a href="/contact" class="btn-primary">
          Plan een gratis adviesgesprek
          <Icon name="arrow-right" size={16} />
        </a>
      </div>
    </div>
  </section>
</Layout>
