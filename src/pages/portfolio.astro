      'A charity platform that processes donations and auctions securely and communicates impact clearly.',
    techStack: ['Astro', 'HTML Email', 'Vercel'],
    liveUrl: 'https://www.whiskyforcharity.com/',
    caseStudyUrl: '/portfolio/whisky-for-charity',
    metrics: ['Closed payment flow', 'Fraud prevention included'],
  },
  {
    name: 'TuinHub',
    category: 'Marketplace',
    description:
      'A platform that matches garden owners with landscaping professionals and routes qualified leads.',
    techStack: ['Astro', 'Convex', 'Go Auth', 'SEO'],
    liveUrl: 'https://tuinhub.nl/',
    caseStudyUrl: '/portfolio/tuinhub',
    metrics: ['Leads routed instantly', 'Automated matching'],
  },
  {
    name: 'SmartCoolCare',
    category: 'IoT & Hardware',
    description:
      'Live cold-chain monitoring that detects temperature anomalies before they cause product loss or downtime.',
    techStack: ['C++/ESP32', 'BLE', 'Convex', 'React'],
    liveUrl: 'https://www.smartcoolcare.nl/',
    caseStudyUrl: '/portfolio/smartcoolcare',
    metrics: ['Months of battery life', 'Live cloud dashboard', 'Remote updates'],
  },
  {
    name: 'Dustin Auto Garage',
    category: 'Workshop Operations',
    description:
      'A workshop system for vehicle registration, Dutch vehicle data, planning and invoicing.',
    techStack: ['Astro', 'React 19', 'Convex', 'Go Auth'],
