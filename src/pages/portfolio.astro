---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import CaseStudyCard from '../components/blocks/CaseStudyCard.astro';
import Icon from '../components/ui/Icon.astro';


const caseStudies = [
  {
    name: 'De Koninklijke Loop',
    category: 'Evenementen',
    description: 'Compleet evenementenplatform met online registratie, ticketing, donaties en live inzicht in deelnemersdata. 100+ deelnemers verwerkt zonder handmatige invoer.',
    techStack: ['Astro', 'React 19', 'Convex', 'Go Auth', 'Vercel'],
    liveUrl: 'https://www.dekoninklijkeloop.nl/',
    caseStudyUrl: '/portfolio/de-koninklijke-loop',
    lighthouseScores: [
      { category: 'Perf', score: 93 },
      { category: 'A11y', score: 95 },
      { category: 'BP', score: 92 },
    ],
  },
  {
    name: 'JeffDash',
    category: 'QR Platform',
    description: 'Professionele dynamische QR-codes die u op elk moment kunt aanpassen. Scan-tracking in realtime, zodat u weet wie, waar en wanneer scant.',
    techStack: ['Next.js', 'Convex', 'React 19', 'Go Auth'],
    liveUrl: 'https://www.jeffdash.com/',
    caseStudyUrl: '/portfolio/jeffdash',
    lighthouseScores: [
      { category: 'Perf', score: 99 },
      { category: 'A11y', score: 95 },
      { category: 'BP', score: 96 },
      { category: 'SEO', score: 92 },
    ],
  },
  {
    name: 'C&F Bouw',
    category: 'Lead Generation',
    description: 'Professional lead-generation portaal voor de bouwsector: +340% organisch verkeer, automatische offertetrajecten en een veilig klantportaal.',
    techStack: ['Next.js', 'Supabase', 'Vercel'],
    liveUrl: 'https://www.cfbouw.nl/',
    caseStudyUrl: '/portfolio/cf-bouw',
    lighthouseScores: [
      { category: 'Perf', score: 99 },
      { category: 'A11y', score: 97 },
      { category: 'BP', score: 100 },
      { category: 'SEO', score: 100 },
    ],
  },
  {
    name: 'Whisky for Charity',
    category: 'Charity',
    description: 'Liefdadigheidsplatform op het snijvlak van kunst, whisky en goede doelen. Veilige donaties, veilingverwerking en automatische communicatie met donateurs.',
    techStack: ['Astro', 'Convex', 'HTML Email'],
    liveUrl: 'https://www.whiskyforcharity.com/',
    caseStudyUrl: '/portfolio/whisky-for-charity',
    lighthouseScores: [
      { category: 'Perf', score: 71 },
      { category: 'A11y', score: 95 },
      { category: 'BP', score: 96 },
      { category: 'SEO', score: 100 },
    ],
  },
  {
    name: 'TuinHub',
    category: 'Matchmaking',
    description: 'Matchmaking-platform waar tuineigenaren en hoveniers samenkomen. Stapsgewijze offertetrajecten en directe leads voor aangesloten hoveniers.',
    techStack: ['Next.js', 'Supabase', 'Vercel', 'SEO'],
    liveUrl: 'https://tuinhub.nl/',
    caseStudyUrl: '/portfolio/tuinhub',
    lighthouseScores: [
      { category: 'Perf', score: 98 },
      { category: 'A11y', score: 96 },
      { category: 'BP', score: 92 },
      { category: 'SEO', score: 100 },
    ],
  },
  {
    name: 'SmartCoolCare',
    category: 'IoT & Hardware',
    description: 'Industriële koelmonitoring: 24/7 temperatuurbewaking met automatische alarmering. Sensordata direct zichtbaar op uw dashboard.',
    techStack: ['C++/ESP32', 'BLE', 'Convex', 'React'],
    liveUrl: 'https://www.smartcoolcare.nl/',
    caseStudyUrl: '/portfolio/smartcoolcare',
    lighthouseScores: [
      { category: 'Perf', score: 99 },
      { category: 'A11y', score: 90 },
      { category: 'BP', score: 96 },
      { category: 'SEO', score: 100 },
    ],
  },
  {
    name: 'Dustin Auto Garage',
    category: 'Werkplaatsbeheer',
    description: 'Compleet werkplaats-managementsysteem: Kanban-bord, klantenbeheer, voertuigregistratie met RDW-koppeling en automatische facturatie.',
    techStack: ['Astro', 'React 19', 'Convex', 'Go Auth'],
    caseStudyUrl: '/portfolio/dustin-auto-garage',
  },
];
---

<Layout
  title="Portfolio: Live Projecten & Case Studies — LaventeCare"
  description="Bekijk het bewezen track record van LaventeCare. Van IoT-firmware tot conversion-driven platformen. Elk project is live in productie."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Bewezen track record"
        heading='Elk project is <span class="text-active">live in productie</span>'
        description="Van IoT-firmware tot conversion-driven platformen. Deze projecten demonstreren de breedte van LaventeCare's technische expertise."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto mb-16">
        {caseStudies.map((study) => (
          <CaseStudyCard {...study} />
        ))}
      </div>
    </div>
  </section>



  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="clinical-glass p-8 md:p-12 rounded-(--radius-hero) border border-white/8 max-w-4xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 font-display">
          Klaar voor het volgende project?
        </h2>
        <p class="text-white/70 mb-6 max-w-xl mx-auto font-ui">
          Laten we bespreken hoe ik uw idee kan realiseren. Begin met een gratis intake gesprek.
        </p>
        <a href="/contact" class="btn-primary">
          Plan een intake
          <Icon name="arrow-right" size={16} />
        </a>
      </div>
    </div>
  </section>
</Layout>
