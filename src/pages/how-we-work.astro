---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import ProcessTimeline from '../components/blocks/ProcessTimeline.astro';
import Icon from '../components/ui/Icon.astro';

const processSteps = [
  {
    phase: '0',
    title: 'Phase 0: IT Consultancy (Optional)',
    description:
      'A low-barrier session to brainstorm, perform a second-opinion or map out technical feasibility. No obligations to build.',
    price: '€95 / hr',
    icon: 'coffee',
  },
  {
    phase: '1',
    title: 'Introduction & Discovery Intake',
    description:
      'A no-obligation conversation (30 min) to clarify your situation, goals and technical possibilities. Including a first assessment of feasibility and investment.',
    price: 'Free',
    icon: 'message-circle',
  },
  {
    phase: '2',
    title: 'Discovery & Blueprint (technical build plan)',
    description:
      'We work out exactly what you need and design the system. You receive one central document with all the agreements and the design (Blueprint). You keep a usable build plan regardless of whether the project proceeds.',
    price: '€500 – €1,500',
    icon: 'search',
  },
  {
    phase: '3',
    title: 'Realisation — Fixed-Price Milestones',
    description:
      'Development based on the build plan (Blueprint) at a fixed project price. Timeline: 2–6 weeks. Billing 40/40/20 in phases. Work beyond the agreement via a separate change (Change Request) only.',
    price: 'Fixed-Price (Blueprint)',
    icon: 'zap',
  },
  {
    phase: '4',
    title: 'Maintenance & Further Development (SLA)',
    description:
      'Your system stays secure, up-to-date and available thanks to live monitoring (Observatory AI). Further improvements based on your requirements, in fixed quarterly blocks. You arrange this with a maintenance contract with fixed terms (SLA).',
    price: 'from €75/month',
    icon: 'refresh-cw',
  },
] as const;

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How does a project with LaventeCare work?',
  description:
    'From a free intake to maintenance with fixed terms (SLA). A structured four-phase model for B2B IT projects, based on a Blueprint: one central document with all agreements and the design.',
  step: processSteps.map((s) => ({
    '@type': 'HowToStep',
    name: `Step ${s.phase}: ${s.title}`,
    text: s.description,
  })),
  totalTime: 'P12W',
  estimatedCost: {
    '@type': 'MonetaryAmount',
    currency: 'EUR',
    value: 'Fixed-Price based on Blueprint',
  },
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

<Layout
  title="How We Work — Blueprint-First, No Surprises | LaventeCare"
  description="How does a project with LaventeCare work? Discovery, Blueprint, fixed-price milestones and maintenance with fixed terms (SLA). Transparent, structured and no surprises beyond the agreement."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Process"
        heading='From idea to <span class="text-active">production</span>'
        description="No chaos or surprises, but a structured process that ensures control, clarity and a reliable end result."
      />

      <!-- Process Timeline -->
      <div class="max-w-5xl mx-auto mb-16">
        <ProcessTimeline steps={[...processSteps]} />
      </div>

      <!-- Billing Flow -->
      <div class="max-w-3xl mx-auto mb-16">
        <SectionHeader
          label="Billing"
          heading='Phased <span class="text-active">billing</span> — full control over your investment'
          description="Billing based on milestones and realised progress. In case of early termination, the terms from the quote and general terms and conditions apply."
        />

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div
            class="clinical-glass p-5 rounded-(--radius-card) border border-active/20 text-center bg-active/5"
          >
            <div class="text-3xl font-black text-active font-display mb-1">40%</div>
            <p class="text-white/70 text-xs font-ui">After Blueprint approval</p>
            <p class="text-white/40 text-[10px] font-ui mt-1">Covers initial costs</p>
          </div>
          <div
            class="clinical-glass p-5 rounded-(--radius-card) border border-active/20 text-center bg-active/5"
          >
            <div class="text-3xl font-black text-active font-display mb-1">40%</div>
            <p class="text-white/70 text-xs font-ui">At beta delivery</p>
            <p class="text-white/40 text-[10px] font-ui mt-1">Interim acceptance</p>
          </div>
          <div
            class="clinical-glass p-5 rounded-(--radius-card) border border-active/20 text-center bg-active/5"
          >
            <div class="text-3xl font-black text-active font-display mb-1">20%</div>
            <p class="text-white/70 text-xs font-ui">After go-live & acceptance</p>
            <p class="text-white/40 text-[10px] font-ui mt-1">Client guarantee</p>
          </div>
        </div>
      </div>

      <!-- Payment Terms -->
      <div
        class="clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8 max-w-3xl mx-auto mb-16"
      >
        <h3 class="text-lg font-bold text-white mb-4 font-display">Payment Terms</h3>
        <ul class="space-y-3 text-sm font-ui text-white/70">
          <li class="flex gap-3">
            <Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Payment term: <strong
              class="text-white">30 days</strong
            > after invoice date (Article 9 of our terms and conditions)
          </li>
          <li class="flex gap-3">
            <Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Discovery (research) phases
            are invoiced <strong class="text-white">in advance</strong>
          </li>
          <li class="flex gap-3">
            <Icon name="check" size={14} class="text-active shrink-0 mt-0.5" /> Maintenance (SLA): <strong
              class="text-white">monthly in advance</strong
            > via direct debit — the price rises yearly with inflation (CBS)
          </li>
          <li class="flex gap-3">
            <Icon name="external-link" size={14} class="text-active shrink-0 mt-0.5" />
            <span
              >Full payment and cancellation terms:
              <a href="/terms" class="text-active hover:underline">Terms & Conditions</a>
            </span>
          </li>
        </ul>
        <div
          class="mt-4 p-3 rounded-(--radius-card) bg-white/3 border border-white/8 flex items-start gap-3"
        >
          <Icon name="alert-triangle" size={13} class="text-active shrink-0 mt-0.5" />
          <p class="text-white/40 text-xs font-ui leading-relaxed">
            <span class="text-white/70 font-bold">Cancellation (Consultancy/Phase 0):</span> Free up to
            24h before the session. After that, 100% is billed.
            <span class="text-white/70 font-bold ml-1">Realisation phase:</span> hours already worked
            + 30% of the remaining amount. Discovery: fixed fee only. See <a
              href="/terms"
              class="text-active hover:underline">Terms & Conditions</a
            >.
          </p>
        </div>
      </div>

      <!-- When we are / aren't a fit -->
      <div class="max-w-3xl mx-auto">
        <SectionHeader
          label="Transparency"
          heading='Honest about <span class="text-active">expectations</span>'
        />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div
            data-animate="fade-up"
            class="clinical-glass p-6 rounded-(--radius-feature) border border-cta/20 bg-cta/5"
          >
            <h3 class="text-base font-bold text-white mb-4 font-display flex items-center gap-2">
              <Icon name="check" size={16} class="text-cta shrink-0" /> Ideal match
            </h3>
            <ul class="space-y-2 text-sm font-ui text-white/60">
              <li>
                There is a concrete business process that affects time, errors, revenue or customer
                experience
              </li>
              <li>You have ownership: you can decide, prioritise and give feedback</li>
              <li>
                Willingness to properly work through the research and build plan (Discovery and
                Blueprint) before building starts
              </li>
              <li>The question is about a system or work process, not standalone styling</li>
              <li>There is room for maintenance, documentation and further development</li>
            </ul>
          </div>
          <div
            data-animate="fade-up"
            class="delay-100 clinical-glass p-6 rounded-(--radius-feature) border border-white/8"
          >
            <h3 class="text-base font-bold text-white mb-4 font-display flex items-center gap-2">
              <Icon name="arrow-right" size={16} class="text-white/40 shrink-0" /> We'll refer you elsewhere
            </h3>
            <ul class="space-y-2 text-sm font-ui text-white/40">
              <li>Only a fast, cheap website without an underlying process question</li>
              <li>No owner, budget direction or decision moment within the organisation</li>
              <li>A wish to start building without doing analysis first</li>
              <li>Continuously support-intensive without a suitable maintenance contract (SLA)</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4 text-center">
      <a href="/contact?type=discovery" class="btn-primary text-lg px-10">
        Book a free intro call
        <Icon name="arrow-right" size={20} />
      </a>
      <p class="text-white/40 text-sm font-ui mt-3">
        Book a free intro call and get immediate insight into feasibility, approach and costs for
        your situation.
      </p>
    </div>
  </section>
</Layout>
