---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="404 - Pagina niet gevonden | LaventeCare"
  description="De pagina die u zoekt bestaat niet of is verplaatst."
>
  <section class="flex items-center justify-center min-h-[80vh] py-24">
    <div class="container mx-auto px-4 text-center max-w-2xl">
      <!-- Glitch Number -->
      <div class="relative mb-8">
        <h1
          class="text-[10rem] md:text-[14rem] font-black font-display leading-none text-transparent bg-clip-text bg-linear-to-r from-active via-secondary to-active/50 select-none"
        >
          404
        </h1>
        <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
          <div class="w-64 h-64 rounded-full bg-active/10 blur-3xl"></div>
        </div>
      </div>

      <!-- Message -->
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4 font-display">
        Pagina niet gevonden
      </h2>
      <p class="text-lg text-white/60 mb-10 font-ui leading-relaxed">
        De pagina die u zoekt bestaat niet, is verplaatst of is tijdelijk niet beschikbaar.
        Controleer de URL of ga terug naar de homepage.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="px-8 py-4 bg-active text-background rounded-2xl font-semibold text-lg shadow-lg hover:bg-primary-hover hover:-translate-y-0.5 transition-all duration-300"
        >
          Terug naar Home
        </a>
        <a
          href="/contact"
          class="px-8 py-4 clinical-glass border-2 border-white/20 text-white rounded-2xl font-semibold text-lg hover:bg-white/10 hover:border-white/40 hover:-translate-y-0.5 transition-all duration-300"
        >
          Contact Opnemen
        </a>
      </div>
    </div>
  </section>
</Layout>
