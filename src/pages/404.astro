---
import Layout from '../layouts/Layout.astro';
const isEnglish = Astro.locals.locale === 'en';
---

<Layout
  title={isEnglish
    ? '404 — Page not found | LaventeCare'
    : '404 — Pagina niet gevonden | LaventeCare'}
  description={isEnglish
    ? 'The page you are looking for does not exist or has moved.'
    : 'De pagina die u zoekt bestaat niet of is verplaatst.'}
  noindex
>
  <section class="flex items-center justify-center min-h-[80vh] py-24">
    <div class="container mx-auto px-4 text-center max-w-2xl">
      <!-- Glitch Number -->
      <div class="relative mb-8">
        <h1
          class="text-[10rem] md:text-[14rem] font-black font-display leading-none text-transparent bg-clip-text bg-linear-to-r from-active via-secondary to-active/50 select-none"
        >
          404
        </h1>
        <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
          <div class="w-64 h-64 rounded-full bg-active/10 blur-3xl"></div>
        </div>
      </div>

      <!-- Message -->
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4 font-display">
        {isEnglish ? 'Page not found' : 'Pagina niet gevonden'}
      </h2>
      <p class="text-lg text-white/60 mb-10 font-ui leading-relaxed">
        {
          isEnglish
            ? 'The page you are looking for does not exist, has moved or is temporarily unavailable. Check the URL or return to the homepage.'
            : 'De pagina die u zoekt bestaat niet, is verplaatst of is tijdelijk niet beschikbaar. Controleer de URL of ga terug naar de homepage.'
        }
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-hero-primary">
          {isEnglish ? 'Back to home' : 'Terug naar home'}
        </a>
        <a href="/contact" class="btn-hero-secondary">
          {isEnglish ? 'Contact us' : 'Contact opnemen'}
        </a>
      </div>
    </div>
  </section>
</Layout>
