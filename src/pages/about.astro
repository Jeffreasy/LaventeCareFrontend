---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import TechStackBadge from '../components/ui/TechStackBadge.astro';
import Icon, { type IconName } from '../components/ui/Icon.astro';

const expertiseDomains = [
  {
    icon: 'brain-circuit',
    title: 'AI & Automation',
    techs: ['LLM Integration', 'Custom Agents', 'A human decides'],
    description:
      'AI that takes over repetitive work and uses your data for faster decisions. Reliable, measurable and with a person who decides along the way — built into your existing workflows.',
  },
  {
    icon: 'radio',
    title: 'Smart Monitoring & Sensors',
    techs: ['C++', 'ESP32', 'BLE', 'OTA Updates'],
    description:
      'From sensor to dashboard: spot problems early and reduce downtime. Live insight on your screen, remote software updates.',
  },
  {
    icon: 'cog',
    title: 'Security & Access',
    techs: ['PostgreSQL RLS', 'RBAC', 'Audit Trails'],
    description:
      "Every client's data stays strictly separated, everyone only sees what they're allowed to, and every action is logged. Security from the ground up, built according to GDPR (Privacy by Design). Under the hood: separated client data (PostgreSQL RLS), access per role (RBAC) and full logging.",
  },
  {
    icon: 'monitor',
    title: 'Custom Platforms',
    techs: ['Astro', 'React 19', 'Convex', 'Go Auth'],
    description:
      'Replace loose tools and manual work with one system that grows with you, with everything in one place. Blazing-fast screens that rank high on Google and help visitors get in touch.',
  },
  {
    icon: 'cloud',
    title: 'Hosting & Management',
    techs: ['Vercel', 'Render', 'CI/CD', 'Sentry'],
    description:
      'Your application runs on fast servers worldwide. Automatic updates, continuous monitoring and SSL certificates — ongoing maintenance with fixed terms available (SLA).',
  },
];

const coreValues = [
  {
    icon: 'lock',
    title: 'Security as standard',
    desc: 'Not as an optional module, but as a foundation.',
  },
  {
    icon: 'link',
    title: 'End-to-end responsibility',
    desc: 'From sensor to dashboard, everything under one roof.',
  },
  {
    icon: 'trending-up',
    title: 'Grows with you',
    desc: 'Systems that grow with the client.',
  },
  {
    icon: 'handshake',
    title: 'Transparency',
    desc: 'Long-term partnerships over quick projects.',
  },
];

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Jeffrey Lavente',
  jobTitle: 'Founder LaventeCare — B2B systems partner for SMEs',
  description:
    'Founder of LaventeCare, a B2B systems partner for SME organisations. Turns the way you work into software that does the work for you: AI, IoT, custom platforms, winning customers and security from the ground up.',
  image:
    'https://ik.imagekit.io/a0oim4e3e/LaventeCare/IMG_0040.JPG?tr=w-512,h-512,fo-face,f-auto,q-85',
  url: 'https://www.laventecare.com/about',
  worksFor: {
    '@type': 'Organization',
    name: 'LaventeCare',
    url: 'https://www.laventecare.com',
  },
  knowsAbout: [
    'AI & Automation',
    'LLM Integration',
    'Go',
    'PostgreSQL',
    'React',
    'Astro',
    'C++',
    'ESP32',
    'IoT',
    'Security-first Architecture',
    'Cloud Architecture',
    'Custom Software',
  ],
  sameAs: [
    'https://linkedin.com/in/jeffrey-lavente',
    'https://github.com/Jeffreasy',
    'https://www.instagram.com/jjalavente/',
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Dronten',
    addressRegion: 'Flevoland',
    addressCountry: 'NL',
  },
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />

<Layout
  title="About LaventeCare — B2B systems partner for SMEs"
  description="LaventeCare is a long-term B2B systems partner that turns the way you work into software that does the work for you: AI, automation, custom software, monitoring and security from the ground up. From idea to working system."
>
  <!-- Hero -->
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="flex flex-col md:flex-row items-center md:items-start gap-8 md:gap-12">
          <!-- Profile Photo -->
          <div class="profile-photo-wrapper shrink-0">
            <div class="profile-photo-container">
              <picture>
                <source
                  media="(max-width: 639px)"
                  srcset="
                    https://ik.imagekit.io/a0oim4e3e/LaventeCare/IMG_0040.JPG?tr=w-160,h-160,fo-face,f-auto,q-80,e-sharpen 1x,
                    https://ik.imagekit.io/a0oim4e3e/LaventeCare/IMG_0040.JPG?tr=w-320,h-320,fo-face,f-auto,q-75,e-sharpen 2x
                  "
                />
                <source
                  media="(min-width: 1024px)"
                  srcset="
                    https://ik.imagekit.io/a0oim4e3e/LaventeCare/IMG_0040.JPG?tr=w-220,h-280,fo-face,f-auto,q-85,e-sharpen 1x,
                    https://ik.imagekit.io/a0oim4e3e/LaventeCare/IMG_0040.JPG?tr=w-440,h-560,fo-face,f-auto,q-80,e-sharpen 2x
                  "
                />
                <img
                  src="https://ik.imagekit.io/a0oim4e3e/LaventeCare/IMG_0040.JPG?tr=w-220,h-280,fo-face,f-auto,q-85,e-sharpen"
                  alt="Jeffrey Lavente — founder LaventeCare"
                  width="220"
                  height="280"
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                  class="profile-photo-img"
                />
              </picture>
              <div class="profile-photo-overlay" aria-hidden="true"></div>
            </div>
          </div>

          <div class="text-center md:text-left">
            <span class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-3 block"
              >About LaventeCare</span
            >
            <h1
              class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-4 font-display tracking-tight"
            >
              From idea to working system
            </h1>
            <p class="text-lg md:text-xl text-white/70 leading-relaxed font-ui">
              LaventeCare is a <span class="text-white font-semibold"
                >B2B systems partner for SME organisations</span
              > that want to get digital growth, automation and custom software done right. Not a one-off
              website builder or freelancer, but a <span class="text-active font-semibold"
                >long-term partner</span
              > that turns the way you work into software that does the work for you.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What we do -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <SectionHeader
          label="The partner"
          heading='A long-term partner, not a <span class="text-active">loose supplier</span>'
        />
        <div
          class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-active/20 bg-active/5"
        >
          <p class="text-white/80 text-sm md:text-base leading-relaxed font-ui mb-4">
            LaventeCare builds systems that make businesses more efficient, prevent errors and
            accelerate growth: <span class="text-white font-semibold"
              >AI, IoT, custom platforms, winning customers and systems with security from the
              ground up</span
            >. We focus on SMEs, service providers and operational teams with recurring processes.
          </p>
          <p class="text-white/80 text-sm md:text-base leading-relaxed font-ui mb-4">
            Our core promise: from loose tools and manual work to one <span
              class="text-active font-semibold">digital system that grows with you</span
            >. Intro call, analysis, blueprint (the full build plan), build, maintenance and further
            development — not a loose project that stalls after delivery, but a system that keeps
            working and grows with you.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-6">
            <div class="text-center p-4 rounded-lg bg-white/3 border border-white/5">
              <Icon name="brain-circuit" size={20} class="text-active mx-auto mb-2" />
              <p class="text-white text-xs font-bold font-display">Process first</p>
              <p class="text-white/50 text-[11px] font-ui">Systems, not loose styling</p>
            </div>
            <div class="text-center p-4 rounded-lg bg-white/3 border border-white/5">
              <Icon name="lock" size={20} class="text-active mx-auto mb-2" />
              <p class="text-white text-xs font-bold font-display">Security from the ground up</p>
              <p class="text-white/50 text-[11px] font-ui">Security as a foundation</p>
            </div>
            <div class="text-center p-4 rounded-lg bg-white/3 border border-white/5">
              <Icon name="handshake" size={20} class="text-active mx-auto mb-2" />
              <p class="text-white text-xs font-bold font-display">Long-term partner</p>
              <p class="text-white/50 text-[11px] font-ui">Maintenance and development</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Transparency: solo-founder + AI as build team -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <SectionHeader
          label="Radical transparency"
          heading='Who stands behind <span class="text-active">LaventeCare</span>'
        />
        <div class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-white/8">
          <p class="text-white/80 text-sm md:text-base leading-relaxed font-ui mb-4">
            I believe in radical honesty about how LaventeCare works. LaventeCare was set up and is
            led by <span class="text-white font-semibold">Jeffrey Lavente</span> as founder and engineer.
            I act as the architect who defines the blueprint, and use advanced AI models as my <span
              class="text-active font-semibold">executing build team</span
            >.
          </p>
          <p class="text-white/80 text-sm md:text-base leading-relaxed font-ui mb-4">
            AI builds at lightning speed, but tends to take the easiest route and skip the
            exceptions. That's where the strength of this approach lies. I define the setup and
            steer where needed. I enforce strict security rules: data kept strictly separated and
            every action logged. This is how LaventeCare delivers systems with built-in security,
            separated data and live monitoring — the discipline of a team, delivered by one
            accountable partner.
          </p>
          <div
            class="flex flex-col sm:flex-row gap-4 mt-6 p-4 rounded-lg bg-active/5 border border-active/15"
          >
            <div data-animate="fade-up" class="flex-1 flex items-start gap-3">
              <Icon name="cog" size={18} class="text-active shrink-0 mt-0.5" />
              <div>
                <p class="text-white text-xs font-bold font-display">AI = Executor</p>
                <p class="text-white/60 text-[11px] font-ui">Build, improve and test at speed</p>
              </div>
            </div>
            <div data-animate="fade-up" class="delay-100 flex-1 flex items-start gap-3">
              <Icon name="brain-circuit" size={18} class="text-active shrink-0 mt-0.5" />
              <div>
                <p class="text-white text-xs font-bold font-display">Jeffrey = Architect</p>
                <p class="text-white/60 text-[11px] font-ui">
                  Blueprint, security and quality control
                </p>
              </div>
            </div>
            <div data-animate="fade-up" class="delay-200 flex-1 flex items-start gap-3">
              <Icon name="lock" size={18} class="text-active shrink-0 mt-0.5" />
              <div>
                <p class="text-white text-xs font-bold font-display">Database as fortress</p>
                <p class="text-white/60 text-[11px] font-ui">
                  The AI in check, the data strictly protected
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Background in care -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <SectionHeader
          label="The background"
          heading='Structure and security, learned in <span class="text-active">care</span>'
        />
        <div
          class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-active/20 bg-active/5"
        >
          <p class="text-white/80 text-sm md:text-base leading-relaxed font-ui mb-4">
            Before starting LaventeCare, I worked for years as an intensive 1-on-1 care professional
            for individuals with complex acquired brain injuries. In that world I learned a
            fundamental lesson: <span class="text-white font-semibold"
              >where chaos reigns, calm, structure and boundless dedication are essential</span
            >.
          </p>
          <p class="text-white/80 text-sm md:text-base leading-relaxed font-ui mb-4">
            I apply that same lens to software architecture. I don't build loose websites, but
            <span class="text-active font-semibold">systems with structure and boundaries</span> — stable,
            secure and manageable. Staying analytical in complexity, setting boundaries and taking 1-on-1
            accountability: that's what I bring to every system I deliver.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Quote -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div
          class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-active/20 relative"
        >
          <div class="absolute top-4 left-6 text-4xl text-active/30 font-display">"</div>
          <blockquote
            class="text-base md:text-lg text-white/80 leading-relaxed font-ui pl-4 md:pl-8 border-l-2 border-active/40"
          >
            I don't believe in perfection, I believe in <span class="text-white font-semibold"
              >extreme curiosity, transparency and rock-solid security</span
            >. Silence is Golden, the Database is a Fortress. Whether it's an SME portal, an IoT
            dashboard or a custom platform: <span class="text-active font-semibold"
              >your data gets the same level of protection</span
            >.
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- Background: Education & Experience -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Education -->
        <div class="clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8">
          <h2 class="text-xl font-bold text-white mb-5 font-display flex items-center gap-3">
            <Icon name="graduation-cap" size={20} class="text-active" /> Education
          </h2>
          <ul class="space-y-4">
            <li>
              <p class="text-white font-semibold text-sm">MBO Level 4</p>
              <p class="text-white/60 text-sm font-ui">
                Personal Support Worker for Specific Target Groups (2017–2018)
              </p>
            </li>
            <li>
              <p class="text-white font-semibold text-sm">MBO Level 3</p>
              <p class="text-white/60 text-sm font-ui">Social Care Worker (2015–2017)</p>
            </li>
            <li>
              <p class="text-white font-semibold text-sm">Self-Taught Systems Engineer</p>
              <p class="text-white/60 text-sm font-ui">
                Go, PostgreSQL, Security Architecture, IoT, Cloud Infrastructure
              </p>
            </li>
          </ul>
        </div>

        <!-- Experience -->
        <div class="clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8">
          <h2 class="text-xl font-bold text-white mb-5 font-display flex items-center gap-3">
            <Icon name="briefcase" size={20} class="text-active" /> Experience
          </h2>
          <ul class="space-y-4">
            <li>
              <div class="flex items-baseline justify-between">
                <p class="text-white font-semibold text-sm">Founder & Systems Engineer</p>
                <span class="text-active text-xs font-bold">2026 – present</span>
              </div>
              <p class="text-white/60 text-sm font-ui">
                LaventeCare — Long-term systems partner for SMEs: design and build of custom
                platforms with built-in security, AI automation and live monitoring (IoT).
              </p>
            </li>
            <li>
              <div class="flex items-baseline justify-between">
                <p class="text-white font-semibold text-sm">1-on-1 Support Worker NAH++</p>
                <span class="text-active text-xs font-bold">2018 – present</span>
              </div>
              <p class="text-white/60 text-sm font-ui">
                's Heeren Loo — Intensive individual support of clients with acquired brain
                injuries. Staying analytical in chaos, taking 1-on-1 accountability, setting
                boundaries and building safe structures.
              </p>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Technical Expertise -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Technical expertise"
        heading='Exceptionally broad <span class="text-active">field</span>'
        description="From smart sensors to strictly separated client data and blazing-fast platforms — everything under one roof. That's rare, and exactly what makes the difference."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        {
          expertiseDomains.map((domain) => (
            <div class="clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8 hover:border-active/20 transition-colors">
              <div class="flex items-center gap-3 mb-4">
                <Icon name={domain.icon as IconName} size={24} class="text-active" />
                <h3 class="text-lg font-bold text-white font-display">{domain.title}</h3>
              </div>
              <p class="text-white/60 text-sm leading-relaxed mb-4 font-ui">{domain.description}</p>
              <div class="flex flex-wrap gap-2">
                {domain.techs.map((tech) => (
                  <TechStackBadge tech={tech} variant="subtle" />
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Core Values -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Core values"
        heading='What I <span class="text-active">stand for</span>'
      />

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 max-w-5xl mx-auto">
        {
          coreValues.map((value) => (
            <div class="clinical-glass p-5 rounded-(--radius-card) border border-white/8 text-center">
              <Icon name={value.icon as IconName} size={24} class="text-active block mb-3" />
              <h3 class="text-sm font-bold text-white mb-2 font-display">{value.title}</h3>
              <p class="text-white/50 text-xs font-ui">{value.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Company Details -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div
        class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-white/8 max-w-3xl mx-auto"
      >
        <h2 class="text-xl font-bold text-white mb-6 font-display text-center">Company Details</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm font-ui">
          <div class="flex justify-between sm:flex-col gap-1">
            <span class="text-white/50">Legal form</span>
            <span class="text-white font-medium">Sole trader</span>
          </div>
          <div class="flex justify-between sm:flex-col gap-1">
            <span class="text-white/50">Chamber of Commerce</span>
            <span class="text-white font-medium">88162710</span>
          </div>
          <div class="flex justify-between sm:flex-col gap-1">
            <span class="text-white/50">VAT number</span>
            <span class="text-white font-medium">NL004553268B57</span>
          </div>
          <div class="flex justify-between sm:flex-col gap-1">
            <span class="text-white/50">Founded</span>
            <span class="text-white font-medium">2026</span>
          </div>
          <div class="flex justify-between sm:flex-col gap-1">
            <span class="text-white/50">Location</span>
            <span class="text-white font-medium">Dronten, Netherlands</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4 text-center">
      <a href="/contact" class="btn-primary text-lg px-10">
        Get in touch
        <Icon name="arrow-right" size={20} />
      </a>
    </div>
  </section>
</Layout>

<style>
  .profile-photo-wrapper {
    position: relative;
  }
  .profile-photo-container {
    position: relative;
    width: 160px;
    height: 160px;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow:
      0 0 0 2px color-mix(in oklch, var(--color-active) 30%, transparent),
      0 0 30px -5px color-mix(in oklch, var(--color-active) 15%, transparent),
      0 8px 24px -8px rgba(0, 0, 0, 0.4);
    transition:
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.4s ease;
  }
  .profile-photo-container:hover {
    transform: scale(1.03);
    box-shadow:
      0 0 0 2px color-mix(in oklch, var(--color-active) 50%, transparent),
      0 0 40px -5px color-mix(in oklch, var(--color-active) 25%, transparent),
      0 16px 40px -8px rgba(0, 0, 0, 0.5);
  }
  .profile-photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .profile-photo-overlay {
    position: absolute;
    inset: 0;
    border-radius: 1rem;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
    pointer-events: none;
  }
  @media (min-width: 640px) {
    .profile-photo-container {
      width: 200px;
      height: 240px;
      border-radius: 1.25rem;
    }
    .profile-photo-overlay {
      border-radius: 1.25rem;
    }
  }
  @media (min-width: 1024px) {
    .profile-photo-container {
      width: 220px;
      height: 280px;
      border-radius: 1.5rem;
    }
    .profile-photo-overlay {
      border-radius: 1.5rem;
    }
  }
</style>
