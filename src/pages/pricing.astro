---
import Layout from '../layouts/Layout.astro';
import PricingOverview from '../components/blocks/PricingOverview.astro';

const pricingSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'LaventeCare',
  url: 'https://www.laventecare.com/pricing',
  priceRange: '€750 - €1,500+ one-off; website management from €29/month',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'LaventeCare pricing and management',
    itemListElement: [
      {
        '@type': 'Offer',
        name: 'Website Start',
        price: '750',
        priceCurrency: 'EUR',
        description: 'A complete responsive one-page business website.',
      },
      {
        '@type': 'Offer',
        name: 'Website Business',
        price: '1000',
        priceCurrency: 'EUR',
        description:
          'A business website of up to three pages with a secure form and automatic confirmation.',
      },
      {
        '@type': 'Offer',
        name: 'Custom Website',
        price: '1500',
        priceCurrency: 'EUR',
        description: 'Custom website starting at €1,500.',
      },
      {
        '@type': 'Offer',
        name: 'Website Care Start',
        price: '29',
        priceCurrency: 'EUR',
        unitText: 'per month',
        description: 'Managed hosting, SSL, monitoring and technical updates.',
      },
      {
        '@type': 'Offer',
        name: 'Website Care Business',
        price: '49',
        priceCurrency: 'EUR',
        unitText: 'per month',
        description: 'Website management including form and transactional email monitoring.',
      },
      {
        '@type': 'Offer',
        name: 'Custom Website Care',
        price: '75',
        priceCurrency: 'EUR',
        unitText: 'per month',
        description: 'Custom hosting, monitoring and technical continuity from €75 per month.',
      },
      {
        '@type': 'Offer',
        name: 'IT Consultancy',
        price: '95',
        priceCurrency: 'EUR',
        unitText: 'per hour',
        description: 'Independent technical advice without an obligation to build.',
      },
      {
        '@type': 'AggregateOffer',
        name: 'Discovery & Blueprint',
        lowPrice: '500',
        highPrice: '1500',
        priceCurrency: 'EUR',
        description: 'Research and a usable technical plan for custom development.',
      },
      {
        '@type': 'Offer',
        name: 'SLA Essential',
        price: '75',
        priceCurrency: 'EUR',
        unitText: 'per month',
        description: 'Technical continuity for a compact custom system.',
      },
      {
        '@type': 'Offer',
        name: 'SLA Professional',
        price: '150',
        priceCurrency: 'EUR',
        unitText: 'per month',
        description: 'Proactive management with four reserved support hours per month.',
      },
      {
        '@type': 'Offer',
        name: 'SLA Continuity',
        price: '300',
        priceCurrency: 'EUR',
        unitText: 'per month',
        description: 'Business-critical continuity and extended management from €300 per month.',
      },
    ],
  },
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(pricingSchema)} />

<Layout
  title="Pricing & Investment — Websites, Systems and Management | LaventeCare"
  description="Transparent pricing for websites, advice, B2B custom platforms and management. Website builds from €750 and Website Care from €29 per month."
>
  <PricingOverview locale="en" />
</Layout>
