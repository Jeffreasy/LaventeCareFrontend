---
/**
 * /pricing — English pricing page (served on www.laventecare.com)
 *
 * The old NL redirect (→ /prijzen) is no longer needed here because:
 * - .nl domain: prijzen.astro handles Dutch pricing
 * - .com domain: this file serves English pricing
 *
 * Middleware ensures locale detection per domain.
 */
import Layout from '../layouts/Layout.astro';
import Icon from '../components/ui/Icon.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';

const pricingSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'LaventeCare',
  url: 'https://www.laventecare.com/pricing',
  priceRange: '€75 - €300+/maand',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'LaventeCare Services & SLA',
    itemListElement: [
      {
        '@type': 'Offer',
        name: 'Phase 0: IT Consultancy',
        price: '95',
        priceCurrency: 'EUR',
        unitText: 'per hour',
        description:
          'Independent strategic and technical advice, without any obligation to build software.',
      },
      {
        '@type': 'Offer',
        name: 'Step 1: Discovery & Blueprint (technical build plan)',
        price: '500',
        priceCurrency: 'EUR',
        description:
          'We work out exactly what you need and design the system. You receive a usable build plan (Blueprint): one central document with all the agreements and the design.',
      },
      {
        '@type': 'Offer',
        name: 'Step 2: Realisation (Fixed-Price Milestones)',
        price: 'Fixed project price',
        priceCurrency: 'EUR',
        description: 'Fixed price based on the Blueprint. Billing in 40/40/20 milestones.',
      },
      {
        '@type': 'Offer',
        name: 'SLA Essential',
        price: '75',
        priceCurrency: 'EUR',
        unitText: 'per month',
        description: 'Updates, support and uptime monitoring.',
      },
      {
        '@type': 'Offer',
        name: 'SLA Professional',
        price: '150',
        priceCurrency: 'EUR',
        unitText: 'per month',
        description: 'Monitoring, performance and reporting.',
      },
      {
        '@type': 'Offer',
        name: 'SLA Enterprise',
        price: '300',
        priceCurrency: 'EUR',
        unitText: 'per month',
        description:
          'Priority for major outages (we do our utmost; no hard guarantee unless stated in the contract), plus Observatory AI monitoring.',
      },
    ],
  },
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(pricingSchema)} />

<Layout
  title="Pricing & Investment — Transparent, Fixed-Price Projects | LaventeCare"
  description="Transparent investments for B2B custom platforms. Fixed milestone pricing (40/40/20) based on a technical Blueprint. No unexpected additional costs."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Investment"
        heading='Transparent <span class="text-active">Pricing</span>'
        description="No surprises — clear pricing, clear phases, full control over your investment. Every phase can be taken separately, keeping you in control of costs and risk."
      />

      <!-- Project Pricing -->
      <div class="max-w-5xl mx-auto mb-16">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
          <!-- Consultancy -->
          <div
            data-animate="scale-up"
            class="clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8 flex flex-col"
          >
            <span class="text-active text-xs font-bold uppercase tracking-wider mb-3 font-display"
              >Phase 0</span
            >
            <h2 class="text-xl font-bold text-white mb-2 font-display">IT Consultancy</h2>
            <p class="text-white/50 text-sm mb-5 font-ui">Strategic & technical advice</p>
            <div class="text-3xl font-black text-white mb-1 font-display">
              €95 <span class="text-lg text-white/40 font-normal">/ hour</span>
            </div>
            <p class="text-white/40 text-xs mb-6 font-ui">First meeting is free</p>
            <div class="h-px bg-white/8 my-4"></div>
            <ul class="space-y-3 mb-6 flex-1 text-sm font-ui text-white/70">
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Independent advice
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> No build obligations
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Second opinion & audit
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Flexible hourly rate
              </li>
            </ul>
            <a
              href="/contact?type=advies"
              class="text-center py-3 rounded-lg border border-white/15 text-white hover:bg-white/5 transition-colors font-bold font-ui min-h-12 flex items-center justify-center"
            >
              Schedule meeting
            </a>
          </div>

          <!-- Discovery -->
          <div
            data-animate="scale-up"
            class="clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8 flex flex-col"
          >
            <span class="text-active text-xs font-bold uppercase tracking-wider mb-3 font-display"
              >Step 1</span
            >
            <h2 class="text-xl font-bold text-white mb-2 font-display">
              Discovery & Blueprint (technical build plan)
            </h2>
            <p class="text-white/50 text-sm mb-5 font-ui">
              We research your question and design the system
            </p>
            <div class="text-3xl font-black text-white mb-1 font-display">
              €500 <span class="text-lg text-white/40 font-normal">– €1,500</span>
            </div>
            <p class="text-white/40 text-xs mb-6 font-ui">One-off, fixed fee — excl. VAT</p>
            <div class="h-px bg-white/8 my-4"></div>
            <ul class="space-y-3 mb-6 flex-1 text-sm font-ui text-white/70">
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Technical requirements
                analysis
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Custom architecture design
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Detailed build plan (Blueprint)
                — one central document with all agreements and the design
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> You always retain a usable
                build plan
              </li>
            </ul>
            <a
              href="/contact?type=discovery"
              class="text-center py-3 rounded-lg border border-white/15 text-white hover:bg-white/5 transition-colors font-bold font-ui min-h-12 flex items-center justify-center"
            >
              Start the research
            </a>
          </div>

          <!-- Realisation (Featured) -->
          <div
            data-animate="scale-up"
            class="delay-100 clinical-glass p-6 md:p-8 rounded-(--radius-feature) border-2 border-active relative flex flex-col shadow-xl shadow-active/10 md:scale-105 z-10"
          >
            <div
              class="absolute top-0 right-0 bg-active text-white text-[10px] font-bold px-3 py-1 rounded-bl-lg rounded-tr-lg tracking-wider font-display"
            >
              PROJECT WORK
            </div>
            <span class="text-active text-xs font-bold uppercase tracking-wider mb-3 font-display"
              >Step 2</span
            >
            <h2 class="text-xl font-bold text-white mb-2 font-display">Realisation</h2>
            <p class="text-white/50 text-sm mb-5 font-ui">
              Fixed price based on the build plan (Blueprint)
            </p>
            <div class="text-3xl font-black text-white mb-1 font-display">
              Fixed <span class="text-lg text-white/40 font-normal">Project Price</span>
            </div>
            <p class="text-white/40 text-xs mb-6 font-ui">
              Phased billing (40/40/20) — if you don't pay, we may temporarily pause the work (<a
                href="/terms"
                class="text-active hover:underline">suspension right</a
              >).
            </p>
            <div class="h-px bg-white/8 my-4"></div>
            <ul class="space-y-3 mb-6 flex-1 text-sm font-ui text-white/70">
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Strictly within the agreement
                from the build plan (Blueprint)
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Interim demos & acceptance
                testing
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> No additional charges
                or surprises
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Security from the ground
                up (Zero-Trust) included
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Work beyond the agreement
                always via a separate change (Change Request, €95/hr)
              </li>
              <li class="flex gap-2 text-white/40">
                <span class="text-active"><Icon name="external-link" size={14} /></span>
                <span
                  >Generic modules & AuthSystem remain LaventeCare IP; client receives usage rights
                  — see <a href="/terms" class="text-active hover:underline">terms</a></span
                >
              </li>
            </ul>
            <a
              href="/contact?type=project"
              class="text-center py-3 rounded-lg bg-active text-white font-bold hover:bg-active/90 transition-colors font-ui shadow-lg shadow-active/25 min-h-12 flex items-center justify-center"
            >
              Start a project
            </a>
          </div>

          <!-- IoT -->
          <div
            data-animate="scale-up"
            class="delay-200 clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8 flex flex-col"
          >
            <span class="text-active text-xs font-bold uppercase tracking-wider mb-3 font-display"
              >Per Device</span
            >
            <h2 class="text-xl font-bold text-white mb-2 font-display">IoT Integration</h2>
            <p class="text-white/50 text-sm mb-5 font-ui">Grows with you, per device</p>
            <div class="text-3xl font-black text-white mb-1 font-display">
              From €2<span class="text-lg text-white/40 font-normal">/device per month</span>
            </div>
            <p class="text-white/40 text-xs mb-6 font-ui">Scales as your system grows</p>
            <div class="h-px bg-white/8 my-4"></div>
            <ul class="space-y-3 mb-6 flex-1 text-sm font-ui text-white/70">
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Secure collection of
                sensor data
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Real-time data storage
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Managed cloud infrastructure
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Secure device verification
              </li>
            </ul>
            <a
              href="/contact?type=iot"
              class="text-center py-3 rounded-lg border border-white/15 text-white hover:bg-white/5 transition-colors font-bold font-ui min-h-12 flex items-center justify-center"
            >
              Connect hardware
            </a>
          </div>
        </div>
      </div>

      <!-- SLA Tiers -->
      <div class="max-w-5xl mx-auto mb-16">
        <SectionHeader
          label="After delivery"
          heading='Maintenance with <span class="text-active">fixed terms (SLA)</span>'
          description="Your system stays secure, up-to-date and available — even after delivery. You arrange this with a maintenance contract with fixed terms (SLA). Choose the level that suits your business."
        />

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Basic -->
          <div class="clinical-glass p-6 rounded-(--radius-feature) border border-white/8">
            <h3 class="text-lg font-bold text-white mb-1 font-display">Essential</h3>
            <div class="text-2xl font-black text-white font-display mb-1">
              €75<span class="text-sm text-white/40 font-normal">/month</span>
            </div>
            <p class="text-white/40 text-xs mb-4 font-ui">
              Hosting & availability monitoring · price rises yearly with inflation (CBS)
            </p>
            <ul class="space-y-2 text-xs font-ui text-white/60">
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Managed hosting
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Security updates
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> SSL & domain management
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Email delivery
              </li>
            </ul>
          </div>

          <!-- Pro -->
          <div
            class="clinical-glass p-6 rounded-(--radius-feature) border border-active/30 bg-active/5"
          >
            <span class="text-active text-[10px] font-bold uppercase tracking-wider font-display"
              >Recommended</span
            >
            <h3 class="text-lg font-bold text-white mb-1 font-display">Professional</h3>
            <div class="text-2xl font-black text-white font-display mb-1">
              €150<span class="text-sm text-white/40 font-normal">/month</span>
            </div>
            <p class="text-white/40 text-xs mb-4 font-ui">Monitoring, performance & reporting</p>
            <ul class="space-y-2 text-xs font-ui text-white/60">
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Everything in Basic
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> We keep outside components
                up to date
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> 4 hours support per month
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Performance monitoring
              </li>
            </ul>
          </div>

          <!-- Enterprise -->
          <div class="clinical-glass p-6 rounded-(--radius-feature) border border-white/8">
            <h3 class="text-lg font-bold text-white mb-1 font-display">Enterprise</h3>
            <div class="text-2xl font-black text-white font-display mb-1">
              €300+<span class="text-sm text-white/40 font-normal">/month</span>
            </div>
            <p class="text-white/40 text-xs mb-4 font-ui">
              24/7 monitoring, priority & Observatory AI
            </p>
            <ul class="space-y-2 text-xs font-ui text-white/60">
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Everything in Professional
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Observatory AI realtime
                monitoring
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Priority handling of
                P1 incidents (full outage)
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> 24/7 availability for
                business-critical incidents
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Weekly proactive maintenance
              </li>
            </ul>
            <p class="text-white/35 text-[10px] mt-3 font-ui leading-relaxed">
              Target response times (P1 full outage · P2 severe disruption with a temporary fix ·
              P3/P4 limited or cosmetic): we do our utmost to meet these times, but they are
              guidelines — not a hard guarantee, unless stated in the contract.
            </p>
          </div>
        </div>
      </div>

      <!-- Legal Footer -->
      <div class="text-center mt-8">
        <p class="text-white/35 text-xs font-ui">
          All our services are subject to the
          <a
            href="/terms"
            class="text-active hover:text-active/80 transition-colors underline underline-offset-2"
            >Terms & Conditions</a
          >
          of LaventeCare — including agreements on delivery, acceptance, ownership and liability.
        </p>
      </div>

      <!-- CTA -->
      <div class="text-center mt-8">
        <a href="/contact" class="btn-primary">
          Book a free intro call
          <Icon name="arrow-right" size={16} />
        </a>
        <p class="text-white/40 text-sm font-ui mt-3">
          Book a free intro call and receive a concrete estimate for your project.
        </p>
      </div>
    </div>
  </section>
</Layout>
