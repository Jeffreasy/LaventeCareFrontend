---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import TechStackBadge from '../../components/ui/TechStackBadge.astro';
import Icon from '../../components/ui/Icon.astro';
import LighthouseScoreBlock from '../../components/blocks/LighthouseScoreBlock.astro';
import ClientTestimonial from '../../components/blocks/ClientTestimonial.astro';

const results = [
  { value: '+340%', label: 'Meer organisch verkeer' },
  { value: '< 1.5s', label: 'LCP (Largest Contentful Paint)' },
  { value: '99 avg', label: 'Lighthouse Score' },
  { value: '24/7', label: 'Lead-notificaties' },
];

const lighthouseScores = [
  { category: 'Performance', score: 99 },
  { category: 'Accessibility', score: 97 },
  { category: 'Best Practices', score: 100 },
  { category: 'SEO', score: 100 },
];

const challenges = [
  {
    title: 'Lage online zichtbaarheid',
    desc: 'De bouwsector zoekt lokaal. Zonder branche-specifieke SEO en Google Maps-integratie bleef de website onzichtbaar voor potentiële klanten.',
  },
  {
    title: 'Handmatig offerteproces',
    desc: 'Offerteaanvragen kwamen via e-mail en telefoon, zonder structuur. Leads gingen verloren en opvolging was inconsistent.',
  },
  {
    title: 'Geen klantportaal',
    desc: 'Klanten hadden geen inzicht in projectstatus, offertes of communicatiehistorie. Alles verliep via losse e-mails en telefoontjes.',
  },
  {
    title: 'Verouderde website',
    desc: 'De bestaande website was een statisch WordPress-template zonder conversieoptimalisatie, trage laadtijden en geen mobiele optimalisatie.',
  },
];
---

<Layout
  title="Case Study: C&F Bouw — LaventeCare"
  description="Hoe LaventeCare een lead-generation portaal bouwde voor de bouwsector. Multi-step offertetrajecten, SEO-optimalisatie en 340% meer organisch verkeer."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <!-- Hero -->
      <div class="max-w-4xl mx-auto mb-16">
        <span class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-3 flex items-center gap-2"><Icon name="clipboard-list" size={16} class="text-active" /> Case Study</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 font-display tracking-tight">
          C&F <span class="text-active">Bouw</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 font-ui leading-relaxed mb-6">
          Een professioneel lead-generation portaal voor de bouwsector. Van een verouderde WordPress-site naar een high-performance platform met gestructureerde offertetrajecten, SEO-optimalisatie en realtime lead-notificaties.
        </p>
        <div class="flex flex-wrap items-center gap-4 mb-8">
          <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20">Lead Generation</span>
          <a href="https://www.cfbouw.nl/" target="_blank" rel="noopener noreferrer" class="text-active text-sm font-semibold hover:underline flex items-center gap-1">
            Bekijk live
            <Icon name="external-link" size={12} class="inline" />
          </a>
        </div>
        <div class="flex flex-wrap gap-2">
          {['Next.js', 'Supabase', 'Vercel', 'SEO', 'Analytics', 'Resend'].map((t) => (
            <TechStackBadge tech={t} />
          ))}
        </div>
      </div>

      <!-- Resultaten -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto mb-16">
        {results.map((r) => (
          <div data-animate="fade-up" class="clinical-glass p-5 rounded-(--radius-card) border border-active/20 text-center">
            <div class="text-2xl md:text-3xl font-black text-active mb-1 font-display">{r.value}</div>
            <p class="text-white/50 text-xs font-ui">{r.label}</p>
          </div>
        ))}
      </div>

      <!-- Uitdaging -->
      <div class="max-w-4xl mx-auto mb-16">
        <SectionHeader
          label="De uitdaging"
          heading='Van WordPress naar <span class="text-active">leadmachine</span>'
        />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {challenges.map((c) => (
            <div data-animate="fade-up" class="clinical-glass p-5 rounded-(--radius-card) border border-white/8">
              <h3 class="text-sm font-bold text-white mb-2 font-display">{c.title}</h3>
              <p class="text-white/60 text-xs font-ui leading-relaxed">{c.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Oplossing -->
      <div class="max-w-4xl mx-auto mb-16">
        <SectionHeader
          label="De oplossing"
          heading='Conversie door <span class="text-active">technologie</span>'
        />
        <div data-animate="fade-up" class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-white/8 space-y-6">
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">Multi-step Offertetrajecten</h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Gestructureerde, meerstaps formulieren die de bezoeker begeleiden van projecttype-selectie tot contactgegevens. Elke stap verlaagt de drempel en verhoogt de kwaliteit van binnenkomende leads.
            </p>
          </div>
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">Branche-specifieke SEO</h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Technische SEO-optimalisatie gericht op lokale zoektermen in de bouwsector. Gestructureerde data (LocalBusiness schema), geoptimaliseerde meta-tags en snelle laadtijden resulteren in een verdrievoudiging van organisch verkeer.
            </p>
          </div>
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">Realtime Lead-notificaties</h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Dual-mail dispatch bij elke lead: de klant ontvangt een professionele bevestiging, het C&F Bouw team ontvangt direct een gedetailleerde notificatie met alle projectdetails. Maximale zichtbaarheid op elke aanvraag.
            </p>
          </div>
        </div>
      </div>

      <!-- Lighthouse Audit -->
      <div class="max-w-4xl mx-auto mb-16">
        <SectionHeader
          label="Bewezen prestaties"
          heading='Verifieerbare <span class="text-active">Lighthouse</span> data'
        />
        <LighthouseScoreBlock
          projectName="C&F Bouw"
          scores={lighthouseScores}
          context="Met een sterk geoptimaliseerde Next.js build pipeline en branche-specifieke SEO behaal ik uitstekende scores over alle vier de categorieën. 100 op Best Practices en SEO bewijst een robuust, zoekmachinevriendelijk fundament."
          liveUrl="https://www.cfbouw.nl/"
        />
      </div>
    </div>
  </section>

  <!-- Klantervaring (wacht op echte quotes van klant)
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <SectionHeader
          label="Klantervaring"
          heading='Wat de klant <span class="text-active">zegt</span>'
        />
        <ClientTestimonial
          quote="Jeffrey begrijpt wat je nodig hebt zonder dat je het technisch hoeft uit te leggen. Binnen een paar weken hadden we een professionele website die echt leads genereert. De snelheid waarmee hij werkt en de kwaliteit die hij levert is indrukwekkend."
          name="Ferry Bouwman"
          role="Eigenaar"
          company="C&F Bouw"
          companyUrl="https://www.cfbouw.nl/"
          projectContext="Over de samenwerking"
        />
      </div>
    </div>
  </section>
  -->

  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4 text-center">
      <p class="text-white/50 text-sm font-ui mb-4">Meer leads voor uw bedrijf?</p>
      <a href="/contact?type=leadgen" class="btn-primary">
        Bespreek uw project
        <Icon name="arrow-right" size={16} />
      </a>
    </div>
  </section>
</Layout>
