---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import TechStackBadge from '../../components/ui/TechStackBadge.astro';
import Icon from '../../components/ui/Icon.astro';

const results = [
  { value: '€10K+', label: 'Opgehaald voor goede doelen' },
  { value: '100%', label: 'Succesvolle transacties' },
  { value: '< 2s', label: 'Gemiddelde laadtijd' },
  { value: 'Dual', label: 'E-mail dispatch' },
];

const challenges = [
  {
    title: 'Veilige donatiestromen',
    desc: 'Financiële transacties voor liefdadigheid vereisen absolute betrouwbaarheid. Elke euro moet traceerbaar en verantwoord zijn.',
  },
  {
    title: 'Complexe orderverwerking',
    desc: 'Bestellingen van whisky-veilingen, donaties en merchandise moeten feilloos verwerkt worden met automatische bevestigingen.',
  },
  {
    title: 'Geautomatiseerde communicatie',
    desc: 'Deelnemers, donateurs en organisatoren moeten op het juiste moment de juiste informatie ontvangen, volledig geautomatiseerd.',
  },
  {
    title: 'Event-dag betrouwbaarheid',
    desc: 'Tijdens het event mag het platform niet falen. Nul downtime is geen wens maar een vereiste bij live liefdadigheidsacties.',
  },
];
---

<Layout
  title="Case Study: Whisky for Charity — LaventeCare"
  description="Hoe LaventeCare een liefdadigheidsplatform bouwde met veilige donatiestromen, orderverwerking en geautomatiseerde communicatie. Astro + Convex."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto mb-16">
        <span class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-3 flex items-center gap-2"><Icon name="clipboard-list" size={16} class="text-active" /> Case Study</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 font-display tracking-tight">
          Whisky for <span class="text-active">Charity</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 font-ui leading-relaxed mb-6">
          Een evenementenplatform voor liefdadigheid waar whisky-liefhebbers en goede doelen samenkomen. Veilige donatiestromen, orderverwerking en volledig geautomatiseerde communicatie.
        </p>
        <div class="flex flex-wrap items-center gap-4 mb-8">
          <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20">Charity</span>
          <a href="https://www.whiskyforcharity.com/" target="_blank" rel="noopener noreferrer" class="text-active text-sm font-semibold hover:underline flex items-center gap-1">
            Bekijk live
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        </div>
        <div class="flex flex-wrap gap-2">
          {['Astro', 'Convex', 'HTML Email', 'Vercel'].map((t) => (
            <TechStackBadge tech={t} />
          ))}
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto mb-16">
        {results.map((r) => (
          <div class="clinical-glass p-5 rounded-(--radius-card) border border-active/20 text-center">
            <div class="text-2xl md:text-3xl font-black text-active mb-1 font-display">{r.value}</div>
            <p class="text-white/50 text-xs font-ui">{r.label}</p>
          </div>
        ))}
      </div>

      <div class="max-w-4xl mx-auto mb-16">
        <SectionHeader label="De uitdaging" heading='Liefdadigheid verdient <span class="text-active">betrouwbaarheid</span>' />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {challenges.map((c) => (
            <div class="clinical-glass p-5 rounded-(--radius-card) border border-white/8">
              <h3 class="text-sm font-bold text-white mb-2 font-display">{c.title}</h3>
              <p class="text-white/60 text-xs font-ui leading-relaxed">{c.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="max-w-4xl mx-auto mb-16">
        <SectionHeader label="De oplossing" heading='Veilig, snel en <span class="text-active">geautomatiseerd</span>' />
        <div class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-white/8 space-y-6">
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">Convex Real-time Backend</h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Alle transacties, bestellingen en donaties worden verwerkt via Convex met server-side validatie. Real-time synchronisatie zorgt ervoor dat het organisatieteam live meekijkt met binnenkomende orders.
            </p>
          </div>
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">HTML Email Templates</h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Pixel-perfect e-mailbevestigingen die correct renderen in alle e-mailclients — van Gmail tot Outlook. Dual-dispatch: de klant ontvangt een orderbevestiging, het team ontvangt een admin-notificatie.
            </p>
          </div>
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">Astro Islands voor Performance</h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Statische contentpagina's met interactieve React Islands voor het bestel- en donatieproces. Minimale JavaScript payload resulteert in razendsnelle laadtijden, zelfs op mobiel.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container mx-auto px-4 text-center">
      <p class="text-white/50 text-sm font-ui mb-4">Liefdadigheidsplatform nodig?</p>
      <a href="/contact?type=platform" class="btn-primary">
        Bespreek uw project
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </section>
</Layout>
