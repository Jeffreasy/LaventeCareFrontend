---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import TechStackBadge from '../../components/ui/TechStackBadge.astro';
import Icon from '../../components/ui/Icon.astro';

if (Astro.locals.locale === 'en') {
  return Astro.rewrite('/en-case-study?slug=de-koninklijke-loop');
}

const results = [
  { value: 'Real-time', label: 'Registratie & live tellers' },
  { value: '0', label: 'Handmatig werk voor organisatie' },
  { value: 'Veilig', label: 'Betalingen apart afgehandeld' },
  { value: 'Snel', label: 'Laadt vlot, ook op mobiel' },
];

const challenges = [
  {
    title: 'Ingewikkelde aanmeldingen',
    desc: 'Verschillende soorten deelnemers (los, in groepen, met begeleiders). Elk met een eigen formulier, eigen prijs en eigen regels.',
  },
  {
    title: 'Live overzicht tijdens het evenement',
    desc: 'Organisatoren wilden live zien hoeveel mensen er waren, wat er binnenkwam en wie was aangemeld. Zonder de pagina te verversen.',
  },
  {
    title: 'Veilige betalingen',
    desc: 'Donaties en deelnamegeld moesten betrouwbaar worden verwerkt en terug te vinden zijn. Met automatische bevestigingsmails.',
  },
  {
    title: 'Blijft werken bij grote drukte',
    desc: 'Rond promotieacties schrijven veel mensen zich tegelijk in. Het systeem moet dat aankunnen zonder vast te lopen.',
  },
];
---

<Layout
  title="Case Study: De Koninklijke Loop — LaventeCare"
  description="Hoe LaventeCare een compleet evenementenplatform bouwde voor De Koninklijke Loop. Real-time registratie, ticketing, donaties en live dashboards. Astro + Convex + Go."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <!-- Hero -->
      <div class="max-w-4xl mx-auto mb-16">
        <span
          class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-3 flex items-center gap-2"
          ><Icon name="clipboard-list" size={16} class="text-active" /> Case Study</span
        >
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 font-display tracking-tight"
        >
          De Koninklijke <span class="text-active">Loop</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 font-ui leading-relaxed mb-6">
          Een compleet evenementenplatform voor een liefdadigheidswandeltocht. Van aanmelden en
          tickets tot donaties en live overzicht. Deelnemers worden verwerkt zonder één handmatige
          actie.
        </p>
        <div class="flex flex-wrap items-center gap-4 mb-8">
          <span
            class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20"
            >Evenementen</span
          >
          <a
            href="https://www.dekoninklijkeloop.nl/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-active text-sm font-semibold hover:underline flex items-center gap-1"
          >
            Bekijk live
            <Icon name="external-link" size={12} class="inline" />
          </a>
        </div>
        <div class="flex flex-wrap gap-2">
          {
            ['Astro', 'React 19', 'Convex', 'Go Auth', 'Vercel', 'HTML Email'].map((t) => (
              <TechStackBadge tech={t} />
            ))
          }
        </div>
      </div>

      <!-- Resultaten -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto mb-16">
        {
          results.map((r) => (
            <div
              data-animate="fade-up"
              class="clinical-glass p-5 rounded-(--radius-card) border border-active/20 text-center"
            >
              <div class="text-2xl md:text-3xl font-black text-active mb-1 font-display">
                {r.value}
              </div>
              <p class="text-white/50 text-xs font-ui">{r.label}</p>
            </div>
          ))
        }
      </div>

      <!-- Uitdaging -->
      <div class="max-w-4xl mx-auto mb-16">
        <SectionHeader
          label="De uitdaging"
          heading='Wat het project <span class="text-active">complex</span> maakte'
        />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {
            challenges.map((c) => (
              <div
                data-animate="fade-up"
                class="clinical-glass p-5 rounded-(--radius-card) border border-white/8"
              >
                <h3 class="text-sm font-bold text-white mb-2 font-display">{c.title}</h3>
                <p class="text-white/60 text-xs font-ui leading-relaxed">{c.desc}</p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Oplossing -->
      <div class="max-w-4xl mx-auto mb-16">
        <SectionHeader
          label="De oplossing"
          heading='Architectuur & <span class="text-active">aanpak</span>'
        />
        <div
          data-animate="fade-up"
          class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-white/8 space-y-6"
        >
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">
              Snelle schermen, veilige betalingen
            </h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              De schermen die live moeten bijwerken (registraties, tellers) draaien op een supersnel
              systeem. Alles wat met inloggen en geld te maken heeft, loopt apart over een extra
              beveiligd systeem. Zo blijft het scherm snel én blijven betalingen veilig. Onder de
              motorkap: Convex voor de live database en een aparte Go-backend voor inloggen,
              e-mailverificatie en beveiliging (CSRF).
            </p>
          </div>
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">
              Laadt snel, ook op mobiel
            </h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Alleen de formulieren en het beheerscherm zijn interactief; de rest van de pagina is
              kant-en-klaar. Daardoor laadt de pagina razendsnel, ook op een telefoon met een matige
              verbinding. Onder de motorkap: Astro Islands, waarbij alleen de nodige onderdelen
              worden geactiveerd.
            </p>
          </div>
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">Automatische e-mails</h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Bij elke registratie gaan er automatisch twee e-mails uit: de deelnemer krijgt een
              bevestiging met alle details, het organisatieteam krijgt een melding met een
              samenvatting. De e-mails zien er altijd goed uit, in elk e-mailprogramma (van Gmail
              tot Outlook).
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Klantervaring (wacht op echte quotes van klant)
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <SectionHeader
          label="Klantervaring"
          heading='Wat de organisatie <span class="text-active">zegt</span>'
        />
        <ClientTestimonial
          quote="Op de dag zelf liep alles feilloos. Registraties, betalingen, real-time deelnemersaantallen — we hoefden ons nergens zorgen om te maken. Jeffrey denkt mee als partner, niet als leverancier."
          name="Organisatie"
          role="Evenementencommissie"
          company="De Koninklijke Loop"
          companyUrl="https://www.dekoninklijkeloop.nl/"
          projectContext="Over het evenement"
        />
      </div>
    </div>
  </section>
  -->

  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4 text-center">
      <p class="text-white/50 text-sm font-ui mb-4">Vergelijkbaar project nodig?</p>
      <a href="/contact?type=evenement" class="btn-primary">
        Bespreek uw evenement
        <Icon name="arrow-right" size={16} />
      </a>
    </div>
  </section>
</Layout>
