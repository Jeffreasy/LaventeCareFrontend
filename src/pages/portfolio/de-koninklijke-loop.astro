---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import TechStackBadge from '../../components/ui/TechStackBadge.astro';
import Icon from '../../components/ui/Icon.astro';

const results = [
  { value: '100+', label: 'Real-time registraties verwerkt' },
  { value: '0', label: 'Handmatig werk voor organisatie' },
  { value: '93 avg', label: 'Lighthouse Score' },
  { value: '0', label: 'Downtime tijdens event' },
];

const challenges = [
  {
    title: 'Complexe registratiestromen',
    desc: 'Meerdere deelnemerstypes (individueel, groepen, begeleiders) met elk eigen formulieren, prijsberekeningen en validatieregels.',
  },
  {
    title: 'Real-time data tijdens evenement',
    desc: 'Organisatoren hadden live inzicht nodig in deelnemersaantallen, financiën en check-in status, zonder pagina refresh.',
  },
  {
    title: 'Veilige financiële transacties',
    desc: 'Donaties en deelnamegelden moesten betrouwbaar en traceerbaar verwerkt worden, met automatische bevestigingsmails.',
  },
  {
    title: 'Schaalbaarheid onder piekbelasting',
    desc: 'Inschrijfpieken rond promotieacties vereisten een architectuur die niet bezwijkt onder 100+ gelijktijdige registraties.',
  },
];
---

<Layout
  title="Case Study: De Koninklijke Loop — LaventeCare"
  description="Hoe LaventeCare een compleet evenementenplatform bouwde voor De Koninklijke Loop. Real-time registratie, ticketing, donaties en live dashboards. Astro + Convex + Go."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <!-- Hero -->
      <div class="max-w-4xl mx-auto mb-16">
        <span
          class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-3 flex items-center gap-2"
          ><Icon name="clipboard-list" size={16} class="text-active" /> Case Study</span
        >
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 font-display tracking-tight"
        >
          De Koninklijke <span class="text-active">Loop</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 font-ui leading-relaxed mb-6">
          Een compleet evenementenplatform voor een liefdadigheidswandeltocht. Van registratie en
          ticketing tot donaties en real-time data — 100+ deelnemers verwerkt zonder één handmatige actie.
        </p>
        <div class="flex flex-wrap items-center gap-4 mb-8">
          <span
            class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20"
            >Evenementen</span
          >
          <a
            href="https://www.dekoninklijkeloop.nl/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-active text-sm font-semibold hover:underline flex items-center gap-1"
          >
            Bekijk live
            <Icon name="external-link" size={12} class="inline" />
          </a>
        </div>
        <div class="flex flex-wrap gap-2">
          {
            ['Astro', 'React 19', 'Convex', 'Go Auth', 'Vercel', 'HTML Email'].map((t) => (
              <TechStackBadge tech={t} />
            ))
          }
        </div>
      </div>

      <!-- Resultaten -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto mb-16">
        {
          results.map((r) => (
            <div
              data-animate="fade-up"
              class="clinical-glass p-5 rounded-(--radius-card) border border-active/20 text-center"
            >
              <div class="text-2xl md:text-3xl font-black text-active mb-1 font-display">
                {r.value}
              </div>
              <p class="text-white/50 text-xs font-ui">{r.label}</p>
            </div>
          ))
        }
      </div>

      <!-- Uitdaging -->
      <div class="max-w-4xl mx-auto mb-16">
        <SectionHeader
          label="De uitdaging"
          heading='Wat het project <span class="text-active">complex</span> maakte'
        />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {
            challenges.map((c) => (
              <div
                data-animate="fade-up"
                class="clinical-glass p-5 rounded-(--radius-card) border border-white/8"
              >
                <h3 class="text-sm font-bold text-white mb-2 font-display">{c.title}</h3>
                <p class="text-white/60 text-xs font-ui leading-relaxed">{c.desc}</p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Oplossing -->
      <div class="max-w-4xl mx-auto mb-16">
        <SectionHeader
          label="De oplossing"
          heading='Architectuur & <span class="text-active">aanpak</span>'
        />
        <div
          data-animate="fade-up"
          class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-white/8 space-y-6"
        >
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">Dual Backend Pattern</h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              De applicatie combineert twee backends: Convex voor de real-time reactieve database
              (registraties, live counters) en een Go-gebaseerde backend voor alle security-kritieke
              operaties (authenticatie, e-mailverificatie, CSRF-bescherming). Dit scheidt snelle
              UI-updates van zware transacties.
            </p>
          </div>
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">
              Islands Architecture (Astro)
            </h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Statische HTML voor 95% van de pagina. Alleen de registratieformulieren en het
              admin-dashboard worden als React Islands hydriert. Resultaat: consistent 90+
              Lighthouse scores over alle categorieën met minimale JavaScript payload.
            </p>
          </div>
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">
              Geautomatiseerde E-mailpipeline
            </h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Dual-dispatch e-mails bij elke registratie: de deelnemer ontvangt een bevestiging met
              alle details, het organisatieteam ontvangt een admin-notificatie met samenvattende
              data. Alles via server-side HTML Email Templates voor pixel-perfect rendering in alle
              e-mailclients.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Klantervaring (wacht op echte quotes van klant)
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <SectionHeader
          label="Klantervaring"
          heading='Wat de organisatie <span class="text-active">zegt</span>'
        />
        <ClientTestimonial
          quote="Op de dag zelf liep alles feilloos. Registraties, betalingen, real-time deelnemersaantallen — we hoefden ons nergens zorgen om te maken. Jeffrey denkt mee als partner, niet als leverancier."
          name="Organisatie"
          role="Evenementencommissie"
          company="De Koninklijke Loop"
          companyUrl="https://www.dekoninklijkeloop.nl/"
          projectContext="Over het evenement"
        />
      </div>
    </div>
  </section>
  -->

  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4 text-center">
      <p class="text-white/50 text-sm font-ui mb-4">Vergelijkbaar project nodig?</p>
      <a href="/contact?type=evenement" class="btn-primary">
        Bespreek uw evenement
        <Icon name="arrow-right" size={16} />
      </a>
    </div>
  </section>
</Layout>
