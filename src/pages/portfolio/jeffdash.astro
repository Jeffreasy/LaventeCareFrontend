---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import TechStackBadge from '../../components/ui/TechStackBadge.astro';
import Icon from '../../components/ui/Icon.astro';

const results = [
  { value: 'Dynamisch', label: 'Aanpasbare QR codes' },
  { value: 'Real-time', label: 'Scan analytics' },
  { value: 'HQ Export', label: 'SVG & PNG downloads' },
  { value: 'Branded', label: 'Custom styling' },
];

const challenges = [
  {
    title: 'Dynamische QR codes',
    desc: 'QR codes die na het printen nog gewijzigd kunnen worden. De bestemmings-URL moet aanpasbaar zijn zonder de fysieke code te vervangen.',
  },
  {
    title: 'Real-time scan tracking',
    desc: 'Elke scan moet geregistreerd worden met tijdstip, locatie en apparaattype. Gebruikers willen live inzicht in hun QR-campagnes.',
  },
  {
    title: 'Professionele export-kwaliteit',
    desc: 'QR codes moeten in hoge resolutie geëxporteerd worden voor drukwerk — pixel-perfect in SVG en PNG formaat.',
  },
  {
    title: 'Brand-consistentie',
    desc: 'Bedrijven willen QR codes die aansluiten bij hun huisstijl — custom kleuren, logo-integratie en vormgeving.',
  },
];
---

<Layout
  title="Case Study: JeffDash — Dynamische QR Codes — LaventeCare"
  description="Professionele dynamische QR codes die je op elk moment kunt aanpassen. Scan-tracking in realtime, analytics en hoge kwaliteit downloads. Gebouwd door LaventeCare."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto mb-16">
        <span
          class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-3 flex items-center gap-2"
          ><Icon name="clipboard-list" size={16} class="text-active" /> Case Study</span
        >
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 font-display tracking-tight"
        >
          Jeff<span class="text-active">Dash</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 font-ui leading-relaxed mb-6">
          Professionele dynamische QR codes die mee veranderen met jouw merk. Maak QR codes die je
          op elk moment kunt aanpassen, volg scans in realtime, analyseer je publiek en download in
          hoge kwaliteit.
        </p>
        <div class="flex flex-wrap items-center gap-4 mb-8">
          <span
            class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20"
            >QR Platform</span
          >
          <span
            class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-white/5 text-white/50 border border-white/10"
            >Eigen Product</span
          >
          <a
            href="https://www.jeffdash.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-active text-sm font-semibold hover:underline flex items-center gap-1"
          >
            Bekijk live
            <Icon name="external-link" size={12} class="inline" />
          </a>
        </div>
        <div class="flex flex-wrap gap-2">
          {['Next.js', 'Convex', 'React 19', 'Go Auth'].map((t) => <TechStackBadge tech={t} />)}
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto mb-16">
        {
          results.map((r) => (
            <div
              data-animate="fade-up"
              class="clinical-glass p-5 rounded-(--radius-card) border border-active/20 text-center"
            >
              <div class="text-2xl md:text-3xl font-black text-active mb-1 font-display">
                {r.value}
              </div>
              <p class="text-white/50 text-xs font-ui">{r.label}</p>
            </div>
          ))
        }
      </div>

      <div class="max-w-4xl mx-auto mb-16">
        <SectionHeader
          label="De uitdaging"
          heading='Meer dan een <span class="text-active">statische code</span>'
        />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {
            challenges.map((c) => (
              <div
                data-animate="fade-up"
                class="clinical-glass p-5 rounded-(--radius-card) border border-white/8"
              >
                <h3 class="text-sm font-bold text-white mb-2 font-display">{c.title}</h3>
                <p class="text-white/60 text-xs font-ui leading-relaxed">{c.desc}</p>
              </div>
            ))
          }
        </div>
      </div>

      <div class="max-w-4xl mx-auto mb-16">
        <SectionHeader
          label="De oplossing"
          heading='Dynamisch QR <span class="text-active">ecosysteem</span>'
        />
        <div
          data-animate="fade-up"
          class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-white/8 space-y-6"
        >
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">Dynamische QR Engine</h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              QR codes worden gegenereerd met aanpasbare bestemmings-URL's. Na het printen kan de
              eigenaar de bestemming wijzigen zonder de fysieke code te vervangen. Ideaal voor
              marketingcampagnes, visitekaartjes en productverpakkingen.
            </p>
          </div>
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">
              Real-time Scan Analytics
            </h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Elke scan wordt geregistreerd via Convex met tijdstip, apparaattype en herkomst.
              Gebruikers zien live dashboards met scan-trends, geografische spreiding en
              campagne-performance.
            </p>
          </div>
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">Branded QR Design</h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Custom kleurselectie, logo-integratie en vormgeving zodat elke QR code past bij de
              huisstijl van het merk. Export in SVG en hoge-resolutie PNG voor pixel-perfect
              drukwerk.
            </p>
          </div>
        </div>
      </div>

      <!-- Lighthouse Scores -->
      <div class="max-w-4xl mx-auto mb-16">
        <LighthouseScoreBlock
          projectName="JeffDash"
          scores={lighthouseScores}
          context="Met een geoptimaliseerde Next.js build en minimale client-side JavaScript behaal ik een 99 op Performance. De combinatie van server-side rendering en edge-caching resulteert in razendsnelle laadtijden."
          liveUrl="https://www.jeffdash.com/"
        />
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container mx-auto px-4 text-center">
      <p class="text-white/50 text-sm font-ui mb-4">Eigen QR-platform of SaaS-product bouwen?</p>
      <a href="/contact?type=platform" class="btn-primary">
        Bespreek uw idee
        <Icon name="arrow-right" size={16} />
      </a>
    </div>
  </section>
</Layout>
