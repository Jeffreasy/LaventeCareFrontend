---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import TechStackBadge from '../../components/ui/TechStackBadge.astro';
import Icon from '../../components/ui/Icon.astro';

const results = [
  { value: 'Multi-tenant', label: 'Architectuur' },
  { value: 'Real-time', label: 'Convex synchronisatie' },
  { value: 'IoT', label: 'Smart Home integratie' },
  { value: 'OAuth2', label: 'Google Calendar sync' },
];

const challenges = [
  {
    title: 'Multi-tenant data isolatie',
    desc: 'Een persoonlijk dashboard dat als SaaS-platform kan schalen naar meerdere gebruikers, met strikte data-scheiding per tenant.',
  },
  {
    title: 'Real-time data uit meerdere bronnen',
    desc: 'Google Calendar, Gmail, financiële data en IoT-sensoren moeten allemaal real-time gesynchroniseerd worden in één dashboard.',
  },
  {
    title: 'Complexe state management',
    desc: 'Duizenden datapunten uit verschillende bronnen vereisen geavanceerd state management zonder performance-verlies.',
  },
  {
    title: 'Security voor persoonlijke data',
    desc: 'Financiële gegevens, e-mails en agenda\'s bevatten zeer gevoelige informatie. Zero-Trust security is geen optie maar een vereiste.',
  },
];
---

<Layout
  title="Case Study: JeffDash — LaventeCare"
  description="Hoe LaventeCare een persoonlijk SaaS-dashboard ecosysteem bouwde met multi-tenant architectuur, real-time synchronisatie en IoT-integraties."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto mb-16">
        <span class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-3 flex items-center gap-2"><Icon name="clipboard-list" size={16} class="text-active" /> Case Study</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 font-display tracking-tight">
          Jeff<span class="text-active">Dash</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 font-ui leading-relaxed mb-6">
          Een persoonlijk SaaS-dashboard ecosysteem met multi-tenant architectuur, real-time data synchronisatie, IoT-integraties en geavanceerd state management. Het eigen product dat de volledige LaventeCare stack demonstreert.
        </p>
        <div class="flex flex-wrap items-center gap-4 mb-8">
          <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20">SaaS Platform</span>
          <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-white/5 text-white/50 border border-white/10">Eigen Product</span>
          <a href="https://www.jeffdash.com/" target="_blank" rel="noopener noreferrer" class="text-active text-sm font-semibold hover:underline flex items-center gap-1">
            Bekijk live
            <Icon name="external-link" size={12} class="inline" />
          </a>
        </div>
        <div class="flex flex-wrap gap-2">
          {['Next.js', 'Convex', 'React 19', 'Go Auth', 'Google OAuth2'].map((t) => (
            <TechStackBadge tech={t} />
          ))}
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto mb-16">
        {results.map((r) => (
          <div class="clinical-glass p-5 rounded-(--radius-card) border border-active/20 text-center">
            <div class="text-2xl md:text-3xl font-black text-active mb-1 font-display">{r.value}</div>
            <p class="text-white/50 text-xs font-ui">{r.label}</p>
          </div>
        ))}
      </div>

      <div class="max-w-4xl mx-auto mb-16">
        <SectionHeader label="De uitdaging" heading='Alles in <span class="text-active">één scherm</span>' />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {challenges.map((c) => (
            <div class="clinical-glass p-5 rounded-(--radius-card) border border-white/8">
              <h3 class="text-sm font-bold text-white mb-2 font-display">{c.title}</h3>
              <p class="text-white/60 text-xs font-ui leading-relaxed">{c.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="max-w-4xl mx-auto mb-16">
        <SectionHeader label="De oplossing" heading='Full-stack <span class="text-active">SaaS</span> architectuur' />
        <div class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-white/8 space-y-6">
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">Convex Real-time Engine</h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Alle dashboard-data wordt gesynchroniseerd via Convex reactieve queries. Wijzigingen in één tab verschijnen direct in alle andere sessies. Server-side functies garanderen data-integriteit.
            </p>
          </div>
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">Google API Integratie</h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              OAuth2-gekoppelde synchronisatie met Google Calendar en Gmail. Automatische cron-jobs halen agenda-events en e-mails op, verwerken ze en presenteren ze in het dashboard met privacy-first masking.
            </p>
          </div>
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">LaventeCare Auth (Go)</h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Dual-Token authenticatie met JWKS-validatie. Multi-tenant isolatie via Row Level Security. Elke API-call wordt geautoriseerd en geaudit. CSRF-bescherming op alle mutaties.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container mx-auto px-4 text-center">
      <p class="text-white/50 text-sm font-ui mb-4">Eigen SaaS-platform bouwen?</p>
      <a href="/contact?type=platform" class="btn-primary">
        Bespreek uw idee
        <Icon name="arrow-right" size={16} />
      </a>
    </div>
  </section>
</Layout>
