---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import TechStackBadge from '../../components/ui/TechStackBadge.astro';
import Icon from '../../components/ui/Icon.astro';

const results = [
  { value: "2 regio's", label: 'Actief in Nederland' },
  { value: 'Direct', label: 'Aanvragen bij hoveniers' },
  { value: 'Lokale SEO', label: 'Per regio & dienst' },
  { value: 'In stappen', label: 'Offerte aanvragen' },
];

const challenges = [
  {
    title: 'Twee doelgroepen, één platform',
    desc: 'Tuineigenaren zoeken hoveniers, hoveniers zoeken klanten. Het platform moet beide kanten van de markt bedienen met verschillende UX-flows.',
  },
  {
    title: 'Lokale SEO per regio',
    desc: 'Hoveniers opereren lokaal. Het platform moet ranken op locatie-specifieke zoektermen om relevante matches te maken.',
  },
  {
    title: 'Kwaliteitsfiltering',
    desc: 'Niet elke aanvraag is waardevol. Aanvragen worden eerst gefilterd op budget, projectomvang en locatie voordat ze bij hoveniers terechtkomen.',
  },
  {
    title: 'Meer bezoekers die aanvragen',
    desc: 'Bezoekers die halverwege een formulier afhaken zijn het grootste knelpunt. Elke stap moet de drempel verlagen en vertrouwen opbouwen.',
  },
];
---

<Layout
  title="Case Study: TuinHub — LaventeCare"
  description="Hoe LaventeCare een platform bouwde dat tuineigenaren en hoveniers koppelt. Offertes in stappen, lokale SEO en aanvragen die direct binnenkomen."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto mb-16">
        <span
          class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-3 flex items-center gap-2"
          ><Icon name="clipboard-list" size={16} class="text-active" /> Case Study</span
        >
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 font-display tracking-tight"
        >
          Tuin<span class="text-active">Hub</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 font-ui leading-relaxed mb-6">
          Een platform voor de groensector dat tuineigenaren en hoveniers koppelt. Offertes in
          stappen, aanvragen die direct binnenkomen en branche-specifieke SEO.
        </p>
        <div class="flex flex-wrap items-center gap-4 mb-8">
          <span
            class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20"
            >Matchmaking</span
          >
          <a
            href="https://tuinhub.nl/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-active text-sm font-semibold hover:underline flex items-center gap-1"
          >
            Bekijk live
            <Icon name="external-link" size={12} class="inline" />
          </a>
        </div>
        <div class="flex flex-wrap gap-2">
          {
            ['Astro', 'Convex', 'Go Auth', 'Vercel', 'SEO'].map((t) => (
              <TechStackBadge tech={t} />
            ))
          }
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto mb-16">
        {
          results.map((r) => (
            <div
              data-animate="fade-up"
              class="clinical-glass p-5 rounded-(--radius-card) border border-active/20 text-center"
            >
              <div class="text-2xl md:text-3xl font-black text-active mb-1 font-display">
                {r.value}
              </div>
              <p class="text-white/50 text-xs font-ui">{r.label}</p>
            </div>
          ))
        }
      </div>

      <div class="max-w-4xl mx-auto mb-16">
        <SectionHeader
          label="De uitdaging"
          heading='Twee markten, <span class="text-active">één platform</span>'
        />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {
            challenges.map((c) => (
              <div
                data-animate="fade-up"
                class="clinical-glass p-5 rounded-(--radius-card) border border-white/8"
              >
                <h3 class="text-sm font-bold text-white mb-2 font-display">{c.title}</h3>
                <p class="text-white/60 text-xs font-ui leading-relaxed">{c.desc}</p>
              </div>
            ))
          }
        </div>
      </div>

      <div class="max-w-4xl mx-auto mb-16">
        <SectionHeader
          label="De oplossing"
          heading='De juiste klant bij de <span class="text-active">juiste hovenier</span>'
        />
        <div
          data-animate="fade-up"
          class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-white/8 space-y-6"
        >
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">
              Offerte aanvragen in stappen
            </h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Overzichtelijke formulieren die de tuineigenaar stap voor stap begeleiden, van type
              tuin tot budget. Elke stap is zo opgezet dat zo weinig mogelijk mensen afhaken en de
              aanvragen zo bruikbaar mogelijk zijn.
            </p>
          </div>
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">Lokale SEO Engine</h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Dynamische landingspagina's per regio en dienst. "Hovenier in [stad]" pagina's met
              gestructureerde data, lokale signalen en geoptimaliseerde meta-tags voor maximale
              organische vindbaarheid.
            </p>
          </div>
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">
              Aanvragen direct in beeld
            </h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Hoveniers ontvangen aanvragen direct via e-mail én een beveiligd dashboard. Inclusief
              een score per aanvraag, de opvolgstatus en cijfers waarmee ze zien wat het hun
              oplevert.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Klantervaring (wacht op echte quotes van klant)
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <SectionHeader
          label="Klantervaring"
          heading='Wat de klant <span class="text-active">zegt</span>'
        />
        <ClientTestimonial
          quote="Sinds de lancering krijgen we structureel betere leads binnen. Het platform matcht klanten met de juiste hovenier op basis van regio en specialisatie. Precies wat we nodig hadden."
          name="TuinHub"
          role="Platform eigenaar"
          company="TuinHub"
          companyUrl="https://tuinhub.nl/"
          projectContext="Over het platform"
        />
      </div>
    </div>
  </section>
  -->

  <section class="section-padding">
    <div class="container mx-auto px-4 text-center">
      <p class="text-white/50 text-sm font-ui mb-4">Matchmaking-platform nodig?</p>
      <a href="/contact?type=leadgen" class="btn-primary">
        Bespreek uw platform
        <Icon name="arrow-right" size={16} />
      </a>
    </div>
  </section>
</Layout>
