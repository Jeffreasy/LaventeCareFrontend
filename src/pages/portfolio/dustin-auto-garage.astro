---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import TechStackBadge from '../../components/ui/TechStackBadge.astro';
import Icon from '../../components/ui/Icon.astro';

const results = [
  { value: 'Gescheiden', label: 'Gegevens per garage' },
  { value: 'Real-time', label: 'Alles direct bijgewerkt' },
  { value: 'RDW', label: 'Kenteken automatisch opgehaald' },
  { value: 'Per rol', label: 'Iedereen ziet alleen wat hij mag' },
];

const phases = [
  {
    num: '01',
    title: 'Onderzoek & ontwerp (Discovery)',
    status: 'done' as const,
    desc: 'Gescheiden gegevens per garage, rechten per rol en RDW-koppeling ontworpen.',
  },
  {
    num: '02',
    title: 'Bouwen',
    status: 'done' as const,
    desc: 'Werkplaatsbord, klantbeheer, voertuigbeheer en facturatie gebouwd.',
  },
  {
    num: '03',
    title: 'Livegang & inwerken',
    status: 'done' as const,
    desc: 'Systeem live gezet, gebruikers ingewerkt en oude gegevens overgezet.',
  },
  {
    num: '04',
    title: 'Onderhoud & Doorontwikkeling',
    status: 'active' as const,
    desc: 'Dagelijks gebruik, feedback verwerken en stap voor stap verbeteren.',
  },
];

const challenges = [
  {
    title: 'Gegevens strikt gescheiden',
    desc: 'Meerdere garages op één platform, maar hun gegevens moeten strikt gescheiden blijven. Elke garage ziet uitsluitend zijn eigen klanten en voertuigen.',
  },
  {
    title: 'Real-time werkplaatsbeheer',
    desc: "Monteurs moeten live zien welke auto's in de werkplaats staan, welke onderhoudsbeurten lopen en wat de status is — zonder pagina te verversen.",
  },
  {
    title: 'RDW-integratie voor voertuigdata',
    desc: 'Bij het invoeren van een kenteken moet het systeem automatisch merk, model, bouwjaar en APK-status ophalen uit de RDW open data API.',
  },
  {
    title: 'Complexe rolhiërarchie',
    desc: 'Eigenaar, manager, monteur en receptionist hebben elk andere rechten. Het systeem moet op elk niveau voorkomen dat iemand gegevens ziet waar hij geen recht op heeft.',
  },
];
---

<Layout
  title="Case Study: Dustin Auto Garage — LaventeCare"
  description="Hoe LaventeCare een compleet werkplaatssysteem bouwde met werkplaatsbord, klantbeheer, RDW-koppeling en gegevens die per garage strikt gescheiden blijven."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto mb-16">
        <span
          class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-3 flex items-center gap-2"
          ><Icon name="clipboard-list" size={16} class="text-active" /> Case Study</span
        >
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 font-display tracking-tight"
        >
          Dustin Auto <span class="text-active">Garage</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 font-ui leading-relaxed mb-6">
          Een compleet werkplaatssysteem met werkplaatsbord, klantbeheer, voertuigbeheer,
          RDW-koppeling en facturatie. Gebouwd om mee te groeien, met de gegevens van elke garage
          strikt gescheiden.
        </p>
        <div class="flex flex-wrap items-center gap-4 mb-8">
          <span
            class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20"
            >Werkplaatsbeheer</span
          >
          <span
            class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 flex items-center gap-2"
          >
            <span class="relative flex h-2 w-2">
              <span
                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
              ></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            Live in gebruik
          </span>
        </div>
        <div class="flex flex-wrap gap-2">
          {
            ['Astro', 'React 18.3.1', 'Convex', 'Go Auth', 'RDW-proxy', 'Grok Vision OCR'].map(
              (t) => <TechStackBadge tech={t} />
            )
          }
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto mb-16">
        {
          results.map((r) => (
            <div
              data-animate="fade-up"
              class="clinical-glass p-5 rounded-(--radius-card) border border-active/20 text-center"
            >
              <div class="text-2xl md:text-3xl font-black text-active mb-1 font-display">
                {r.value}
              </div>
              <p class="text-white/50 text-xs font-ui">{r.label}</p>
            </div>
          ))
        }
      </div>

      <div class="max-w-4xl mx-auto mb-16">
        <SectionHeader
          label="De uitdaging"
          heading='Garage-chaos naar <span class="text-active">digitaal systeem</span>'
        />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {
            challenges.map((c) => (
              <div
                data-animate="fade-up"
                class="clinical-glass p-5 rounded-(--radius-card) border border-white/8"
              >
                <h3 class="text-sm font-bold text-white mb-2 font-display">{c.title}</h3>
                <p class="text-white/60 text-xs font-ui leading-relaxed">{c.desc}</p>
              </div>
            ))
          }
        </div>
      </div>

      <div class="max-w-4xl mx-auto mb-16">
        <SectionHeader
          label="De oplossing"
          heading='Alles-in-één <span class="text-active">garagebeheer</span>'
        />
        <div
          data-animate="fade-up"
          class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-white/8 space-y-6"
        >
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">
              Digitaal werkplaatsbord
            </h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Een live bord waar werkorders van "Ingepland" naar "In behandeling" naar "Gereed"
              schuiven. Monteurs slepen kaarten, managers zien de status meteen. Onder de motorkap:
              een Kanban-bord op Convex, dat direct bijwerkt.
            </p>
          </div>
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">
              Kenteken automatisch opgehaald
            </h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Vul een kenteken in en het systeem haalt de voertuiggegevens automatisch op bij de
              RDW: merk, model, bouwjaar, brandstof en APK-datum. U kunt het kenteken ook met de
              camera laten herkennen. Onder de motorkap: de open data van de RDW en xAI Grok Vision.
            </p>
          </div>
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">
              Iedereen ziet alleen wat hij mag zien
            </h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Elke medewerker (eigenaar, manager, monteur, receptionist) heeft eigen rechten. Het
              systeem controleert bij elke actie of iemand het wel mag doen. En garages kunnen nooit
              bij elkaars gegevens. Onder de motorkap: rolgebaseerde toegang (RBAC) met validatie op
              de server.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Development Phases -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <SectionHeader
          label="Ontwikkeltraject"
          heading='Van concept tot <span class="text-active">dagelijks gebruik</span>'
        />

        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-16">
          {
            phases.map((phase) => (
              <div
                class:list={[
                  'clinical-glass p-5 rounded-(--radius-card) border relative',
                  phase.status === 'active' ? 'border-active/40 bg-active/5' : 'border-white/8',
                ]}
              >
                {phase.status === 'active' && (
                  <div class="absolute -top-2 -right-2">
                    <span class="relative flex h-4 w-4">
                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-active opacity-50" />
                      <span class="relative inline-flex rounded-full h-4 w-4 bg-active" />
                    </span>
                  </div>
                )}
                <span
                  class:list={[
                    'text-2xl font-black font-display block mb-2',
                    phase.status === 'active' ? 'text-active' : 'text-white/20',
                  ]}
                >
                  {phase.num}
                </span>
                <h3 class="text-sm font-bold text-white mb-1 font-display">{phase.title}</h3>
                <p class="text-white/50 text-xs font-ui leading-relaxed">{phase.desc}</p>
                <div class="mt-3">
                  {phase.status === 'done' ? (
                    <span class="text-emerald-400 text-xs font-bold flex items-center gap-1">
                      <Icon name="check" size={12} /> Afgerond
                    </span>
                  ) : (
                    <span class="text-active text-xs font-bold flex items-center gap-1">
                      <span class="relative flex h-1.5 w-1.5 mr-0.5">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-active opacity-75" />
                        <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-active" />
                      </span>
                      Actieve fase
                    </span>
                  )}
                </div>
              </div>
            ))
          }
        </div>

        <!-- Ongoing Partnership -->
        <div
          data-animate="fade-up"
          class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-active/20 relative"
        >
          <div class="absolute top-4 left-6 text-4xl text-active/30 font-display">"</div>
          <blockquote
            class="text-base md:text-lg text-white/80 leading-relaxed font-ui pl-4 md:pl-8 border-l-2 border-active/40 mb-6"
          >
            Dit project laat het ideale LaventeCare-traject zien: van eerste ontwerp tot dagelijks
            gebruik in de werkplaats. De eigenaar gebruikt het systeem actief, ik onderhoud het
            platform en pas aan waar nodig. <span class="text-active font-semibold"
              >Geen eenmalige oplevering, maar een vaste, langdurige samenwerking.</span
            >
          </blockquote>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="text-center">
              <Icon name="shield-check" size={20} class="text-active mx-auto mb-2" />
              <p class="text-sm font-bold text-white font-display">Actief Onderhoud</p>
              <p class="text-white/50 text-xs font-ui">Beveiligingsupdates & verbeteringen</p>
            </div>
            <div class="text-center">
              <Icon name="trending-up" size={20} class="text-active mx-auto mb-2" />
              <p class="text-sm font-bold text-white font-display">Groei stap voor stap</p>
              <p class="text-white/50 text-xs font-ui">Nieuwe functies op basis van gebruik</p>
            </div>
            <div class="text-center">
              <Icon name="gauge" size={20} class="text-active mx-auto mb-2" />
              <p class="text-sm font-bold text-white font-display">Live bewaking</p>
              <p class="text-white/50 text-xs font-ui">Foutmeldingen & snelheid in de gaten</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container mx-auto px-4 text-center">
      <p class="text-white/50 text-sm font-ui mb-4">Maatwerk bedrijfssoftware nodig?</p>
      <a href="/contact?type=platform" class="btn-primary">
        Bespreek uw project
        <Icon name="arrow-right" size={16} />
      </a>
    </div>
  </section>
</Layout>
