---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import TechStackBadge from '../../components/ui/TechStackBadge.astro';
import Icon from '../../components/ui/Icon.astro';
import LighthouseScoreBlock from '../../components/blocks/LighthouseScoreBlock.astro';

const results = [
  { value: '24/7', label: 'Remote monitoring' },
  { value: '< 1W', label: 'Stroomverbruik (deep-sleep)' },
  { value: 'Real-time', label: 'Cloud dashboards' },
  { value: 'OTA', label: 'Firmware updates' },
];

const lighthouseScores = [
  { category: 'Performance', score: 99 },
  { category: 'Accessibility', score: 90 },
  { category: 'Best Practices', score: 96 },
  { category: 'SEO', score: 100 },
];

const challenges = [
  {
    title: 'Energiebeheer in het veld',
    desc: 'Sensoren moeten maanden opereren op batterij in omgevingen zonder continue stroomvoorziening. Elke milliampère telt.',
  },
  {
    title: 'Betrouwbare datacommunicatie',
    desc: 'Industriële omgevingen met metalen behuizingen en elektromagnetische interferentie vereisen robuuste draadloze protocollen.',
  },
  {
    title: 'Kritieke alarmering',
    desc: 'Temperatuuroverschrijdingen bij koelinstallaties moeten binnen seconden gedetecteerd en gemeld worden om schade te voorkomen.',
  },
  {
    title: 'Firmware-updates op afstand',
    desc: 'Fysieke toegang tot geïnstalleerde sensoren is kostbaar. Over-the-air updates zijn essentieel voor onderhoud en bugfixes.',
  },
];
---

<Layout
  title="Case Study: SmartCoolCare — LaventeCare"
  description="Hoe LaventeCare een industrieel IoT-monitoringsysteem bouwde met ESP32-sensors, deep-sleep firmware en live cloud dashboards. Van chip tot cloud."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <!-- Hero -->
      <div class="max-w-4xl mx-auto mb-16">
        <span
          class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-3 flex items-center gap-2"
          ><Icon name="clipboard-list" size={16} class="text-active" /> Case Study</span
        >
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 font-display tracking-tight"
        >
          Smart<span class="text-active">Cool</span>Care
        </h1>
        <p class="text-lg md:text-xl text-white/70 font-ui leading-relaxed mb-6">
          Industriële koelmonitoring met ESP32-sensors, deep-sleep firmware en live cloud
          dashboards. Het ultieme "van chip tot cloud" project dat de volledige breedte van
          LaventeCare's expertise demonstreert.
        </p>
        <div class="flex flex-wrap items-center gap-4 mb-8">
          <span
            class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20"
            >IoT & Hardware</span
          >
          <a
            href="https://www.smartcoolcare.nl/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-active text-sm font-semibold hover:underline flex items-center gap-1"
          >
            Bekijk live
            <Icon name="external-link" size={12} class="inline" />
          </a>
        </div>
        <div class="flex flex-wrap gap-2">
          {
            ['C++/ESP32', 'BLE', 'Deep-sleep', 'Convex', 'React Dashboard', 'OTA Updates'].map(
              (t) => <TechStackBadge tech={t} />
            )
          }
        </div>
      </div>

      <!-- Resultaten -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto mb-16">
        {
          results.map((r) => (
            <div
              data-animate="fade-up"
              class="clinical-glass p-5 rounded-(--radius-card) border border-active/20 text-center"
            >
              <div class="text-2xl md:text-3xl font-black text-active mb-1 font-display">
                {r.value}
              </div>
              <p class="text-white/50 text-xs font-ui">{r.label}</p>
            </div>
          ))
        }
      </div>

      <!-- Uitdaging -->
      <div class="max-w-4xl mx-auto mb-16">
        <SectionHeader
          label="De uitdaging"
          heading='Hardware meets <span class="text-active">cloud</span>'
        />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {
            challenges.map((c) => (
              <div
                data-animate="fade-up"
                class="clinical-glass p-5 rounded-(--radius-card) border border-white/8"
              >
                <h3 class="text-sm font-bold text-white mb-2 font-display">{c.title}</h3>
                <p class="text-white/60 text-xs font-ui leading-relaxed">{c.desc}</p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Oplossing -->
      <div class="max-w-4xl mx-auto mb-16">
        <SectionHeader
          label="De oplossing"
          heading='Van sensor tot <span class="text-active">dashboard</span>'
        />
        <div
          data-animate="fade-up"
          class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-white/8 space-y-6"
        >
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">
              ESP32 Deep-Sleep Firmware (C++)
            </h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Custom C++ firmware met intelligent energiebeheer. De sensor waakt op, leest
              temperatuur- en vochtigheidsdata, verzendt via BLE of WiFi, en gaat terug in
              deep-sleep. Resultaat: maanden batterijduur in het veld zonder onderhoud.
            </p>
          </div>
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">
              BLE Gateway & Cloud Sync
            </h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Bluetooth Low Energy voor energiezuinige korte-afstandscommunicatie naar een lokale
              gateway. De gateway aggregeert sensordata en synchroniseert naar Convex voor
              persistente opslag en real-time queries.
            </p>
          </div>
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">
              React Dashboard met Convex
            </h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Live temperatuur- en alarmvisualisatie via een React dashboard met Convex reactieve
              queries. Drempelwaardeconfiguratie, historische grafieken en automatische notificaties
              bij kritieke overschrijdingen.
            </p>
          </div>
        </div>
      </div>

      <!-- Lighthouse Audit -->
      <div class="max-w-4xl mx-auto mb-16">
        <SectionHeader
          label="Bewezen prestaties"
          heading='Verifieerbare <span class="text-active">Lighthouse</span> data'
        />
        <LighthouseScoreBlock
          projectName="SmartCoolCare"
          scores={lighthouseScores}
          context="Ondanks de continue datastroom van ESP32 sensoren en complexe datavisualisatie behoud ik een 99% performance score dankzij een geoptimaliseerde eiland-architectuur. Een uitzonderlijke prestatie voor een IoT-platform."
          liveUrl="https://www.smartcoolcare.nl/"
        />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4 text-center">
      <p class="text-white/50 text-sm font-ui mb-4">Uw apparatuur 'Smart' maken?</p>
      <a href="/contact?type=iot" class="btn-primary">
        Bespreek uw IoT-project
        <Icon name="arrow-right" size={16} />
      </a>
    </div>
  </section>
</Layout>
