---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import TechStackBadge from '../../components/ui/TechStackBadge.astro';
import Icon from '../../components/ui/Icon.astro';

if (Astro.locals.locale === 'en') {
  return Astro.rewrite('/en-case-study?slug=smartcoolcare');
}

const results = [
  { value: '24/7', label: 'Bewaking op afstand' },
  { value: '< 1W', label: 'Zuinig, werkt maandenlang' },
  { value: 'Real-time', label: 'Live overzicht in de cloud' },
  { value: 'Op afstand', label: 'Updates zonder ter plaatse te gaan' },
];

const challenges = [
  {
    title: 'Energiebeheer in het veld',
    desc: 'Sensoren moeten maanden opereren op batterij in omgevingen zonder continue stroomvoorziening. Elke milliampère telt.',
  },
  {
    title: 'Betrouwbare datacommunicatie',
    desc: 'Industriële omgevingen met metalen behuizingen en storing op de lijn vragen om een stabiele draadloze verbinding.',
  },
  {
    title: 'Kritieke alarmering',
    desc: 'Temperatuuroverschrijdingen bij koelinstallaties moeten binnen seconden gedetecteerd en gemeld worden om schade te voorkomen.',
  },
  {
    title: 'Updates op afstand',
    desc: 'Ter plaatse bij elke sensor langsgaan is duur. Updates op afstand zijn essentieel voor onderhoud en het oplossen van fouten.',
  },
];
---

<Layout
  title="Case Study: SmartCoolCare — LaventeCare"
  description="Hoe LaventeCare een industrieel IoT-bewakingssysteem bouwde met zuinige sensoren die maandenlang werken en hun metingen live naar de cloud sturen. Van chip tot cloud."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <!-- Hero -->
      <div class="max-w-4xl mx-auto mb-16">
        <span
          class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-3 flex items-center gap-2"
          ><Icon name="clipboard-list" size={16} class="text-active" /> Case Study</span
        >
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 font-display tracking-tight"
        >
          Smart<span class="text-active">Cool</span>Care
        </h1>
        <p class="text-lg md:text-xl text-white/70 font-ui leading-relaxed mb-6">
          Live koelbewaking met zuinige sensoren die maandenlang op een batterij werken en hun
          metingen naar een live dashboard sturen. Hét "van chip tot cloud"-project dat laat zien
          hoe breed LaventeCare gaat: van de hardware tot het scherm.
        </p>
        <div class="flex flex-wrap items-center gap-4 mb-8">
          <span
            class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20"
            >IoT & Hardware</span
          >
          <a
            href="https://www.smartcoolcare.nl/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-active text-sm font-semibold hover:underline flex items-center gap-1"
          >
            Bekijk live
            <Icon name="external-link" size={12} class="inline" />
          </a>
        </div>
        <div class="flex flex-wrap gap-2">
          {
            ['C++/ESP32', 'BLE', 'Deep-sleep', 'Convex', 'React Dashboard', 'OTA Updates'].map(
              (t) => <TechStackBadge tech={t} />
            )
          }
        </div>
      </div>

      <!-- Resultaten -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto mb-16">
        {
          results.map((r) => (
            <div
              data-animate="fade-up"
              class="clinical-glass p-5 rounded-(--radius-card) border border-active/20 text-center"
            >
              <div class="text-2xl md:text-3xl font-black text-active mb-1 font-display">
                {r.value}
              </div>
              <p class="text-white/50 text-xs font-ui">{r.label}</p>
            </div>
          ))
        }
      </div>

      <!-- Uitdaging -->
      <div class="max-w-4xl mx-auto mb-16">
        <SectionHeader
          label="De uitdaging"
          heading='Hardware meets <span class="text-active">cloud</span>'
        />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {
            challenges.map((c) => (
              <div
                data-animate="fade-up"
                class="clinical-glass p-5 rounded-(--radius-card) border border-white/8"
              >
                <h3 class="text-sm font-bold text-white mb-2 font-display">{c.title}</h3>
                <p class="text-white/60 text-xs font-ui leading-relaxed">{c.desc}</p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Oplossing -->
      <div class="max-w-4xl mx-auto mb-16">
        <SectionHeader
          label="De oplossing"
          heading='Van sensor tot <span class="text-active">dashboard</span>'
        />
        <div
          data-animate="fade-up"
          class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-white/8 space-y-6"
        >
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">
              Zuinig: werkt maandenlang op een batterij
            </h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              De sensor wordt kort wakker, meet de temperatuur en luchtvochtigheid, stuurt de meting
              draadloos door en gaat daarna weer in slaapstand om stroom te sparen. Zo werkt hij
              maandenlang zonder onderhoud. Onder de motorkap: eigen C++-software op een ESP32 met
              slimme slaapstand (deep-sleep).
            </p>
          </div>
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">
              Van sensor naar de cloud
            </h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              De sensor stuurt zijn metingen draadloos en zuinig naar een klein kastje in de buurt
              (de gateway). Dat kastje verzamelt alle metingen en stuurt ze door naar de cloud, waar
              ze veilig worden bewaard en direct opvraagbaar zijn. Onder de motorkap: Bluetooth Low
              Energy (BLE) en Convex.
            </p>
          </div>
          <div>
            <h3 class="text-base font-bold text-white mb-2 font-display">
              Alles in één overzichtelijk dashboard
            </h3>
            <p class="text-white/60 text-sm font-ui leading-relaxed">
              Live temperaturen en waarschuwingen in één helder scherm. U stelt zelf de grenswaarden
              in, ziet grafieken uit het verleden en krijgt automatisch een melding zodra iets
              buiten de veilige zone valt. Onder de motorkap: een React-dashboard met Convex.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4 text-center">
      <p class="text-white/50 text-sm font-ui mb-4">Uw apparatuur 'Smart' maken?</p>
      <a href="/contact?type=iot" class="btn-primary">
        Bespreek uw IoT-project
        <Icon name="arrow-right" size={16} />
      </a>
    </div>
  </section>
</Layout>
