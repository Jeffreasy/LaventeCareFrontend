---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Het Ecosysteem - LaventeCare">
  <div class="container mx-auto px-4 py-24">
    <div class="max-w-4xl mx-auto text-center mb-16">
      <span class="text-[oklch(0.70_0.18_158)] font-semibold tracking-wider uppercase mb-4 block">The Platform</span>
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-8">De Centrale Hub voor Groei</h1>
      <p class="text-xl text-white/70 max-w-2xl mx-auto">
        Ervaar de kracht van een geïntegreerd ecosysteem waar multi-tenancy en de snelheid van Astro samenkomen.
      </p>
    </div>

    <!-- Visual Placeholder for Architecture Diagram -->
    <div class="w-full max-w-5xl mx-auto mb-24 aspect-video rounded-3xl border border-white/10 bg-gradient-to-br from-black to-white/5 flex items-center justify-center relative overflow-hidden group">
      <div class="absolute inset-0 bg-[url('/grid-pattern.svg')] opacity-20"></div>
      <div class="text-center z-10">
        <p class="text-white/40 text-sm uppercase tracking-widest mb-2">[Architecture Diagram Placeholder]</p>
        <h3 class="text-2xl font-bold text-white">Zero-Gravity Infrastructure</h3>
        <p class="text-white/60 mt-2">Go Backend • Convex Engine • Astro Frontend</p>
      </div>
       <!-- Simplified visual elements -->
       <div class="absolute top-1/2 left-1/4 w-32 h-32 bg-[oklch(0.70_0.18_158)]/20 rounded-full blur-3xl group-hover:bg-[oklch(0.70_0.18_158)]/30 transition-colors"></div>
       <div class="absolute bottom-1/4 right-1/4 w-40 h-40 bg-orange-500/20 rounded-full blur-3xl group-hover:bg-orange-500/30 transition-colors"></div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-12 gap-12 items-center max-w-7xl mx-auto mb-24">
        <!-- Why Astro Text (Takes 7 columns) -->
        <div class="lg:col-span-7">
             <span class="text-[oklch(0.70_0.18_158)] font-semibold mb-2 block">Why Astro?</span>
             <h2 class="text-4xl font-bold text-white mb-6">Snelheid is geen feature.<br/>Het is uw omzet.</h2>
             <p class="text-white/70 mb-6 text-lg">
                Elke 100ms vertraging kost u 1% conversie. Traditionele frameworks sturen megabytes aan JavaScript naar uw klant. Wij niet.
             </p>
             <ul class="space-y-4">
                <li class="flex items-center text-white/80">
                    <span class="w-8 h-8 rounded-full bg-green-500/20 text-green-400 flex items-center justify-center mr-4 text-xs font-bold">SEO</span>
                    <span>Google beloont Core Web Vitals met hogere rankings.</span>
                </li>
                <li class="flex items-center text-white/80">
                    <span class="w-8 h-8 rounded-full bg-blue-500/20 text-blue-400 flex items-center justify-center mr-4 text-xs font-bold">UX</span>
                    <span>Directe interactie. Geen laadschermen, geen wachten.</span>
                </li>
                 <li class="flex items-center text-white/80">
                    <span class="w-8 h-8 rounded-full bg-[oklch(0.70_0.18_158)]/20 text-[oklch(0.70_0.18_158)] flex items-center justify-center mr-4 text-xs font-bold">ROI</span>
                    <span>Lagere hostingkosten, hogere conversie.</span>
                </li>
             </ul>
        </div>

        <!-- Metric Cards (Takes 5 columns) -->
        <div class="grid gap-6 lg:col-span-5">
            <div class="clinical-glass p-6 rounded-2xl border border-white/10 flex items-center justify-between">
                <div>
                    <div class="text-3xl font-bold text-white mb-1">99+</div>
                    <div class="text-sm text-white/50">Google Performance Score</div>
                </div>
                <div class="h-12 w-12 rounded-full border-4 border-green-500 flex items-center justify-center text-green-500 font-bold">A+</div>
            </div>
             <div class="clinical-glass p-6 rounded-2xl border border-white/10 flex items-center justify-between">
                <div>
                    <div class="text-3xl font-bold text-white mb-1">0ms</div>
                    <div class="text-sm text-white/50">JavaScript Blocking Time</div>
                </div>
                 <div class="h-12 w-12 rounded-full border-4 border-green-500 flex items-center justify-center text-green-500 font-bold">⚡</div>
            </div>
        </div>
    </div>

    <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-white mb-8">Centraal Beheer</h2>
        <p class="text-white/70 max-w-2xl mx-auto mb-12">
            Beheer al uw tenants, gebruikers en analytische gegevens vanuit één krachtig dashboard.
        </p>

        <!-- Dashboard Mockup Placeholder -->
        <div class="relative max-w-5xl mx-auto rounded-xl overflow-hidden shadow-2xl border border-white/10 bg-[#0F1115] aspect-[16/9] group mb-24">
            <!-- Mockup Header -->
            <div class="h-12 bg-white/5 border-b border-white/5 flex items-center px-4 space-x-2">
                <div class="w-3 h-3 rounded-full bg-red-500/50"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500/50"></div>
                <div class="w-3 h-3 rounded-full bg-green-500/50"></div>
            </div>
            <!-- Mockup Content -->
            <div class="p-8 grid grid-cols-4 gap-6 h-full">
                <!-- Sidebar -->
                <div class="col-span-1 border-r border-white/5 pr-6 space-y-4">
                    <div class="h-8 w-3/4 bg-white/10 rounded"></div>
                    <div class="h-4 w-1/2 bg-white/5 rounded"></div>
                    <div class="h-4 w-1/2 bg-white/5 rounded"></div>
                    <div class="h-4 w-1/2 bg-white/5 rounded"></div>
                </div>
                <!-- Main Area -->
                <div class="col-span-3 space-y-6">
                     <div class="flex justify-between">
                        <div class="h-10 w-1/3 bg-white/10 rounded"></div>
                        <div class="h-10 w-1/4 bg-[oklch(0.70_0.18_158)]/20 rounded"></div>
                     </div>
                     <div class="grid grid-cols-3 gap-4">
                         <div class="h-32 bg-white/5 rounded-lg border border-white/5"></div>
                         <div class="h-32 bg-white/5 rounded-lg border border-white/5"></div>
                         <div class="h-32 bg-white/5 rounded-lg border border-white/5"></div>
                     </div>
                     <div class="h-64 bg-white/5 rounded-lg border border-white/5"></div>
                </div>
            </div>
            
            <div class="absolute inset-0 flex items-center justify-center bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity">
                <span class="text-white font-bold tracking-widest uppercase">Admin Interface Preview</span>
            </div>
        </div>

        <h2 class="text-3xl font-bold text-white mb-8">Features voor de toekomst</h2>
    </div>

    <div class="grid md:grid-cols-12 gap-8 text-left max-w-4xl mx-auto">
        <div class="md:col-span-7 clinical-glass p-8 rounded-2xl border border-white/10">
          <div class="w-12 h-12 rounded-lg bg-[oklch(0.70_0.18_158)]/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-[oklch(0.70_0.18_158)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-3">Multi-Tenancy Core</h3>
          <p class="text-white/70">
            Eén krachtige kern die al uw applicaties en diensten aandrijft. Beheer alles vanuit één centraal dashboard. Van gebruikersrechten tot facturatie.
          </p>
        </div>

        <div class="md:col-span-5 clinical-glass p-8 rounded-2xl border border-white/10 bg-white/5 translate-y-4">
          <div class="w-12 h-12 rounded-lg bg-[oklch(0.70_0.18_158)]/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-[oklch(0.70_0.18_158)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-3">Islands Architecture</h3>
          <p class="text-white/70">
            Wij laden interactieve componenten alleen waar nodig. Een chatvenster? Interactief. De footer? Statisch.
          </p>
        </div>
      </div>
  </div>
</Layout>
