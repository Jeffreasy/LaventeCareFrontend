---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/ui/Icon.astro';

const pageTitle = 'Algemene Voorwaarden 2026 — LaventeCare';
const pageDescription =
  'Lees de algemene voorwaarden van LaventeCare. Versie april 2026. Download de PDF of bekijk deze direct in uw browser.';

const pdfPath = '/LCVoorwaarden2026april.pdf';
const pdfLabel = 'LC Algemene Voorwaarden — April 2026';

const legalSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Algemene Voorwaarden LaventeCare',
  description: pageDescription,
  url: 'https://www.laventecare.nl/voorwaarden',
  inLanguage: 'nl',
  dateModified: '2026-04-01',
  publisher: {
    '@type': 'Organization',
    name: 'LaventeCare',
    url: 'https://www.laventecare.nl',
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(legalSchema)} />

<Layout title={pageTitle} description={pageDescription}>
  <!-- ── Hero ──────────────────────────────────────────── -->
  <section class="vc-hero section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <!-- Label -->
        <span class="vc-hero__label">Juridisch</span>

        <!-- Title -->
        <h1 class="vc-hero__title">
          Algemene <span class="text-active">Voorwaarden</span>
        </h1>

        <!-- Subtitle -->
        <p class="vc-hero__subtitle">
          Versie <strong class="text-white">april 2026</strong> — LaventeCare · KVK 88162710
        </p>

        <!-- Action buttons -->
        <div class="vc-hero__actions">
          <a
            id="download-voorwaarden-btn"
            href={pdfPath}
            download={pdfLabel}
            class="vc-btn vc-btn--primary"
            aria-label="Download de algemene voorwaarden als PDF"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            <span>PDF Downloaden</span>
          </a>

          <a
            id="open-voorwaarden-btn"
            href={pdfPath}
            target="_blank"
            rel="noopener noreferrer"
            class="vc-btn vc-btn--ghost"
            aria-label="Open de algemene voorwaarden in een nieuw tabblad"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            <span>In nieuw tabblad</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Info Strip ─────────────────────────────────────── -->
  <section class="vc-strip" aria-label="Document info">
    <div class="container mx-auto px-4">
      <div class="vc-strip__grid" data-animate="fade-up">
        <div class="vc-strip__item">
          <span class="vc-strip__label">Versie</span>
          <span class="vc-strip__value">April 2026</span>
        </div>
        <div class="vc-strip__divider" aria-hidden="true"></div>
        <div class="vc-strip__item">
          <span class="vc-strip__label">Bedrijf</span>
          <span class="vc-strip__value">LaventeCare</span>
        </div>
        <div class="vc-strip__divider" aria-hidden="true"></div>
        <div class="vc-strip__item">
          <span class="vc-strip__label">KVK</span>
          <span class="vc-strip__value">88162710</span>
        </div>
        <div class="vc-strip__divider" aria-hidden="true"></div>
        <div class="vc-strip__item">
          <span class="vc-strip__label">Formaat</span>
          <span class="vc-strip__value">PDF · ~44 KB</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PDF Viewer ─────────────────────────────────────── -->
  <section class="vc-viewer section-padding" aria-labelledby="pdf-viewer-heading">
    <div class="container mx-auto px-4">
      <h2 id="pdf-viewer-heading" class="sr-only">Voorwaarden document</h2>

      <div class="vc-viewer__shell" data-animate="fade-up">
        <!-- Toolbar -->
        <div class="vc-viewer__toolbar" role="toolbar" aria-label="PDF acties">
          <div class="vc-viewer__toolbar-left">
            <svg class="w-4 h-4 text-active flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <span class="vc-viewer__filename">{pdfLabel}</span>
          </div>

          <div class="vc-viewer__toolbar-right">
            <a
              href={pdfPath}
              download={pdfLabel}
              class="vc-viewer__action"
              title="Downloaden"
              aria-label="Download PDF"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
            </a>
            <a
              href={pdfPath}
              target="_blank"
              rel="noopener noreferrer"
              class="vc-viewer__action"
              title="In nieuw tabblad"
              aria-label="Open in nieuw tabblad"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Embed — iframe works best in Chromium/Firefox/Safari -->
        <div class="vc-viewer__embed-wrap">
          <iframe
            id="pdf-embed"
            src={pdfPath}
            class="vc-viewer__embed"
            title="LaventeCare Algemene Voorwaarden april 2026"
            loading="lazy"
          ></iframe>
          <!-- No-JS / unsupported browser fallback -->
          <noscript>
            <div class="vc-viewer__fallback">
              <p class="text-white/60 text-sm font-ui mb-4">
                Uw browser ondersteunt geen ingebedde PDF-weergave.
              </p>
              <a href={pdfPath} download={pdfLabel} class="vc-btn vc-btn--primary vc-btn--sm">
                PDF Downloaden
              </a>
            </div>
          </noscript>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Contact Strip ─────────────────────────────────── -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div
        data-animate="fade-up"
        class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-active/20 max-w-3xl mx-auto text-center"
      >
        <h3 class="text-lg font-bold text-white mb-2 font-display">Vragen over de voorwaarden?</h3>
        <p class="text-white/60 text-sm font-ui mb-6">
          Neem vrijblijvend contact op — ik beantwoord uw juridische vragen graag persoonlijk.
        </p>
        <a href="/contact" class="vc-btn vc-btn--primary">
          Contact opnemen
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ────────────────────────────────────────────── */

  .vc-hero__label {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-active);
    margin-bottom: 0.75rem;
  }

  .vc-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: white;
    margin-bottom: 1rem;
  }

  .vc-hero__subtitle {
    font-family: var(--font-ui);
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 2rem;
  }

  .vc-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  /* ── Buttons ──────────────────────────────────────────── */

  .vc-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    border-radius: 0.625rem;
    padding: 0.75rem 1.5rem;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    white-space: nowrap;
  }

  .vc-btn--sm {
    font-size: 0.875rem;
    padding: 0.5625rem 1.125rem;
  }

  .vc-btn--primary {
    background: var(--color-active);
    color: white;
    border: 1px solid var(--color-active);
    box-shadow: 0 0 0 0 color-mix(in oklch, var(--color-active) 35%, transparent);
  }

  .vc-btn--primary:hover {
    background: var(--color-primary-hover, color-mix(in oklch, var(--color-active) 80%, white));
    box-shadow: 0 0 24px -4px color-mix(in oklch, var(--color-active) 45%, transparent);
    transform: translateY(-1px);
  }

  .vc-btn--ghost {
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .vc-btn--ghost:hover {
    background: rgba(255, 255, 255, 0.08);
    color: white;
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-1px);
  }

  /* ── Info Strip ──────────────────────────────────────── */

  .vc-strip {
    padding-block: 1.5rem;
  }

  .vc-strip__grid {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0;
    max-width: 640px;
    margin-inline: auto;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.875rem;
    background: rgba(255, 255, 255, 0.02);
    overflow: hidden;
  }

  .vc-strip__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.125rem;
    padding: 1rem 1.5rem;
    flex: 1 1 auto;
  }

  .vc-strip__divider {
    width: 1px;
    height: 2rem;
    background: rgba(255, 255, 255, 0.08);
    flex-shrink: 0;
  }

  .vc-strip__label {
    font-family: var(--font-ui);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
  }

  .vc-strip__value {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
  }

  /* ── PDF Viewer Shell ────────────────────────────────── */

  .vc-viewer__shell {
    max-width: 900px;
    margin-inline: auto;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.02);
    overflow: hidden;
    box-shadow:
      0 20px 60px -20px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(255, 255, 255, 0.04);
  }

  /* ── Toolbar ─────────────────────────────────────────── */

  .vc-viewer__toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(255, 255, 255, 0.025);
  }

  .vc-viewer__toolbar-left {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    min-width: 0;
  }

  .vc-viewer__filename {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.6);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .vc-viewer__toolbar-right {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  .vc-viewer__action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.375rem;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition:
      color 0.15s ease,
      background 0.15s ease;
  }

  .vc-viewer__action:hover {
    color: var(--color-active);
    background: color-mix(in oklch, var(--color-active) 10%, transparent);
  }

  /* ── Embed ───────────────────────────────────────────── */

  .vc-viewer__embed-wrap {
    position: relative;
    width: 100%;
    /* 16:11 ratio — good for A4 PDF */
    padding-bottom: 68.75%;
  }

  .vc-viewer__embed {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
    display: block;
    background: #1a1a1a;
  }

  /* ── Fallback ────────────────────────────────────────── */

  .vc-viewer__fallback {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.02);
    padding: 2rem;
  }

  /* ── Scroll animations ───────────────────────────────── */

  [data-animate='fade-up'] {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-animate='fade-up'].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-animate='fade-up'] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* ── Responsive ──────────────────────────────────────── */

  @media (max-width: 480px) {
    .vc-strip__divider {
      display: none;
    }

    .vc-strip__item {
      padding: 0.875rem 1rem;
      flex: 1 1 45%;
    }

    .vc-viewer__filename {
      display: none;
    }
  }
</style>
