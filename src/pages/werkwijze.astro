---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import ProcessTimeline from '../components/blocks/ProcessTimeline.astro';
import Icon from '../components/ui/Icon.astro';

const processSteps = [
  {
    phase: '0',
    title: 'IT Advies (Optioneel)',
    description:
      'Heeft u nog geen concrete bouwvraag? Huur ons in als onafhankelijk sparringpartner of voor een second opinion, zonder bouwverplichting.',
    price: '€95/uur',
    icon: 'lightbulb',
  },
  {
    phase: '1',
    title: 'Kennismaking & Intake',
    description:
      'Vrijblijvend gesprek (30 min) om uw situatie, doelen en technische mogelijkheden helder te krijgen. Inclusief eerste inschatting van haalbaarheid en investering.',
    price: 'Gratis',
    icon: 'coffee',
  },
  {
    phase: '2',
    title: 'Onderzoek & Blueprint (technisch bouwplan)',
    description:
      'We onderzoeken precies wat u nodig heeft en hoe de gegevens moeten stromen. U krijgt één centraal document met alle afspraken en het ontwerp (Blueprint). Doorlooptijd: 1-2 weken. Het bouwplan is na betaling uw eigendom.',
    price: '€500 \u2013 €1.500',
    icon: 'search',
  },
  {
    phase: '3',
    title: 'Ontwikkeling & Oplevering',
    description:
      'Stap voor stap bouwen volgens het bouwplan (Blueprint). We blijven strak binnen de afspraak; extra werk gaat via een aparte wijziging (Change Request). Doorlooptijd: 2–6 weken. Facturatie in fases (40/40/20).',
    price: 'Vaste Mijlpalen',
    icon: 'zap',
  },
  {
    phase: '4',
    title: 'Onderhoud & doorontwikkeling (SLA)',
    description:
      'Uw systeem blijft veilig, up-to-date en beschikbaar dankzij live bewaking (Observatory AI). Verder verbeteren op basis van uw wensen, in vaste blokken per kwartaal. Dit regelt u met een onderhoudscontract met vaste afspraken (SLA).',
    price: 'vanaf €75/mnd',
    icon: 'refresh-cw',
  },
] as const;

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'Hoe werkt een project met LaventeCare?',
  description:
    'Van gratis intake tot onderhoud met vaste afspraken (SLA). Een gestructureerd model in vier fases voor B2B IT-projecten.',
  step: processSteps.map((s) => ({
    '@type': 'HowToStep',
    name: `Stap ${s.phase}: ${s.title}`,
    text: s.description,
  })),
  totalTime: 'P12W',
  estimatedCost: {
    '@type': 'MonetaryAmount',
    currency: 'EUR',
    value: '500',
    minValue: '500',
    maxValue: '1500',
  },
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

<Layout
  title="Werkwijze — Duidelijk proces met een vast bouwplan | LaventeCare"
  description="Hoe werkt een project met LaventeCare? Van onderzoek en bouwplan (Discovery Blueprint) tot onderhoud met vaste afspraken (SLA). Transparant, gestructureerd en zonder verrassingen buiten de afspraak."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <SectionHeader
        level={1}
        label="Werkwijze"
        heading='Van idee tot <span class="text-active">werkend systeem</span>'
        description="Een vast websitepakket gebruikt een korte route. Complexe systemen krijgen eerst onderzoek en een technisch bouwplan. Zo blijft de aanpak passend bij de vraag."
      />

      <!-- Twee routes -->
      <div class="max-w-5xl mx-auto mb-20">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <article
            data-animate="fade-up"
            class="clinical-glass rounded-(--radius-feature) border border-active/25 bg-active/5 p-6 md:p-8"
          >
            <span class="font-display text-xs font-bold uppercase tracking-[0.18em] text-active"
              >Website Fast Track</span
            >
            <h2 class="mt-3 mb-3 font-display text-xl font-black text-white">
              Vaste pakketten vanaf €750
            </h2>
            <p class="mb-5 font-ui text-sm leading-relaxed text-white/60">
              Voor een one-page of compacte bedrijfswebsite met complete inhoud en een vaste
              afspraak. Geen betaald bouwplan nodig.
            </p>
            <ol class="space-y-2 font-ui text-sm text-white/60">
              <li>1. Gratis afstemming en pakketkeuze</li>
              <li>2. Teksten, logo en afbeeldingen compleet</li>
              <li>3. Bouw, controle en gebundelde feedback</li>
              <li>4. Akkoord en gecontroleerde livegang</li>
            </ol>
            <a
              href="/diensten/websites"
              class="mt-6 inline-flex items-center gap-2 font-ui text-sm font-bold text-active"
            >
              Bekijk de websitepakketten <Icon name="arrow-right" size={15} />
            </a>
          </article>

          <article
            data-animate="fade-up"
            class="delay-100 clinical-glass rounded-(--radius-feature) border border-white/8 p-6 md:p-8"
          >
            <span class="font-display text-xs font-bold uppercase tracking-[0.18em] text-white/40"
              >Systeemtraject</span
            >
            <h2 class="mt-3 mb-3 font-display text-xl font-black text-white">
              Eerst begrijpen, dan bouwen
            </h2>
            <p class="mb-5 font-ui text-sm leading-relaxed text-white/60">
              Voor accounts, databases, koppelingen, dashboards en processen die werk overnemen.
              Hier voorkomt een bouwplan verkeerde aannames en kostbaar meerwerk.
            </p>
            <ol class="space-y-2 font-ui text-sm text-white/60">
              <li>1. Gratis intake en eerste haalbaarheid</li>
              <li>2. Betaald onderzoek en technisch bouwplan</li>
              <li>3. Realisatie met vaste mijlpalen</li>
              <li>4. Beheer en gerichte doorontwikkeling</li>
            </ol>
          </article>
        </div>
      </div>

      <!-- Process Timeline -->
      <div class="max-w-5xl mx-auto mb-16">
        <SectionHeader
          label="Het systeemtraject"
          heading='Controle bij iedere <span class="text-active">beslissing</span>'
          description="Onderstaande fases gelden voor maatwerksoftware en uitbreidingen buiten de vaste websitepakketten."
        />
        <ProcessTimeline steps={[...processSteps]} />
      </div>

      <!-- Facturatieflow -->
      <div class="max-w-3xl mx-auto mb-16">
        <SectionHeader
          label="Facturatie"
          heading='Gefaseerde <span class="text-active">facturatie</span> — volledige controle over uw investering'
          description="Facturatie op basis van mijlpalen en gerealiseerde voortgang. Bij tussentijdse beëindiging gelden de afspraken uit de offerte en algemene voorwaarden."
        />

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div
            class="clinical-glass p-5 rounded-(--radius-card) border border-active/20 text-center bg-active/5"
          >
            <div class="text-3xl font-black text-active font-display mb-1">40%</div>
            <p class="text-white/70 text-xs font-ui">Na goedkeuring Blueprint</p>
            <p class="text-white/40 text-[10px] font-ui mt-1">Dekking initiële kosten</p>
          </div>
          <div
            class="clinical-glass p-5 rounded-(--radius-card) border border-active/20 text-center bg-active/5"
          >
            <div class="text-3xl font-black text-active font-display mb-1">40%</div>
            <p class="text-white/70 text-xs font-ui">Bij bèta-oplevering</p>
            <p class="text-white/40 text-[10px] font-ui mt-1">Tussentijdse acceptatie</p>
          </div>
          <div
            class="clinical-glass p-5 rounded-(--radius-card) border border-active/20 text-center bg-active/5"
          >
            <div class="text-3xl font-black text-active font-display mb-1">20%</div>
            <p class="text-white/70 text-xs font-ui">Na livegang & acceptatie</p>
            <p class="text-white/40 text-[10px] font-ui mt-1">Waarborg voor klant</p>
          </div>
        </div>
      </div>

      <!-- Betalingsvoorwaarden -->
      <div class="max-w-3xl mx-auto mb-16">
        <div class="flex items-center gap-3 mb-6">
          <div
            class="w-8 h-8 rounded-lg bg-active/10 flex items-center justify-center flex-shrink-0"
          >
            <Icon name="clipboard-list" size={16} class="text-active" />
          </div>
          <h3 class="text-lg font-bold text-white font-display">Betalingsvoorwaarden</h3>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <!-- 30 dagen (algemene voorwaarden art. 9) -->
          <div
            class="clinical-glass p-5 rounded-(--radius-card) border border-white/8 flex gap-4 group hover:border-active/20 transition-colors"
          >
            <div
              class="w-9 h-9 rounded-lg bg-active/10 flex items-center justify-center flex-shrink-0 mt-0.5"
            >
              <Icon name="clock" size={16} class="text-active" />
            </div>
            <div>
              <div class="flex items-center gap-2 mb-1">
                <span class="text-white font-bold text-sm font-display">Betalingstermijn</span>
                <span
                  class="px-2 py-0.5 rounded-full bg-active/15 text-active text-[10px] font-bold uppercase tracking-wider font-display"
                  >30 dagen</span
                >
              </div>
              <p class="text-white/55 text-xs font-ui leading-relaxed">
                Na factuurdatum, volgens artikel 9 van de algemene voorwaarden. Betaalt u niet op
                tijd, dan sturen we eerst een schriftelijke herinnering (ingebrekestelling); blijft
                betaling uit, dan mogen we <span class="text-white/80"
                  >het werk tijdelijk stilleggen</span
                >.
              </p>
            </div>
          </div>

          <!-- Discovery vooraf -->
          <div
            class="clinical-glass p-5 rounded-(--radius-card) border border-white/8 flex gap-4 group hover:border-active/20 transition-colors"
          >
            <div
              class="w-9 h-9 rounded-lg bg-active/10 flex items-center justify-center flex-shrink-0 mt-0.5"
            >
              <Icon name="search" size={16} class="text-active" />
            </div>
            <div>
              <div class="flex items-center gap-2 mb-1">
                <span class="text-white font-bold text-sm font-display">Onderzoek (Discovery)</span>
                <span
                  class="px-2 py-0.5 rounded-full bg-active/15 text-active text-[10px] font-bold uppercase tracking-wider font-display"
                  >Vooraf</span
                >
              </div>
              <p class="text-white/55 text-xs font-ui leading-relaxed">
                Wordt gefactureerd voordat we beginnen. Geen start zonder betaalde factuur.
              </p>
            </div>
          </div>

          <!-- Change Request -->
          <div
            class="clinical-glass p-5 rounded-(--radius-card) border border-white/8 flex gap-4 group hover:border-active/20 transition-colors"
          >
            <div
              class="w-9 h-9 rounded-lg bg-active/10 flex items-center justify-center flex-shrink-0 mt-0.5"
            >
              <Icon name="git-merge" size={16} class="text-active" />
            </div>
            <div>
              <div class="flex items-center gap-2 mb-1">
                <span class="text-white font-bold text-sm font-display">Meerwerk</span>
                <span
                  class="px-2 py-0.5 rounded-full bg-active/15 text-active text-[10px] font-bold uppercase tracking-wider font-display"
                  >Change Request</span
                >
              </div>
              <p class="text-white/55 text-xs font-ui leading-relaxed">
                Werk buiten de afspraak vereist altijd een <span class="text-white/80"
                  >goedgekeurde wijziging (Change Request)</span
                > voordat we het uitvoeren.
              </p>
            </div>
          </div>

          <!-- SLA incasso -->
          <div
            class="clinical-glass p-5 rounded-(--radius-card) border border-white/8 flex gap-4 group hover:border-active/20 transition-colors"
          >
            <div
              class="w-9 h-9 rounded-lg bg-active/10 flex items-center justify-center flex-shrink-0 mt-0.5"
            >
              <Icon name="refresh-cw" size={16} class="text-active" />
            </div>
            <div>
              <div class="flex items-center gap-2 mb-1">
                <span class="text-white font-bold text-sm font-display">Onderhoud (SLA)</span>
                <span
                  class="px-2 py-0.5 rounded-full bg-active/15 text-active text-[10px] font-bold uppercase tracking-wider font-display"
                  >Maandelijks</span
                >
              </div>
              <p class="text-white/55 text-xs font-ui leading-relaxed">
                Maandelijks vooraf via automatische incasso. De prijs stijgt jaarlijks mee met de
                inflatie (CBS).
              </p>
            </div>
          </div>
        </div>

        <div class="clinical-glass p-4 rounded-(--radius-card) border border-white/8 mt-4">
          <div class="flex items-start gap-3">
            <Icon name="alert-triangle" size={14} class="text-active flex-shrink-0 mt-0.5" />
            <p class="text-white/40 text-xs font-ui leading-relaxed">
              <span class="text-white/70 font-bold">Annulering advies/bouwfase:</span> Voor IT Advies:
              tot 24u vooraf kosteloos verzetten. Voor de bouwfase: de al gewerkte uren + 30% van het
              resterende bedrag. Zie <a href="/voorwaarden" class="text-active hover:underline"
                >artikel 10 van de algemene voorwaarden</a
              >.
            </p>
          </div>
        </div>

        <!-- AV Link -->
        <div class="mt-4 flex items-center gap-2 px-1">
          <Icon name="external-link" size={13} class="text-active flex-shrink-0" />
          <p class="text-white/40 text-xs font-ui">
            Volledige betalings- en annuleringsafspraken:
            <a
              href="/voorwaarden"
              class="text-active hover:text-active/80 transition-colors ml-1 underline underline-offset-2"
            >
              Algemene Voorwaarden →
            </a>
          </p>
        </div>
      </div>

      <!-- Wanneer wel/niet -->
      <div class="max-w-3xl mx-auto">
        <SectionHeader
          label="Transparantie"
          heading='Eerlijk over <span class="text-active">verwachtingen</span>'
        />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div
            data-animate="fade-up"
            class="clinical-glass p-6 rounded-(--radius-feature) border border-cta/20 bg-cta/5"
          >
            <h3 class="text-base font-bold text-white mb-4 font-display flex items-center gap-2">
              <Icon name="check" size={16} class="text-cta shrink-0" /> Ideale match
            </h3>
            <ul class="space-y-2 text-sm font-ui text-white/60">
              <li>
                Er is een concreet bedrijfsproces dat tijd, fouten, omzet of klantbeleving raakt
              </li>
              <li>U heeft eigenaarschap: u kunt beslissen, prioriteren en feedback geven</li>
              <li>
                Bereidheid om eerst het onderzoek en het bouwplan (Discovery en Blueprint) serieus
                te doorlopen wanneer de vraag verder gaat dan een vast websitepakket
              </li>
              <li>Of: complete website-inhoud en bereidheid om binnen een vast pakket te werken</li>
              <li>Er is ruimte voor onderhoud, documentatie en doorontwikkeling</li>
            </ul>
          </div>
          <div
            data-animate="fade-up"
            class="delay-100 clinical-glass p-6 rounded-(--radius-feature) border border-white/8"
          >
            <h3 class="text-base font-bold text-white mb-4 font-display flex items-center gap-2">
              <Icon name="arrow-right" size={16} class="text-white/40 shrink-0" /> Doorverwijzing
            </h3>
            <ul class="space-y-2 text-sm font-ui text-white/40">
              <li>Een vaste prijs verwachten terwijl inhoud, pagina’s en functies nog openstaan</li>
              <li>Geen eigenaar, budgetrichting of beslismoment binnen de organisatie</li>
              <li>De wens om te bouwen zonder eerst analyse te doen</li>
              <li>Doorlopend veel support nodig zonder passend onderhoudscontract (SLA)</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4 text-center">
      <a href="/contact?type=discovery" class="btn-primary text-lg px-10">
        Plan een gratis adviesgesprek
        <Icon name="arrow-right" size={20} />
      </a>
      <p class="text-white/40 text-sm font-ui mt-3">
        Plan een gratis adviesgesprek en krijg direct inzicht in haalbaarheid, aanpak en kosten voor
        uw situatie.
      </p>
    </div>
  </section>
</Layout>
