const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'Hoe werkt een project met LaventeCare?',
  description:
    'Van gratis intake tot SLA-ondersteuning. Een gestructureerd vierfasen-model voor B2B IT-projecten.',
  step: processSteps.map((s) => ({
    '@type': 'HowToStep',
    name: `Stap ${s.phase}: ${s.title}`,
    text: s.description,
  })),
  totalTime: 'P12W',
  estimatedCost: {
    '@type': 'MonetaryAmount',
    currency: 'EUR',
    value: '500',
    minValue: '500',
    maxValue: '1500',
  },
