---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Webshops - LaventeCare">
  <div class="container mx-auto px-4 py-24">
    <div class="max-w-4xl mx-auto">
      <span class="text-[oklch(0.70_0.18_158)] font-semibold tracking-wider uppercase mb-4 block">Diensten</span>
      <h1 class="text-5xl font-bold text-white mb-8">Schaalbare Webshops</h1>
      <p class="text-xl text-white/70 mb-12">
        Robuuste e-commerce platformen die uw verkoop stimuleren zonder in te leveren op prestaties of veiligheid.
      </p>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="clinical-glass p-6 rounded-xl border border-white/10">
          <h3 class="text-xl font-bold text-white mb-2">Modern Commerce</h3>
          <p class="text-white/60">Gebouwd op moderne headless architectuur voor maximale flexibiliteit.</p>
        </div>
        <div class="clinical-glass p-6 rounded-xl border border-white/10">
          <h3 class="text-xl font-bold text-white mb-2">Veilig Betalen</h3>
          <p class="text-white/60">Integratie met alle grote betalingsproviders (Mollie, Stripe, Adyen).</p>
        </div>
      </div>
    </div>
  </div>
</Layout>
