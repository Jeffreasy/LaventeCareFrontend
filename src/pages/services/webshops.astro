---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Webshops - LaventeCare">
  <div class="container mx-auto px-4 py-24">
    <div class="max-w-4xl mx-auto">
      <span class="text-[oklch(0.70_0.18_158)] font-semibold tracking-wider uppercase mb-4 block">Diensten</span>
      <h1 class="text-5xl font-bold text-white mb-8">Schaalbare Webshops</h1>
      <p class="text-xl text-white/70 mb-12">
        Robuuste e-commerce platformen die uw verkoop stimuleren zonder in te leveren op prestaties of veiligheid.
      </p>

      <div class="grid md:grid-cols-12 gap-8 items-start">
        <div class="md:col-span-5 clinical-glass p-8 rounded-2xl border border-white/10 hover:border-[oklch(0.70_0.18_158)]/30 transition-colors">
          <div class="text-3xl mb-4">🚀</div>
          <h3 class="text-2xl font-bold text-white mb-2">Modern Commerce</h3>
          <p class="text-white/60 text-lg">Gebouwd op moderne headless architectuur voor maximale flexibiliteit en snelheid.</p>
        </div>
        <div class="md:col-span-7 clinical-glass p-8 rounded-2xl border border-white/10 bg-white/5 mt-8 md:mt-0">
          <div class="text-3xl mb-4">💳</div>
          <h3 class="text-2xl font-bold text-white mb-2">Veilig Betalen</h3>
          <p class="text-white/60 text-lg">Naadloze integratie met alle grote betalingsproviders (Mollie, Stripe, Adyen). Uw checkout, geoptimaliseerd.</p>
        </div>
      </div>
    </div>
  </div>
</Layout>
