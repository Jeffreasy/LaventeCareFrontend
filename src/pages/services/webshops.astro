---
import Layout from '../../layouts/Layout.astro';
import IconBox from '../../components/ui/IconBox.astro';
import {
  ShoppingCart,
  CreditCard,
  Zap,
  Database,
  BarChart3,
  Globe,
  ShoppingBag,
  Building2,
  Repeat,
} from 'lucide-react';
---

<Layout
  title="Webshop laten maken — LaventeCare"
  description="Webshop laten bouwen? Snelle webshops met veilige betalingen via iDEAL, creditcard en meer. Inclusief voorraadbeheer en mobiel geoptimaliseerd."
>
  <!-- Hero Section -->
  <div class="container mx-auto px-4 py-24">
    <div class="max-w-6xl mx-auto">
      <span class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-4 block"
        >Diensten</span
      >
      <h1 class="text-5xl md:text-6xl font-black text-white mb-6 font-display tracking-tight">
        Schaalbare Webshops
      </h1>
      <p class="text-xl md:text-2xl text-white/70 mb-12 max-w-3xl">
        <span class="text-white font-semibold">Moderne webshop</span> oplossingen die conversie stimuleren
        zonder in te leveren op <span class="text-white font-semibold">snelheid of veiligheid</span
        >.
      </p>
    </div>
  </div>

  <!-- USPs Grid -->
  <div class="container mx-auto px-4 pb-16">
    <div class="max-w-6xl mx-auto">
      <div class="clinical-glass p-10 rounded-(--radius-feature) border border-white/10 mb-16">
        <h2 class="text-3xl font-bold text-white mb-8 font-display">
          Waarom LaventeCare voor E-commerce
        </h2>
        <div class="grid md:grid-cols-2 gap-6">
          <!-- Headless Commerce -->
          <div
            class="group hover:bg-white/5 p-6 rounded-xl transition-all duration-(--transition-base)"
          >
            <div class="flex items-start gap-4">
              <IconBox icon={ShoppingCart} />
              <div>
                <h3 class="text-xl font-bold text-white mb-2">Flexibele Webshop Architectuur</h3>
                <p class="text-white/70 text-sm leading-relaxed">
                  Slimme aanpak met <span class="text-white font-medium"
                    >Shopify Storefront API</span
                  >, <span class="text-white font-medium">Snipcart</span>, of maatwerk oplossingen.
                  Volledige controle over de klantervaring.
                </p>
              </div>
            </div>
          </div>

          <!-- Payment Integration -->
          <div
            class="group hover:bg-white/5 p-6 rounded-xl transition-all duration-(--transition-base)"
          >
            <div class="flex items-start gap-4">
              <IconBox icon={CreditCard} />
              <div>
                <h3 class="text-xl font-bold text-white mb-2">Naadloze Betalingsintegratie</h3>
                <p class="text-white/70 text-sm leading-relaxed">
                  Directe ondersteuning voor <span class="text-white font-medium">Mollie</span>, <span
                    class="text-white font-medium">Stripe</span
                  >, en <span class="text-white font-medium">Adyen</span>. Veilige checkout met 3D
                  Secure en PCI-conforme afhandeling.
                </p>
              </div>
            </div>
          </div>

          <!-- Performance Optimization -->
          <div
            class="group hover:bg-white/5 p-6 rounded-xl transition-all duration-(--transition-base)"
          >
            <div class="flex items-start gap-4">
              <IconBox icon={Zap} />
              <div>
                <h3 class="text-xl font-bold text-white mb-2">Snelheid Verkoopt</h3>
                <p class="text-white/70 text-sm leading-relaxed">
                  Ultieme snelheid met <span class="text-white font-medium">Vercel Edge</span> en geoptimaliseerde
                  productafbeeldingen via <span class="text-white font-medium">Cloudinary</span>.
                  Elke seconde sneller = hogere conversie.
                </p>
              </div>
            </div>
          </div>

          <!-- Inventory Management -->
          <div
            class="group hover:bg-white/5 p-6 rounded-xl transition-all duration-(--transition-base)"
          >
            <div class="flex items-start gap-4">
              <IconBox icon={Database} />
              <div>
                <h3 class="text-xl font-bold text-white mb-2">Direct Voorraadbeheer</h3>
                <p class="text-white/70 text-sm leading-relaxed">
                  Automatische synchronisatie tussen webshop en ERP-systemen. Voorkom te veel
                  verkoop met directe voorraadupdates via <span class="text-white font-medium"
                    >webhooks</span
                  >.
                </p>
              </div>
            </div>
          </div>

          <!-- Analytics & Insights -->
          <div
            class="group hover:bg-white/5 p-6 rounded-xl transition-all duration-(--transition-base)"
          >
            <div class="flex items-start gap-4">
              <IconBox icon={BarChart3} />
              <div>
                <h3 class="text-xl font-bold text-white mb-2">Conversie-analyse</h3>
                <p class="text-white/70 text-sm leading-relaxed">
                  Volg elke stap in het aankoopproces met <span class="text-white font-medium"
                    >Vercel Analytics</span
                  >, heatmaps, en trechteroptimalisatie. Datagedreven verkoopverbetering.
                </p>
              </div>
            </div>
          </div>

          <!-- Mobile-First -->
          <div
            class="group hover:bg-white/5 p-6 rounded-xl transition-all duration-(--transition-base)"
          >
            <div class="flex items-start gap-4">
              <IconBox icon={Globe} />
              <div>
                <h3 class="text-xl font-bold text-white mb-2">Mobiel Winkelen</h3>
                <p class="text-white/70 text-sm leading-relaxed">
                  70%+ van e-commerce is mobiel. Onze webshops zijn <span
                    class="text-white font-medium">mobiel-eerst</span
                  > ontworpen met touch-geoptimaliseerde checkout en razendsnelle prestaties.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Tech Stack -->
      <div class="clinical-glass p-10 rounded-2xl border border-white/10 mb-16">
        <h2 class="text-3xl font-bold text-white mb-3 font-display">Onze E-commerce Technologie</h2>
        <p class="text-white/60 mb-8">De tools waarmee we snelle webshops bouwen</p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- E-commerce Platforms -->
          <div>
            <h3 class="text-sm font-semibold text-active uppercase tracking-wider mb-4">
              E-commerce
            </h3>
            <div class="space-y-3">
              <div class="flex items-center gap-3 text-white/80">
                <div class="w-2 h-2 rounded-full bg-active"></div>
                <span class="font-medium">Shopify Storefront API</span>
              </div>
              <div class="flex items-center gap-3 text-white/80">
                <div class="w-2 h-2 rounded-full bg-active"></div>
                <span class="font-medium">Snipcart</span>
              </div>
              <div class="flex items-center gap-3 text-white/80">
                <div class="w-2 h-2 rounded-full bg-active"></div>
                <span class="font-medium">Maatwerk oplossingen</span>
              </div>
              <p class="text-sm text-white/50 pl-5">
                Flexibele webshop-architectuur voor volledige controle
              </p>
            </div>
          </div>

          <!-- Payments -->
          <div>
            <h3 class="text-sm font-semibold text-active uppercase tracking-wider mb-4">
              Betalingen
            </h3>
            <div class="space-y-3">
              <div class="flex items-center gap-3 text-white/80">
                <div class="w-2 h-2 rounded-full bg-active"></div>
                <span class="font-medium">Mollie</span>
              </div>
              <div class="flex items-center gap-3 text-white/80">
                <div class="bullet-accent"></div>
                <span class="font-medium">Stripe</span>
              </div>
              <div class="flex items-center gap-3 text-white/80">
                <div class="w-2 h-2 rounded-full bg-active"></div>
                <span class="font-medium">Adyen</span>
              </div>
              <p class="text-sm text-white/50 pl-5">Veilige, PCI-conforme checkout</p>
            </div>
          </div>

          <!-- Infrastructure -->
          <div>
            <h3 class="text-sm font-semibold text-active uppercase tracking-wider mb-4">
              Infrastructuur
            </h3>
            <div class="space-y-3">
              <div class="flex items-center gap-3 text-white/80">
                <div class="w-2 h-2 rounded-full bg-active"></div>
                <span class="font-medium">Vercel Edge</span>
              </div>
              <div class="flex items-center gap-3 text-white/80">
                <div class="w-2 h-2 rounded-full bg-active"></div>
                <span class="font-medium">Cloudinary</span>
              </div>
              <div class="flex items-center gap-3 text-white/80">
                <div class="w-2 h-2 rounded-full bg-active"></div>
                <span class="font-medium">PostgreSQL</span>
              </div>
              <p class="text-sm text-white/50 pl-5">Wereldwijd snel, altijd beschikbaar</p>
            </div>
          </div>
        </div>
      </div>

      <!-- E-commerce Types -->
      <div class="mb-16">
        <h2 class="text-3xl font-bold text-white mb-3 font-display">
          Wat Voor Webshops Bouwen We?
        </h2>
        <p class="text-white/60 mb-8">Van consumentenwinkel tot zakelijke bestelportals</p>

        <div class="grid md:grid-cols-3 gap-6">
          <!-- B2C Retail -->
          <div
            class="clinical-glass p-8 rounded-(--radius-feature) border border-white/10 hover:border-active/30 transition-all duration-(--transition-base)"
          >
            <IconBox icon={ShoppingBag} size="lg" class="mb-4" />
            <h3 class="text-xl font-bold text-white mb-3 font-display">Consumentenwebshops</h3>
            <p class="text-white/70 text-sm leading-relaxed mb-4">
              Klantgerichte webshops met productfilters, verlanglijstjes, reviews en
              geoptimaliseerde mobiele checkout. Perfect voor mode, elektronica of lifestyle.
            </p>
            <div class="flex flex-wrap gap-2">
              <span
                class="text-xs px-3 py-1 rounded-full bg-white/5 text-white/70 border border-white/10"
                >Beoordelingen</span
              >
            </div>
          </div>

          <!-- B2B Wholesale -->
          <div
            class="clinical-glass p-8 rounded-(--radius-feature) border border-white/10 hover:border-active/30 transition-all duration-(--transition-base)"
          >
            <IconBox icon={Building2} size="lg" class="mb-4" />
            <h3 class="text-xl font-bold text-white mb-3 font-display">Zakelijke Bestelportals</h3>
            <p class="text-white/70 text-sm leading-relaxed mb-4">
              Gestaffelde prijzen, groothandelsbestellingen, offerteaanvragen en klantspecifieke
              catalogi. Professionele inlogsystemen en orderbeheer.
            </p>
            <div class="flex flex-wrap gap-2">
              <span
                class="text-xs px-3 py-1 rounded-full bg-white/5 text-white/70 border border-white/10"
                >Groothandel</span
              >
              <span
                class="text-xs px-3 py-1 rounded-full bg-white/5 text-white/70 border border-white/10"
                >Klantprijzen</span
              >
            </div>
          </div>

          <!-- Subscriptions -->
          <div
            class="clinical-glass p-8 rounded-(--radius-feature) border border-white/10 hover:border-active/30 transition-all duration-(--transition-base)"
          >
            <IconBox icon={Repeat} size="lg" class="mb-4" />
            <h3 class="text-xl font-bold text-white mb-3 font-display">
              Abonnementen & Lidmaatschappen
            </h3>
            <p class="text-white/70 text-sm leading-relaxed mb-4">
              Terugkerende facturatie, ledenomgevingen en automatische verlengingen. Perfect voor
              SaaS, maandboxen of premium content platforms.
            </p>
            <div class="flex flex-wrap gap-2">
              <span
                class="text-xs px-3 py-1 rounded-full bg-white/5 text-white/70 border border-white/10"
                >Terugkerende facturatie</span
              >
              <span
                class="text-xs px-3 py-1 rounded-full bg-white/5 text-white/70 border border-white/10"
                >Ledengebied</span
              >
            </div>
          </div>
        </div>
      </div>

      <!-- CTA Section -->
      <div class="clinical-glass p-12 rounded-2xl border border-white/10 text-center">
        <h2 class="text-3xl font-bold text-white mb-4 font-display">
          Klaar voor een Snelle, Professionele Webshop?
        </h2>
        <p class="text-white/70 mb-8 max-w-2xl mx-auto">
          Bekijk onze portfolio voor e-commerce voorbeelden, of neem direct contact op voor een
          vrijblijvend gesprek over uw verkoopdoelen.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contact?ref=webshops"
            class="inline-flex items-center justify-center px-8 py-4 rounded-(--radius-action) bg-linear-to-br from-(--color-active-gradient-from) to-active-gradient-to text-white font-semibold hover:shadow-lg hover:shadow-active/20 transition-all duration-(--transition-base)"
          >
            Bekijk Portfolio
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center px-8 py-4 rounded-(--radius-action) border border-white/20 text-white font-semibold hover:bg-white/5 transition-all duration-(--transition-base)"
          >
            Neem Contact Op
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
