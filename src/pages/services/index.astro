---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Onze Diensten - LaventeCare">
  <div class="container mx-auto px-4 py-24">
    <h1 class="text-4xl font-bold text-white mb-6">Onze Diensten</h1>
    <p class="text-xl text-white/70 mb-12 max-w-3xl">
      Ontdek hoe LaventeCare uw digitale aanwezigheid kan transformeren met onze gespecialiseerde oplossingen.
    </p>

    <div class="grid md:grid-cols-3 gap-8">
      <div class="clinical-glass p-8 rounded-2xl border border-white/10 hover:border-[oklch(0.70_0.18_158)]/50 transition-colors">
        <h2 class="text-2xl font-bold text-white mb-4">Landing Pages</h2>
        <p class="text-white/70 mb-6">High-performance pagina's ontworpen voor conversie en snelheid.</p>
        <a href="/services/landing-pages" class="text-[oklch(0.70_0.18_158)] hover:underline">Meer informatie &rarr;</a>
      </div>

      <div class="clinical-glass p-8 rounded-2xl border border-white/10 hover:border-[oklch(0.70_0.18_158)]/50 transition-colors">
        <h2 class="text-2xl font-bold text-white mb-4">Webshops</h2>
        <p class="text-white/70 mb-6">Schaalbare e-commerce oplossingen die groeien met uw bedrijf.</p>
        <a href="/services/webshops" class="text-[oklch(0.70_0.18_158)] hover:underline">Meer informatie &rarr;</a>
      </div>

      <div class="clinical-glass p-8 rounded-2xl border border-white/10 hover:border-[oklch(0.70_0.18_158)]/50 transition-colors">
        <h2 class="text-2xl font-bold text-white mb-4">Maatwerk Applicaties</h2>
        <p class="text-white/70 mb-6">Complex business logica vertaald naar intuïtieve interfaces.</p>
        <a href="/services/custom-apps" class="text-[oklch(0.70_0.18_158)] hover:underline">Meer informatie &rarr;</a>
      </div>
    </div>
  </div>
</Layout>
