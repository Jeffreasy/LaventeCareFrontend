---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import PillarCard from '../../components/blocks/PillarCard.astro';
import Icon from '../../components/ui/Icon.astro';

const pillars = [
  {
    title: 'AI & Prompt Engineering',
    description:
      'AI that takes over repetitive work and uses your data for better and faster decisions — reliable, scalable and measurable in your daily processes.',
    icon: 'brain-circuit',
    tags: ['AI Automation', 'Digital Employees', 'Business Data'],
    href: '/services/ai-prompt-engineering',
    featured: true,
  },
  {
    title: 'Smart Monitoring & Sensors',
    description:
      'Real-time monitoring that detects failures early and prevents damage or costly downtime. From sensor to dashboard, remotely and without maintenance.',
    icon: 'radio',
    tags: ['Real-time monitoring', 'Automatic alerting', 'Remote'],
    href: '/services/iot-hardware',
  },
  {
    title: 'Custom Platforms & Events',
    description:
      'Registration, ticketing and donations — fully automated and designed to run flawlessly. Your complete event or campaign managed from one central system.',
    icon: 'building-2',
    tags: ['Registration', 'Donations', 'Dashboards', 'Scalable'],
    href: '/services/custom-platforms',
  },
  {
    title: 'Lead Generation & Matchmaking',
    description:
      'More enquiries from your website, without extra marketing costs. Visitors are automatically directed toward a quote or enquiry, so they convert faster.',
    icon: 'target',
    tags: ['Quote Flows', 'Lead Management', 'SEO'],
    href: '/services/lead-generation',
  },
  {
    title: 'Security & Authentication',
    description:
      "Your customer data is structurally protected and separated, minimising risks and keeping your data safe — even in the event of errors or attacks.",
    icon: 'shield-check',
    tags: ['Data Isolation', 'Authentication', 'GDPR Compliance'],
    href: '/services/security',
    featured: true,
  },
] as const;
---

<Layout
  title="Services — Custom Platforms, AI, IoT & Security | LaventeCare"
  description="From AI automation to built-in security — complete systems that scale, secure and automate. Five integrated services, one engineer."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Platform Services"
        heading='Five pillars, one <span class="text-active">complete ecosystem</span>'
        description="Not separate projects, but an integrated system: each pillar strengthens the other. From AI automation to data protection — everything runs on the same robust core."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto mb-16">
        {
          pillars.map((pillar, index) => (
            <div data-animate="fade-up" class={`delay-${index * 100}`}>
              <PillarCard {...pillar} />
            </div>
          ))
        }
      </div>

      <!-- Target Audiences -->
      <div class="max-w-4xl mx-auto">
        <SectionHeader
          label="Who we serve"
          heading='Businesses where downtime, errors or inefficiency directly <span class="text-active">cost money</span>'
        />

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div
            data-animate="fade-up"
            class="clinical-glass p-6 rounded-(--radius-card) border border-white/8 text-center"
          >
            <Icon name="factory" size={24} class="text-active block mb-3 mx-auto" />
            <h3 class="text-sm font-bold text-white mb-2 font-display">Industry & Installations</h3>
            <p class="text-white/50 text-xs font-ui">
              Where downtime directly costs money. Real-time monitoring and preventive maintenance.
            </p>
          </div>
          <div
            data-animate="fade-up"
            class="delay-100 clinical-glass p-6 rounded-(--radius-card) border border-white/8 text-center"
          >
            <Icon name="building" size={24} class="text-active block mb-3 mx-auto" />
            <h3 class="text-sm font-bold text-white mb-2 font-display">
              SME (Construction, Green, Automotive)
            </h3>
            <p class="text-white/50 text-xs font-ui">
              More enquiries, better visibility and secure client portals.
            </p>
          </div>
          <div
            data-animate="fade-up"
            class="delay-200 clinical-glass p-6 rounded-(--radius-card) border border-white/8 text-center"
          >
            <Icon name="heart" size={24} class="text-active block mb-3 mx-auto" />
            <h3 class="text-sm font-bold text-white mb-2 font-display">Non-Profits & Events</h3>
            <p class="text-white/50 text-xs font-ui">
              Less chaos, more overview. Automated registration and donations.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div
        class="clinical-glass p-8 md:p-12 rounded-(--radius-hero) border border-white/8 max-w-4xl mx-auto text-center"
      >
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 font-display">
          Ready to get started?
        </h2>
        <p class="text-white/70 mb-6 max-w-xl mx-auto font-ui">
          Schedule an intake and discover where you can immediately save time, costs or risk.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/how-we-work" class="btn-secondary">View how we work</a>
          <a href="/contact" class="btn-primary">
            Schedule an intake
            <Icon name="arrow-right" size={16} />
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
