---
import Layout from '../../layouts/Layout.astro';
import IconBox from '../../components/ui/IconBox.astro';
import { BarChart3, ShoppingCart } from 'lucide-react';
---

<Layout
  title="Websites, Webshops & Apps laten maken — LaventeCare"
  description="Professionele websites, webshops en maatwerk applicaties. Snel, veilig en SEO-geoptimaliseerd. Bekijk onze diensten."
>
  <!-- Hero Section -->
  <div class="container mx-auto px-4 py-24">
    <div class="max-w-6xl mx-auto text-center">
      <span class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-4 block"
        >Onze diensten</span
      >
      <h1 class="text-5xl md:text-6xl font-black text-white mb-6 font-display tracking-tight">
        Onze Diensten
      </h1>
      <p class="text-xl md:text-2xl text-white/70 mb-16 max-w-3xl mx-auto">
        Van <span class="text-white font-semibold">professionele websites</span> tot <span
          class="text-white font-semibold">complete applicaties</span
        >. Ontdek wat wij voor uw bedrijf kunnen betekenen.
      </p>
    </div>

    <!-- Asymmetric Services Grid -->
    <div class="max-w-6xl mx-auto">
      <!-- Row 1: Landing Pages (Major) + Custom Apps -->
      <div class="grid md:grid-cols-12 gap-8 mb-8">
        <!-- Landing Pages - 8 columns (Major Feature) -->
        <a
          href="/services/landing-pages"
          class="md:col-span-8 clinical-glass p-10 rounded-(--radius-hero) border border-white/10 hover:border-active/50 hover:-translate-y-2 transition-all duration-(--transition-base) group block"
        >
          <div class="flex-1">
            <h2
              class="text-3xl font-bold text-white mb-3 font-display group-hover:text-active transition-colors"
            >
              Landing Pages
            </h2>
            <p class="text-white/70 text-lg mb-6 leading-relaxed">
              Professionele websites die bezoekers <span class="text-white font-medium"
                >omzetten in klanten</span
              >. Razendsnel, goed vindbaar in Google en volledig op maat. Perfect voor bedrijven,
              events en lokale ondernemers.
            </p>
            <div class="flex flex-wrap gap-2">
              <span
                class="text-xs px-3 py-1.5 rounded-full bg-white/5 text-white/70 border border-white/10"
                >100/100 Lighthouse</span
              >
              <span
                class="text-xs px-3 py-1.5 rounded-full bg-white/5 text-white/70 border border-white/10"
                >Live data</span
              >
              <span
                class="text-xs px-3 py-1.5 rounded-full bg-white/5 text-white/70 border border-white/10"
                >SEO geoptimaliseerd</span
              >
            </div>
          </div>
          <div
            class="flex items-center text-active text-sm font-bold mt-6 pt-6 border-t border-white/5"
          >
            <span class="group-hover:underline">Meer informatie</span>
            <svg
              class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </div>
        </a>
      </div>

      <!-- Custom Apps - 4 columns -->
      <a
        href="/services/custom-apps"
        class="md:col-span-4 clinical-glass p-8 rounded-(--radius-hero) border border-white/10 hover:border-active/50 hover:-translate-y-2 transition-all duration-(--transition-base) group flex flex-col"
      >
        <IconBox
          icon={BarChart3}
          size="lg"
          class="mb-6 group-hover:scale-110 transition-transform"
        />
        <h2
          class="text-2xl font-bold text-white mb-3 font-display group-hover:text-active transition-colors"
        >
          Maatwerk Applicaties
        </h2>
        <p class="text-white/70 mb-6 leading-relaxed flex-1">
          Dashboards, portals en interne tools gebouwd op maat. Veilig, schaalbaar en precies wat uw
          bedrijf nodig heeft.
        </p>
        <div
          class="flex items-center text-active text-sm font-bold mt-auto pt-6 border-t border-white/5"
        >
          <span class="group-hover:underline">Meer informatie</span>
          <svg
            class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </div>
      </a>
    </div>

    <!-- Row 2: Webshops (Major) -->
    <div class="grid md:grid-cols-12 gap-8">
      <!-- Webshops - Full Width with Internal Layout -->
      <a
        href="/services/webshops"
        class="md:col-span-12 clinical-glass p-10 rounded-(--radius-hero) border border-white/10 hover:border-active/50 hover:-translate-y-1 transition-all duration-(--transition-base) group block"
      >
        <div class="flex flex-col md:flex-row items-start gap-8">
          <IconBox
            icon={ShoppingCart}
            size="lg"
            class="group-hover:scale-110 transition-transform"
          />
          <div class="flex-1">
            <h2
              class="text-3xl font-bold text-white mb-3 font-display group-hover:text-active transition-colors"
            >
              Schaalbare Webshops
            </h2>
            <p class="text-white/70 text-lg mb-6 leading-relaxed">
              Professionele webshops die snel laden en veilig afrekenen. Betalingen via iDEAL,
              creditcard en meer. Van kleine webwinkel tot groot e-commerce platform.
            </p>
            <div class="flex flex-wrap gap-2">
              <span
                class="text-xs px-3 py-1.5 rounded-full bg-white/5 text-white/70 border border-white/10"
                >Veilig betalen</span
              >
              <span
                class="text-xs px-3 py-1.5 rounded-full bg-white/5 text-white/70 border border-white/10"
                >Mobiel geoptimaliseerd</span
              >
              <span
                class="text-xs px-3 py-1.5 rounded-full bg-white/5 text-white/70 border border-white/10"
                >Voorraadbeheer</span
              >
            </div>
          </div>
          <div class="flex items-center text-active text-sm font-bold md:self-end">
            <span class="group-hover:underline">Meer informatie</span>
            <svg
              class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </div>
        </div>
      </a>
    </div>
  </div>

  <!-- CTA Section -->
  <div class="container mx-auto px-4 pb-24">
    <div
      class="max-w-4xl mx-auto clinical-glass p-12 rounded-2xl border border-white/10 text-center"
    >
      <h2 class="text-3xl font-bold text-white mb-4 font-display">Klaar om te Starten?</h2>
      <p class="text-white/70 mb-8 max-w-2xl mx-auto">
        Bekijk onze portfolio met concrete voorbeelden, of neem direct contact op voor een
        vrijblijvend gesprek over uw project.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact?ref=services"
          class="inline-flex items-center justify-center px-8 py-4 rounded-(--radius-action) bg-linear-to-br from-(--color-active-gradient-from) to-active-gradient-to text-white font-semibold hover:shadow-lg hover:shadow-active/20 transition-all duration-(--transition-base)"
        >
          Bekijk Portfolio
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-8 py-4 rounded-(--radius-action) border border-white/20 text-white font-semibold hover:bg-white/5 transition-all duration-(--transition-base)"
        >
          Neem Contact Op
        </a>
      </div>
    </div>
  </div>
</Layout>
