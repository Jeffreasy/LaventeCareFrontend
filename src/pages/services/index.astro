---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import PillarCard from '../../components/blocks/PillarCard.astro';
import Icon from '../../components/ui/Icon.astro';

const pillars = [
  {
    title: 'IT Advice & Consultancy',
    description:
      'An independent sparring partner and second opinion, without any obligation to build. Sober advice on architecture, tooling and choices — €95/hr, first conversation free.',
    icon: 'handshake',
    tags: ['Second opinion', 'Architecture', 'No build obligation'],
    href: '/services/consultancy',
  },
  {
    title: 'AI & Automation',
    description:
      'AI that takes over repetitive work and uses your data for better and faster decisions — reliable, measurable and with a person deciding at the important moments, integrated into your daily processes.',
    icon: 'brain-circuit',
    tags: ['AI Automation', 'Digital Employees', 'Business Data'],
    href: '/services/ai-prompt-engineering',
    featured: true,
  },
  {
    title: 'Smart Monitoring & Sensors',
    description:
      'Real-time monitoring that detects failures early and prevents damage or costly downtime. From sensor to dashboard, remotely and without maintenance.',
    icon: 'radio',
    tags: ['Real-time monitoring', 'Automatic alerting', 'Remote'],
    href: '/services/iot-hardware',
  },
  {
    title: 'Custom Platforms',
    description:
      'Replace disconnected tools and manual work with one system that grows with you — everything in one place for your processes, users and data.',
    icon: 'building-2',
    tags: ['Everything in one place', 'Dashboards', 'Grows with you'],
    href: '/services/custom-platforms',
  },
  {
    title: 'Lead Generation',
    description:
      'Turn your website into a system that converts visitors into concrete enquiries — automatically and measurably, without extra marketing costs.',
    icon: 'target',
    tags: ['Quote Flows', 'Lead Management', 'SEO'],
    href: '/services/lead-generation',
  },
  {
    title: 'Security & Authentication',
    description:
      "Your clients' data is kept strictly separate and protected: everyone sees only what they are allowed to, and every action is recorded. Security built in from the start (PostgreSQL RLS, role-based access, audit trails) — even if something goes wrong.",
    icon: 'shield-check',
    tags: ['Separated client data', 'Access per role', 'GDPR Compliance'],
    href: '/services/security',
    featured: true,
  },
] as const;
---

<Layout
  title="Services — Consultancy, AI, IoT, Platforms & Security | LaventeCare"
  description="From independent IT advice to AI automation and built-in security — a long-term partner that turns the way you work into software that does the work for you. Six integrated services."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Services"
        heading='Six services, one <span class="text-active">partner that builds it</span>'
        description="Not separate projects, but a long-term partner that turns the way you work into software that does the work for you. From independent advice to AI automation and data protection — from idea to working system."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto mb-16">
        {
          pillars.map((pillar, index) => (
            <div data-animate="fade-up" class={`delay-${index * 100}`}>
              <PillarCard {...pillar} />
            </div>
          ))
        }
      </div>

      <!-- Target Audiences -->
      <div class="max-w-4xl mx-auto">
        <SectionHeader
          label="Who we serve"
          heading='Businesses where downtime, errors or inefficiency directly <span class="text-active">cost money</span>'
        />

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div
            data-animate="fade-up"
            class="clinical-glass p-6 rounded-(--radius-card) border border-white/8 text-center"
          >
            <Icon name="building" size={24} class="text-active block mb-3 mx-auto" />
            <h3 class="text-sm font-bold text-white mb-2 font-display">SMEs</h3>
            <p class="text-white/50 text-xs font-ui">
              Growing businesses that want to get digital growth, automation and custom software
              done right.
            </p>
          </div>
          <div
            data-animate="fade-up"
            class="delay-100 clinical-glass p-6 rounded-(--radius-card) border border-white/8 text-center"
          >
            <Icon name="handshake" size={24} class="text-active block mb-3 mx-auto" />
            <h3 class="text-sm font-bold text-white mb-2 font-display">Service providers</h3>
            <p class="text-white/50 text-xs font-ui">
              More enquiries, better visibility and secure client portals — a website that works as
              a system.
            </p>
          </div>
          <div
            data-animate="fade-up"
            class="delay-200 clinical-glass p-6 rounded-(--radius-card) border border-white/8 text-center"
          >
            <Icon name="cog" size={24} class="text-active block mb-3 mx-auto" />
            <h3 class="text-sm font-bold text-white mb-2 font-display">Operational teams</h3>
            <p class="text-white/50 text-xs font-ui">
              Teams with recurring processes that want to move from manual work to a scalable
              digital system.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div
        class="clinical-glass p-8 md:p-12 rounded-(--radius-hero) border border-white/8 max-w-4xl mx-auto text-center"
      >
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 font-display">
          Ready to get started?
        </h2>
        <p class="text-white/70 mb-6 max-w-xl mx-auto font-ui">
          Book a free intro call and discover where you can immediately save time, costs or risk.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/how-we-work" class="btn-secondary">View how we work</a>
          <a href="/contact" class="btn-primary">
            Book a free intro call
            <Icon name="arrow-right" size={16} />
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
