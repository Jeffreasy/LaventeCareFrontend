---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Landing Pages - LaventeCare">
  <div class="container mx-auto px-4 py-24">
    <div class="max-w-4xl mx-auto">
      <span class="text-[oklch(0.70_0.18_158)] font-semibold tracking-wider uppercase mb-4 block">Diensten</span>
      <h1 class="text-5xl font-bold text-white mb-8">Landing Pages die Converteren</h1>
      <p class="text-xl text-white/70 mb-12">
        Geoptimaliseerd voor snelheid, SEO en gebruikerservaring. Onze landing pages zijn gebouwd om bezoekers om te zetten in klanten.
      </p>
      
      <div class="clinical-glass p-8 rounded-2xl border border-white/10 mb-8">
        <h2 class="text-2xl font-bold text-white mb-4">Waarom LaventeCare?</h2>
        <ul class="space-y-4">
          <li class="flex items-start">
            <svg class="w-6 h-6 text-[oklch(0.70_0.18_158)] mr-3 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span class="text-white/80">Bliksemsnelle laadtijden met Astro</span>
          </li>
          <li class="flex items-start">
            <svg class="w-6 h-6 text-[oklch(0.70_0.18_158)] mr-3 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span class="text-white/80">Premium Design System Integratie</span>
          </li>
          <li class="flex items-start">
            <svg class="w-6 h-6 text-[oklch(0.70_0.18_158)] mr-3 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span class="text-white/80">Technische SEO optimalisatie standaard inbegrepen</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</Layout>
