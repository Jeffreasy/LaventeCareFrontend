---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Maatwerk Applicaties - LaventeCare">
  <!-- Hero Section -->
  <div class="container mx-auto px-4 py-24">
    <div class="max-w-6xl mx-auto">
      <span class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-4 block">Diensten</span>
      <h1 class="text-5xl md:text-6xl font-black text-white mb-6 font-display tracking-tight">Maatwerk Applicaties</h1>
      <p class="text-xl md:text-2xl text-white/70 mb-12 max-w-3xl">
        Van <span class="text-white font-semibold">CRM-dashboards</span> tot <span class="text-white font-semibold">complexe data-platforms</span>. Wij bouwen enterprise-grade applicaties die precies doen wat u nodig heeft.
      </p>
    </div>
  </div>

  <!-- USPs Grid -->
  <div class="container mx-auto px-4 pb-16">
    <div class="max-w-6xl mx-auto">
      <div class="clinical-glass p-10 rounded-2xl border border-white/10 mb-16">
        <h2 class="text-3xl font-bold text-white mb-8 font-display">Waarom LaventeCare voor Maatwerk</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <!-- Real-time Data -->
          <div class="group hover:bg-white/5 p-6 rounded-xl transition-all duration-300">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-[oklch(0.70_0.18_158)] to-[oklch(0.60_0.15_158)] flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-bold text-white mb-2">Real-time Data Synchronisatie</h3>
                <p class="text-white/70 text-sm leading-relaxed">
                  Met <span class="text-white font-medium">Convex</span> en <span class="text-white font-medium">WebSockets</span> bouwen we applicaties die instant reageren op datawijzigingen. Ideaal voor dashboards en collaboratieve tools.
                </p>
              </div>
            </div>
          </div>

          <!-- Enterprise Security -->
          <div class="group hover:bg-white/5 p-6 rounded-xl transition-all duration-300">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-[oklch(0.70_0.18_158)] to-[oklch(0.60_0.15_158)] flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-bold text-white mb-2">Enterprise-Grade Authenticatie</h3>
                <p class="text-white/70 text-sm leading-relaxed">
                  Onze <span class="text-white font-medium">Go backend</span> implementeert JWT-based auth met refresh tokens, 2FA/OTP, en Row Level Security (RLS) voor absolute data-isolatie.
                </p>
              </div>
            </div>
          </div>

          <!-- Admin Dashboards -->
          <div class="group hover:bg-white/5 p-6 rounded-xl transition-all duration-300">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-[oklch(0.70_0.18_158)] to-[oklch(0.60_0.15_158)] flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-bold text-white mb-2">Krachtige Admin Dashboards</h3>
                <p class="text-white/70 text-sm leading-relaxed">
                  "Deep Tech" glassmorphism interfaces met real-time analytics, export functionaliteit, en intuïtieve data-visualisatie. Referentie: <span class="text-white font-medium">De Koninklijke Loop</span>.
                </p>
              </div>
            </div>
          </div>

          <!-- Type-Safe Development -->
          <div class="group hover:bg-white/5 p-6 rounded-xl transition-all duration-300">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-[oklch(0.70_0.18_158)] to-[oklch(0.60_0.15_158)] flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-bold text-white mb-2">Type-Safe Development</h3>
                <p class="text-white/70 text-sm leading-relaxed">
                  End-to-end <span class="text-white font-medium">TypeScript</span>, van database schema (met <span class="text-white font-medium">Zod</span>) tot frontend. Minder bugs, snellere development cycles.
                </p>
              </div>
            </div>
          </div>

          <!-- Scalable Architecture -->
          <div class="group hover:bg-white/5 p-6 rounded-xl transition-all duration-300">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-[oklch(0.70_0.18_158)] to-[oklch(0.60_0.15_158)] flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-bold text-white mb-2">Multi-tenant Architectuur</h3>
                <p class="text-white/70 text-sm leading-relaxed">
                  Schaal zonder grenzen. Onze <span class="text-white font-medium">PostgreSQL</span> setup met partitioning en RLS isoleert tenants volledig en bespaart 25% geheugen.
                </p>
              </div>
            </div>
          </div>

          <!-- API-First -->
          <div class="group hover:bg-white/5 p-6 rounded-xl transition-all duration-300">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-[oklch(0.70_0.18_158)] to-[oklch(0.60_0.15_158)] flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-bold text-white mb-2">API-First Design</h3>
                <p class="text-white/70 text-sm leading-relaxed">
                  Bouw op een robuuste RESTful API met automatische documentatie (OpenAPI) en rate limiting. Klaar voor toekomstige integraties.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Tech Stack -->
      <div class="clinical-glass p-10 rounded-2xl border border-white/10 mb-16">
        <h2 class="text-3xl font-bold text-white mb-3 font-display">Onze Tech Stack voor Maatwerk</h2>
        <p class="text-white/60 mb-8">De tools waarmee we enterprise applicaties bouwen</p>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Framework -->
          <div>
            <h3 class="text-sm font-semibold text-[oklch(0.70_0.18_158)] uppercase tracking-wider mb-4">Framework</h3>
            <div class="space-y-3">
              <div class="flex items-center gap-3 text-white/80">
                <div class="w-2 h-2 rounded-full bg-[oklch(0.70_0.18_158)]"></div>
                <span class="font-medium">Astro 5</span>
              </div>
              <div class="flex items-center gap-3 text-white/80">
                <div class="w-2 h-2 rounded-full bg-[oklch(0.70_0.18_158)]"></div>
                <span class="font-medium">React 19</span>
              </div>
              <div class="flex items-center gap-3 text-white/80">
                <div class="w-2 h-2 rounded-full bg-[oklch(0.70_0.18_158)]"></div>
                <span class="font-medium">Alpine.js</span>
              </div>
              <p class="text-sm text-white/50 pl-5">Modulaire, schaalbare frontend architectuur</p>
            </div>
          </div>

          <!-- Backend & Data -->
          <div>
            <h3 class="text-sm font-semibold text-[oklch(0.70_0.18_158)] uppercase tracking-wider mb-4">Backend & Data</h3>
            <div class="space-y-3">
              <div class="flex items-center gap-3 text-white/80">
                <div class="w-2 h-2 rounded-full bg-[oklch(0.70_0.18_158)]"></div>
                <span class="font-medium">Go (Golang)</span>
              </div>
              <div class="flex items-center gap-3 text-white/80">
                <div class="w-2 h-2 rounded-full bg-[oklch(0.70_0.18_158)]"></div>
                <span class="font-medium">PostgreSQL</span>
              </div>
              <div class="flex items-center gap-3 text-white/80">
                <div class="w-2 h-2 rounded-full bg-[oklch(0.70_0.18_158)]"></div>
                <span class="font-medium">Convex</span>
              </div>
              <p class="text-sm text-white/50 pl-5">Veilig, snel, en schaalbaar</p>
            </div>
          </div>

          <!-- UI/UX & Media -->
          <div>
            <h3 class="text-sm font-semibold text-[oklch(0.70_0.18_158)] uppercase tracking-wider mb-4">UI/UX & Media</h3>
            <div class="space-y-3">
              <div class="flex items-center gap-3 text-white/80">
                <div class="w-2 h-2 rounded-full bg-[oklch(0.70_0.18_158)]"></div>
                <span class="font-medium">Tailwind CSS 4</span>
              </div>
              <div class="flex items-center gap-3 text-white/80">
                <div class="w-2 h-2 rounded-full bg-[oklch(0.70_0.18_158)]"></div>
                <span class="font-medium">Radix UI</span>
              </div>
              <div class="flex items-center gap-3 text-white/80">
                <div class="w-2 h-2 rounded-full bg-[oklch(0.70_0.18_158)]"></div>
                <span class="font-medium">Cloudinary</span>
              </div>
              <p class="text-sm text-white/50 pl-5">Moderne, toegankelijke interfaces</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Use Cases -->
      <div class="mb-16">
        <h2 class="text-3xl font-bold text-white mb-3 font-display">Wat Bouwen We?</h2>
        <p class="text-white/60 mb-8">Van CRM tot complexe data-platforms</p>
        
        <div class="grid md:grid-cols-3 gap-6">
          <!-- CRM & Admin -->
          <div class="clinical-glass p-8 rounded-xl border border-white/10 hover:border-[oklch(0.70_0.18_158)]/30 transition-all duration-300">
            <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-[oklch(0.70_0.18_158)] to-[oklch(0.60_0.15_158)] flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-3 font-display">CRM & Admin Panels</h3>
            <p class="text-white/70 text-sm leading-relaxed mb-4">
              Complete administratieve dashboards met registratiebeheer, donatie-tracking, media-bibliotheek en gebruikersmanagement.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="text-xs px-3 py-1 rounded-full bg-white/5 text-white/70 border border-white/10">Real-time Updates</span>
              <span class="text-xs px-3 py-1 rounded-full bg-white/5 text-white/70 border border-white/10">Export/Import</span>
            </div>
          </div>

          <!-- Data Dashboards -->
          <div class="clinical-glass p-8 rounded-xl border border-white/10 hover:border-[oklch(0.70_0.18_158)]/30 transition-all duration-300">
            <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-[oklch(0.70_0.18_158)] to-[oklch(0.60_0.15_158)] flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-3 font-display">Data Analytics Platforms</h3>
            <p class="text-white/70 text-sm leading-relaxed mb-4">
              Visualiseer complexe datasets met interactieve grafieken, filters, en export-functionaliteit. Perfect voor business intelligence.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="text-xs px-3 py-1 rounded-full bg-white/5 text-white/70 border border-white/10">Visualisatie</span>
              <span class="text-xs px-3 py-1 rounded-full bg-white/5 text-white/70 border border-white/10">Filters</span>
            </div>
          </div>

          <!-- Internal Tools -->
          <div class="clinical-glass p-8 rounded-xl border border-white/10 hover:border-[oklch(0.70_0.18_158)]/30 transition-all duration-300">
            <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-[oklch(0.70_0.18_158)] to-[oklch(0.60_0.15_158)] flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-3 font-display">Interne Workflow Tools</h3>
            <p class="text-white/70 text-sm leading-relaxed mb-4">
              Streamline uw bedrijfsprocessen met custom-built tools voor facturatie, projectmanagement, of resource planning.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="text-xs px-3 py-1 rounded-full bg-white/5 text-white/70 border border-white/10">Automation</span>
              <span class="text-xs px-3 py-1 rounded-full bg-white/5 text-white/70 border border-white/10">Integraties</span>
            </div>
          </div>
        </div>
      </div>

      <!-- CTA Section -->
      <div class="clinical-glass p-12 rounded-2xl border border-white/10 text-center">
        <h2 class="text-3xl font-bold text-white mb-4 font-display">Klaar voor een Maatwerk Applicatie?</h2>
        <p class="text-white/70 mb-8 max-w-2xl mx-auto">
          Bekijk onze portfolio met concrete voorbeelden zoals <span class="text-white font-medium">De Koninklijke Loop</span>, of neem direct contact op voor een vrijblijvend gesprek.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href="/portfolio" 
            class="inline-flex items-center justify-center px-8 py-4 rounded-xl bg-gradient-to-br from-[oklch(0.70_0.18_158)] to-[oklch(0.60_0.15_158)] text-white font-semibold hover:shadow-lg hover:shadow-[oklch(0.70_0.18_158)]/20 transition-all duration-300"
          >
            Bekijk Portfolio
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
          <a 
            href="/contact" 
            class="inline-flex items-center justify-center px-8 py-4 rounded-xl border border-white/20 text-white font-semibold hover:bg-white/5 transition-all duration-300"
          >
            Neem Contact Op
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
