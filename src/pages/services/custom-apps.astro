---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Maatwerk Applicaties - LaventeCare">
  <div class="container mx-auto px-4 py-24">
    <div class="max-w-4xl mx-auto">
      <span class="text-[oklch(0.70_0.18_158)] font-semibold tracking-wider uppercase mb-4 block">Diensten</span>
      <h1 class="text-5xl font-bold text-white mb-8">Maatwerk Applicaties</h1>
      <p class="text-xl text-white/70 mb-12">
        Specifieke bedrijfsbehoeften vragen om specifieke oplossingen. Wij bouwen applicaties die precies doen wat u nodig heeft.
      </p>

      <div class="clinical-glass p-8 rounded-2xl border border-white/10">
        <h2 class="text-2xl font-bold text-white mb-4">Enterprise Grade</h2>
        <p class="text-white/70 mb-4">
          Of het nu gaat om interne dashboards, klantenportalen of complexe data-verwerking systemen, wij zorgen voor een veilige en schaalbare oplossing.
        </p>
        <div class="flex flex-wrap gap-2 mt-6">
          <span class="px-3 py-1 rounded-full bg-white/5 text-sm text-white/80 border border-white/10">React</span>
          <span class="px-3 py-1 rounded-full bg-white/5 text-sm text-white/80 border border-white/10">Node.js</span>
          <span class="px-3 py-1 rounded-full bg-white/5 text-sm text-white/80 border border-white/10">PostgreSQL</span>
          <span class="px-3 py-1 rounded-full bg-white/5 text-sm text-white/80 border border-white/10">TypeScript</span>
        </div>
      </div>
    </div>
  </div>
</Layout>
