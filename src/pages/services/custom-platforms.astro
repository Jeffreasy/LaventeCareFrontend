---
import Layout from '../../layouts/Layout.astro';
import TechStackBadge from '../../components/ui/TechStackBadge.astro';
import Icon, { type IconName } from '../../components/ui/Icon.astro';

const features = [
  {
    icon: 'layout-dashboard',
    title: 'Everything in one place',
    desc: 'Users, data, workflows and communication — all managed from one clear system, instead of scattered across disconnected tools.',
  },
  {
    icon: 'clipboard-list',
    title: 'Processes automated',
    desc: 'Recurring steps are handled automatically — from intake to confirmation, follow-up and reporting. No manual work.',
  },
  {
    icon: 'bar-chart-2',
    title: 'Immediate insight',
    desc: 'You see in real time what is happening in your process, so you can adjust and decide faster.',
  },
  {
    icon: 'mail',
    title: 'Automatic communication',
    desc: 'Users and stakeholders are kept informed automatically — confirmations, updates and reminders, without extra effort.',
  },
  {
    icon: 'trending-up',
    title: 'Grows with you',
    desc: 'The system grows with you: more users, more data and more workflows, without rebuilding from scratch.',
  },
  {
    icon: 'git-merge',
    title: 'Connected to your tools',
    desc: 'Custom API integrations link the platform to the software you already use, so everything stays in sync.',
  },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Custom Platforms',
  description:
    'Replace disconnected tools and manual work with one system that grows with you — everything in one place for your processes, users and data.',
  provider: {
    '@type': 'ProfessionalService',
    name: 'LaventeCare',
    url: 'https://www.laventecare.com',
  },
  areaServed: ['NL', 'BE', 'DE', 'International'],
  serviceType: 'Custom Platform Software Development',
  serviceOutput: 'Custom platforms, live dashboards and custom API integrations',
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

<Layout
  title="Custom Platforms — One System That Grows With You | LaventeCare"
  description="Replace disconnected tools and manual work with one system that grows with you. Everything in one place for your processes, users and data — automated and reliable."
>
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto mb-16">
        <span
          class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-3 flex items-center gap-2"
        >
          <Icon name="building-2" size={16} class="text-active" /> Custom Platforms
        </span>
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 font-display tracking-tight"
        >
          Everything in <span class="text-active">one place</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 font-ui leading-relaxed mb-4">
          Many organisations work with disconnected tools and manual processes. That leaves their
          data and workflows fragmented and error-prone. LaventeCare builds platforms that bring
          everything together in one system — automatic, reliable and growing with you.
        </p>
        <p class="text-base text-active/80 font-ui font-bold mb-6">
          One system that grows with you — everything in one place for your processes.
        </p>
        <div class="flex flex-wrap gap-2">
          {
            [
              'One system:',
              'Everything in one place',
              'Workflows',
              'Integrations',
              'Dashboards',
              'Management',
            ].map((t) => <TechStackBadge tech={t} />)
          }
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto mb-16">
        {
          features.map((f, i) => (
            <div
              data-animate="fade-up"
              class={`delay-${(i % 3) * 100} clinical-glass p-5 rounded-(--radius-card) border border-white/8 hover:border-active/20 transition-colors group`}
            >
              <div class="flex items-start gap-3 mb-3">
                <div class="w-9 h-9 rounded-lg bg-active/10 flex items-center justify-center shrink-0 group-hover:bg-active/20 transition-colors">
                  <Icon name={f.icon as IconName} size={18} class="text-active" />
                </div>
                <h3 class="text-sm font-bold text-white font-display pt-1.5">{f.title}</h3>
              </div>
              <p class="text-white/60 text-xs font-ui leading-relaxed">{f.desc}</p>
            </div>
          ))
        }
      </div>

      <!-- References -->
      <div class="max-w-3xl mx-auto">
        <p class="text-white/50 text-sm font-ui mb-4 text-center">Reference projects</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <a
            href="/portfolio/de-koninklijke-loop"
            data-animate="fade-up"
            class="clinical-glass p-6 rounded-(--radius-feature) border border-white/8 hover:border-active/30 transition-colors group"
          >
            <h3
              class="text-lg font-bold text-white font-display mb-1 group-hover:text-active transition-colors"
            >
              De Koninklijke Loop
            </h3>
            <p class="text-white/60 text-sm font-ui mb-2">
              Platform with real-time registration and live data.
            </p>
            <p class="text-active text-xs font-bold font-ui">
              Real-time registration • automated processing for the organisation
            </p>
          </a>
          <a
            href="/portfolio/whisky-for-charity"
            data-animate="fade-up"
            class="clinical-glass p-6 rounded-(--radius-feature) border border-white/8 hover:border-active/30 transition-colors group"
          >
            <h3
              class="text-lg font-bold text-white font-display mb-1 group-hover:text-active transition-colors"
            >
              Whisky for Charity
            </h3>
            <p class="text-white/60 text-sm font-ui mb-2">
              Charity platform with secure donation flows.
            </p>
            <p class="text-active text-xs font-bold font-ui">
              Astro • HTML email • secure donation flow
            </p>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container mx-auto px-4 text-center">
      <a href="/contact?type=platform" class="btn-primary">
        Book a free intro call
        <Icon name="arrow-right" size={16} />
      </a>
      <p class="text-white/40 text-sm font-ui mt-3">
        Book a free intro call and discover how to save time and regain overview.
      </p>
    </div>
  </section>
</Layout>
