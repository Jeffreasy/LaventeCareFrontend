---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/blocks/Hero.astro';
import Icon from '../components/ui/Icon.astro';
import FAQSection from '../components/blocks/FAQSection.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import StatCard from '../components/ui/StatCard.astro';
import PillarCard from '../components/blocks/PillarCard.astro';

const heroData = {
  headline: 'B2B systems partner for SMEs',
  subtitle: 'From idea to working system',
  description:
    'For SMEs that want to get digital growth, automation and custom software <span class="text-active font-bold">done right</span>. Not a one-off website builder or freelancer, but a <span class="text-active font-bold">long-term partner</span> that turns the way you work into software that does the work for you.',
  ctaPrimary: {
    label: 'Book a free intro call',
    url: '/contact',
  },
  ctaSecondary: {
    label: 'View portfolio',
    url: '/portfolio',
  },
  stats: [
    { value: '6+', label: 'Live projects' },
    { value: '6', label: 'Integrated services' },
    { value: '1', label: 'Dedicated point of contact' },
  ],
  alignment: 'center' as const,
  size: 'large' as const,
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'LaventeCare',
  url: 'https://www.laventecare.com',
  logo: 'https://www.laventecare.com/og-image.png',
  image: 'https://www.laventecare.com/og-image.png',
  description:
    'LaventeCare builds systems that make businesses more efficient, prevent errors and accelerate growth: AI, IoT, custom platforms, lead generation and security-first systems.',
  founder: {
    '@type': 'Person',
    name: 'Jeffrey Lavente',
    jobTitle: 'Systems Engineer & Founder',
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Spiegelstraat 6',
    postalCode: '8251 ZB',
    addressLocality: 'Dronten',
    addressRegion: 'Flevoland',
    addressCountry: 'NL',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 52.5286,
    longitude: 5.7178,
  },
  telephone: '+31-6-39034085',
  areaServed: ['NL', 'BE', 'DE', 'International'],
  priceRange: '€75 - €300+/month',
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '17:00',
    },
  ],
  knowsAbout: [
    'IT Consultancy',
    'Security-first Systems',
    'AI & Automation',
    'B2B Custom Platforms',
    'IoT Telemetry',
    'PostgreSQL RLS',
    'Data Isolation',
    'GDPR Compliance',
    'API Integrations',
    'Systems Engineering',
    'Discovery & Blueprinting',
    'Digital Transformation',
  ],
  sameAs: [
    'https://linkedin.com/in/jeffrey-lavente',
    'https://github.com/Jeffreasy',
    'https://www.instagram.com/jjalavente/',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'jeffrey@laventecare.nl',
    contactType: 'customer service',
    availableLanguage: ['Dutch', 'English'],
  },
};

const pillars = [
  {
    title: 'IT Consultancy',
    description:
      'An independent sparring partner and second opinion, without any obligation to build. Straightforward advice on your digital direction, architecture and next step.',
    icon: 'message-circle',
    tags: ['Sparring partner', 'Second opinion', 'Roadmap'],
    href: '/services/consultancy',
  },
  {
    title: 'AI & Automation',
    description:
      'AI that takes over repetitive work and uses your data for faster decisions. Reliable, measurable and with a human who reviews and decides in your daily processes.',
    icon: 'brain-circuit',
    tags: ['Automation', 'Data processing', 'A human decides'],
    href: '/services/ai-prompt-engineering',
    featured: true,
  },
  {
    title: 'Smart Monitoring & Sensors',
    description:
      'From sensor to dashboard: detect problems early and reduce downtime. Real-time insight into your processes, remotely and without manual management.',
    icon: 'radio',
    tags: ['Sensor data', 'Alerting', 'Dashboards'],
    href: '/services/iot-hardware',
  },
  {
    title: 'Custom Platforms',
    description:
      'Replace separate tools and manual work with one system that grows with you: one central place where all your data is correct and up to date, built for stability and growth.',
    icon: 'building-2',
    tags: ['B2B Portals', 'Integrations', 'Everything in one place'],
    href: '/services/custom-platforms',
  },
  {
    title: 'Lead Generation',
    description:
      'Your website becomes a system that turns visitors into enquiries. Visitors are directed toward a quote or enquiry, so they become customers faster.',
    icon: 'target',
    tags: ['Manage enquiries', 'Become a customer', 'SEO'],
    href: '/services/lead-generation',
  },
  {
    title: 'Security & Authentication',
    description:
      'Your data is strictly separated per client and protected, even in the event of errors or attacks. Under the hood: PostgreSQL RLS, role-based access (RBAC) and full logging.',
    icon: 'shield-check',
    tags: ['Separated client data', 'Access per role', 'Everything logged'],
    href: '/services/security',
    featured: true,
  },
] as const;
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<Layout
  title="LaventeCare — B2B systems partner for SMEs | Netherlands"
  description="B2B systems partner for SMEs that want to get digital growth, automation and custom software done right. From idea to working system."
>
  <Hero {...heroData} />

  <!-- Core Services -->
  <section class="section-padding relative overflow-hidden">
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-active/5 rounded-full blur-3xl pointer-events-none"
    >
    </div>

    <div class="container mx-auto px-4 relative">
      <SectionHeader
        label="Services"
        heading='Six services, one <span class="text-active">working system</span>'
        description="Not separate projects, but an integrated system: each service strengthens the other. From advice and AI automation to custom platforms and security — together from idea to working system."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        {pillars.map((pillar) => <PillarCard {...pillar} />)}
      </div>
    </div>
  </section>

  <!-- USPs -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Differentiators"
        heading='Why <span class="text-active">LaventeCare</span>?'
        description="A long-term partner that turns the way you work into software that does the work for you: from intake and Blueprint (the build plan) to build, maintenance and further development — with built-in security."
      />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <!-- USP 1 -->
        <div
          data-animate="fade-up"
          class="clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8 text-center group hover:border-active/20 transition-colors"
        >
          <div
            class="w-14 h-14 rounded-2xl bg-active/10 flex items-center justify-center mx-auto mb-5 group-hover:scale-110 transition-transform"
          >
            <Icon name="link" size={24} class="text-active" />
          </div>
          <h3 class="text-lg font-bold text-white mb-3 font-display">
            One point of contact, full ownership
          </h3>
          <p class="text-white/60 text-sm leading-relaxed font-ui">
            From intake to go-live — one fixed point of contact who knows your processes and system
            inside out. No rotating developers, no miscommunication, no knowledge loss.
          </p>
        </div>

        <!-- USP 2 -->
        <div
          data-animate="fade-up"
          class="delay-100 clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8 text-center group hover:border-active/20 transition-colors"
        >
          <div
            class="w-14 h-14 rounded-2xl bg-active/10 flex items-center justify-center mx-auto mb-5 group-hover:scale-110 transition-transform"
          >
            <Icon name="zap" size={24} class="text-active" />
          </div>
          <h3 class="text-lg font-bold text-white mb-3 font-display">
            Security-first architecture
          </h3>
          <p class="text-white/60 text-sm leading-relaxed font-ui">
            Your data is strictly separated per client and every action is logged. Under the hood:
            Privacy by Design with PostgreSQL RLS, role-based access (RBAC) and full logging.
          </p>
        </div>

        <!-- USP 3 -->
        <div
          data-animate="fade-up"
          class="delay-200 clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8 text-center group hover:border-active/20 transition-colors"
        >
          <div
            class="w-14 h-14 rounded-2xl bg-active/10 flex items-center justify-center mx-auto mb-5 group-hover:scale-110 transition-transform"
          >
            <Icon name="gauge" size={24} class="text-active" />
          </div>
          <h3 class="text-lg font-bold text-white mb-3 font-display">Fast and stable by design</h3>
          <p class="text-white/60 text-sm leading-relaxed font-ui">
            Server-rendered pages and focused interactive components keep the interface light. Speed
            and stability are design principles, with results validated per delivery.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="py-8 md:py-12">
    <div class="container mx-auto px-4">
      <div
        data-animate="scale-up"
        class="clinical-glass p-6 md:p-8 rounded-(--radius-hero) border border-white/8 max-w-4xl mx-auto"
      >
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <StatCard value="6+" label="Live projects" />
          <StatCard value="6" label="Integrated services" />
          <StatCard value="1" label="Dedicated point of contact" />
          <StatCard value="SLA" label="Managed maintenance available" />
        </div>
      </div>
    </div>
  </section>

  <!-- Portfolio Preview -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="References"
        heading='Proven in <span class="text-active">practice</span>'
        description="No demos — real systems used daily that deliver demonstrable results."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        <a
          href="https://dekoninklijkeloop.nl"
          target="_blank"
          rel="noopener noreferrer"
          class="group clinical-glass p-6 rounded-(--radius-feature) border border-white/8 hover:border-active/30 transition-all cursor-pointer"
        >
          <div class="flex items-start justify-between mb-4">
            <h3
              class="text-xl font-bold text-white font-display group-hover:text-active transition-colors"
            >
              De Koninklijke Loop
            </h3>
            <span
              class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20"
              >Event</span
            >
          </div>
          <p class="text-white/60 text-sm mb-4 font-ui leading-relaxed">
            Real-time registration platform for a charity event. Registrations are processed
            instantly, with no manual management for the organisation.
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Astro</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">React 19</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Convex</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Go Auth</span>
          </div>
          <div class="flex items-center gap-4 py-3 mb-4 border-t border-b border-white/5">
            <div class="flex items-center gap-1.5">
              <Icon name="check" size={14} class="text-active" />
              <span class="text-white/70 text-xs font-ui">Real-time registration</span>
            </div>
            <div class="flex items-center gap-1.5">
              <Icon name="check" size={14} class="text-active" />
              <span class="text-white/70 text-xs font-ui">Automated processing</span>
            </div>
          </div>
          <span class="text-active text-sm font-bold flex items-center gap-2 font-ui">
            View project
            <Icon
              name="arrow-right"
              size={16}
              class="group-hover:translate-x-1 transition-transform"
            />
          </span>
        </a>

        <a
          href="https://www.smartcoolcare.nl"
          target="_blank"
          rel="noopener noreferrer"
          class="group clinical-glass p-6 rounded-(--radius-feature) border border-white/8 hover:border-active/30 transition-all cursor-pointer"
        >
          <div class="flex items-start justify-between mb-4">
            <h3
              class="text-xl font-bold text-white font-display group-hover:text-active transition-colors"
            >
              SmartCoolCare
            </h3>
            <span
              class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20"
              >IoT</span
            >
          </div>
          <p class="text-white/60 text-sm mb-4 font-ui leading-relaxed">
            Cooling monitoring with automatic alerts on deviations. Sensor data directly visible on
            your screen, wherever you are.
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">C++</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">ESP32</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">BLE</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Convex</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">React</span>
          </div>
          <div class="flex items-center gap-4 py-3 mb-4 border-t border-b border-white/5">
            <div class="flex items-center gap-1.5">
              <Icon name="check" size={14} class="text-active" />
              <span class="text-white/70 text-xs font-ui">Real-time sensor data</span>
            </div>
            <div class="flex items-center gap-1.5">
              <Icon name="check" size={14} class="text-active" />
              <span class="text-white/70 text-xs font-ui">Automatic alerting</span>
            </div>
          </div>
          <span class="text-active text-sm font-bold flex items-center gap-2 font-ui">
            View project
            <Icon
              name="arrow-right"
              size={16}
              class="group-hover:translate-x-1 transition-transform"
            />
          </span>
        </a>
      </div>

      <div class="text-center mt-8">
        <a href="/portfolio" class="btn-secondary">
          View all projects
          <Icon name="arrow-right" size={16} />
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div
        class="clinical-glass p-8 md:p-12 rounded-(--radius-hero) border border-active/20 max-w-4xl mx-auto text-center"
      >
        <span class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-4 block"
          >The person behind the system</span
        >
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 font-display">Jeffrey Lavente</h2>
        <p
          class="text-white/70 text-base md:text-lg leading-relaxed mb-6 max-w-2xl mx-auto font-ui"
        >
          Systems engineer with a background in intensive neurological rehabilitation care. I build
          systems that are not only technically solid, but also provide structure and safety in the
          real world.
        </p>
        <p class="text-white/40 text-sm font-ui mb-6">
          Book a free intro call and discover where you can immediately save time, costs or risk.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/about" class="btn-secondary"> Read my story </a>
          <a href="/contact" class="btn-primary">
            Book a free intro call
            <Icon name="arrow-right" size={16} />
          </a>
        </div>
      </div>
    </div>
  </section>

  <FAQSection locale="en" />
</Layout>
