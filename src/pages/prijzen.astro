---
import Layout from '../layouts/Layout.astro';
import PricingOverview from '../components/blocks/PricingOverview.astro';

const pricingSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'LaventeCare',
  url: 'https://www.laventecare.nl/prijzen',
  priceRange: '€750 - €1.500+ eenmalig; websitebeheer vanaf €29/maand',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'LaventeCare prijzen en beheer',
    itemListElement: [
      {
        '@type': 'Offer',
        name: 'Website Start',
        price: '750',
        priceCurrency: 'EUR',
        description: 'Een complete responsive one-page bedrijfswebsite.',
      },
      {
        '@type': 'Offer',
        name: 'Website Business',
        price: '1000',
        priceCurrency: 'EUR',
        description:
          'Een bedrijfswebsite tot drie pagina’s met veilig formulier en automatische bevestiging.',
      },
      {
        '@type': 'Offer',
        name: 'Website Maatwerk',
        price: '1500',
        priceCurrency: 'EUR',
        description: 'Maatwerkwebsite vanaf €1.500.',
      },
      {
        '@type': 'Offer',
        name: 'Website Care Start',
        price: '29',
        priceCurrency: 'EUR',
        unitText: 'per maand',
        description: 'Beheerde hosting, SSL, bewaking en technische updates.',
      },
      {
        '@type': 'Offer',
        name: 'Website Care Business',
        price: '49',
        priceCurrency: 'EUR',
        unitText: 'per maand',
        description: 'Websitebeheer met bewaking van formulier en transactionele e-mail.',
      },
      {
        '@type': 'Offer',
        name: 'Website Care Maatwerk',
        price: '75',
        priceCurrency: 'EUR',
        unitText: 'per maand',
        description: 'Maatwerkhosting, bewaking en technische continuïteit vanaf €75 per maand.',
      },
      {
        '@type': 'Offer',
        name: 'IT Advies & Consultancy',
        price: '95',
        priceCurrency: 'EUR',
        unitText: 'per uur',
        description: 'Onafhankelijk technisch advies zonder verplicht bouwtraject.',
      },
      {
        '@type': 'AggregateOffer',
        name: 'Onderzoek & Blueprint',
        lowPrice: '500',
        highPrice: '1500',
        priceCurrency: 'EUR',
        description: 'Onderzoek en een bruikbaar technisch bouwplan voor maatwerkontwikkeling.',
      },
      {
        '@type': 'Offer',
        name: 'SLA Essential',
        price: '75',
        priceCurrency: 'EUR',
        unitText: 'per maand',
        description: 'Technische continuïteit voor een compact maatwerksysteem.',
      },
      {
        '@type': 'Offer',
        name: 'SLA Professional',
        price: '150',
        priceCurrency: 'EUR',
        unitText: 'per maand',
        description: 'Proactief beheer met vier gereserveerde supporturen per maand.',
      },
      {
        '@type': 'Offer',
        name: 'SLA Continuity',
        price: '300',
        priceCurrency: 'EUR',
        unitText: 'per maand',
        description: 'Bedrijfskritische continuïteit en uitgebreid beheer vanaf €300 per maand.',
      },
    ],
  },
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(pricingSchema)} />

<Layout
  title="Prijzen & Tarieven — Websites, Systemen en Beheer | LaventeCare"
  description="Transparante tarieven voor websites, advies, B2B maatwerkplatformen en beheer. Websitebouw vanaf €750 en Website Care vanaf €29 per maand."
>
  <PricingOverview locale="nl" />
</Layout>
