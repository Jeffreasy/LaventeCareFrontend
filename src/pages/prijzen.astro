---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import Icon from '../components/ui/Icon.astro';

const pricingSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'LaventeCare',
  url: 'https://www.laventecare.nl/prijzen',
  priceRange: '€75 - €300+/maand',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'LaventeCare Diensten & SLA',
    itemListElement: [
      {
        '@type': 'Offer',
        name: 'Fase 0: IT Advies & Consultancy',
        price: '95',
        priceCurrency: 'EUR',
        unitText: 'per uur',
        description: 'Technisch sparringpartner en onafhankelijk advies zonder verplicht bouwtraject.',
      },
      {
        '@type': 'Offer',
        name: 'Stap 1: Onderzoek & Blueprint (technisch bouwplan)',
        price: '500',
        priceCurrency: 'EUR',
        description:
          'We onderzoeken precies wat u nodig heeft en ontwerpen het systeem. U krijgt een bruikbaar bouwplan (Blueprint).',
      },
      {
        '@type': 'Offer',
        name: 'Stap 2: Realisatie (Fixed-Price Mijlpalen)',
        price: 'Vaste projectprijs',
        priceCurrency: 'EUR',
        description: 'Vaste prijs op basis van de Blueprint. Facturatie in 40/40/20 mijlpalen.',
      },
      {
        '@type': 'Offer',
        name: 'SLA Essential',
        price: '75',
        priceCurrency: 'EUR',
        unitText: 'per maand',
        description: 'Beheerde hosting, beveiligingsupdates, SSL & domeinbeheer.',
      },
      {
        '@type': 'Offer',
        name: 'SLA Professional',
        price: '150',
        priceCurrency: 'EUR',
        unitText: 'per maand',
        description: 'Proactieve patching, 4 uur support per maand, performance monitoring.',
      },
      {
        '@type': 'Offer',
        name: 'SLA Enterprise',
        price: '300',
        priceCurrency: 'EUR',
        unitText: 'per maand',
        description: 'Voorrang bij grote storingen (we doen ons uiterste best; geen harde garantie tenzij in het contract), plus een vaste back-up developer.',
      },
    ],
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(pricingSchema)} />

<Layout
  title="Prijzen & Tarieven — Transparant en Zonder Verrassingen | LaventeCare"
  description="Transparante investeringen voor B2B maatwerkplatformen. Vaste mijlpaalprijzen (40/40/20) gebaseerd op een technische Blueprint. Geen onverwachte nacalculaties."
>
  <section class="section-padding pt-32 md:pt-40 relative flex items-center overflow-hidden">
    <!-- Floating Background Mesh (Shared style from Hero) -->
    <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
      <div
        class="absolute top-10 right-10 md:right-1/4 w-120 h-120 rounded-full bg-active/15 blur-3xl animate-float-slow will-change-transform mix-blend-screen"
      >
      </div>
      <div
        class="absolute bottom-40 left-10 w-72 h-72 rounded-full bg-secondary/15 blur-3xl animate-float-medium will-change-transform mix-blend-screen"
        style="animation-delay: 1s;"
      >
      </div>
      <div
        class="absolute top-1/3 left-10 md:left-1/3 w-100 h-100 rounded-full blur-[100px] animate-float-fast will-change-transform opacity-50 mix-blend-screen"
        style="background: radial-gradient(circle, oklch(0.65 0.22 15 / 0.25), transparent 70%); animation-delay: 2s;"
      >
      </div>
    </div>
    <div class="absolute inset-0 z-0 opacity-[0.03]">
      <div
        class="absolute inset-0"
        style="background-image: linear-gradient(white 1px, transparent 1px), linear-gradient(90deg, white 1px, transparent 1px); background-size: 50px 50px;"
      >
      </div>
    </div>

    <!-- Content Wrap -->
    <div class="container mx-auto px-4 relative z-10 py-10">
      <SectionHeader
        label="Investering"
        heading='Transparante <span class="text-active">Prijzen</span>'
        description="Geen verrassingen achteraf — duidelijke prijzen, duidelijke fases en volledige controle over uw investering. Elke fase is los af te nemen, zodat u controle houdt over kosten en risico."
      />

      <!-- Project Pricing -->
      <div class="max-w-5xl mx-auto mb-16">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
          <!-- Advies -->
          <div
            data-animate="scale-up"
            class="clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8 flex flex-col"
          >
            <span class="text-active text-xs font-bold uppercase tracking-wider mb-3 font-display"
              >Fase 0</span
            >
            <h3 class="text-xl font-bold text-white mb-2 font-display">IT Advies & Consultancy</h3>
            <p class="text-white/50 text-sm mb-5 font-ui">Sparringpartner en strategisch inzicht</p>
            <div class="text-3xl font-black text-white mb-1 font-display">
              €95 <span class="text-lg text-white/40 font-normal">/ uur</span>
            </div>
            <p class="text-white/40 text-xs mb-6 font-ui">Eerste gesprek gratis</p>
            <div class="h-px bg-white/8 my-4"></div>
            <ul class="space-y-3 mb-6 flex-1 text-sm font-ui text-white/70">
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Onafhankelijk advies
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Geen bouwverplichting
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Second opinion & audit
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Flexibel per uur
              </li>
            </ul>
            <a
              href="/contact?type=advies"
              class="text-center py-3 rounded-lg border border-white/15 text-white hover:bg-white/5 transition-colors font-bold font-ui min-h-12 flex items-center justify-center"
            >
              Plan gesprek
            </a>
          </div>

          <!-- Discovery -->
          <div
            data-animate="scale-up"
            class="clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8 flex flex-col"
          >
            <span class="text-active text-xs font-bold uppercase tracking-wider mb-3 font-display"
              >Stap 1</span
            >
            <h3 class="text-xl font-bold text-white mb-2 font-display">Onderzoek & Blueprint (technisch bouwplan)</h3>
            <p class="text-white/50 text-sm mb-5 font-ui">We onderzoeken uw vraag en ontwerpen het systeem</p>
            <div class="text-3xl font-black text-white mb-1 font-display">
              €500 <span class="text-lg text-white/40 font-normal">– €1.500</span>
            </div>
            <p class="text-white/40 text-xs mb-6 font-ui">Eenmalig, vaste fee — excl. BTW</p>
            <div class="h-px bg-white/8 my-4"></div>
            <ul class="space-y-3 mb-6 flex-1 text-sm font-ui text-white/70">
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> We brengen precies in kaart
                wat u nodig heeft
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Ontwerp van het systeem op
                maat
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Uitgewerkt bouwplan (Blueprint-document)
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> U houdt altijd een bruikbaar
                bouwplan over
              </li>
            </ul>
            <a
              href="/contact?type=discovery"
              class="text-center py-3 rounded-lg border border-white/15 text-white hover:bg-white/5 transition-colors font-bold font-ui min-h-12 flex items-center justify-center"
            >
              Start het vooronderzoek
            </a>
          </div>

          <!-- Ontwikkeling (Featured) -->
          <div
            data-animate="scale-up"
            class="delay-100 clinical-glass p-6 md:p-8 rounded-(--radius-feature) border-2 border-active relative flex flex-col shadow-xl shadow-active/10 md:scale-105 z-10"
          >
            <div
              class="absolute top-0 right-0 bg-active text-white text-[10px] font-bold px-3 py-1 rounded-bl-lg rounded-tr-lg tracking-wider font-display"
            >
              PROJECTWERK
            </div>
            <span class="text-active text-xs font-bold uppercase tracking-wider mb-3 font-display"
              >Stap 2</span
            >
            <h3 class="text-xl font-bold text-white mb-2 font-display">Realisatie</h3>
            <p class="text-white/50 text-sm mb-5 font-ui">Vaste prijs op basis van het bouwplan (Blueprint)</p>
            <div class="text-3xl font-black text-white mb-1 font-display">
              Vaste <span class="text-lg text-white/40 font-normal">Projectprijs</span>
            </div>
            <p class="text-white/40 text-xs mb-6 font-ui">
              Facturatie in fases (40/40/20) — bij niet-betalen mogen we het werk tijdelijk stilleggen (<a href="/voorwaarden" class="text-active hover:underline">opschortingsrecht</a>).
            </p>
            <div class="h-px bg-white/8 my-4"></div>
            <ul class="space-y-3 mb-6 flex-1 text-sm font-ui text-white/70">
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Strak binnen de afspraak uit het bouwplan (Blueprint)
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Tussentijdse demo's &
                acceptatie
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Geen nacalculatie of verrassingen
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Veiligheid vanaf de basis (Zero-Trust)
                inbegrepen
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Extra werk buiten de afspraak gaat altijd via een aparte wijziging (Change Request, €95/uur)
              </li>
              <li class="flex gap-2 text-white/40">
                <span class="text-active"><Icon name="external-link" size={14} /></span>
                <span>Generieke modules &amp; AuthSystem blijven eigendom LaventeCare; klant ontvangt
                gebruiksrecht — zie <a href="/voorwaarden" class="text-active hover:underline">voorwaarden</a></span>
              </li>
            </ul>
            <a
              href="/contact?type=project"
              class="text-center py-3 rounded-lg bg-active text-white font-bold hover:bg-active/90 transition-colors font-ui shadow-lg shadow-active/25 min-h-12 flex items-center justify-center"
            >
              Start een project
            </a>
          </div>

          <!-- IoT Licentie -->
          <div
            data-animate="scale-up"
            class="delay-200 clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8 flex flex-col"
          >
            <span class="text-active text-xs font-bold uppercase tracking-wider mb-3 font-display"
              >Per Device</span
            >
            <h3 class="text-xl font-bold text-white mb-2 font-display">IoT Koppeling</h3>
            <p class="text-white/50 text-sm mb-5 font-ui">Groeit mee per apparaat</p>
            <div class="text-3xl font-black text-white mb-1 font-display">
              Vanaf €2<span class="text-lg text-white/40 font-normal">/apparaat per maand</span>
            </div>
            <p class="text-white/40 text-xs mb-6 font-ui">Groeit mee naarmate uw systeem groeit</p>
            <div class="h-px bg-white/8 my-4"></div>
            <ul class="space-y-3 mb-6 flex-1 text-sm font-ui text-white/70">
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Veilig binnenhalen van sensorgegevens
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Real-time data-opslag
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Beheerde cloud-infrastructuur
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Veilige apparaat-verificatie
              </li>
            </ul>
            <a
              href="/contact?type=iot"
              class="text-center py-3 rounded-lg border border-white/15 text-white hover:bg-white/5 transition-colors font-bold font-ui min-h-12 flex items-center justify-center"
            >
              Koppel hardware
            </a>
          </div>
        </div>
      </div>

      <!-- SLA Tiers -->
      <div class="max-w-5xl mx-auto mb-16">
        <SectionHeader
          label="Na oplevering"
          heading='Onderhoud met <span class="text-active">vaste afspraken (SLA)</span>'
          description="Uw systeem blijft veilig, up-to-date en beschikbaar — ook na oplevering. Dit regelt u met een onderhoudscontract met vaste afspraken (SLA). Kies het niveau dat bij uw bedrijf past."
        />

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Basic -->
          <div class="clinical-glass p-6 rounded-(--radius-feature) border border-white/8">
            <h3 class="text-lg font-bold text-white mb-1 font-display">Essential</h3>
            <div class="text-2xl font-black text-white font-display mb-1">
              €75<span class="text-sm text-white/40 font-normal">/maand</span>
            </div>
            <p class="text-white/40 text-xs mb-4 font-ui">Hosting &amp; bewaking van beschikbaarheid · prijs stijgt jaarlijks mee met de inflatie (CBS)</p>
            <ul class="space-y-2 text-xs font-ui text-white/60">
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Beheerde hosting
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Beveiligingsupdates
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> SSL & domeinbeheer
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> E-mail bezorging
              </li>
            </ul>
          </div>

          <!-- Pro -->
          <div
            class="clinical-glass p-6 rounded-(--radius-feature) border border-active/30 bg-active/5"
          >
            <span class="text-active text-[10px] font-bold uppercase tracking-wider font-display"
              >Aanbevolen</span
            >
            <h3 class="text-lg font-bold text-white mb-1 font-display">Professional</h3>
            <div class="text-2xl font-black text-white font-display mb-1">
              €150<span class="text-sm text-white/40 font-normal">/maand</span>
            </div>
            <p class="text-white/40 text-xs mb-4 font-ui">Bewaking, snelheid & rapportage</p>
            <ul class="space-y-2 text-xs font-ui text-white/60">
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Alles uit Basic
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> We werken onderdelen van buitenaf op tijd bij
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> 4 uur support per maand
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Snelheid bewaakt
              </li>
            </ul>
          </div>

          <!-- Enterprise -->
          <div class="clinical-glass p-6 rounded-(--radius-feature) border border-white/8">
            <h3 class="text-lg font-bold text-white mb-1 font-display">Enterprise</h3>
            <div class="text-2xl font-black text-white font-display mb-1">
              €300+<span class="text-sm text-white/40 font-normal">/maand</span>
            </div>
            <p class="text-white/40 text-xs mb-4 font-ui">24/7 bewaking, voorrang & Observatory AI</p>
            <ul class="space-y-2 text-xs font-ui text-white/60">
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Alles uit Professional
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Live bewaking met Observatory AI
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Voorrang bij P1-incidenten (volledige uitval)
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> 24/7 bereikbaarheid voor bedrijfskritieke incidenten
              </li>
              <li class="flex gap-2">
                <span class="text-active"><Icon name="check" size={14} /></span> Wekelijks pro-actief onderhoud
              </li>
            </ul>
            <p class="text-white/35 text-[10px] mt-3 font-ui leading-relaxed">
              Richtwaarden voor reactietijden (P1 volledige uitval · P2 zware verstoring met tijdelijke oplossing · P3/P4 beperkt of cosmetisch): we doen ons uiterste best om deze tijden te halen, maar het zijn richtlijnen — geen harde garantie, tenzij dat in het contract staat.
            </p>
          </div>
        </div>
      </div>
      <!-- Filosofie & Tarief -->
      <div class="max-w-4xl mx-auto mb-16">
        <SectionHeader
          label="Werkwijze"
          heading='Stap voor stap bouwen, <span class="text-active">betrouwbaar</span> opleveren'
        />
        <div
          class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-active/20 bg-active/5"
        >
          <p class="text-white/80 text-sm md:text-base leading-relaxed font-ui mb-4">
            Mijn werkwijze is stap voor stap: systemen worden stukje voor stukje gebouwd, getest en
            verbeterd. Hierdoor ontstaat een <span class="text-white font-semibold"
              >stabiel en betrouwbaar eindproduct</span
            > dat we continu kunnen blijven verbeteren. Als er iets onverwachts gebeurt, wordt het rustig
            uitgezocht, opgelost en direct steviger teruggebouwd. <span
              class="text-active font-semibold">Transparantie staat hierbij voorop</span
            >.
          </p>
          <p class="text-white/80 text-sm md:text-base leading-relaxed font-ui mb-6">
            Omdat we altijd eerst onderzoeken en ontwerpen (Discovery), haalt u geen "template-bouwer" in huis, maar
            iemand die uw <span class="text-white font-semibold">systeem echt doordenkt en bouwt</span>. We werken met vaste projectprijzen op basis van een uitgewerkt bouwplan (Blueprint). Geen verborgen uurtje-factuurtje, geen anonieme helpdesk, maar directe lijnen, strak binnen de afspraak blijven en keiharde garanties.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="flex items-start gap-3 p-3 rounded-lg bg-white/3 border border-white/5">
              <Icon name="brain-circuit" size={18} class="text-active shrink-0 mt-0.5" />
              <div>
                <p class="text-white text-xs font-bold font-display">Zelf ontworpen, niet in elkaar geklikt</p>
                <p class="text-white/50 text-[11px] font-ui">AI helpt bij het bouwen; ik ontwerp en beveilig het systeem</p>
              </div>
            </div>
            <div class="flex items-start gap-3 p-3 rounded-lg bg-white/3 border border-white/5">
              <Icon name="trending-up" size={18} class="text-active shrink-0 mt-0.5" />
              <div>
                <p class="text-white text-xs font-bold font-display">Stap voor stap</p>
                <p class="text-white/50 text-[11px] font-ui">
                  Stukje voor stukje gebouwd, continu verbeterd
                </p>
              </div>
            </div>
            <div class="flex items-start gap-3 p-3 rounded-lg bg-white/3 border border-white/5">
              <Icon name="handshake" size={18} class="text-active shrink-0 mt-0.5" />
              <div>
                <p class="text-white text-xs font-bold font-display">Directe lijnen</p>
                <p class="text-white/50 text-[11px] font-ui">
                  Geen tussenpersonen, één aanspreekpunt
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Juridisch / Voorwaarden -->
      <div class="text-center mt-8">
        <p class="text-white/35 text-xs font-ui">
          Op alle opdrachten zijn de
          <a href="/voorwaarden" class="text-active hover:text-active/80 transition-colors underline underline-offset-2">Algemene Voorwaarden</a>
          van LaventeCare van toepassing — inclusief afspraken over oplevering, acceptatie,
          eigendomsrecht en aansprakelijkheid.
        </p>
      </div>

      <!-- Werkwijze link -->
      <div class="text-center">
        <a href="/contact" class="btn-primary">
          Plan een intake
          <Icon name="arrow-right" size={16} />
        </a>
        <p class="text-white/40 text-sm font-ui mt-3">
          Plan een intake en ontvang een concrete inschatting voor uw project.
        </p>
      </div>
    </div>
  </section>
</Layout>
