---
import Layout from '../layouts/Layout.astro';
import Card from '../components/ui/Card.astro';
import { ContactForm } from '../components/islands/ContactForm';

const pageTitle = 'Contact - LaventeCare';
const pageDescription = 'Neem contact op met LaventeCare voor high-performance web development en veilige backend oplossingen.';
---

<Layout title={pageTitle} description={pageDescription}>
  <!-- Contact Hero Section -->
  <section class="bg-linear-to-b from-panel to-background py-24">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h1
          class="text-5xl md:text-6xl font-black text-white mb-4 font-display tracking-tight"
          transition:name="contact-title"
        >
          Neem <span class="text-active">contact</span> op
        </h1>
        <p class="text-xl text-white/70 font-ui">
          Vul het formulier in en we nemen <span class="text-white font-medium">zo snel mogelijk</span> contact met je op.
        </p>
      </div>

      <Card padding="lg" class="max-w-2xl mx-auto">
        <ContactForm client:visible />
      </Card>
    </div>
  </section>

  <!-- Contact Info Section -->
  <section class="bg-background py-16" aria-labelledby="contact-info-heading">
    <div class="container mx-auto px-4">
      <h2
        id="contact-info-heading"
        class="text-3xl font-bold text-center text-white mb-8 font-display"
      >
        Andere manieren om <span class="text-active">contact</span> op te nemen
      </h2>

      <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <Card hover padding="md" class="text-center">
          <div class="text-3xl mb-3">📧</div>
          <h3 class="font-semibold text-white mb-2">Email</h3>
          <p class="text-white/70 text-sm">info@laventecare.nl</p>
        </Card>

        <!-- Placeholder Data Commented Out for SEO Trust -->
        <!--
        <Card hover padding="md" class="text-center">
          <div class="text-3xl mb-3">📞</div>
          <h3 class="font-semibold text-white mb-2">Telefoon</h3>
          <p class="text-white/70 text-sm">+31 (0) 20 123 4567</p>
        </Card>

        <Card hover padding="md" class="text-center">
          <div class="text-3xl mb-3">📍</div>
          <h3 class="font-semibold text-white mb-2">Adres</h3>
          <p class="text-white/70 text-sm">Amsterdam, Nederland</p>
        </Card>
        -->
      </div>
    </div>
  </section>
    </div>
  </section>
</Layout>
