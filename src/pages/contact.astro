---
import Layout from '../layouts/Layout.astro';
import Card from '../components/ui/Card.astro';
import { ContactForm } from '../components/islands/ContactForm';
import Icon from '../components/ui/Icon.astro';

const pageTitle = 'Contact — LaventeCare';
const pageDescription =
  'Neem contact op voor een gratis intake gesprek van 30 minuten. Bespreek uw project, scope en technische haalbaarheid.';
---

<Layout title={pageTitle} description={pageDescription}>
  <!-- Contact Hero Section -->
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-3 block">Contact</span>
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-4 font-display tracking-tight"
          transition:name="contact-title"
        >
          Laten we <span class="text-active">praten</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 font-ui">
          Begin met een <span class="text-white font-semibold">gratis intake gesprek</span> van 30 minuten. Ik bespreek met u de scope, technische haalbaarheid en budgetindicatie.
        </p>
      </div>

      <Card padding="lg" class="max-w-2xl mx-auto">
        <ContactForm client:visible />
      </Card>
    </div>
  </section>

  <!-- Contact Info Section -->
  <section class="section-padding" aria-labelledby="contact-info-heading">
    <div class="container mx-auto px-4">
      <h2
        id="contact-info-heading"
        class="text-2xl md:text-3xl font-bold text-center text-white mb-8 font-display"
      >
        Andere manieren om <span class="text-active">contact</span> op te nemen
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto">
        <Card hover padding="md" class="text-center">
          <Icon name="mail" size={24} class="text-active block mb-3 mx-auto" />
          <h3 class="font-semibold text-white mb-2 text-sm font-display">Email</h3>
          <a
            href="mailto:jeffrey@laventecare.nl"
            class="text-active hover:text-primary-hover transition-colors text-sm font-medium font-ui"
          >jeffrey@laventecare.nl</a>
        </Card>

        <Card hover padding="md" class="text-center">
          <Icon name="clock" size={24} class="text-active block mb-3 mx-auto" />
          <h3 class="font-semibold text-white mb-2 text-sm font-display">Reactietijd</h3>
          <p class="text-white/70 text-sm font-ui">Binnen 24 uur op werkdagen</p>
        </Card>

        <Card hover padding="md" class="text-center">
          <Icon name="map-pin" size={24} class="text-active block mb-3 mx-auto" />
          <h3 class="font-semibold text-white mb-2 text-sm font-display">Locatie</h3>
          <p class="text-white/70 text-sm font-ui">Dronten, Nederland</p>
        </Card>

        <Card hover padding="md" class="text-center">
          <Icon name="briefcase" size={24} class="text-active block mb-3 mx-auto" />
          <h3 class="font-semibold text-white mb-2 text-sm font-display">LinkedIn</h3>
          <a
            href="https://linkedin.com/in/jeffrey-lavente"
            target="_blank"
            rel="noopener noreferrer"
            class="text-active hover:text-primary-hover transition-colors text-sm font-medium font-ui"
          >Connecten</a>
        </Card>
      </div>
    </div>
  </section>

  <!-- Intake info -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-active/20 max-w-3xl mx-auto">
        <h3 class="text-lg font-bold text-white mb-4 font-display text-center">Wat kunt u verwachten?</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
          <div>
            <span class="text-active text-2xl font-black font-display block mb-1">30 min</span>
            <p class="text-white/60 text-xs font-ui">Vrijblijvend intake gesprek</p>
          </div>
          <div>
            <span class="text-active text-2xl font-black font-display block mb-1">Go/No-Go</span>
            <p class="text-white/60 text-xs font-ui">Eerlijk advies over haalbaarheid</p>
          </div>
          <div>
            <span class="text-active text-2xl font-black font-display block mb-1">24 uur</span>
            <p class="text-white/60 text-xs font-ui">Reactie op werkdagen</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
