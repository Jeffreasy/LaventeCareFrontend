---
import Layout from '../layouts/Layout.astro';

// Force server rendering for auth middleware
export const prerender = false;
---

<Layout
  title="Admin - LaventeCare"
  description="LaventeCare admin dashboard: gebruikersbeheer, e-mail configuratie, tenant-overzicht en systeeminstellingen."
>
  <div class="min-h-screen pt-24 pb-16">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="mb-8">
          <h1 class="text-4xl font-bold text-white mb-2 font-display tracking-tight">
            Admin <span class="text-active">Dashboard</span>
          </h1>
          <p class="text-white/60 font-ui">Manage your LaventeCare system settings</p>
        </div>

        <!-- Quick Actions Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Settings Card -->
          <a href="/admin/settings" class="clinical-glass-hover p-6">
            <div class="flex items-center space-x-4">
              <div class="w-12 h-12 rounded-lg bg-active/10 flex items-center justify-center">
                <svg
                  class="w-6 h-6 text-active"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
                  ></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div>
                <h2 class="text-lg font-bold text-white font-display">Settings</h2>
                <p class="text-sm text-white/60 font-ui">Email, security & more</p>
              </div>
            </div>
          </a>

          <!-- Users Card (Future) -->
          <div class="clinical-glass p-6 opacity-50 cursor-not-allowed">
            <div class="flex items-center space-x-4">
              <div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center">
                <svg
                  class="w-6 h-6 text-white/50"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"
                  ></path>
                </svg>
              </div>
              <div>
                <h2 class="text-lg font-bold text-white/50 font-display">Users</h2>
                <p class="text-sm text-white/40 font-ui">Coming soon</p>
              </div>
            </div>
          </div>

          <!-- Audit Logs Card (Future) -->
          <div class="clinical-glass p-6 opacity-50 cursor-not-allowed">
            <div class="flex items-center space-x-4">
              <div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center">
                <svg
                  class="w-6 h-6 text-white/50"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                  ></path>
                </svg>
              </div>
              <div>
                <h2 class="text-lg font-bold text-white/50 font-display">Audit Logs</h2>
                <p class="text-sm text-white/40 font-ui">Coming soon</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
