---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/blocks/Hero.astro';
import ShowcaseGrid from '../components/blocks/ShowcaseGrid.astro';
import FAQSection from '../components/blocks/FAQSection.astro';

// Type-safe hero data
const heroData = {
	headline: 'The Foundation for Digital Growth',
	subtitle: 'Next-Gen Web Infrastructure & Digital Experiences.',
	description:
		'LaventeCare biedt het ultieme fundament voor uw digitale ambities. Van <span class="text-active font-bold">bliksemsnelle websites</span> tot <span class="text-active font-bold">complexe data-gedreven applicaties</span>.',
	ctaPrimary: {
		label: 'Start gratis trial',
		url: '/contact',
	},
	ctaSecondary: {
		label: 'Ontdek het ecosysteem',
		url: '#ecosystem',
	},
	stats: [
		{ value: '100/100', label: 'Lighthouse Score' },
		{ value: 'Zero-JS', label: 'Runtime' },
		{ value: 'Anti-Gravity', label: 'Security' },
	],
	alignment: 'center' as const,
	size: 'large' as const,
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "LaventeCare",
  "url": "https://laventecare.nl",
  "logo": "https://laventecare.nl/logo.png",
  "description": "LaventeCare is a high-performance web agency in Amsterdam specialized in Astro-based infrastructure and secure backend systems.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Amsterdam",
    "addressCountry": "NL"
  }
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<Layout title="LaventeCare - The Foundation for Growth">
	<Hero {...heroData} />
	
	<ShowcaseGrid />

	<!-- Service Intro Section -->
	<section id="ecosystem" class="bg-background py-24 relative overflow-hidden">
		<!-- Decorative bg element -->
		<div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[500px] bg-active/5 rounded-full blur-3xl pointer-events-none"></div>

		<div class="container mx-auto px-4 relative">
			<div class="max-w-4xl mx-auto text-center mb-20">
				<span class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-4 block"
					>Het Ecosysteem</span
				>
				<h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 font-display tracking-tight leading-[1.1]">
					Meer dan alleen code
				</h2>
				<p class="text-xl text-white/70">
					LaventeCare is niet zomaar een development agency. Wij bieden een geïntegreerd platform waar snelheid, veiligheid en schaalbaarheid samenkomen. Uw centrale hub voor digitale innovatie.
				</p>
			</div>

			<!-- USPs Section -->
			<!-- USPs Section (Asymmetric Layout) -->
			<div class="grid md:grid-cols-12 gap-8">
				<!-- USP 1: Snelheid (Major Feature - 8 Cols) -->
				<div
					class="md:col-span-8 clinical-glass p-10 rounded-3xl hover:scale-[1.02] transition-transform duration-300 border border-white/10 group flex flex-col justify-between"
				>
					<div>
						<div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-500/20 to-emerald-500/20 flex items-center justify-center mb-8 group-hover:from-blue-500/30 group-hover:to-emerald-500/30 transition-colors">
							<svg class="w-8 h-8 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
						</div>
						<h3 class="text-3xl font-bold text-white mb-4 font-display">Ultieme Snelheid</h3>
						<p class="text-xl text-white/70 max-w-2xl">
							Gebouwd op <strong>Astro</strong>. Wij leveren nagenoeg nul overbodige JavaScript aan de browser. Dit resulteert in topscores in Google Lighthouse en een ongeëvenaarde gebruikerservaring.
						</p>
					</div>
				</div>

				<!-- USP 2: Security (Compact - 4 Cols) -->
				<div
					class="md:col-span-4 clinical-glass p-8 rounded-3xl hover:scale-[1.02] transition-transform duration-300 border border-white/10 group"
				>
					<div class="w-14 h-14 rounded-xl bg-gradient-to-br from-active/20 to-green-500/20 flex items-center justify-center mb-6 group-hover:from-active/30 group-hover:to-green-500/30 transition-colors">
						<svg class="w-8 h-8 text-active" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
					</div>
					<h3 class="text-2xl font-bold text-white mb-3 font-display">Militaire Beveiliging</h3>
					<p class="text-white/70">
						Onze <strong>Anti-Gravity</strong> backend architectuur beschermt uw data met Row Level Security (RLS).
					</p>
				</div>

				<!-- USP 3: Flexibiliteit (Wide Banner - 12 Cols) -->
				<div
					class="md:col-span-12 clinical-glass p-8 md:p-12 rounded-3xl hover:scale-[1.01] transition-transform duration-300 border border-white/10 group flex flex-col md:flex-row items-center gap-8"
				>
					<div class="shrink-0 w-16 h-16 rounded-2xl bg-gradient-to-br from-orange-500/20 to-pink-500/20 flex items-center justify-center group-hover:from-orange-500/30 group-hover:to-pink-500/30 transition-colors">
						<svg class="w-8 h-8 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
					</div>
					<div class="text-center md:text-left">
						<h3 class="text-2xl md:text-3xl font-bold text-white mb-3 font-display">Totale Flexibiliteit</h3>
						<p class="text-xl text-white/70">
							Van een high-converting <strong>landing page</strong> tot een complex <strong>IoT-dashboard</strong>. Het fundament schaalt moeiteloos mee met uw ambities, zonder technische limieten.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<FAQSection />
</Layout>
