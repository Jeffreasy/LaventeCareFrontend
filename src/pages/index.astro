---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/blocks/Hero.astro';
import Icon from '../components/ui/Icon.astro';
import FAQSection from '../components/blocks/FAQSection.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import StatCard from '../components/ui/StatCard.astro';
import PillarCard from '../components/blocks/PillarCard.astro';
import LighthouseGauge from '../components/ui/LighthouseGauge.astro';

const heroData = {
  headline: 'Van idee tot werkend systeem',
  subtitle: 'Geen losse tools, geen complexiteit — alles in één systeem',
  description:
    'Ik bouw systemen die bedrijven <span class="text-active font-bold">efficiënter</span> maken, <span class="text-active font-bold">fouten voorkomen</span> en <span class="text-active font-bold">groei versnellen</span>. Van AI-automatisering tot IoT-monitoring en maatwerkplatformen — alles wat nodig is om uw processen te automatiseren, risico\'s te verminderen en meer resultaat te halen.',
  ctaPrimary: {
    label: 'Plan een intake',
    url: '/contact',
  },
  ctaSecondary: {
    label: 'Bekijk mijn werk',
    url: '/portfolio',
  },
  stats: [
    { value: 'Direct laden', label: 'Uw site laadt razendsnel' },
    { value: '6+', label: 'Live in productie' },
    { value: 'Maximaal veilig', label: 'Uw data structureel beschermd' },
  ],
  alignment: 'center' as const,
  size: 'large' as const,
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'LaventeCare',
  url: 'https://www.laventecare.nl',
  logo: 'https://www.laventecare.nl/og-image.png',
  image: 'https://www.laventecare.nl/og-image.png',
  description:
    'LaventeCare — AI-automatisering, resultaatgerichte maatwerkplatformen, IoT-monitoring en professionele databescherming. Eén partner voor efficiëntere bedrijfsprocessen zonder complexiteit.',
  founder: {
    '@type': 'Person',
    name: 'Jeffrey Lavente',
    jobTitle: 'AI Prompt Engineer & Full-Stack Developer',
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Spiegelstraat 6',
    postalCode: '8251 ZB',
    addressLocality: 'Dronten',
    addressRegion: 'Flevoland',
    addressCountry: 'NL',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 52.5286,
    longitude: 5.7178,
  },
  telephone: '+31-6-39034085',
  areaServed: 'NL',
  priceRange: '€€',
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '17:00',
    },
  ],
  knowsAbout: [
    'AI-automatisering', 'AI Prompt Engineering', 'Bedrijfsprocessen automatiseren',
    'Slimme monitoring', 'IoT-oplossingen', 'Storingen voorkomen',
    'Databescherming', 'AVG-compliance', 'Security fundament',
    'Maatwerk platformen', 'Lead Generation', 'Digitale efficiency',
  ],
  sameAs: [
    'https://linkedin.com/in/jeffrey-lavente',
    'https://github.com/Jeffreasy',
    'https://www.instagram.com/jjalavente/',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'jeffrey@laventecare.nl',
    contactType: 'customer service',
    availableLanguage: 'Dutch',
  },
};

const pillars = [
  {
    title: 'AI & Automatisering',
    description: 'AI die repetitief werk overneemt en uw data benut voor betere en snellere beslissingen — betrouwbaar, schaalbaar en meetbaar in uw dagelijkse processen.',
    icon: 'brain-circuit',
    tags: ['AI-automatisering', 'Digitale medewerkers', 'Bedrijfsdata'],
    href: '/diensten/ai-prompt-engineering',
    featured: true,
  },
  {
    title: 'Slimme Monitoring & Sensoren',
    description: 'Realtime monitoring die storingen vroegtijdig detecteert en schade of kostbare stilstand voorkomt. Van sensor tot dashboard, op afstand en zonder onderhoud.',
    icon: 'radio',
    tags: ['Realtime monitoring', 'Automatische alarmering', 'Op afstand'],
    href: '/diensten/iot-hardware',
  },
  {
    title: 'Maatwerk Platformen',
    description: 'Registratie, ticketing en donaties — volledig geautomatiseerd en ontworpen om foutloos te draaien. Uw volledige evenement of actie beheerd vanuit één centraal systeem.',
    icon: 'building-2',
    tags: ['Registratie', 'Donaties', 'Dashboards', 'Schaalbaar'],
    href: '/diensten/maatwerk-platformen',
  },
  {
    title: 'Lead Generation',
    description: 'Meer aanvragen uit uw website, zonder extra marketingkosten. Bezoekers worden automatisch gestuurd richting een offerte of aanvraag, zodat ze sneller converteren.',
    icon: 'target',
    tags: ['Offertetrajecten', 'Lead-management', 'SEO'],
    href: '/diensten/lead-generation',
  },
  {
    title: 'Beveiliging & Authenticatie',
    description: 'Uw klantdata is structureel beschermd en gescheiden, zodat risico\'s worden geminimaliseerd en uw data veilig blijft — ook bij fouten of aanvallen.',
    icon: 'shield-check',
    tags: ['Data-isolatie', 'Authenticatie', 'AVG-compliance'],
    href: '/diensten/security',
    featured: true,
  },
] as const;
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<Layout
  title="LaventeCare — Systeemontwikkeling: AI, IoT & Platformen"
  description="Systemen die bedrijven efficiënter maken, fouten voorkomen en groei versnellen. AI-automatisering, IoT-monitoring, maatwerkplatformen en professionele databescherming."
>
  <Hero {...heroData} />

  <!-- Kernactiviteiten -->
  <section class="section-padding relative overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-active/5 rounded-full blur-3xl pointer-events-none"></div>

    <div class="container mx-auto px-4 relative">
      <SectionHeader
        label="Wat ik bouw"
        heading='Vijf pijlers, één <span class="text-active">complete oplossing</span>'
        description="Vijf pijlers die samen zorgen voor minder handmatig werk, meer controle en betere resultaten."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        {pillars.map((pillar) => (
          <PillarCard {...pillar} />
        ))}
      </div>
    </div>
  </section>

  <!-- USPs -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Onderscheidend vermogen"
        heading='Waarom <span class="text-active">LaventeCare</span>?'
        description="Eén partner voor alles — van idee tot werkend systeem, zonder afhankelijkheid van meerdere partijen."
      />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <!-- USP 1 -->
        <div class="clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8 text-center group hover:border-active/20 transition-colors">
          <div class="w-14 h-14 rounded-2xl bg-active/10 flex items-center justify-center mx-auto mb-5 group-hover:scale-110 transition-transform">
            <Icon name="link" size={24} class="text-active" />
          </div>
          <h3 class="text-lg font-bold text-white mb-3 font-display">Eén partner voor alles</h3>
          <p class="text-white/60 text-sm leading-relaxed font-ui">
            Van het idee tot het werkende product — alles via één partner. Geen afhankelijkheid van meerdere partijen, geen miscommunicatie, geen vertraging.
          </p>
        </div>

        <!-- USP 2 -->
        <div class="clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8 text-center group hover:border-active/20 transition-colors">
          <div class="w-14 h-14 rounded-2xl bg-active/10 flex items-center justify-center mx-auto mb-5 group-hover:scale-110 transition-transform">
            <Icon name="zap" size={24} class="text-active" />
          </div>
          <h3 class="text-lg font-bold text-white mb-3 font-display">Beveiliging als fundament</h3>
          <p class="text-white/60 text-sm leading-relaxed font-ui">
            Uw klantdata is structureel gescheiden van andere bedrijven. Niet achteraf als optie, maar ingebouwd in elke applicatie die ik bouw.
          </p>
        </div>

        <!-- USP 3 -->
        <div class="clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8 text-center group hover:border-active/20 transition-colors">
          <div class="w-14 h-14 rounded-2xl bg-active/10 flex items-center justify-center mx-auto mb-5 group-hover:scale-110 transition-transform">
            <Icon name="gauge" size={24} class="text-active" />
          </div>
          <h3 class="text-lg font-bold text-white mb-3 font-display">Websites die verkopen</h3>
          <p class="text-white/60 text-sm leading-relaxed font-ui">
            Niet alleen mooi, maar sites die daadwerkelijk aanvragen opleveren — meetbaar en aantoonbaar. Elke seconde sneller = 7% meer conversie (bron: Google/Deloitte).
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="py-8 md:py-12">
    <div class="container mx-auto px-4">
      <div class="clinical-glass p-6 md:p-8 rounded-(--radius-hero) border border-white/8 max-w-4xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <StatCard value="<1.5s" label="Gemiddelde Laadtijd" />
          <StatCard value="99/100" label="Google PageSpeed" />
          <StatCard value="6+" label="Live Projecten" />
          <StatCard value="€95" label="Uurtarief" />
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof: Verifieerbare Lighthouse Scores -->
  <section class="py-8 md:py-12">
    <div class="container mx-auto px-4">
      <div class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-active/20 max-w-4xl mx-auto">
        <div class="text-center mb-6">
          <span class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-2 block">Verifieerbaar bewijs</span>
          <h2 class="text-xl md:text-2xl font-bold text-white font-display">Google Lighthouse Scores</h2>
          <p class="text-white/50 text-sm font-ui mt-2">Onafhankelijk gemeten door Google — niet door mij. Verifieer het zelf.</p>
        </div>

        <div class="flex flex-col md:flex-row items-center gap-8">
          <!-- Project highlight -->
          <div class="flex-1 text-center md:text-left">
            <p class="text-white/40 text-xs font-ui uppercase tracking-wider mb-1">Uitgelicht project</p>
            <h3 class="text-lg font-bold text-white font-display mb-1">C&F Bouw</h3>
            <p class="text-white/60 text-sm font-ui mb-3">Lead-generation portaal • +340% organisch verkeer</p>
            <a href="https://pagespeed.web.dev/analysis?url=https%3A%2F%2Fwww.cfbouw.nl%2F" target="_blank" rel="noopener noreferrer" class="text-active text-sm font-bold hover:underline flex items-center gap-1 justify-center md:justify-start">
              Verifieer op PageSpeed Insights
              <Icon name="external-link" size={12} />
            </a>
          </div>

          <!-- Gauges -->
          <div class="grid grid-cols-4 gap-3 md:gap-6 place-items-center">
            <LighthouseGauge score={99} label="Perf" size="sm" class="md:hidden" />
            <LighthouseGauge score={97} label="A11y" size="sm" class="md:hidden" />
            <LighthouseGauge score={100} label="BP" size="sm" class="md:hidden" />
            <LighthouseGauge score={100} label="SEO" size="sm" class="md:hidden" />
            <LighthouseGauge score={99} label="Perf" size="md" class="hidden md:flex" />
            <LighthouseGauge score={97} label="A11y" size="md" class="hidden md:flex" />
            <LighthouseGauge score={100} label="BP" size="md" class="hidden md:flex" />
            <LighthouseGauge score={100} label="SEO" size="md" class="hidden md:flex" />
          </div>
        </div>

        <div class="text-center mt-6">
          <a href="/portfolio" class="text-white/40 text-sm font-ui hover:text-active transition-colors">
            Bekijk alle projectscores →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Portfolio Preview -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Referenties"
        heading='Bewezen in <span class="text-active">productie</span>'
        description="Geen demo's, maar echte systemen die dagelijks gebruikt worden en aantoonbaar resultaat opleveren."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        <!-- Project 1: De Koninklijke Loop -->
        <a href="https://dekoninklijkeloop.nl" target="_blank" rel="noopener noreferrer" class="group clinical-glass p-6 rounded-(--radius-feature) border border-white/8 hover:border-active/30 transition-all cursor-pointer">
          <div class="flex items-start justify-between mb-4">
            <h3 class="text-xl font-bold text-white font-display group-hover:text-active transition-colors">De Koninklijke Loop</h3>
            <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20">Event</span>
          </div>
          <p class="text-white/60 text-sm mb-4 font-ui leading-relaxed">
            Real-time registratieplatform voor liefdadigheidsevenement. 100+ deelnemers, live dashboard en geautomatiseerde e-mailbevestigingen.
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Astro</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Convex</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Go</span>
          </div>
          <!-- Lighthouse Scores -->
          <div class="flex items-center justify-around gap-2 py-3 mb-4 border-t border-b border-white/5">
            <LighthouseGauge score={93} label="Perf" size="sm" />
            <LighthouseGauge score={95} label="A11y" size="sm" />
            <LighthouseGauge score={92} label="BP" size="sm" />
          </div>
          <span class="text-active text-sm font-bold flex items-center gap-2 font-ui">
            Bekijk project
            <Icon name="arrow-right" size={16} class="group-hover:translate-x-1 transition-transform" />
          </span>
        </a>

        <!-- Project 2: SmartCoolCare -->
        <a href="https://www.smartcoolcare.nl" target="_blank" rel="noopener noreferrer" class="group clinical-glass p-6 rounded-(--radius-feature) border border-white/8 hover:border-active/30 transition-all cursor-pointer">
          <div class="flex items-start justify-between mb-4">
            <h3 class="text-xl font-bold text-white font-display group-hover:text-active transition-colors">SmartCoolCare</h3>
            <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20">IoT</span>
          </div>
          <p class="text-white/60 text-sm mb-4 font-ui leading-relaxed">
            24/7 koelmonitoring met automatische alarmering bij afwijkingen. Sensordata direct zichtbaar op uw scherm, waar u ook bent.
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">C++</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">ESP32</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">BLE</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Convex</span>
          </div>
          <!-- Lighthouse Scores -->
          <div class="flex items-center justify-around gap-2 py-3 mb-4 border-t border-b border-white/5">
            <LighthouseGauge score={99} label="Perf" size="sm" />
            <LighthouseGauge score={90} label="A11y" size="sm" />
            <LighthouseGauge score={96} label="BP" size="sm" />
            <LighthouseGauge score={100} label="SEO" size="sm" />
          </div>
          <span class="text-active text-sm font-bold flex items-center gap-2 font-ui">
            Bekijk project
            <Icon name="arrow-right" size={16} class="group-hover:translate-x-1 transition-transform" />
          </span>
        </a>

        <!-- Project 3: C&F Bouw -->
        <a href="https://cfbouw.nl" target="_blank" rel="noopener noreferrer" class="group clinical-glass p-6 rounded-(--radius-feature) border border-white/8 hover:border-active/30 transition-all cursor-pointer">
          <div class="flex items-start justify-between mb-4">
            <h3 class="text-xl font-bold text-white font-display group-hover:text-active transition-colors">C&F Bouw</h3>
            <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20">Lead-Gen</span>
          </div>
          <p class="text-white/60 text-sm mb-4 font-ui leading-relaxed">
            Stapsgewijs offertetraject, projectgalerij en automatische klantcommunicatie. +340% organisch verkeer na lancering.
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Next.js</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Convex</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Go</span>
          </div>
          <!-- Lighthouse Scores -->
          <div class="flex items-center justify-around gap-2 py-3 mb-4 border-t border-b border-white/5">
            <LighthouseGauge score={99} label="Perf" size="sm" />
            <LighthouseGauge score={97} label="A11y" size="sm" />
            <LighthouseGauge score={100} label="BP" size="sm" />
            <LighthouseGauge score={100} label="SEO" size="sm" />
          </div>
          <span class="text-active text-sm font-bold flex items-center gap-2 font-ui">
            Bekijk project
            <Icon name="arrow-right" size={16} class="group-hover:translate-x-1 transition-transform" />
          </span>
        </a>

        <!-- Project 4: Dustin Auto Garage -->
        <div class="clinical-glass p-6 rounded-(--radius-feature) border border-white/8">
          <div class="flex items-start justify-between mb-4">
            <h3 class="text-xl font-bold text-white font-display">Dustin Auto Garage</h3>
            <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20">Platform</span>
          </div>
          <p class="text-white/60 text-sm mb-4 font-ui leading-relaxed">
            Compleet werkplaatsbeheer: planning, klantenbeheer, voertuigregistratie met RDW-koppeling en automatische facturatie.
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Astro</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">React 19</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Convex</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Go</span>
          </div>
          <span class="text-white/30 text-sm font-ui italic">In ontwikkeling</span>
        </div>
      </div>

      <div class="text-center mt-8">
        <a href="/portfolio" class="btn-secondary">
          Bekijk alle projecten
          <Icon name="arrow-right" size={16} />
        </a>
      </div>
    </div>
  </section>

  <!-- Personal Touch / CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="clinical-glass p-8 md:p-12 rounded-(--radius-hero) border border-active/20 max-w-4xl mx-auto text-center">
        <span class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-4 block">De mens achter de code</span>
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 font-display">
          Jeffrey Lavente
        </h2>
        <p class="text-white/70 text-base md:text-lg leading-relaxed mb-6 max-w-2xl mx-auto font-ui">
          AI prompt engineer en full-stack developer met een achtergrond in de zorg. Ik bouw systemen die niet alleen technisch sterk zijn, maar ook praktisch werken in de echte wereld.
        </p>
        <p class="text-white/40 text-sm font-ui mb-6">
          Plan een intake en ontdek waar u direct tijd, kosten of risico kunt besparen.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/over" class="btn-secondary">
            Lees mijn verhaal
          </a>
          <a href="/contact" class="btn-primary">
            Plan een intake
            <Icon name="arrow-right" size={16} />
          </a>
        </div>
      </div>
    </div>
  </section>

  <FAQSection />
</Layout>
