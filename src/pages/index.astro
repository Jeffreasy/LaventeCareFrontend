---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/blocks/Hero.astro';
import ShowcaseGrid from '../components/blocks/ShowcaseGrid.astro';
import FAQSection from '../components/blocks/FAQSection.astro';
import IconBox from '../components/ui/IconBox.astro';
import { Zap, Shield, Database } from 'lucide-react';


// Type-safe hero data
const heroData = {
	headline: 'The Foundation for Digital Growth',
	subtitle: 'Next-Gen Web Infrastructure & Digital Experiences.',
	description:
		'LaventeCare biedt het ultieme fundament voor uw digitale ambities. Van <span class="text-active font-bold">bliksemsnelle websites</span> tot <span class="text-active font-bold">complexe data-gedreven applicaties</span>.',
	ctaPrimary: {
		label: 'Start gratis trial',
		url: '/contact',
	},
	ctaSecondary: {
		label: 'Ontdek het ecosysteem',
		url: '#ecosystem',
	},
	stats: [
		{ value: '100/100', label: 'Lighthouse Score' },
		{ value: 'Zero-JS', label: 'Runtime' },
		{ value: 'Anti-Gravity', label: 'Security' },
	],
	alignment: 'center' as const,
	size: 'large' as const,
};

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: 'LaventeCare',
	url: 'https://laventecare.nl',
	logo: 'https://laventecare.nl/logo.png',
	description:
		'LaventeCare is a high-performance web agency in Amsterdam specialized in Astro-based infrastructure and secure backend systems.',
	address: {
		'@type': 'PostalAddress',
		addressLocality: 'Amsterdam',
		addressCountry: 'NL',
	},
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<Layout title="LaventeCare - The Foundation for Growth">
	<Hero {...heroData} />

	<ShowcaseGrid />

	<!-- Service Intro Section -->
	<section id="ecosystem" class="bg-background py-24 relative overflow-hidden">
		<!-- Decorative bg element -->
		<div
			class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[500px] bg-active/5 rounded-full blur-3xl pointer-events-none"
		>
		</div>

		<div class="container mx-auto px-4 relative">
			<div class="max-w-4xl mx-auto text-center mb-20">
				<span class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-4 block"
					>Het Ecosysteem</span
				>
				<h2
					class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 font-display tracking-tight leading-[1.1]"
				>
					Meer dan alleen code
				</h2>
				<p class="text-xl text-white/70">
					LaventeCare is niet zomaar een development agency. Wij bieden een geïntegreerd platform
					waar snelheid, veiligheid en schaalbaarheid samenkomen. Uw centrale hub voor digitale
					innovatie.
				</p>
			</div>

			<!-- USPs Section -->
			<!-- USPs Section (Asymmetric Layout) -->
			<div class="grid md:grid-cols-12 gap-8">
				<!-- USP 1: Snelheid (Major Feature - 8 Cols) -->
				<div
					class="md:col-span-8 clinical-glass p-10 rounded-[var(--radius-hero)] hover:scale-[1.02] transition-transform duration-[var(--transition-base)] border border-white/10 group flex flex-col justify-between"
				>
					<div>
						<IconBox icon={Zap} size="lg" class="mb-8 group-hover:scale-110 transition-transform" />
						<h3 class="text-3xl font-bold text-white mb-4 font-display">Ultieme Snelheid</h3>
						<p class="text-xl text-white/70 max-w-2xl">
							Gebouwd op <strong>Astro</strong>. Wij leveren nagenoeg nul overbodige JavaScript aan
							de browser. Dit resulteert in topscores in Google Lighthouse en een ongeëvenaarde
							gebruikerservaring.
						</p>
					</div>
				</div>

				<!-- USP 2: Security (Compact - 4 Cols) -->
				<div
					class="md:col-span-4 clinical-glass p-8 rounded-[var(--radius-hero)] hover:scale-[1.02] transition-transform duration-[var(--transition-base)] border border-white/10 group"
				>
					<IconBox icon={Shield} size="lg" class="mb-6 group-hover:scale-110 transition-transform" />
					<h3 class="text-2xl font-bold text-white mb-3 font-display">Militaire Beveiliging</h3>
					<p class="text-white/70">
						Onze <strong>Anti-Gravity</strong> backend architectuur beschermt uw data met Row Level Security
						(RLS).
					</p>
				</div>

				<!-- USP 3: Flexibiliteit (Wide Banner - 12 Cols) -->
				<div
					class="md:col-span-12 clinical-glass p-8 md:p-12 rounded-[var(--radius-hero)] hover:scale-[1.01] transition-transform duration-[var(--transition-base)] border border-white/10 group flex flex-col md:flex-row items-center gap-8"
				>
					<IconBox icon={Database} size="lg" class="group-hover:scale-110 transition-transform" />
					<div class="text-center md:text-left">
						<h3 class="text-2xl md:text-3xl font-bold text-white mb-3 font-display">
							Totale Flexibiliteit
						</h3>
						<p class="text-xl text-white/70">
							Van een high-converting <strong>landing page</strong> tot een complex <strong
								>IoT-dashboard</strong
							>. Het fundament schaalt moeiteloos mee met uw ambities, zonder technische limieten.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<FAQSection />
</Layout>
