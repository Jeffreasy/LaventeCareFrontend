---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/blocks/Hero.astro';
import Icon from '../components/ui/Icon.astro';
import FAQSection from '../components/blocks/FAQSection.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import StatCard from '../components/ui/StatCard.astro';
import PillarCard from '../components/blocks/PillarCard.astro';
import WebsiteOfferTeaser from '../components/blocks/WebsiteOfferTeaser.astro';
import BrandSystemVisual from '../components/blocks/BrandSystemVisual.astro';
import { AntiGravityShield } from '../components/islands/AntiGravityShield';

// Dual-domain: serve EN homepage on .com without changing the URL
if (Astro.locals.locale === 'en') {
  return Astro.rewrite('/en-index');
}

const heroData = {
  headline: 'B2B systeempartner voor mkb-organisaties',
  subtitle: 'Van idee tot werkend systeem',
  description:
    'Voor mkb-organisaties die digitale groei, automatisering en maatwerksoftware <span class="text-active font-bold">serieus willen aanpakken</span>. Van een professionele website tot een compleet bedrijfssysteem: één <span class="text-active font-bold">vaste partner</span> die techniek laat meegroeien met uw bedrijf.',
  ctaPrimary: {
    label: 'Plan een gratis adviesgesprek',
    url: '/contact',
  },
  ctaSecondary: {
    label: 'Bekijk portfolio',
    url: '/portfolio',
  },
  stats: [
    { value: 'Per project', label: 'Snelheid gemeten' },
    { value: '7', label: 'Live projecten' },
    { value: 'Astro-first', label: 'Lichte technische basis' },
  ],
  alignment: 'center' as const,
  size: 'large' as const,
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'LaventeCare',
  url: 'https://www.laventecare.nl',
  logo: 'https://www.laventecare.nl/og-laventecare-2026.png',
  image: 'https://www.laventecare.nl/og-laventecare-2026.png',
  description:
    'LaventeCare bouwt professionele websites en systemen die bedrijven efficiënter maken: websites vanaf €750, AI, IoT, maatwerkplatformen en beveiliging vanaf de basis.',
  founder: {
    '@type': 'Person',
    name: 'Jeffrey Lavente',
    jobTitle: 'Systems Engineer & Oprichter',
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Spiegelstraat 6',
    postalCode: '8251 ZB',
    addressLocality: 'Dronten',
    addressRegion: 'Flevoland',
    addressCountry: 'NL',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 52.5286,
    longitude: 5.7178,
  },
  telephone: '+31-6-39034085',
  areaServed: 'NL',
  priceRange: '€€€',
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '17:00',
    },
  ],
  knowsAbout: [
    'Professionele websites met Astro',
    'IT Advies & Consultancy',
    'Security-first systemen',
    'AI & Automatisering',
    'B2B Maatwerk Platformen',
    'IoT Telemetrie',
    'PostgreSQL RLS',
    'Data-isolatie',
    'AVG-compliance',
    'API Integraties',
    'Systeemontwikkeling',
    'Discovery & Blueprinting',
    'Digitale Transformatie',
  ],
  sameAs: [
    'https://linkedin.com/in/jeffrey-lavente',
    'https://github.com/Jeffreasy',
    'https://www.instagram.com/jjalavente/',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'jeffrey@laventecare.nl',
    contactType: 'customer service',
    availableLanguage: 'Dutch',
  },
};

const pillars = [
  {
    title: 'IT Advies & Consultancy',
    description:
      'Een onafhankelijk sparringpartner en second opinion, zonder bouwverplichting. Nuchter advies over uw digitale koers, architectuur en volgende stap.',
    icon: 'message-circle',
    tags: ['Sparringpartner', 'Second opinion', 'Roadmap'],
    href: '/diensten/consultancy',
  },
  {
    title: 'AI & Automatisering',
    description:
      'AI die repetitief werk overneemt en uw data benut voor snellere beslissingen. Betrouwbaar, meetbaar en met een mens die meekijkt en beslist in uw dagelijkse processen.',
    icon: 'brain-circuit',
    tags: ['Automatisering', 'Dataverwerking', 'Mens beslist mee'],
    href: '/diensten/ai-prompt-engineering',
    featured: true,
  },
  {
    title: 'Slimme Monitoring & Sensoren',
    description:
      'Van sensor tot dashboard: problemen vroeg signaleren en minder downtime. Realtime inzicht in uw processen, op afstand en zonder handmatig beheer.',
    icon: 'radio',
    tags: ['Sensordata', 'Alarmering', 'Dashboards'],
    href: '/diensten/iot-hardware',
  },
  {
    title: 'Maatwerk Platformen',
    description:
      'Losse tools en handwerk vervangen door één systeem dat met u meegroeit: één centrale plek waar al uw gegevens kloppen en actueel zijn, gebouwd voor stabiliteit en groei.',
    icon: 'building-2',
    tags: ['B2B Portalen', 'Integraties', 'Alles op één plek'],
    href: '/diensten/maatwerk-platformen',
  },
  {
    title: 'Lead Generation',
    description:
      'Uw website wordt een systeem dat bezoekers omzet in aanvragen. Bezoekers worden gericht naar een offerte of aanvraag, zodat ze sneller klant worden.',
    icon: 'target',
    tags: ['Aanvragen beheren', 'Klant worden', 'SEO'],
    href: '/diensten/lead-generation',
  },
  {
    title: 'Beveiliging & Authenticatie',
    description:
      'Uw gegevens zijn per klant strikt gescheiden en beschermd, ook bij fouten of aanvallen. Onder de motorkap: PostgreSQL RLS, toegang per rol (RBAC) en volledige logging.',
    icon: 'shield-check',
    tags: ['Gescheiden klantdata', 'Toegang per rol', 'Alles vastgelegd'],
    href: '/diensten/security',
    featured: true,
  },
] as const;
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<Layout
  title="LaventeCare — B2B systeempartner voor mkb | Dronten"
  description="B2B systeempartner voor mkb-organisaties die digitale groei, automatisering en maatwerksoftware goed en betrouwbaar willen regelen. Van idee tot werkend systeem."
>
  <Hero {...heroData} />

  <WebsiteOfferTeaser locale="nl" />

  <!-- Kernactiviteiten -->
  <section class="section-padding relative overflow-hidden">
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-active/5 rounded-full blur-3xl pointer-events-none"
    >
    </div>

    <div class="container mx-auto px-4 relative">
      <SectionHeader
        label="Diensten"
        heading='Zes specialistische diensten, één <span class="text-active">werkend systeem</span>'
        description="Geen losse projecten, maar een geïntegreerd systeem: elke dienst versterkt de andere. Van advies en AI-automatisering tot maatwerkplatformen en beveiliging — samen van idee tot werkend systeem."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        {pillars.map((pillar) => <PillarCard {...pillar} />)}
      </div>
    </div>
  </section>

  <BrandSystemVisual locale="nl" />

  <!-- USPs -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Onderscheidend vermogen"
        heading='Waarom <span class="text-active">LaventeCare</span>?'
        description="Een vaste partner die uw manier van werken omzet in software die het werk uit handen neemt: van intake en Blueprint (het bouwplan) tot realisatie, beheer en doorontwikkeling — met ingebouwde beveiliging."
      />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <!-- USP 1 -->
        <div
          data-animate="fade-up"
          class="clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8 text-center group hover:border-active/20 transition-colors"
        >
          <div
            class="w-14 h-14 rounded-2xl bg-active/10 flex items-center justify-center mx-auto mb-5 group-hover:scale-110 transition-transform"
          >
            <Icon name="link" size={24} class="text-active" />
          </div>
          <h3 class="text-lg font-bold text-white mb-3 font-display">
            Eén aanspreekpunt, volledig eigenaarschap
          </h3>
          <p class="text-white/60 text-sm leading-relaxed font-ui">
            Van intake tot livegang — één vast aanspreekpunt dat uw processen en systeem door en
            door kent. Geen wisselende developers, geen miscommunicatie, geen kennisverloop.
          </p>
        </div>

        <!-- USP 2 -->
        <div
          data-animate="fade-up"
          class="delay-100 clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8 text-center group hover:border-active/20 transition-colors"
        >
          <div
            class="w-14 h-14 rounded-2xl bg-active/10 flex items-center justify-center mx-auto mb-5 group-hover:scale-110 transition-transform"
          >
            <Icon name="zap" size={24} class="text-active" />
          </div>
          <h3 class="text-lg font-bold text-white mb-3 font-display">
            Security-first architectuur
          </h3>
          <p class="text-white/60 text-sm leading-relaxed font-ui">
            Uw gegevens zijn per klant strikt gescheiden en elke actie wordt vastgelegd. Onder de
            motorkap: Privacy by Design met PostgreSQL RLS, toegang per rol (RBAC) en volledige
            logging.
          </p>
        </div>

        <!-- USP 3 -->
        <div
          data-animate="fade-up"
          class="delay-200 clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8 text-center group hover:border-active/20 transition-colors"
        >
          <div
            class="w-14 h-14 rounded-2xl bg-active/10 flex items-center justify-center mx-auto mb-5 group-hover:scale-110 transition-transform"
          >
            <Icon name="gauge" size={24} class="text-active" />
          </div>
          <h3 class="text-lg font-bold text-white mb-3 font-display">
            Meetbaar sneller, aantoonbaar beter
          </h3>
          <p class="text-white/60 text-sm leading-relaxed font-ui">
            Ik meet snelheid en stabiliteit per project en optimaliseer op basis van het echte
            gebruik. Een lichte technische basis is het vertrekpunt, geen losse belofte.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="py-8 md:py-12">
    <div class="container mx-auto px-4">
      <div
        data-animate="scale-up"
        class="clinical-glass p-6 md:p-8 rounded-(--radius-hero) border border-white/8 max-w-4xl mx-auto"
      >
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <StatCard value="7" label="Live projecten" />
          <StatCard value="Per project" label="Snelheid gemeten" />
          <StatCard value="Astro-first" label="Lichte technische basis" />
          <StatCard value="SLA" label="Doorlopend onderhoud mogelijk" />
        </div>
      </div>
    </div>
  </section>

  <!-- Secure by Design: Live Security -->
  <section class="py-8 md:py-12">
    <div class="container mx-auto px-4">
      <div data-animate="fade-up" class="max-w-3xl mx-auto">
        <div class="text-center mb-8">
          <span class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-2 block"
            >Secure by Design</span
          >
          <h2 class="text-xl md:text-2xl font-bold text-white font-display">
            Actieve Systeembeveiliging
          </h2>
          <p class="text-white/50 text-sm font-ui mt-2">
            Geen loze beloftes over veiligheid. Zie hier live overzicht van de beveiligingslaag die
            kwaadwillend verkeer signaleert en weert.
          </p>
        </div>

        <AntiGravityShield client:load />

        <div class="text-center mt-6">
          <a
            href="/diensten/security"
            class="text-white/40 text-sm font-ui hover:text-active transition-colors"
          >
            Lees meer over onze security-first aanpak →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Portfolio Preview -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Referenties"
        heading='Bewezen in de <span class="text-active">praktijk</span>'
        description="Geen demo's, maar echte systemen die dagelijks gebruikt worden en aantoonbaar resultaat opleveren."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        <!-- Project 1: De Koninklijke Loop -->
        <a
          href="https://dekoninklijkeloop.nl"
          target="_blank"
          rel="noopener noreferrer"
          class="group clinical-glass p-6 rounded-(--radius-feature) border border-white/8 hover:border-active/30 transition-all cursor-pointer"
        >
          <div class="flex items-start justify-between mb-4">
            <h3
              class="text-xl font-bold text-white font-display group-hover:text-active transition-colors"
            >
              De Koninklijke Loop
            </h3>
            <span
              class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20"
              >Event</span
            >
          </div>
          <p class="text-white/60 text-sm mb-4 font-ui leading-relaxed">
            Real-time registratieplatform voor een liefdadigheidsevenement. Aanmeldingen worden
            direct verwerkt, waardoor de organisatie minder handmatig hoeft over te nemen.
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Astro</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">React 19</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Convex</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Go Auth</span>
          </div>
          <div class="flex items-center gap-4 py-3 mb-4 border-t border-b border-white/5">
            <div class="flex items-center gap-1.5">
              <Icon name="check" size={14} class="text-active" />
              <span class="text-white/70 text-xs font-ui">Real-time registratie</span>
            </div>
            <div class="flex items-center gap-1.5">
              <Icon name="check" size={14} class="text-active" />
              <span class="text-white/70 text-xs font-ui">Minder handwerk</span>
            </div>
          </div>
          <span class="text-active text-sm font-bold flex items-center gap-2 font-ui">
            Bekijk project
            <Icon
              name="arrow-right"
              size={16}
              class="group-hover:translate-x-1 transition-transform"
            />
          </span>
        </a>

        <!-- Project 2: SmartCoolCare -->
        <a
          href="https://www.smartcoolcare.nl"
          target="_blank"
          rel="noopener noreferrer"
          class="group clinical-glass p-6 rounded-(--radius-feature) border border-white/8 hover:border-active/30 transition-all cursor-pointer"
        >
          <div class="flex items-start justify-between mb-4">
            <h3
              class="text-xl font-bold text-white font-display group-hover:text-active transition-colors"
            >
              SmartCoolCare
            </h3>
            <span
              class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20"
              >IoT</span
            >
          </div>
          <p class="text-white/60 text-sm mb-4 font-ui leading-relaxed">
            Koelmonitoring met automatische alarmering bij afwijkingen. Sensordata direct zichtbaar
            op uw scherm, waar u ook bent.
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">C++</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">ESP32</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">BLE</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Convex</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">React</span>
          </div>
          <div class="flex items-center gap-4 py-3 mb-4 border-t border-b border-white/5">
            <div class="flex items-center gap-1.5">
              <Icon name="check" size={14} class="text-active" />
              <span class="text-white/70 text-xs font-ui">Realtime sensordata</span>
            </div>
            <div class="flex items-center gap-1.5">
              <Icon name="check" size={14} class="text-active" />
              <span class="text-white/70 text-xs font-ui">Automatische alarmering</span>
            </div>
          </div>
          <span class="text-active text-sm font-bold flex items-center gap-2 font-ui">
            Bekijk project
            <Icon
              name="arrow-right"
              size={16}
              class="group-hover:translate-x-1 transition-transform"
            />
          </span>
        </a>

        <!-- Project 3: C&F Bouw -->
        <a
          href="https://cfbouw.nl"
          target="_blank"
          rel="noopener noreferrer"
          class="group clinical-glass p-6 rounded-(--radius-feature) border border-white/8 hover:border-active/30 transition-all cursor-pointer"
        >
          <div class="flex items-start justify-between mb-4">
            <h3
              class="text-xl font-bold text-white font-display group-hover:text-active transition-colors"
            >
              C&F Bouw
            </h3>
            <span
              class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20"
              >Lead-Gen</span
            >
          </div>
          <p class="text-white/60 text-sm mb-4 font-ui leading-relaxed">
            Stapsgewijs offertetraject, projectgalerij en automatische klantcommunicatie in één
            systeem, gebouwd voor snelheid en vindbaarheid.
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Astro</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Convex</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Go Auth</span>
          </div>
          <div class="flex items-center gap-4 py-3 mb-4 border-t border-b border-white/5">
            <div class="flex items-center gap-1.5">
              <Icon name="check" size={14} class="text-active" />
              <span class="text-white/70 text-xs font-ui">Offertetraject geautomatiseerd</span>
            </div>
            <div class="flex items-center gap-1.5">
              <Icon name="check" size={14} class="text-active" />
              <span class="text-white/70 text-xs font-ui">SEO-geoptimaliseerd</span>
            </div>
          </div>
          <span class="text-active text-sm font-bold flex items-center gap-2 font-ui">
            Bekijk project
            <Icon
              name="arrow-right"
              size={16}
              class="group-hover:translate-x-1 transition-transform"
            />
          </span>
        </a>

        <!-- Project 4: Dustin Auto Garage -->
        <div class="clinical-glass p-6 rounded-(--radius-feature) border border-white/8">
          <div class="flex items-start justify-between mb-4">
            <h3 class="text-xl font-bold text-white font-display">Dustin Auto Garage</h3>
            <span
              class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20"
              >Platform</span
            >
          </div>
          <p class="text-white/60 text-sm mb-4 font-ui leading-relaxed">
            Compleet werkplaatsbeheer: planning, klantenbeheer, voertuigregistratie met
            RDW-koppeling en automatische facturatie.
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Astro</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">React 18.3.1</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Convex</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Go Auth</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">RDW-proxy</span>
          </div>
          <span class="text-emerald-400 text-sm font-bold flex items-center gap-2 font-ui">
            <span class="relative flex h-2 w-2">
              <span
                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
              ></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            Live in gebruik
          </span>
        </div>
      </div>

      <div class="text-center mt-8">
        <a href="/portfolio" class="btn-secondary">
          Bekijk alle projecten
          <Icon name="arrow-right" size={16} />
        </a>
      </div>
    </div>
  </section>

  <!-- Personal Touch / CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div
        class="clinical-glass p-8 md:p-12 rounded-(--radius-hero) border border-active/20 max-w-4xl mx-auto text-center"
      >
        <span class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-4 block"
          >De mens achter het systeem</span
        >
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 font-display">Jeffrey Lavente</h2>
        <p
          class="text-white/70 text-base md:text-lg leading-relaxed mb-6 max-w-2xl mx-auto font-ui"
        >
          Systems engineer met een achtergrond in intensieve NAH-zorg. Ik bouw systemen die niet
          alleen technisch solide zijn, maar ook structuur en veiligheid bieden in de echte wereld.
        </p>
        <p class="text-white/40 text-sm font-ui mb-6">
          Plan een gratis adviesgesprek en ontdek waar u direct tijd, kosten of risico kunt
          besparen.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/over" class="btn-secondary"> Lees mijn verhaal </a>
          <a href="/contact?type=discovery" class="btn-primary">
            Plan een gratis adviesgesprek
            <Icon name="arrow-right" size={16} />
          </a>
        </div>
      </div>
    </div>
  </section>

  <FAQSection />
</Layout>
