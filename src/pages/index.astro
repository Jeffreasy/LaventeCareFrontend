---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/blocks/Hero.astro';
import Icon from '../components/ui/Icon.astro';
import FAQSection from '../components/blocks/FAQSection.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import StatCard from '../components/ui/StatCard.astro';
import PillarCard from '../components/blocks/PillarCard.astro';
import LighthouseGauge from '../components/ui/LighthouseGauge.astro';

// Dual-domain: serve EN homepage on .com without changing the URL
if (Astro.locals.locale === 'en') {
  return Astro.rewrite('/en-index');
}

const heroData = {
  headline: 'High-End Systeem- & Architectuurpartner',
  subtitle: 'Ontworpen, gebouwd en onderhouden door één engineer',
  description:
    'Van beveiligde datastromen tot complexe maatwerkplatformen — gebouwd op een <span class="text-active font-bold">Zero-Trust backend</span> met focus op betrouwbaarheid en schaalbaarheid. Geen losse tools, maar <span class="text-active font-bold">gesloten systemen</span> die processen automatiseren zonder controle te verliezen.',
  ctaPrimary: {
    label: 'Plan een Discovery',
    url: '/contact',
  },
  ctaSecondary: {
    label: 'Bekijk architectuur',
    url: '/portfolio',
  },
  stats: [
    { value: '99/100', label: 'Google PageSpeed (verifieerbaar)' },
    { value: '6+', label: 'Platformen in productie' },
    { value: 'Zero-Trust', label: 'Strikte scheiding van data en toegang' },
  ],
  alignment: 'center' as const,
  size: 'large' as const,
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'LaventeCare',
  url: 'https://www.laventecare.nl',
  logo: 'https://www.laventecare.nl/og-image.png',
  image: 'https://www.laventecare.nl/og-image.png',
  description:
    'LaventeCare — High-End Systeem- en Architectuurpartner: maatwerk B2B platformen met Zero-Trust beveiliging, gecontroleerde AI-automatisering en IoT-monitoring.',
  founder: {
    '@type': 'Person',
    name: 'Jeffrey Lavente',
    jobTitle: 'Systems Engineer & Oprichter',
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Spiegelstraat 6',
    postalCode: '8251 ZB',
    addressLocality: 'Dronten',
    addressRegion: 'Flevoland',
    addressCountry: 'NL',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 52.5286,
    longitude: 5.7178,
  },
  telephone: '+31-6-39034085',
  areaServed: 'NL',
  priceRange: '€€€',
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '17:00',
    },
  ],
  knowsAbout: [
    'Enterprise Architectuur',
    'Zero-Trust Beveiliging',
    'Worker Automation',
    'B2B Maatwerk Platformen',
    'IoT Telemetrie',
    'PostgreSQL RLS',
    'Data-isolatie',
    'AVG-compliance',
    'API Integraties',
    'Systeemontwikkeling',
    'Discovery & Blueprinting',
    'Digitale Transformatie',
  ],
  sameAs: [
    'https://linkedin.com/in/jeffrey-lavente',
    'https://github.com/Jeffreasy',
    'https://www.instagram.com/jjalavente/',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'jeffrey@laventecare.nl',
    contactType: 'customer service',
    availableLanguage: 'Dutch',
  },
};

const pillars = [
  {
    title: 'Worker Automation & AI',
    description:
      'Een gecontroleerde worker-laag die repetitief werk overneemt. Geen black-box AI, maar ingebed in uw data met behoud van strikte toegangscontrole en human-in-the-loop.',
    icon: 'brain-circuit',
    tags: ['Automatisering', 'Rapportages', 'Dataverwerking'],
    href: '/diensten/ai-prompt-engineering',
    featured: true,
  },
  {
    title: 'IoT Telemetry & Observability',
    description:
      'Realtime sensordata gekoppeld aan robuuste cloud-dashboards. Detecteer afwijkingen en voorkom uitval met zero-maintenance hardware en secure-ingest API’s.',
    icon: 'radio',
    tags: ['Sensordata', 'Alarmering', 'Dashboards'],
    href: '/diensten/iot-hardware',
  },
  {
    title: 'Enterprise Maatwerk Platformen',
    description:
      'Geproduceerd via een strikt Discovery & Blueprint proces. Eén Single Source of Truth voor al uw datastromen, gebouwd voor schaalbaarheid en stabiliteit.',
    icon: 'building-2',
    tags: ['B2B Portalen', 'Integraties', 'SaaS Architectuur'],
    href: '/diensten/maatwerk-platformen',
  },
  {
    title: 'Digitale Infrastructuur',
    description:
      'Wij bouwen geen "websites", maar converterende systemen. Uw digitale voordeur geoptimaliseerd voor snelheid, lead-generatie en perfecte Core Web Vitals.',
    icon: 'target',
    tags: ['Lead-management', 'Conversie', 'SEO'],
    href: '/diensten/lead-generation',
  },
  {
    title: 'Zero-Trust Security & Data',
    description:
      "Strikte tenant-isolatie via PostgreSQL RLS. Uw data is cryptografisch gescheiden en AVG-compliant (Privacy by Design). Veiligheid als fundament, niet als afterthought.",
    icon: 'shield-check',
    tags: ['Tenant-isolatie', 'RBAC', 'AVG Art. 28'],
    href: '/diensten/security',
    featured: true,
  },
] as const;
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<Layout
  title="LaventeCare — High-End Systeem- & Architectuurpartner | Dronten"
  description="B2B Maatwerkplatformen met Zero-Trust beveiliging, Worker Automation en SLA-managed infrastructuur. Ontworpen en gebouwd door één engineer."
>
  <Hero {...heroData} />

  <!-- Kernactiviteiten -->
  <section class="section-padding relative overflow-hidden">
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-active/5 rounded-full blur-3xl pointer-events-none"
    >
    </div>

    <div class="container mx-auto px-4 relative">
      <SectionHeader
        label="Platformdiensten"
        heading='Vijf pijlers, één <span class="text-active">compleet ecosysteem</span>'
        description="Geen losse projecten, maar een geïntegreerd systeem: elke pijler versterkt de andere. Van AI-automatisering tot databescherming — alles draait op dezelfde robuuste kern."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        {pillars.map((pillar) => <PillarCard {...pillar} />)}
      </div>
    </div>
  </section>

  <!-- USPs -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Onderscheidend vermogen"
        heading='Waarom <span class="text-active">LaventeCare</span>?'
        description="Geen webbureau, geen agency — maar één engineer die complete systemen bouwt en onderhoudt. Van ontwerp tot productie, met ingebouwde beveiliging."
      />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <!-- USP 1 -->
        <div
          data-animate="fade-up"
          class="clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8 text-center group hover:border-active/20 transition-colors"
        >
          <div
            class="w-14 h-14 rounded-2xl bg-active/10 flex items-center justify-center mx-auto mb-5 group-hover:scale-110 transition-transform"
          >
            <Icon name="link" size={24} class="text-active" />
          </div>
          <h3 class="text-lg font-bold text-white mb-3 font-display">Eén aanspreekpunt, volledig eigenaarschap</h3>
          <p class="text-white/60 text-sm leading-relaxed font-ui">
            Van ontwerp tot livegang — alles via één persoon die het systeem kent. Geen wisselende developers, geen miscommunicatie, geen kennisverloop.
          </p>
        </div>

        <!-- USP 2 -->
        <div
          data-animate="fade-up"
          class="delay-100 clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8 text-center group hover:border-active/20 transition-colors"
        >
          <div
            class="w-14 h-14 rounded-2xl bg-active/10 flex items-center justify-center mx-auto mb-5 group-hover:scale-110 transition-transform"
          >
            <Icon name="zap" size={24} class="text-active" />
          </div>
          <h3 class="text-lg font-bold text-white mb-3 font-display">Zero-Trust Architectuur</h3>
          <p class="text-white/60 text-sm leading-relaxed font-ui">
            Elk systeem is Privacy by Design opgebouwd met multi-tenant data-isolatie (PostgreSQL RLS), strikt rolgebaseerd beheer en automatische dreigingsdetectie.
          </p>
        </div>

        <!-- USP 3 -->
        <div
          data-animate="fade-up"
          class="delay-200 clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8 text-center group hover:border-active/20 transition-colors"
        >
          <div
            class="w-14 h-14 rounded-2xl bg-active/10 flex items-center justify-center mx-auto mb-5 group-hover:scale-110 transition-transform"
          >
            <Icon name="gauge" size={24} class="text-active" />
          </div>
          <h3 class="text-lg font-bold text-white mb-3 font-display">Meetbaar sneller, aantoonbaar beter</h3>
          <p class="text-white/60 text-sm leading-relaxed font-ui">
            99/100 Google PageSpeed is geen marketing — het is verifieerbaar via PageSpeed Insights. Elke seconde sneller = 7% meer conversie (bron: Google/Deloitte).
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="py-8 md:py-12">
    <div class="container mx-auto px-4">
      <div
        data-animate="scale-up"
        class="clinical-glass p-6 md:p-8 rounded-(--radius-hero) border border-white/8 max-w-4xl mx-auto"
      >
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <StatCard value="Zero-Trust" label="Security Fundament" />
          <StatCard value="99/100" label="Google PageSpeed" />
          <StatCard value="40/40/20" label="Milestone Facturatie" />
          <StatCard value="1" label="Single Source of Truth" />
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof: Verifieerbare Lighthouse Scores -->
  <section class="py-8 md:py-12">
    <div class="container mx-auto px-4">
      <div
        data-animate="fade-up"
        class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-active/20 max-w-4xl mx-auto"
      >
        <div class="text-center mb-6">
          <span class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-2 block"
            >Verifieerbaar bewijs</span
          >
          <h2 class="text-xl md:text-2xl font-bold text-white font-display">
            Google Lighthouse Scores
          </h2>
          <p class="text-white/50 text-sm font-ui mt-2">
            Onafhankelijk gemeten door Google — niet door mij. Verifieer het zelf.
          </p>
        </div>

        <div class="flex flex-col md:flex-row items-center gap-8">
          <!-- Project highlight -->
          <div class="flex-1 text-center md:text-left">
            <p class="text-white/40 text-xs font-ui uppercase tracking-wider mb-1">
              Uitgelicht project
            </p>
            <h3 class="text-lg font-bold text-white font-display mb-1">C&F Bouw</h3>
            <p class="text-white/60 text-sm font-ui mb-3">
              Lead-generation portaal • +340% organisch verkeer binnen 6 maanden
            </p>
            <a
              href="https://pagespeed.web.dev/analysis?url=https%3A%2F%2Fwww.cfbouw.nl%2F"
              target="_blank"
              rel="noopener noreferrer"
              class="text-active text-sm font-bold hover:underline flex items-center gap-1 justify-center md:justify-start"
            >
              Verifieer op PageSpeed Insights
              <Icon name="external-link" size={12} />
            </a>
          </div>

          <!-- Gauges -->
          <div class="grid grid-cols-4 gap-3 md:gap-6 place-items-center">
            <LighthouseGauge score={99} label="Perf" size="sm" class="md:hidden" />
            <LighthouseGauge score={97} label="A11y" size="sm" class="md:hidden" />
            <LighthouseGauge score={100} label="BP" size="sm" class="md:hidden" />
            <LighthouseGauge score={100} label="SEO" size="sm" class="md:hidden" />
            <LighthouseGauge score={99} label="Perf" size="md" class="hidden md:flex" />
            <LighthouseGauge score={97} label="A11y" size="md" class="hidden md:flex" />
            <LighthouseGauge score={100} label="BP" size="md" class="hidden md:flex" />
            <LighthouseGauge score={100} label="SEO" size="md" class="hidden md:flex" />
          </div>
        </div>

        <div class="text-center mt-6">
          <a
            href="/portfolio"
            class="text-white/40 text-sm font-ui hover:text-active transition-colors"
          >
            Bekijk alle projectscores →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Portfolio Preview -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Referenties"
        heading='Bewezen in <span class="text-active">productie</span>'
        description="Geen demo's, maar echte systemen die dagelijks gebruikt worden en aantoonbaar resultaat opleveren."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        <!-- Project 1: De Koninklijke Loop -->
        <a
          href="https://dekoninklijkeloop.nl"
          target="_blank"
          rel="noopener noreferrer"
          class="group clinical-glass p-6 rounded-(--radius-feature) border border-white/8 hover:border-active/30 transition-all cursor-pointer"
        >
          <div class="flex items-start justify-between mb-4">
            <h3
              class="text-xl font-bold text-white font-display group-hover:text-active transition-colors"
            >
              De Koninklijke Loop
            </h3>
            <span
              class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20"
              >Event</span
            >
          </div>
          <p class="text-white/60 text-sm mb-4 font-ui leading-relaxed">
            Real-time registratieplatform voor liefdadigheidsevenement. 100+ deelnemers verwerkt,
            0 handmatig werk voor de organisatie.
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Astro</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Convex</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Go</span>
          </div>
          <!-- Lighthouse Scores -->
          <div
            class="flex items-center justify-around gap-2 py-3 mb-4 border-t border-b border-white/5"
          >
            <LighthouseGauge score={93} label="Perf" size="sm" />
            <LighthouseGauge score={95} label="A11y" size="sm" />
            <LighthouseGauge score={92} label="BP" size="sm" />
          </div>
          <span class="text-active text-sm font-bold flex items-center gap-2 font-ui">
            Bekijk project
            <Icon
              name="arrow-right"
              size={16}
              class="group-hover:translate-x-1 transition-transform"
            />
          </span>
        </a>

        <!-- Project 2: SmartCoolCare -->
        <a
          href="https://www.smartcoolcare.nl"
          target="_blank"
          rel="noopener noreferrer"
          class="group clinical-glass p-6 rounded-(--radius-feature) border border-white/8 hover:border-active/30 transition-all cursor-pointer"
        >
          <div class="flex items-start justify-between mb-4">
            <h3
              class="text-xl font-bold text-white font-display group-hover:text-active transition-colors"
            >
              SmartCoolCare
            </h3>
            <span
              class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20"
              >IoT</span
            >
          </div>
          <p class="text-white/60 text-sm mb-4 font-ui leading-relaxed">
            24/7 koelmonitoring met automatische alarmering bij afwijkingen. Sensordata direct
            zichtbaar op uw scherm, waar u ook bent.
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">C++</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">ESP32</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">BLE</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Convex</span>
          </div>
          <!-- Lighthouse Scores -->
          <div
            class="flex items-center justify-around gap-2 py-3 mb-4 border-t border-b border-white/5"
          >
            <LighthouseGauge score={99} label="Perf" size="sm" />
            <LighthouseGauge score={90} label="A11y" size="sm" />
            <LighthouseGauge score={96} label="BP" size="sm" />
            <LighthouseGauge score={100} label="SEO" size="sm" />
          </div>
          <span class="text-active text-sm font-bold flex items-center gap-2 font-ui">
            Bekijk project
            <Icon
              name="arrow-right"
              size={16}
              class="group-hover:translate-x-1 transition-transform"
            />
          </span>
        </a>

        <!-- Project 3: C&F Bouw -->
        <a
          href="https://cfbouw.nl"
          target="_blank"
          rel="noopener noreferrer"
          class="group clinical-glass p-6 rounded-(--radius-feature) border border-white/8 hover:border-active/30 transition-all cursor-pointer"
        >
          <div class="flex items-start justify-between mb-4">
            <h3
              class="text-xl font-bold text-white font-display group-hover:text-active transition-colors"
            >
              C&F Bouw
            </h3>
            <span
              class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20"
              >Lead-Gen</span
            >
          </div>
          <p class="text-white/60 text-sm mb-4 font-ui leading-relaxed">
            Stapsgewijs offertetraject, projectgalerij en automatische klantcommunicatie. +340%
            organisch verkeer binnen 6 maanden na lancering.
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Next.js</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Convex</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Go</span>
          </div>
          <!-- Lighthouse Scores -->
          <div
            class="flex items-center justify-around gap-2 py-3 mb-4 border-t border-b border-white/5"
          >
            <LighthouseGauge score={99} label="Perf" size="sm" />
            <LighthouseGauge score={97} label="A11y" size="sm" />
            <LighthouseGauge score={100} label="BP" size="sm" />
            <LighthouseGauge score={100} label="SEO" size="sm" />
          </div>
          <span class="text-active text-sm font-bold flex items-center gap-2 font-ui">
            Bekijk project
            <Icon
              name="arrow-right"
              size={16}
              class="group-hover:translate-x-1 transition-transform"
            />
          </span>
        </a>

        <!-- Project 4: Dustin Auto Garage -->
        <div class="clinical-glass p-6 rounded-(--radius-feature) border border-white/8">
          <div class="flex items-start justify-between mb-4">
            <h3 class="text-xl font-bold text-white font-display">Dustin Auto Garage</h3>
            <span
              class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-active/10 text-active border border-active/20"
              >Platform</span
            >
          </div>
          <p class="text-white/60 text-sm mb-4 font-ui leading-relaxed">
            Compleet werkplaatsbeheer: planning, klantenbeheer, voertuigregistratie met
            RDW-koppeling en automatische facturatie.
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Astro</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">React 19</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Convex</span>
            <span class="text-xs text-white/40 bg-white/5 px-2 py-1 rounded-md">Go</span>
          </div>
          <span class="text-emerald-400 text-sm font-bold flex items-center gap-2 font-ui">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            In Productie
          </span>
        </div>
      </div>

      <div class="text-center mt-8">
        <a href="/portfolio" class="btn-secondary">
          Bekijk alle projecten
          <Icon name="arrow-right" size={16} />
        </a>
      </div>
    </div>
  </section>

  <!-- Personal Touch / CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div
        class="clinical-glass p-8 md:p-12 rounded-(--radius-hero) border border-active/20 max-w-4xl mx-auto text-center"
      >
        <span class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-4 block"
          >De mens achter het systeem</span
        >
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 font-display">Jeffrey Lavente</h2>
        <p
          class="text-white/70 text-base md:text-lg leading-relaxed mb-6 max-w-2xl mx-auto font-ui"
        >
          Systems engineer met een achtergrond in intensieve NAH-zorg. Ik bouw
          systemen die niet alleen technisch solide zijn, maar ook structuur en veiligheid
          bieden in de echte wereld.
        </p>
        <p class="text-white/40 text-sm font-ui mb-6">
          Plan een Discovery en ontdek waar u direct tijd, kosten of risico kunt besparen.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/over" class="btn-secondary"> Lees mijn verhaal </a>
          <a href="/contact?type=discovery" class="btn-primary">
            Plan een Discovery
            <Icon name="arrow-right" size={16} />
          </a>
        </div>
      </div>
    </div>
  </section>

  <FAQSection />
</Layout>
