---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import StatCard from '../components/ui/StatCard.astro';
import TechStackBadge from '../components/ui/TechStackBadge.astro';
import Icon, { type IconName } from '../components/ui/Icon.astro';

const expertiseDomains = [
  {
    icon: 'brain-circuit',
    title: 'AI & Prompt Engineering',
    techs: ['GPT-4', 'Claude', 'LangChain', 'Custom Agents'],
    description: 'Custom AI-workflows, intelligente agents en LLM-integraties. Van prompt design tot productie-klare AI-oplossingen die bedrijfsprocessen automatiseren.',
  },
  {
    icon: 'radio',
    title: 'IoT & Embedded Systems',
    techs: ['C++', 'ESP32', 'BLE', 'OTA Updates'],
    description: 'Deep-sleep firmware, sensortelemetrie en over-the-air updates. Hardware monitoring met real-time cloud-synchronisatie.',
  },
  {
    icon: 'cog',
    title: 'Backend & Security Engineering',
    techs: ['Go', 'PostgreSQL', 'Redis', 'Zero-Trust'],
    description: 'Dual-Token architectuur, Row Level Security, immutable audit logs, Zero-Trust API\'s met rate limiting en RBAC.',
  },
  {
    icon: 'monitor',
    title: 'Full-Stack Web Development',
    techs: ['Astro', 'Next.js', 'React 19', 'Convex'],
    description: 'Islands Architecture voor perfecte Lighthouse scores. Real-time dashboards, server-side rendering en conversiegerichte frontends.',
  },
  {
    icon: 'cloud',
    title: 'Cloud & DevOps',
    techs: ['Vercel', 'Render', 'CI/CD', 'Sentry'],
    description: 'Deployment op edge-netwerken. Geautomatiseerde pipelines, monitoring, SSL en managed hosting architecturen.',
  },
];

const kernwaarden = [
  { icon: 'lock', title: 'Veiligheid als standaard', desc: 'Niet als optionele module, maar als fundament.' },
  { icon: 'link', title: 'End-to-end verantwoordelijkheid', desc: 'Van sensor tot dashboard, alles onder één dak.' },
  { icon: 'trending-up', title: 'Schaalbare architectuur', desc: 'Oplossingen die meegroeien met de klant.' },
  { icon: 'handshake', title: 'Transparantie', desc: 'Langdurige partnerschappen boven snelle projecten.' },
];
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Jeffrey Lavente',
  jobTitle: 'AI Prompt Engineer & Full-Stack Developer',
  description: 'Van intensieve 1-op-1 begeleiding in de NAH-zorg naar IT-architectuur. Combineert psychologisch inzicht met AI-gedreven development en Zero-Trust security.',
  url: 'https://lavente.care/over',
  worksFor: {
    '@type': 'Organization',
    name: 'LaventeCare',
    url: 'https://lavente.care',
  },
  knowsAbout: [
    'AI Prompt Engineering', 'LLM Integration', 'Go', 'PostgreSQL',
    'React', 'Next.js', 'Astro', 'C++', 'ESP32', 'IoT',
    'Zero-Trust Security', 'Cloud Architecture',
    'NAH Begeleiding', 'Psychologische Analyse',
  ],
  sameAs: [
    'https://linkedin.com/in/jeffrey-lavente',
    'https://github.com/Jeffreasy',
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Dronten',
    addressRegion: 'Flevoland',
    addressCountry: 'NL',
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

<Layout
  title="Over Jeffrey Lavente — LaventeCare"
  description="Van intensieve NAH-zorg naar IT-architectuur. Jeffrey Lavente combineert psychologisch inzicht met AI-gedreven development. De mens achter LaventeCare."
>
  <!-- Hero -->
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="flex flex-col md:flex-row items-start gap-8 md:gap-12">
          <!-- Avatar Placeholder -->
          <div class="w-24 h-24 md:w-32 md:h-32 rounded-2xl bg-active/10 border-2 border-active/30 flex items-center justify-center flex-shrink-0 mx-auto md:mx-0">
            <span class="text-4xl md:text-5xl font-black text-active font-display">JL</span>
          </div>

          <div>
            <span class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-3 block">Over de oprichter</span>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-4 font-display tracking-tight">
              Jeffrey Lavente
            </h1>
            <p class="text-lg md:text-xl text-white/70 leading-relaxed font-ui">
              Van intensieve 1-op-1 begeleiding in de NAH-zorg naar IT-architectuur. Ik combineer <span class="text-white font-semibold">psychologisch inzicht</span> met AI-gedreven development en bouw digitale systemen die — net als in de zorg — <span class="text-active font-semibold">structuur, veiligheid en menselijkheid</span> als fundament hebben.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Van Zorg naar Tech -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <SectionHeader
          label="Het verhaal"
          heading='Van menselijke zorg naar <span class="text-active">digitale systemen</span>'
        />
        <div class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-active/20 bg-active/5">
          <p class="text-white/80 text-sm md:text-base leading-relaxed font-ui mb-4">
            Jarenlang werkte ik als intensief 1-op-1 begeleider van individuen met complexe (niet-aangeboren) hersenletsels. In die wereld leerde ik een fundamentele les: <span class="text-white font-semibold">waar chaos heerst, is rust, structuur en grenzeloze toewijding essentieel</span>.
          </p>
          <p class="text-white/80 text-sm md:text-base leading-relaxed font-ui mb-4">
            Vandaag pas ik diezelfde psychologische blik toe op software-architectuur. Het internet is onvoorspelbaar; daarom bouw ik <span class="text-active font-semibold">"Forten"</span> in plaats van gewone websites. Mijn missie is niet het typen van regels code, maar het ontwerpen van digitale ecosystemen die robuust, veilig en beheersbaar zijn.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-6">
            <div class="text-center p-4 rounded-lg bg-white/3 border border-white/5">
              <Icon name="brain-circuit" size={20} class="text-active mx-auto mb-2" />
              <p class="text-white text-xs font-bold font-display">Analytisch in chaos</p>
              <p class="text-white/50 text-[11px] font-ui">Helder denken als alles complex is</p>
            </div>
            <div class="text-center p-4 rounded-lg bg-white/3 border border-white/5">
              <Icon name="lock" size={20} class="text-active mx-auto mb-2" />
              <p class="text-white text-xs font-bold font-display">Grenzen stellen</p>
              <p class="text-white/50 text-[11px] font-ui">Beveiligen is zorgverlening</p>
            </div>
            <div class="text-center p-4 rounded-lg bg-white/3 border border-white/5">
              <Icon name="handshake" size={20} class="text-active mx-auto mb-2" />
              <p class="text-white text-xs font-bold font-display">1-op-1 verantwoordelijk</p>
              <p class="text-white/50 text-[11px] font-ui">Geen schakel, maar eigenaar</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Bouwen in het AI-tijdperk -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <SectionHeader
          label="De werkwijze"
          heading='Bouwen in het <span class="text-active">AI-tijdperk</span>'
        />
        <div class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-white/8">
          <p class="text-white/80 text-sm md:text-base leading-relaxed font-ui mb-4">
            Ik geloof in radicale eerlijkheid: ik ben geen codeklopper die al twintig jaar op een kantoor zit. We leven in een nieuw tijdperk. Ik fungeer als de <span class="text-white font-semibold">IT-Architect</span> en gebruik geavanceerde AI-modellen als mijn uitvoerende bouwteam.
          </p>
          <p class="text-white/80 text-sm md:text-base leading-relaxed font-ui mb-4">
            AI bouwt razendsnel, maar heeft de neiging om "happy paths" te kiezen. Hier ligt mijn absolute kracht: ik bepaal de blauwdruk, hanteer <span class="text-active font-semibold">Spartaanse veiligheidsregels</span> (zoals Zero-Trust en Row Level Security) en stuur de AI bij waar nodig. Door fouten didactisch te analyseren en de architectuur constant te versterken, lever ik in mijn eentje sneller enterprise-concepten dan een traditioneel bureau.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 mt-6 p-4 rounded-lg bg-active/5 border border-active/15">
            <div class="flex-1 flex items-start gap-3">
              <Icon name="cog" size={18} class="text-active flex-shrink-0 mt-0.5" />
              <div>
                <p class="text-white text-xs font-bold font-display">AI = Uitvoerder</p>
                <p class="text-white/60 text-[11px] font-ui">Razendsnel bouwen, itereren en testen</p>
              </div>
            </div>
            <div class="flex-1 flex items-start gap-3">
              <Icon name="brain-circuit" size={18} class="text-active flex-shrink-0 mt-0.5" />
              <div>
                <p class="text-white text-xs font-bold font-display">Ik = Architect</p>
                <p class="text-white/60 text-[11px] font-ui">Blauwdruk, veiligheid en kwaliteitscontrole</p>
              </div>
            </div>
            <div class="flex-1 flex items-start gap-3">
              <Icon name="lock" size={18} class="text-active flex-shrink-0 mt-0.5" />
              <div>
                <p class="text-white text-xs font-bold font-display">Database Fortress</p>
                <p class="text-white/60 text-[11px] font-ui">De AI in toom, de data onkraakbaar</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Radicale Eerlijkheid Quote -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-active/20 relative">
          <div class="absolute top-4 left-6 text-4xl text-active/30 font-display">"</div>
          <blockquote class="text-base md:text-lg text-white/80 leading-relaxed font-ui pl-4 md:pl-8 border-l-2 border-active/40">
            Ik geloof niet in perfectie, ik geloof in <span class="text-white font-semibold">extreme leergierigheid, transparantie en keiharde veiligheid</span>. Ik beloof je niet de infrastructuur van een internationale bank, maar ik bied je wel de paranoïde veiligheidsprincipes ervan, toegepast op maatwerk MKB-, IoT- en webprojecten. Leren door te bouwen, zonder ooit compromissen te sluiten op de veiligheid van <span class="text-active font-semibold">jouw data</span>.
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- Achtergrond -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Opleiding -->
        <div class="clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8">
          <h2 class="text-xl font-bold text-white mb-5 font-display flex items-center gap-3">
            <Icon name="graduation-cap" size={20} class="text-active" /> Opleiding
          </h2>
          <ul class="space-y-4">
            <li>
              <p class="text-white font-semibold text-sm">MBO Niveau 4</p>
              <p class="text-white/60 text-sm font-ui">Persoonlijk Begeleider Specifieke Doelgroepen (2017–2018)</p>
            </li>
            <li>
              <p class="text-white font-semibold text-sm">MBO Niveau 3</p>
              <p class="text-white/60 text-sm font-ui">Medewerker Maatschappelijke Zorg (2015–2017)</p>
            </li>
            <li>
              <p class="text-white font-semibold text-sm">Autodidact Software Engineering</p>
              <p class="text-white/60 text-sm font-ui">Full-stack, IoT, Go, Rust, Cloud Security</p>
            </li>
          </ul>
        </div>

        <!-- Werkervaring -->
        <div class="clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8">
          <h2 class="text-xl font-bold text-white mb-5 font-display flex items-center gap-3">
            <Icon name="briefcase" size={20} class="text-active" /> Werkervaring
          </h2>
          <ul class="space-y-4">
            <li>
              <div class="flex items-baseline justify-between">
                <p class="text-white font-semibold text-sm">Oprichter & Lead Developer</p>
                <span class="text-active text-xs font-bold">2023 – heden</span>
              </div>
              <p class="text-white/60 text-sm font-ui">LaventeCare — End-to-end development van complexe digitale ecosystemen.</p>
            </li>
            <li>
              <div class="flex items-baseline justify-between">
                <p class="text-white font-semibold text-sm">1-op-1 Begeleider NAH++</p>
                <span class="text-active text-xs font-bold">2018 – heden</span>
              </div>
              <p class="text-white/60 text-sm font-ui">'s Heeren Loo — Intensieve individuele begeleiding van cliënten met NAH++. Analytisch blijven in chaos, 1-op-1 verantwoordelijkheid nemen, grenzen stellen en veilige structuren bouwen.</p>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Technische Expertise -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Technische expertise"
        heading='Uitzonderlijk breed <span class="text-active">spectrum</span>'
        description="Van het schrijven van firmware op microcontrollers tot het bouwen van Zero-Trust security backends en pixel-perfect frontends — alles onder één dak."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        {expertiseDomains.map((domain) => (
          <div class="clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8 hover:border-active/20 transition-colors">
            <div class="flex items-center gap-3 mb-4">
              <Icon name={domain.icon as IconName} size={24} class="text-active" />
              <h3 class="text-lg font-bold text-white font-display">{domain.title}</h3>
            </div>
            <p class="text-white/60 text-sm leading-relaxed mb-4 font-ui">{domain.description}</p>
            <div class="flex flex-wrap gap-2">
              {domain.techs.map((tech) => (
                <TechStackBadge tech={tech} variant="subtle" />
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Kernwaarden -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Kernwaarden"
        heading='Waar ik voor <span class="text-active">sta</span>'
      />

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 max-w-5xl mx-auto">
        {kernwaarden.map((waarde) => (
          <div class="clinical-glass p-5 rounded-(--radius-card) border border-white/8 text-center">
            <Icon name={waarde.icon as IconName} size={24} class="text-active block mb-3" />
            <h3 class="text-sm font-bold text-white mb-2 font-display">{waarde.title}</h3>
            <p class="text-white/50 text-xs font-ui">{waarde.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bedrijfsgegevens -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-white/8 max-w-3xl mx-auto">
        <h2 class="text-xl font-bold text-white mb-6 font-display text-center">Bedrijfsgegevens</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm font-ui">
          <div class="flex justify-between sm:flex-col gap-1">
            <span class="text-white/50">Rechtsvorm</span>
            <span class="text-white font-medium">Eenmanszaak (ZZP)</span>
          </div>
          <div class="flex justify-between sm:flex-col gap-1">
            <span class="text-white/50">KVK-nummer</span>
            <span class="text-white font-medium">88162710</span>
          </div>
          <div class="flex justify-between sm:flex-col gap-1">
            <span class="text-white/50">Opgericht</span>
            <span class="text-white font-medium">17 oktober 2022</span>
          </div>
          <div class="flex justify-between sm:flex-col gap-1">
            <span class="text-white/50">Vestiging</span>
            <span class="text-white font-medium">Dronten, Nederland</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4 text-center">
      <a href="/contact" class="btn-primary text-lg px-10">
        Neem contact op
        <Icon name="arrow-right" size={20} />
      </a>
    </div>
  </section>
</Layout>
