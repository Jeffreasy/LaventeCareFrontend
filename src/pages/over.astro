---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import TechStackBadge from '../components/ui/TechStackBadge.astro';
import Icon, { type IconName } from '../components/ui/Icon.astro';

const expertiseDomains = [
  {
    icon: 'brain-circuit',
    title: 'AI & Automatisering',
    techs: ['LLM-integratie', 'Custom Agents', 'Mens beslist mee'],
    description:
      'AI die terugkerend werk overneemt en gegevens benut voor snellere beslissingen. Betrouwbaar, meetbaar en met een mens die meebeslist — geïntegreerd in uw bestaande werkprocessen.',
  },
  {
    icon: 'radio',
    title: 'Slimme bewaking & sensoren',
    techs: ['C++', 'ESP32', 'BLE', 'OTA Updates'],
    description:
      'Van sensor tot dashboard: problemen vroeg signaleren en minder stilstand. Live inzicht via uw scherm, software-updates op afstand.',
  },
  {
    icon: 'cog',
    title: 'Beveiliging & Toegang',
    techs: ['PostgreSQL RLS', 'RBAC', 'Audit Trails'],
    description:
      'De gegevens van elke klant staan strikt gescheiden, iedereen ziet alleen wat hij mag, en elke actie wordt vastgelegd. Veiligheid vanaf de basis, gebouwd volgens de AVG (Privacy by Design). Onder de motorkap: gescheiden klantdata (PostgreSQL RLS), toegang per rol (RBAC) en volledige logging.',
  },
  {
    icon: 'monitor',
    title: 'Maatwerk Platformen',
    techs: ['Astro', 'React 19', 'Convex', 'Go Auth'],
    description:
      'Losse tools en handwerk vervangen door één systeem dat met u meegroeit, met alles op één plek. Razendsnelle schermen die hoog scoren bij Google en bezoekers helpen om een aanvraag te doen.',
  },
  {
    icon: 'cloud',
    title: 'Hosting & Beheer',
    techs: ['Vercel', 'Render', 'CI/CD', 'Sentry'],
    description:
      'Uw applicatie draait op snelle servers wereldwijd. Automatische updates, doorlopende bewaking en SSL-certificaten — doorlopend onderhoud met vaste afspraken mogelijk (SLA).',
  },
];

const kernwaarden = [
  {
    icon: 'lock',
    title: 'Veiligheid als standaard',
    desc: 'Niet als optionele module, maar als fundament.',
  },
  {
    icon: 'link',
    title: 'End-to-end verantwoordelijkheid',
    desc: 'Van sensor tot dashboard, alles onder één dak.',
  },
  {
    icon: 'trending-up',
    title: 'Groeit met u mee',
    desc: 'Systemen die meegroeien met de klant.',
  },
  {
    icon: 'handshake',
    title: 'Transparantie',
    desc: 'Langdurige partnerschappen boven snelle projecten.',
  },
];
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Jeffrey Lavente',
  jobTitle: 'Oprichter LaventeCare — B2B systeempartner voor het mkb',
  description:
    'Oprichter van LaventeCare, een B2B systeempartner voor mkb-organisaties. Bouwt professionele websites, AI, IoT, maatwerkplatformen en beveiligde bedrijfssystemen.',
  image:
    'https://ik.imagekit.io/a0oim4e3e/LaventeCare/IMG_0040.JPG?tr=w-512,h-512,fo-face,f-auto,q-85',
  url: 'https://www.laventecare.nl/over',
  worksFor: {
    '@type': 'Organization',
    name: 'LaventeCare',
    url: 'https://www.laventecare.nl',
  },
  knowsAbout: [
    'Professionele Astro websites',
    'AI & Automatisering',
    'LLM Integration',
    'Go',
    'PostgreSQL',
    'React',
    'Astro',
    'C++',
    'ESP32',
    'IoT',
    'Security-first Architecture',
    'Cloud Architecture',
    'Maatwerksoftware',
  ],
  sameAs: [
    'https://linkedin.com/in/jeffrey-lavente',
    'https://github.com/Jeffreasy',
    'https://www.instagram.com/jjalavente/',
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Dronten',
    addressRegion: 'Flevoland',
    addressCountry: 'NL',
  },
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />

<Layout
  title="Over LaventeCare — B2B systeempartner voor het mkb"
  description="LaventeCare is een vaste B2B systeempartner die uw manier van werken omzet in software die het werk uit handen neemt: AI, automatisering, maatwerksoftware, bewaking en beveiliging vanaf de basis. Van idee tot werkend systeem."
>
  <!-- Hero -->
  <section class="section-padding pt-32 md:pt-40">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="flex flex-col md:flex-row items-center md:items-start gap-8 md:gap-12">
          <!-- Profile Photo — Professional ImageKit with full device support -->
          <div class="profile-photo-wrapper shrink-0">
            <div class="profile-photo-container">
              <picture>
                <!-- Mobile: Square crop, smaller payload -->
                <source
                  media="(max-width: 639px)"
                  srcset="
                    https://ik.imagekit.io/a0oim4e3e/LaventeCare/IMG_0040.JPG?tr=w-160,h-160,fo-face,f-auto,q-80,e-sharpen 1x,
                    https://ik.imagekit.io/a0oim4e3e/LaventeCare/IMG_0040.JPG?tr=w-320,h-320,fo-face,f-auto,q-75,e-sharpen 2x
                  "
                />
                <!-- Tablet: Slightly larger, portrait aspect -->
                <source
                  media="(max-width: 1023px)"
                  srcset="
                    https://ik.imagekit.io/a0oim4e3e/LaventeCare/IMG_0040.JPG?tr=w-200,h-240,fo-face,f-auto,q-82,e-sharpen 1x,
                    https://ik.imagekit.io/a0oim4e3e/LaventeCare/IMG_0040.JPG?tr=w-400,h-480,fo-face,f-auto,q-78,e-sharpen 2x
                  "
                />
                <!-- Desktop: Full quality portrait -->
                <source
                  media="(min-width: 1024px)"
                  srcset="
                    https://ik.imagekit.io/a0oim4e3e/LaventeCare/IMG_0040.JPG?tr=w-220,h-280,fo-face,f-auto,q-85,e-sharpen 1x,
                    https://ik.imagekit.io/a0oim4e3e/LaventeCare/IMG_0040.JPG?tr=w-440,h-560,fo-face,f-auto,q-80,e-sharpen 2x
                  "
                />
                <!-- Fallback -->
                <img
                  src="https://ik.imagekit.io/a0oim4e3e/LaventeCare/IMG_0040.JPG?tr=w-220,h-280,fo-face,f-auto,q-85,e-sharpen"
                  alt="Jeffrey Lavente — oprichter LaventeCare"
                  width="220"
                  height="280"
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                  class="profile-photo-img"
                />
              </picture>
              <!-- Subtle inner glow overlay -->
              <div class="profile-photo-overlay" aria-hidden="true"></div>
            </div>
          </div>

          <div class="text-center md:text-left">
            <span class="text-active font-bold tracking-[0.2em] uppercase text-xs mb-3 block"
              >Over LaventeCare</span
            >
            <h1
              class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-4 font-display tracking-tight"
            >
              Van idee tot werkend systeem
            </h1>
            <p class="text-lg md:text-xl text-white/70 leading-relaxed font-ui">
              LaventeCare is een <span class="text-white font-semibold"
                >B2B systeempartner voor mkb-organisaties</span
              > die digitale groei, websites, automatisering en maatwerksoftware goed en betrouwbaar willen
              regelen. Geen standaard pagebuilder of eenmalige leverancier, maar een <span
                class="text-active font-semibold">vaste partner</span
              > die uw manier van werken omzet in software die het werk uit handen neemt.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Wat wij doen -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <SectionHeader
          label="De partner"
          heading='Een vaste partner, geen <span class="text-active">losse leverancier</span>'
        />
        <div
          class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-active/20 bg-active/5"
        >
          <p class="text-white/80 text-sm md:text-base leading-relaxed font-ui mb-4">
            LaventeCare bouwt systemen die bedrijven efficiënter maken, fouten voorkomen en groei
            versnellen: <span class="text-white font-semibold"
              >AI, IoT, maatwerkplatformen, klanten werven en systemen met beveiliging vanaf de
              basis</span
            >. We richten ons op het mkb, dienstverleners en operationele teams met terugkerende
            processen.
          </p>
          <p class="text-white/80 text-sm md:text-base leading-relaxed font-ui mb-4">
            Onze kernbelofte: van losse tools en handmatig werk naar één <span
              class="text-active font-semibold">digitaal systeem dat met u meegroeit</span
            >. Kennismaking, analyse, bouwplan (Blueprint), bouw, beheer en doorontwikkeling — geen
            los project dat na oplevering stilvalt, maar een systeem dat blijft werken en meegroeit.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-6">
            <div class="text-center p-4 rounded-lg bg-white/3 border border-white/5">
              <Icon name="brain-circuit" size={20} class="text-active mx-auto mb-2" />
              <p class="text-white text-xs font-bold font-display">Proces eerst</p>
              <p class="text-white/50 text-[11px] font-ui">Systemen, geen losse styling</p>
            </div>
            <div class="text-center p-4 rounded-lg bg-white/3 border border-white/5">
              <Icon name="lock" size={20} class="text-active mx-auto mb-2" />
              <p class="text-white text-xs font-bold font-display">Veiligheid vanaf de basis</p>
              <p class="text-white/50 text-[11px] font-ui">Beveiliging als fundament</p>
            </div>
            <div class="text-center p-4 rounded-lg bg-white/3 border border-white/5">
              <Icon name="handshake" size={20} class="text-active mx-auto mb-2" />
              <p class="text-white text-xs font-bold font-display">Vaste partner</p>
              <p class="text-white/50 text-[11px] font-ui">Beheer en doorontwikkeling</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Transparantie: solo-founder + AI als bouwteam -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <SectionHeader
          label="Radicale transparantie"
          heading='Wie er achter <span class="text-active">LaventeCare</span> staat'
        />
        <div class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-white/8">
          <p class="text-white/80 text-sm md:text-base leading-relaxed font-ui mb-4">
            Ik geloof in radicale eerlijkheid over hoe LaventeCare werkt. LaventeCare is opgezet en
            wordt geleid door <span class="text-white font-semibold">Jeffrey Lavente</span> als oprichter
            en engineer. Ik fungeer als de architect die de blauwdruk bepaalt, en gebruik geavanceerde
            AI-modellen als mijn <span class="text-active font-semibold">uitvoerende bouwteam</span
            >.
          </p>
          <p class="text-white/80 text-sm md:text-base leading-relaxed font-ui mb-4">
            AI bouwt razendsnel, maar kiest graag de makkelijkste route en slaat de uitzonderingen
            over. Daar zit de kracht van deze werkwijze. Ik bepaal de opzet en stuur bij waar nodig.
            Ik hanteer strikte veiligheidsregels: gegevens strikt gescheiden en elke actie
            vastgelegd. Zo levert LaventeCare systemen op met ingebouwde beveiliging, gescheiden
            gegevens en live bewaking — de discipline van een team, geleverd door één
            verantwoordelijke partner.
          </p>
          <div
            class="flex flex-col sm:flex-row gap-4 mt-6 p-4 rounded-lg bg-active/5 border border-active/15"
          >
            <div data-animate="fade-up" class="flex-1 flex items-start gap-3">
              <Icon name="cog" size={18} class="text-active shrink-0 mt-0.5" />
              <div>
                <p class="text-white text-xs font-bold font-display">AI = Uitvoerder</p>
                <p class="text-white/60 text-[11px] font-ui">
                  Razendsnel bouwen, verbeteren en testen
                </p>
              </div>
            </div>
            <div data-animate="fade-up" class="delay-100 flex-1 flex items-start gap-3">
              <Icon name="brain-circuit" size={18} class="text-active shrink-0 mt-0.5" />
              <div>
                <p class="text-white text-xs font-bold font-display">Jeffrey = Architect</p>
                <p class="text-white/60 text-[11px] font-ui">
                  Blauwdruk, veiligheid en kwaliteitscontrole
                </p>
              </div>
            </div>
            <div data-animate="fade-up" class="delay-200 flex-1 flex items-start gap-3">
              <Icon name="lock" size={18} class="text-active shrink-0 mt-0.5" />
              <div>
                <p class="text-white text-xs font-bold font-display">Database als fort</p>
                <p class="text-white/60 text-[11px] font-ui">
                  De AI in toom, de data strikt beschermd
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Achtergrond in de zorg -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <SectionHeader
          label="De achtergrond"
          heading='Structuur en veiligheid, geleerd in de <span class="text-active">zorg</span>'
        />
        <div
          class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-active/20 bg-active/5"
        >
          <p class="text-white/80 text-sm md:text-base leading-relaxed font-ui mb-4">
            Voordat ik LaventeCare startte, werkte ik jarenlang als intensief 1-op-1 begeleider van
            individuen met complexe (niet-aangeboren) hersenletsels. In die wereld leerde ik een
            fundamentele les: <span class="text-white font-semibold"
              >waar chaos heerst, zijn rust, structuur en grenzeloze toewijding essentieel</span
            >.
          </p>
          <p class="text-white/80 text-sm md:text-base leading-relaxed font-ui mb-4">
            Diezelfde blik pas ik toe op digitale techniek. Ook een compacte website bouw ik als
            <span class="text-active font-semibold">een basis met structuur en grenzen</span> — snel,
            veilig en beheersbaar. Als de vraag groeit, kan die basis doorgroeien naar formulieren, automatisering
            of een compleet platform.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Radicale Eerlijkheid Quote -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div
          class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-active/20 relative"
        >
          <div class="absolute top-4 left-6 text-4xl text-active/30 font-display">"</div>
          <blockquote
            class="text-base md:text-lg text-white/80 leading-relaxed font-ui pl-4 md:pl-8 border-l-2 border-active/40"
          >
            Ik geloof niet in perfectie, ik geloof in <span class="text-white font-semibold"
              >extreme leergierigheid, transparantie en keiharde veiligheid</span
            >. Een systeem verraadt niets, en de database is een kluis. Of het nu een mkb-portaal,
            een IoT-dashboard of een maatwerkplatform is: <span class="text-active font-semibold"
              >uw data krijgt hetzelfde beschermingsniveau</span
            >.
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- Achtergrond -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Opleiding -->
        <div class="clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8">
          <h2 class="text-xl font-bold text-white mb-5 font-display flex items-center gap-3">
            <Icon name="graduation-cap" size={20} class="text-active" /> Opleiding
          </h2>
          <ul class="space-y-4">
            <li>
              <p class="text-white font-semibold text-sm">MBO Niveau 4</p>
              <p class="text-white/60 text-sm font-ui">
                Persoonlijk Begeleider Specifieke Doelgroepen (2017–2018)
              </p>
            </li>
            <li>
              <p class="text-white font-semibold text-sm">MBO Niveau 3</p>
              <p class="text-white/60 text-sm font-ui">
                Medewerker Maatschappelijke Zorg (2015–2017)
              </p>
            </li>
            <li>
              <p class="text-white font-semibold text-sm">Self-Taught Systems Engineer</p>
              <p class="text-white/60 text-sm font-ui">
                Go, PostgreSQL, Security Architecture, IoT, Cloud Infrastructure
              </p>
            </li>
          </ul>
        </div>

        <!-- Werkervaring -->
        <div class="clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8">
          <h2 class="text-xl font-bold text-white mb-5 font-display flex items-center gap-3">
            <Icon name="briefcase" size={20} class="text-active" /> Werkervaring
          </h2>
          <ul class="space-y-4">
            <li>
              <div class="flex items-baseline justify-between">
                <p class="text-white font-semibold text-sm">Oprichter & Systems Engineer</p>
                <span class="text-active text-xs font-bold">2026 – heden</span>
              </div>
              <p class="text-white/60 text-sm font-ui">
                LaventeCare — Vaste systeempartner voor het mkb: ontwerp en bouw van
                maatwerkplatformen met ingebouwde beveiliging, AI-automatisering en live bewaking
                (IoT).
              </p>
            </li>
            <li>
              <div class="flex items-baseline justify-between">
                <p class="text-white font-semibold text-sm">1-op-1 Begeleider NAH++</p>
                <span class="text-active text-xs font-bold">2018 – heden</span>
              </div>
              <p class="text-white/60 text-sm font-ui">
                's Heeren Loo — Intensieve individuele begeleiding van cliënten met NAH++.
                Analytisch blijven in chaos, 1-op-1 verantwoordelijkheid nemen, grenzen stellen en
                veilige structuren bouwen.
              </p>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Technische Expertise -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Technische expertise"
        heading='Uitzonderlijk breed <span class="text-active">vakgebied</span>'
        description="Van slimme sensoren tot strikt gescheiden klantgegevens en supersnelle platformen — alles onder één dak. Dat is zeldzaam, en precies dát maakt het verschil."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        {
          expertiseDomains.map((domain) => (
            <div class="clinical-glass p-6 md:p-8 rounded-(--radius-feature) border border-white/8 hover:border-active/20 transition-colors">
              <div class="flex items-center gap-3 mb-4">
                <Icon name={domain.icon as IconName} size={24} class="text-active" />
                <h3 class="text-lg font-bold text-white font-display">{domain.title}</h3>
              </div>
              <p class="text-white/60 text-sm leading-relaxed mb-4 font-ui">{domain.description}</p>
              <div class="flex flex-wrap gap-2">
                {domain.techs.map((tech) => (
                  <TechStackBadge tech={tech} variant="subtle" />
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Kernwaarden -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Kernwaarden"
        heading='Waar ik voor <span class="text-active">sta</span>'
      />

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 max-w-5xl mx-auto">
        {
          kernwaarden.map((waarde) => (
            <div class="clinical-glass p-5 rounded-(--radius-card) border border-white/8 text-center">
              <Icon name={waarde.icon as IconName} size={24} class="text-active block mb-3" />
              <h3 class="text-sm font-bold text-white mb-2 font-display">{waarde.title}</h3>
              <p class="text-white/50 text-xs font-ui">{waarde.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Bedrijfsgegevens -->
  <section class="section-padding">
    <div class="container mx-auto px-4">
      <div
        class="clinical-glass p-6 md:p-10 rounded-(--radius-hero) border border-white/8 max-w-3xl mx-auto"
      >
        <h2 class="text-xl font-bold text-white mb-6 font-display text-center">Bedrijfsgegevens</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm font-ui">
          <div class="flex justify-between sm:flex-col gap-1">
            <span class="text-white/50">Rechtsvorm</span>
            <span class="text-white font-medium">Eenmanszaak</span>
          </div>
          <div class="flex justify-between sm:flex-col gap-1">
            <span class="text-white/50">KVK-nummer</span>
            <span class="text-white font-medium">88162710</span>
          </div>
          <div class="flex justify-between sm:flex-col gap-1">
            <span class="text-white/50">BTW-nummer</span>
            <span class="text-white font-medium">NL004553268B57</span>
          </div>
          <div class="flex justify-between sm:flex-col gap-1">
            <span class="text-white/50">Opgericht</span>
            <span class="text-white font-medium">2026</span>
          </div>
          <div class="flex justify-between sm:flex-col gap-1">
            <span class="text-white/50">Vestiging</span>
            <span class="text-white font-medium">Dronten, Nederland</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding">
    <div class="container mx-auto px-4 text-center">
      <a href="/contact" class="btn-primary text-lg px-10">
        Neem contact op
        <Icon name="arrow-right" size={20} />
      </a>
    </div>
  </section>
</Layout>

<style>
  /* Profile Photo — Responsive container */
  .profile-photo-wrapper {
    position: relative;
  }

  .profile-photo-container {
    position: relative;
    width: 160px;
    height: 160px;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow:
      0 0 0 2px color-mix(in oklch, var(--color-active) 30%, transparent),
      0 0 30px -5px color-mix(in oklch, var(--color-active) 15%, transparent),
      0 8px 24px -8px rgba(0, 0, 0, 0.4);
    transition:
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.4s ease;
  }

  .profile-photo-container:hover {
    transform: scale(1.03);
    box-shadow:
      0 0 0 2px color-mix(in oklch, var(--color-active) 50%, transparent),
      0 0 40px -5px color-mix(in oklch, var(--color-active) 25%, transparent),
      0 16px 40px -8px rgba(0, 0, 0, 0.5);
  }

  .profile-photo-img {
