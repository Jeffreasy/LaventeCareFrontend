---
import Navbar from '../components/blocks/Navbar.astro';
import Footer from '../components/blocks/Footer.astro';
import SEO from '../components/blocks/SEO.astro';
import { ClientRouter } from 'astro:transitions';
import { CookieConsent } from '../components/islands/CookieConsent';
import { AnalyticsProvider } from '../components/islands/AnalyticsProvider';
import SpeedInsights from '@vercel/speed-insights/astro';
import { GlobalLoader } from '../components/islands/GlobalLoader';
import { NotificationToast } from '../components/islands/NotificationToast';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  seoOverride?: {
    title?: string;
    description?: string;
    image?: {
      filename: string;
      alt?: string;
    };
  };
}

const { title, description, noindex, seoOverride } = Astro.props;

// Static site settings
import { settings } from '../lib/config';

// Generate BreadcrumbList from URL path
const siteUrl = Astro.site?.href || 'https://www.laventecare.nl';
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);

const breadcrumbLabels: Record<string, string> = {
  over: 'Over',
  diensten: 'Diensten',
  portfolio: 'Portfolio',
  werkwijze: 'Werkwijze',
  pricing: 'Prijzen',
  prijzen: 'Prijzen',
  contact: 'Contact',
  'ai-prompt-engineering': 'AI & Prompt Engineering',
  'iot-hardware': 'IoT & Hardware',
  'maatwerk-platformen': 'Maatwerk Platformen',
  'lead-generation': 'Lead Generation',
  security: 'Security & Auth',
  'cf-bouw': 'C&F Bouw',
  'de-koninklijke-loop': 'De Koninklijke Loop',
  'dustin-auto-garage': 'Dustin Auto Garage',
  jeffdash: 'JeffDash',
  smartcoolcare: 'SmartCoolCare',
  tuinhub: 'TuinHub',
  'whisky-for-charity': 'Whisky for Charity',
};

const breadcrumbItems = [
  { name: 'Home', url: siteUrl },
  ...pathSegments.map((segment, index) => {
    const url = new URL('/' + pathSegments.slice(0, index + 1).join('/'), siteUrl).href;
    const name =
      breadcrumbLabels[segment] ||
      segment.charAt(0).toUpperCase() + segment.slice(1).replace(/-/g, ' ');
    return { name, url };
  }),
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name,
    item: item.url,
  })),
};
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="icon"
      type="image/svg+xml"
      href={settings.favicon?.[0]?.filename || '/favicon.svg'}
    />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0C4A6E" />
    <meta name="google-site-verification" content="InPi-pFXOpFmi6hKGp7_u2VnGrYyL9RUewuw-ApcCeI" />

    <!-- Google Fonts: Geist & Satoshi (Fontshare) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://api.fontshare.com/v2/css?f[]=satoshi@900,700,500,400&display=swap"
      rel="stylesheet"
    />

    <!-- SEO Meta Tags - Props are compatible at runtime -->
    <SEO
      title={seoOverride?.title || title || settings.meta_title}
      description={seoOverride?.description || description || settings.meta_description}
      image={seoOverride?.image || settings.og_image?.[0]}
      noindex={noindex}
    />

    <!-- CSRF Token (only render if available) -->
    {Astro.locals.csrfToken && <meta name="csrf-token" content={Astro.locals.csrfToken} />}

    <!-- Organization Schema moved to page-level (index.astro) to avoid duplication -->

    <!-- BreadcrumbList Schema (SEO Rich Results) -->
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

    <!-- Astro Client Router (View Transitions) -->
    <ClientRouter />

    <!-- GTM Head Script - Consent-Gated (deferred to idle) -->
    {
      settings.gtm_id && (
        <script
          set:html={`(function(){function loadGTM(){try{var d=localStorage.getItem("consent_state");if(!d)return;var c=JSON.parse(d);if(c.marketing){(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({"gtm.start":new Date().getTime(),event:"gtm.js"});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!="dataLayer"?"&l="+l:"";j.async=true;j.src="https://www.googletagmanager.com/gtm.js?id="+i+dl;f.parentNode.insertBefore(j,f)})(window,document,"script","dataLayer","${settings.gtm_id}")}}catch(e){}}if(typeof requestIdleCallback==="function"){requestIdleCallback(loadGTM)}else{setTimeout(loadGTM,1)}})();`}
        />
      )
    }
  </head>
  <body>
    <!-- [C2] Skip to Content — WCAG 2.4.1 -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-100 focus:px-4 focus:py-2 focus:bg-active focus:text-background focus:rounded-lg focus:font-semibold focus:shadow-lg"
    >
      Skip to content
    </a>

    <!-- Ambient Mesh Background Animation -->
    <div class="ambient-mesh" aria-hidden="true">
      <div class="ambient-mesh__orb ambient-mesh__orb--1"></div>
      <div class="ambient-mesh__orb ambient-mesh__orb--2"></div>
      <div class="ambient-mesh__orb ambient-mesh__orb--3"></div>
    </div>

    <!-- GTM Body Noscript -->
    {
      settings.gtm_id && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${settings.gtm_id}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
          />
        </noscript>
      )
    }

    <Navbar
      logo={settings.logo?.[0]}
      menu={settings.main_menu || []}
      siteName={settings.site_name}
    />

    <main id="main-content">
      <slot />
    </main>

    <Footer
      columns={settings.footer_columns || []}
      socialLinks={settings.social_links || []}
      copyright={settings.copyright_text || '© 2026 LaventeCare'}
    />

    <!-- Global UI Islands -->
    <GlobalLoader client:idle />
    <NotificationToast client:idle />

    <!-- GDPR Cookie Consent Banner -->
    <CookieConsent client:idle />

    <!-- Vercel Analytics (Consent-Gated) -->
    <AnalyticsProvider client:idle />

    <!-- Vercel Speed Insights (Core Web Vitals — no PII, no cookies) -->
    <SpeedInsights />

    <!-- Native Scroll Animations (Zero Dependencies, <1KB) -->
    <script is:inline>
      document.addEventListener('astro:page-load', () => {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px',
          }
        );

        document.querySelectorAll('[data-animate]').forEach((el) => {
          observer.observe(el);
        });
      });
    </script>

    <!-- Performance Monitoring (Dev Only) -->
    <script>
      import { initPerformanceMonitoring } from '../lib/performance/performanceMonitor';
      if (typeof window !== 'undefined' && import.meta.env.DEV) {
        window.addEventListener('load', () => {
          initPerformanceMonitoring();
        });
      }
    </script>
  </body>
</html>
