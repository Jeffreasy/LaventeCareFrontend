---
import Navbar from '../components/blocks/Navbar.astro';
import Footer from '../components/blocks/Footer.astro';
import SEO from '../components/blocks/SEO.astro';
import { ClientRouter } from 'astro:transitions';
import { CookieConsent } from '../components/islands/CookieConsent';
import { AnalyticsProvider } from '../components/islands/AnalyticsProvider';
import { GlobalLoader } from '../components/islands/GlobalLoader';
import { NotificationToast } from '../components/islands/NotificationToast';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  seoOverride?: {
    title?: string;
    description?: string;
    image?: {
      filename: string;
      alt?: string;
    };
  };
}

const { title, description, seoOverride } = Astro.props;

// Static site settings
import { settings } from '../lib/config';
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="icon"
      type="image/svg+xml"
      href={settings.favicon?.[0]?.filename || '/favicon.svg'}
    />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0C4A6E" />
    <meta name="google-site-verification" content="InPi-pFXOpFmi6hKGp7_u2VnGrYyL9RUewuw-ApcCeI" />

    <!-- Google Fonts: Geist & Satoshi (Fontshare) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://api.fontshare.com/v2/css?f[]=satoshi@900,700,500,400&display=swap"
      rel="stylesheet"
    />

    <!-- SEO Meta Tags - Props are compatible at runtime -->
    <SEO
      title={seoOverride?.title || title || settings.meta_title}
      description={seoOverride?.description || description || settings.meta_description}
      image={seoOverride?.image || settings.og_image?.[0]}
    />

    <!-- CSRF Token -->
    <meta name="csrf-token" content={Astro.locals.csrfToken} />

    <!-- Sitewide Organization Schema (E-E-A-T) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "LaventeCare",
      "url": "https://lavente.care",
      "logo": "https://lavente.care/og-image.png",
      "founder": {
        "@type": "Person",
        "name": "Jeffrey Lavente",
        "jobTitle": "Full-Stack Developer & IoT Engineer"
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Dronten",
        "addressRegion": "Flevoland",
        "postalCode": "8251 ZB",
        "addressCountry": "NL"
      },
      "sameAs": [
        "https://linkedin.com/in/jeffrey-lavente",
        "https://github.com/Jeffreasy"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "jeffrey@laventecare.nl",
        "contactType": "customer service",
        "availableLanguage": "Dutch"
      }
    })} />

    <!-- Astro Client Router (View Transitions) -->
    <ClientRouter />

    <!-- GTM Head Script - Consent-Gated -->
    {
      settings.gtm_id && (
        <script
          set:html={`(function checkConsent(){try{var d=localStorage.getItem("consent_state");if(!d){setTimeout(checkConsent,500);return}var c=JSON.parse(d);if(c.marketing){(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({"gtm.start":new Date().getTime(),event:"gtm.js"});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!="dataLayer"?"&l="+l:"";j.async=true;j.src="https://www.googletagmanager.com/gtm.js?id="+i+dl;f.parentNode.insertBefore(j,f)})(window,document,"script","dataLayer","${settings.gtm_id}")}}catch(e){}})();`}
        />
      )
    }
  </head>
  <body>
    <!-- [C2] Skip to Content — WCAG 2.4.1 -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-100 focus:px-4 focus:py-2 focus:bg-active focus:text-background focus:rounded-lg focus:font-semibold focus:shadow-lg"
    >
      Skip to content
    </a>

    <!-- Ambient Mesh Background Animation -->
    <div class="ambient-mesh" aria-hidden="true">
      <div class="ambient-mesh__orb ambient-mesh__orb--1"></div>
      <div class="ambient-mesh__orb ambient-mesh__orb--2"></div>
      <div class="ambient-mesh__orb ambient-mesh__orb--3"></div>
    </div>

    <!-- GTM Body Noscript -->
    {
      settings.gtm_id && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${settings.gtm_id}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
          />
        </noscript>
      )
    }

    <Navbar
      logo={settings.logo?.[0]}
      menu={settings.main_menu || []}
      siteName={settings.site_name}
    />

    <main id="main-content">
      <slot />
    </main>

    <Footer
      columns={settings.footer_columns || []}
      socialLinks={settings.social_links || []}
      copyright={settings.copyright_text || '© 2026 LaventeCare'}
    />

    <!-- Global UI Islands -->
    <GlobalLoader client:visible />
    <NotificationToast client:idle />

    <!-- GDPR Cookie Consent Banner -->
    <CookieConsent client:load />

    <!-- Vercel Analytics & Speed Insights (Consent-Gated) -->
    <AnalyticsProvider client:load />

    <!-- Performance Monitoring (Dev Only) -->
    <script>
      import { initPerformanceMonitoring } from '../lib/performance/performanceMonitor';
      if (import.meta.env.DEV && typeof window !== 'undefined') {
        window.addEventListener('load', () => {
          initPerformanceMonitoring();
        });
      }
    </script>
  </body>
</html>
