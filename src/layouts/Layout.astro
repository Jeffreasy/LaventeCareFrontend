---
import Navbar from '../components/blocks/Navbar.astro';
import Footer from '../components/blocks/Footer.astro';
import SEO from '../components/blocks/SEO.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  seoOverride?: {
    title?: string;
    description?: string;
    image?: {
      filename: string;
      alt?: string;
    };
  };
}

const { title, description, seoOverride } = Astro.props;

// Static site settings (previously from Storyblok)
import { settings } from '../lib/config';
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={settings.favicon?.[0]?.filename || '/favicon.svg'} />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Fonts: Geist & Satoshi (Fontshare) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://api.fontshare.com/v2/css?f[]=satoshi@900,700,500,400&display=swap" rel="stylesheet">
    
    <!-- SEO Meta Tags - Props are compatible at runtime -->
    <SEO 
      title={seoOverride?.title || title || settings.meta_title}
      description={seoOverride?.description || description || settings.meta_description}
      image={seoOverride?.image || settings.og_image?.[0]}
    />

    <!-- CSRF Token -->
    <meta name="csrf-token" content={Astro.locals.csrfToken} />

    <!-- Astro Client Router (View Transitions) -->
    <ClientRouter />

    <!-- GTM Head Script -->
    {settings.gtm_id && (
      <script is:inline define:vars={{ gtmId: settings.gtm_id }}>
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer',gtmId);
      </script>
    )}
  </head>
  <body>
    <!-- GTM Body Noscript -->
    {settings.gtm_id && (
      <noscript>
        <iframe 
          src={`https://www.googletagmanager.com/ns.html?id=${settings.gtm_id}`}
          height="0" 
          width="0" 
          style="display:none;visibility:hidden"
        />
      </noscript>
    )}

    <Navbar 
      logo={settings.logo?.[0]} 
      menu={settings.main_menu || []}
      siteName={settings.site_name}
    />
    
    <main>
      <slot />
    </main>

    <Footer 
      columns={settings.footer_columns || []} 
      socialLinks={settings.social_links || []} 
      copyright={settings.copyright_text || '© 2026 LaventeCare'}
    />

    <!-- Cookie Consent -->
    {settings.cookie_consent_code && (
      <div set:html={settings.cookie_consent_code} />
    )}
  </body>
</html>
